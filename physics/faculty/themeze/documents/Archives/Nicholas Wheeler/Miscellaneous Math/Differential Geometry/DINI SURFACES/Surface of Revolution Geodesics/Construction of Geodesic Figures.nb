Cell[CellGroupData[{

Cell["Unit Hexenhut", "Subsection",
 CellChangeTimes->{{3.6643844417634687`*^9, 3.664384452602667*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"hexenhut10", "=", 
  RowBox[{"ParametricPlot3D", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       FractionBox["1", 
        SqrtBox["u"]], 
       RowBox[{"Cos", "[", "v", "]"}]}], ",", 
      RowBox[{
       FractionBox["1", 
        SqrtBox["u"]], 
       RowBox[{"Sin", "[", "v", "]"}]}], ",", "u"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"u", ",", "0", ",", "10"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"v", ",", "0", ",", 
      RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
    RowBox[{"Axes", "\[Rule]", "False"}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"Opacity", "[", "0.3", "]"}], "}"}]}], ",", 
    RowBox[{"Boxed", "\[Rule]", "False"}], ",", 
    RowBox[{
    "PlotLabel", "\[Rule]", "\"\<Geodesic Near Base of Hexenhut\>\""}], ",", 
    RowBox[{"LabelStyle", "\[Rule]", 
     RowBox[{"Directive", "[", "Bold", "]"}]}]}], "]"}]}]], "Input",
