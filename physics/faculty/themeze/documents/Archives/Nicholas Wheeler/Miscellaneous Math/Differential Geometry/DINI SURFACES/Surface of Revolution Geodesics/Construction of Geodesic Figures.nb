Cell[BoxData[{
 RowBox[{
  RowBox[{"vplus", "=", 
   RowBox[{
    SubscriptBox["v", "0"], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"ArcSin", "[", 
       SqrtBox[
        FractionBox[
         RowBox[{"u", "-", 
          SuperscriptBox["c", "2"]}], 
         RowBox[{"u", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"4", 
             SuperscriptBox["c", "2"]}]}], ")"}]}]]], "]"}], "+", 
      RowBox[{"2", "c", " ", 
       RowBox[{"Log", "[", 
        FractionBox[
         RowBox[{
          RowBox[{"2", 
           SqrtBox[
            RowBox[{"u", "-", 
             SuperscriptBox["c", "2"]}]]}], "+", 
          SqrtBox[
           RowBox[{
            RowBox[{"4", "u"}], "+", "1"}]]}], 
         SqrtBox[
          RowBox[{"1", "+", 
           RowBox[{"4", 
            SuperscriptBox["c", "2"]}]}]]], "]"}]}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vminus", "=", 
   RowBox[{
    SubscriptBox["v", "0"], "-", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"ArcSin", "[", 
       SqrtBox[
        FractionBox[
         RowBox[{"u", "-", 
          SuperscriptBox["c", "2"]}], 
         RowBox[{"u", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"4", 
             SuperscriptBox["c", "2"]}]}], ")"}]}]]], "]"}], "+", 
      RowBox[{"2", "c", " ", 
       RowBox[{"Log", "[", 
        FractionBox[
         RowBox[{
          RowBox[{"2", 
           SqrtBox[
            RowBox[{"u", "-", 
             SuperscriptBox["c", "2"]}]]}], "+", 
          SqrtBox[
           RowBox[{
            RowBox[{"4", "u"}], "+", "1"}]]}], 
         SqrtBox[
          RowBox[{"1", "+", 
           RowBox[{"4", 
            SuperscriptBox["c", "2"]}]}]]], "]"}]}]}], ")"}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.664378707489946*^9, 3.664378853415432*^9}, {
  3.66437938368196*^9, 3.664379535566062*^9}, {3.664380777076188*^9, 
  3.664380798726239*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox["v", "0"], "=", 
   RowBox[{
    RowBox[{"-", "\[Pi]"}], "/", "2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"c", "=", "1"}], ";"}]}], "Input",
 CellChangeTimes->{{3.6643791803988943`*^9, 3.664379190810479*^9}, {
  3.664379265025153*^9, 3.664379269192596*^9}, {3.6643799795469503`*^9, 
  3.664379982931919*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"plusgeodesic10", "=", 
