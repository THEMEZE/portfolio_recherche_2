Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"highhexenhut", "=", 
  RowBox[{"ParametricPlot3D", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"20", 
       FractionBox["1", 
        SqrtBox["u"]], 
       RowBox[{"Cos", "[", "v", "]"}]}], ",", 
      RowBox[{"20", 
       FractionBox["1", 
        SqrtBox["u"]], 
       RowBox[{"Sin", "[", "v", "]"}]}], ",", "u"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"u", ",", "90", ",", "110"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"v", ",", "0", ",", 
      RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
    RowBox[{"Axes", "\[Rule]", "False"}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"Opacity", "[", "0.3", "]"}], "}"}]}], ",", 
    RowBox[{"Boxed", "\[Rule]", "False"}], ",", 
    RowBox[{
    "PlotLabel", "\[Rule]", "\"\<Hexenhut Geodesic at Turning Point\>\""}], 
    ",", 
    RowBox[{"LabelStyle", "\[Rule]", 
     RowBox[{"Directive", "[", "Bold", "]"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.664385478952898*^9, 3.6643854802631702`*^9}, {
