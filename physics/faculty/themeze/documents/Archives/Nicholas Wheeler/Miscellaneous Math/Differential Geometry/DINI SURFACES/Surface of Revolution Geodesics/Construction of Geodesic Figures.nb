Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"paraboloid120", "=", 
  RowBox[{"ParametricPlot3D", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SqrtBox["u"], 
       RowBox[{"Cos", "[", "v", "]"}]}], ",", 
      RowBox[{
       SqrtBox["u"], 
       RowBox[{"Sin", "[", "v", "]"}]}], ",", "u"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"u", ",", "0", ",", "120"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"v", ",", "0", ",", 
      RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
    RowBox[{"Axes", "\[Rule]", "False"}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"Opacity", "[", "0.3", "]"}], "}"}]}], ",", 
    RowBox[{"Boxed", "\[Rule]", "False"}], ",", 
    RowBox[{
    "PlotLabel", "\[Rule]", "\"\<Geodesic Crossings on Unit Paraboloid\>\""}],
     ",", 
    RowBox[{"LabelStyle", "\[Rule]", 
     RowBox[{"Directive", "[", "Bold", "]"}]}]}], "]"}]}]], "Input",
