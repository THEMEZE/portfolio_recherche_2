Cell[BoxData[
 RowBox[{"paraboloid10", "=", 
  RowBox[{"ParametricPlot3D", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SqrtBox["u"], 
       RowBox[{"Cos", "[", "v", "]"}]}], ",", 
      RowBox[{
       SqrtBox["u"], 
       RowBox[{"Sin", "[", "v", "]"}]}], ",", "u"}], "}"}], ",", 
