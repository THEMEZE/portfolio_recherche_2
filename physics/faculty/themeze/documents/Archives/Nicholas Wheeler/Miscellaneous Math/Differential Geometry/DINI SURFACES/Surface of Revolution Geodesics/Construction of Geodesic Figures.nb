Cell[BoxData[{
 RowBox[{
  RowBox[{"hexvplus", "=", 
   RowBox[{
    SubscriptBox["v", "0"], "+", 
    FractionBox[
     RowBox[{
      RowBox[{"2", 
       RowBox[{"(", 
        RowBox[{"2", "+", 
         RowBox[{
          SuperscriptBox["c", "2"], "u"}]}], ")"}], 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{
          SuperscriptBox["c", "2"], "u"}]}]]}], "-", "4"}], 
     RowBox[{"3", 
      SuperscriptBox["c", "3"]}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"hexvminus", "=", 
   RowBox[{
    SubscriptBox["v", "0"], "-", 
    FractionBox[
     RowBox[{
      RowBox[{"2", 
       RowBox[{"(", 
        RowBox[{"2", "+", 
         RowBox[{
          SuperscriptBox["c", "2"], "u"}]}], ")"}], 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{
          SuperscriptBox["c", "2"], "u"}]}]]}], "-", "4"}], 
     RowBox[{"3", 
      SuperscriptBox["c", "3"]}]]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.6643846794078493`*^9, 3.6643847788715143`*^9}, {
  3.6643849300160513`*^9, 3.664384932758483*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"c", "=", "0.1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["v", "0"], "=", 
   RowBox[{
    RowBox[{"-", "\[Pi]"}], "/", "2"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.664385023918047*^9, 3.664385078899097*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"hexminusgeodesic10", "=", 
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        FractionBox["1", 
         SqrtBox["u"]], 
        RowBox[{"Cos", "[", "hexvminus", "]"}]}], ",", 
       RowBox[{
        FractionBox["1", 
         SqrtBox["u"]], 
        RowBox[{"Sin", "[", "hexvminus", "]"}]}], ",", "u"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"u", ",", "0", ",", "10"}], "}"}], ",", 
     RowBox[{"Axes", "\[Rule]", "False"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", "Thick", "}"}]}], ",", 
     RowBox[{"Boxed", "\[Rule]", "False"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.664384974861911*^9, 3.664384994270028*^9}, {
   3.664385090583103*^9, 3.6643851390621777`*^9}, {3.6643851693846073`*^9, 
