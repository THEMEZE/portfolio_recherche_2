 RowBox[{
  RowBox[{"plusgeodesic120", "=", 
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        SqrtBox["u"], 
        RowBox[{"Cos", "[", "vplus", "]"}]}], ",", 
