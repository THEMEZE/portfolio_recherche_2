           RowBox[{"x", "+", 
            RowBox[{"\[ImaginaryI]", " ", "y"}]}], "]"}], "]"}], "\[Equal]", 
         "0"}], ",", 
        RowBox[{
         RowBox[{"Im", "[", 
          RowBox[{"Erf", "[", 
           RowBox[{"x", "+", 
