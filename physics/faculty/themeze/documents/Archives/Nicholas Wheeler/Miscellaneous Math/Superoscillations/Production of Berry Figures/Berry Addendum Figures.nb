Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"r", "[", "n_", "]"}], ":=", 
  SqrtBox[
   RowBox[{"2", "\[Pi]", 
    RowBox[{"(", 
     RowBox[{"n", "-", 
      FractionBox["1", "8"]}], ")"}]}]]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"th", "[", "n_", "]"}], ":=", 
  RowBox[{
   FractionBox["\[Pi]", "4"], "+", 
   FractionBox[
    RowBox[{"Log", "[", 
     RowBox[{
      RowBox[{"r", "[", "n", "]"}], 
      SqrtBox[
       RowBox[{"2", "\[Pi]"}]]}], "]"}], 
    RowBox[{"2", " ", 
     SuperscriptBox[
      RowBox[{"r", "[", "n", "]"}], "2"]}]]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"z", "[", "n_", "]"}], ":=", 
   RowBox[{
    RowBox[{"r", "[", "n", "]"}], 
    RowBox[{"Exp", "[", 
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{"th", "[", "n", "]"}]}], "]"}]}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"N", "[", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"n", ",", 
       RowBox[{"z", "[", "n", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "7"}], "}"}]}], "]"}], "]"}], "//", 
  "TableForm"}]}], "Input",
 CellChangeTimes->{{3.730990745530573*^9, 3.730990913336307*^9}, {
  3.731010904066625*^9, 
