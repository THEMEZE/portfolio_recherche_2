d7dd5cba41af"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NullAndStokes", "=", 
  RowBox[{"ContourPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Re", "[", 
        RowBox[{"Erf", "[", 
         RowBox[{"x", "+", 
          RowBox[{"\[ImaginaryI]", " ", "y"}]}], "]"}], "]"}], "\[Equal]", 
       "0"}], ",", 
      RowBox[{
       RowBox[{"Im", "[", 
        RowBox[{"Erf", "[", 
         RowBox[{"x", "+", 
          RowBox[{"\[ImaginaryI]", " ", "y"}]}], "]"}], "]"}], "\[Equal]", 
       "0"}], ",", 
      RowBox[{
       RowBox[{"Arg", "[", 
        RowBox[{"N", "[", 
         RowBox[{"Erf", "[", 
          RowBox[{"x", "+", 
           RowBox[{"\[ImaginaryI]", " ", "y"}]}], "]"}], "]"}], "]"}], 
       "\[Equal]", 
       FractionBox["\[Pi]", "4"]}], ",", 
      RowBox[{
       RowBox[{"Arg", "[", 
        RowBox[{"N", "[", 
         RowBox[{"Erf", "[", 
          RowBox[{"x", "+", 
           RowBox[{"\[ImaginaryI]", " ", "y"}]}], "]"}], "]"}], "]"}], 
       "\[Equal]", 
       RowBox[{"-", 
        FractionBox["\[Pi]", "4"]}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "5"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", "0", ",", "5"}], "}"}], ",", 
    RowBox[{"PlotPoints", "\[Rule]", "50"}]}], "]"}]}]], "Input",
 CellChangeTimes->{
  3.7310371712472982`*^9},ExpressionUUID->"52fc6db1-2b43-4c2e-8c60-\
703b4e3fcef4"],

