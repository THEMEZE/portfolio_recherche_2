Cell[CellGroupData[{

Cell["Introduction", "Subsection",
 CellChangeTimes->{{3.530904943706977*^9, 3.5309049479994993`*^9}}],

Cell[TextData[{
 "My objective is to discover a criterion or algorithm by means of which one \
can discover by inspection whether or not a given circuit yields to \
series/paralled decomposition. I begin with no clear idea in \
mind\[Ellipsis]with some simple exploratory doodles, informed only by the \
hunch that the problem may be best approached by looking to patterns (if any) \
that emerge when uses series/parallel constructions to ",
 StyleBox["build up",
  FontVariations->{"Underline"->True}],
 " complex circuits; i.e., that assembly may be more informative than \
disassembly. "
}], "Text",
 CellChangeTimes->{{3.530904968776658*^9, 3.5309053140820417`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"R", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
  RowBox[{"x", "\[Rule]", "y"}]}]], "Input",
 CellChangeTimes->{{3.530901493378373*^9, 3.530901514142174*^9}}],

