 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"\[Alpha]", "-", "1"}], ")"}], "x"}], "+", 
   RowBox[{"\[Alpha]", " ", "y"}], "+", 
   RowBox[{"\[Alpha]", " ", "z"}]}], "\[Equal]", "0"}]], "Output"],

Cell[CellGroupData[{

