Cell[CellGroupData[{

Cell["Normal diffusion", "Subsubsection",
 CellChangeTimes->{{3.5237358186772003`*^9, 3.523735825960678*^9}}],

Cell["Let", "Text",
 CellChangeTimes->{{3.523733203519665*^9, 3.5237332054160957`*^9}, {
  3.523733351461129*^9, 3.523733360740416*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[Rho]", "[", 
    RowBox[{"x", ",", " ", "y", ",", " ", "N"}], "]"}], "dx", " ", "dy"}], 
  "="}]], "DisplayFormula",
 CellChangeTimes->{{3.523733233597438*^9, 3.5237332547559357`*^9}, {
  3.52373331702754*^9, 3.523733319387155*^9}}],

Cell[TextData[{
 "describe ",
 StyleBox["the fraction of a very large population  of walkers who, after N \
steps, find themselves in the neighborhood [dx, dy] of the point [x, y]",
  FontVariations->{"Underline"->True}],
 ". Random walk theory leads to the conclusion that \[Rho][x, y, N] has the \
form of a simple bivariate normal distribution function"
}], "Text",
 CellChangeTimes->{{3.523733382434219*^9, 3.523733554337597*^9}, {
  3.5237341685261707`*^9, 3.5237341758390913`*^9}, {3.523735881925612*^9, 
  3.523735935987259*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Rho]", "[", 
   RowBox[{"x_", ",", " ", "y_", ",", " ", "N_"}], "]"}], ":=", 
  FractionBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{
       SuperscriptBox["x", "2"], "+", 
       SuperscriptBox["y", "2"]}], 
      RowBox[{"2", "N"}]]}]], 
   RowBox[{"N", " ", 
    SqrtBox[
     RowBox[{"2", " ", "\[Pi]"}]]}]]}]], "Input",
 CellChangeTimes->{{3.523734191179467*^9, 3.523734203655263*^9}, 
   3.523734234063335*^9, {3.523734501966612*^9, 3.5237345316426907`*^9}, 
   3.5237349948827667`*^9}],

Cell[TextData[{
 "and satisfies the ",
 StyleBox["diffusion equation", "Subsection",
  FontSize->12]
}], "Text",
 CellChangeTimes->{{3.523735041848915*^9, 3.523735050022523*^9}}],

Cell[BoxData[
 RowBox[{"                ", 
  RowBox[{
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[PartialD]", 
       RowBox[{"x", ",", "x"}]], 
      RowBox[{"+", 
       SubscriptBox["\[PartialD]", 
        RowBox[{"y", ",", "y"}]]}]}], ")"}], "\[Rho]"}], "=", 
   RowBox[{
    SubscriptBox["\[PartialD]", "N"], "\[Rho]"}]}]}]], "InlineFormula",
 CellChangeTimes->{{3.523735103111568*^9, 3.523735223517693*^9}}],

Cell["which I verify:", "Text",
 CellChangeTimes->{{3.523735235983362*^9, 3.523735239976706*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"\[Rho]", "[", 
         RowBox[{"x", ",", "y", ",", "N"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "2"}], "}"}]}], "]"}], "+", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"\[Rho]", "[", 
         RowBox[{"x", ",", "y", ",", "N"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", "2"}], "}"}]}], "]"}]}], ")"}]}], "==", 
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"\[Rho]", "[", 
      RowBox[{"x", ",", "y", ",", "N"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"N", ",", "1"}], "}"}]}], "]"}]}], "//", "Simplify"}]], "Input",\

 CellChangeTimes->{{3.5237342838829947`*^9, 3.523734411058441*^9}, {
  3.5237352558103952`*^9, 3.523735287974359*^9}}],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{{3.523734306920229*^9, 3.523734411882449*^9}, 
   3.523735012940749*^9, {3.523735272318536*^9, 3.523735289398657*^9}}]
}, Open  ]],

Cell["Here is a 3D display of the  evolving density function", "Text",
 CellChangeTimes->{{3.523735653337152*^9, 3.523735671905056*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot3D", "[", 
    RowBox[{
     RowBox[{"\[Rho]", "[", 
      RowBox[{"x", ",", "y", ",", "N"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", 
        SqrtBox["3000"]}], ",", 
       SqrtBox["3000"]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"-", 
        SqrtBox["3000"]}], ",", 
       SqrtBox["3000"]}], "}"}], ",", " ", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0.004"}], "}"}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"N", ",", "100", ",", "1000", ",", "100"}], "}"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.523732350646894*^9, 3.523732427123336*^9}, {
  3.523732464298821*^9, 3.5237324722258883`*^9}, {3.5237327191942463`*^9, 
  3.523732752227804*^9}, {3.5237327829350653`*^9, 3.523732789901573*^9}, {
  3.523732842904088*^9, 3.5237328632264147`*^9}, {3.523732925853367*^9, 
  3.52373298871664*^9}, {3.52373303266078*^9, 3.5237330884730663`*^9}, {
  3.5237353935043497`*^9, 3.5237354174975243`*^9}, {3.523735510265019*^9, 
  3.523735518951641*^9}, {3.523735684410193*^9, 3.5237356900931463`*^9}}],

Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{N$$ = 600, Typeset`show$$ = True, 
    Typeset`bookmarkList$$ = {}, Typeset`bookmarkMode$$ = "Menu", 
    Typeset`animator$$, Typeset`animvar$$ = 1, Typeset`name$$ = 
    "\"untitled\"", Typeset`specs$$ = {{
      Hold[N$$], 100, 1000, 100}}, Typeset`size$$ = {540., {198., 208.}}, 
    Typeset`update$$ = 0, Typeset`initDone$$, Typeset`skipInitDone$$ = True, 
    N$5272$$ = 0}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, "Variables" :> {N$$ = 100}, "ControllerVariables" :> {
        Hold[N$$, N$5272$$, 0]}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
