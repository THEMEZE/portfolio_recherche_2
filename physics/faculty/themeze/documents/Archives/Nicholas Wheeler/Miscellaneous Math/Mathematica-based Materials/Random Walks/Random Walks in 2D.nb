Cell[TextData[{
 "Theoretically, we expect the average displacement achieved after ",
 StyleBox["N", "InlineFormula"],
 " steps to grow as ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    SqrtBox["N"], "InlineFormula"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 ". That expectation informs the design of the following figure"
}], "Text",
 CellChangeTimes->{{3.523724445535927*^9, 3.52372449705582*^9}, {
  3.523724561620068*^9, 3.523724576556451*^9}, {3.523724637885243*^9, 
  3.523724698349606*^9}}],

