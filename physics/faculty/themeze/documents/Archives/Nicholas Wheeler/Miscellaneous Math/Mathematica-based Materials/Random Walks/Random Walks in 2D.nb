Cell["The theoretical distribtion", "Text",
 CellChangeTimes->{{3.523756952144145*^9, 3.523756980436158*^9}}],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Rho]", "Levi"], "[", 
  RowBox[{"x", ",", "y", ",", "N"}], "]"}]], "DisplayFormula",
 CellChangeTimes->{{3.5237569836199837`*^9, 3.523757004204064*^9}}],

Cell["satisfies a \"fractional diffusion equation\"", "Text",
 CellChangeTimes->{{3.5237570205684443`*^9, 3.523757046050733*^9}}],

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[PartialD]", 
       RowBox[{"x", ",", "x"}]], 
      RowBox[{"+", 
       SubscriptBox["\[PartialD]", 
        RowBox[{"y", ",", "y"}]]}]}], ")"}], "\[Rho]"}], "=", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"[", 
      SubscriptBox["\[PartialD]", "N"], "]"}], "f"], 
    "\[Rho]"}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.5237571079952*^9, 3.523757123825946*^9}}],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{"[", 
    SubscriptBox["\[PartialD]", "N"], "]"}], "f"]],
  CellChangeTimes->{{3.5237571079952*^9, 3.523757123825946*^9}}],
 " is a \"fractional derivative.\""
}], "Text",
 CellChangeTimes->{{3.523757150756868*^9, 3.5237571731355677`*^9}}],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", "\[IndentingNewLine]"}]], "Input",
 CellChangeTimes->{{3.52396952746665*^9, 3.523969527563279*^9}}],

