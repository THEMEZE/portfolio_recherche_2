 CellChangeTimes->{3.523711989097267*^9}],

Cell[CellGroupData[{

Cell["Random Walks on the Plane", "Title",
 CellChangeTimes->{{3.523711994222374*^9, 3.523712001185648*^9}, {
  3.5237120562567253`*^9, 3.5237120683294697`*^9}}],

Cell["\<\
Nicholas Wheeler
30 August 2011\
\>", "Text",
 CellChangeTimes->{{3.5237120750107183`*^9, 3.523712086664295*^9}},
 FontSize->10],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.5237120978028507`*^9}],

Cell[CellGroupData[{

Cell["Introduction", "Subsection",
 CellChangeTimes->{{3.523723529970912*^9, 3.523723533897232*^9}}],

Cell["\<\
The following material is quoted from \"Simulated Random Walks\" (Notebook \
dated 4 April 2008)\
\>", "Text",
 CellChangeTimes->{{3.523723550199059*^9, 3.523723618196224*^9}, 
   3.52372366070949*^9}],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.5237236360701857`*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Steps of unit length, random turn angles uniformly distributed\
\>", "Subsection",
 CellChangeTimes->{{3.523723698875144*^9, 3.523723724218607*^9}}],

Cell["\<\
The following commands generate the steps that contribute to a population  of \
four such 1000-step walks:\
\>", "Text",
 CellChangeTimes->{{3.523723757218101*^9, 3.5237238146507053`*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Steps1", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", "\[Alpha]", "]"}], ",", " ", 
        RowBox[{"Sin", "[", "\[Alpha]", "]"}]}], "}"}], "/.", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]", "\[Rule]", 
        RowBox[{"2", "\[Pi]", " ", 
         RowBox[{"RandomReal", "[", "]"}]}]}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "1000"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Steps2", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", "\[Alpha]", "]"}], ",", " ", 
        RowBox[{"Sin", "[", "\[Alpha]", "]"}]}], "}"}], "/.", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]", "\[Rule]", 
        RowBox[{"2", "\[Pi]", " ", 
         RowBox[{"RandomReal", "[", "]"}]}]}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "1000"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Steps3", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", "\[Alpha]", "]"}], ",", " ", 
        RowBox[{"Sin", "[", "\[Alpha]", "]"}]}], "}"}], "/.", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]", "\[Rule]", 
        RowBox[{"2", "\[Pi]", " ", 
         RowBox[{"RandomReal", "[", "]"}]}]}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "1000"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Steps4", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", "\[Alpha]", "]"}], ",", " ", 
        RowBox[{"Sin", "[", "\[Alpha]", "]"}]}], "}"}], "/.", 
      RowBox[{"{", 
       RowBox[{"\[Alpha]", "\[Rule]", 
        RowBox[{"2", "\[Pi]", " ", 
         RowBox[{"RandomReal", "[", "]"}]}]}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "1000"}], "}"}]}], "]"}]}], ";"}]}], "Input"],

Cell["Here is a typical step", "Text",
 CellChangeTimes->{{3.5237238739258347`*^9, 3.523723879784645*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Part", "[", 
  RowBox[{"Steps1", ",", " ", "137"}], "]"}]], "Input",
 CellChangeTimes->{{3.523723886015506*^9, 3.523723895049376*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", "0.8784234814185883`"}], ",", 
   RowBox[{"-", "0.4778830267884046`"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.523723897491498*^9, 3.523723906741929*^9}}]
}, Open  ]],

Cell["\<\
and here is a demonstration that (like all others) it has unit length:\
\>", "Text",
 CellChangeTimes->{{3.523723919805656*^9, 3.5237239512630033`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Norm", "[", "%", "]"}]], "Input",
 CellChangeTimes->{{3.523723972794074*^9, 3.523723977714336*^9}}],

Cell[BoxData["0.9999999999999999`"], "Output",
 CellChangeTimes->{3.523723979083921*^9}]
}, Open  ]],

Cell[TextData[{
 "The following commands list the successive positions achieved by the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " walker: "
}], "Text",
 CellChangeTimes->{{3.523724021300171*^9, 3.523724056616333*^9}, {
  3.5237241305835037`*^9, 3.523724158820416*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SuccessivePositions1", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"k", "=", "1"}], "m"], 
      RowBox[{
      "Steps1", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}]}], ",",
      " ", 
     RowBox[{"{", 
      RowBox[{"m", ",", "1", ",", "1000"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SuccessivePositions2", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"k", "=", "1"}], "m"], 
      RowBox[{
      "Steps2", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}]}], ",",
      " ", 
     RowBox[{"{", 
      RowBox[{"m", ",", "1", ",", "1000"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SuccessivePositions3", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"k", "=", "1"}], "m"], 
      RowBox[{
      "Steps3", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}]}], ",",
      " ", 
     RowBox[{"{", 
      RowBox[{"m", ",", "1", ",", "1000"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SuccessivePositions4", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"k", "=", "1"}], "m"], 
      RowBox[{
      "Steps4", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}]}], ",",
      " ", 
     RowBox[{"{", 
      RowBox[{"m", ",", "1", ",", "1000"}], "}"}]}], "]"}]}], ";"}]}], "Input"],

Cell["\<\
Here are I construct and draw graphic displays of the paths traced by the \
respective walkers:\
\>", "Text",
 CellChangeTimes->{{3.523724250596937*^9, 3.523724323745968*^9}, {
  3.52373179826712*^9, 3.523731824078454*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"RandomWalk1", "=", 
   RowBox[{"Graphics", "[", 
    RowBox[{"{", 
     RowBox[{"Black", ",", 
      RowBox[{"Line", "[", "SuccessivePositions1", "]"}]}], "}"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RandomWalk2", "=", 
   RowBox[{"Graphics", "[", 
    RowBox[{"{", 
     RowBox[{"Red", ",", 
      RowBox[{"Line", "[", "SuccessivePositions2", "]"}]}], "}"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RandomWalk3", "=", 
   RowBox[{"Graphics", "[", 
    RowBox[{"{", 
     RowBox[{"Blue", ",", 
      RowBox[{"Line", "[", "SuccessivePositions3", "]"}]}], "}"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"RandomWalk4", "=", 
    RowBox[{"Graphics", "[", 
     RowBox[{"{", 
      RowBox[{"Green", ",", 
       RowBox[{"Line", "[", "SuccessivePositions4", "]"}]}], "}"}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
  "RandomWalk1", ",", "RandomWalk2", ",", "RandomWalk3", ",", "RandomWalk4", 
   ",", " ", 
   RowBox[{"Axes", "\[Rule]", "True"}], ",", " ", 
   RowBox[{"Ticks", "\[Rule]", "False"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.52372435089904*^9, 3.5237243518938723`*^9}, {
  3.523731838038951*^9, 3.523731839775043*^9}}],

