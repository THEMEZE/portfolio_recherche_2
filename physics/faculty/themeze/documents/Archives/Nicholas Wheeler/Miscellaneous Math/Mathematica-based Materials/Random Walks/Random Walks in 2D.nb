Cell["\<\
We  compute and display the evolving net displacement from the origin \
achieved by the respective walkers, and compare it to the theoretical \
expectation:\
\>", "Text",
 CellChangeTimes->{{3.523731995298563*^9, 3.523732076349901*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"NetDisplacement1", "[", "n_", "]"}], ":=", 
  RowBox[{"Norm", "[", 
   RowBox[{"Part", "[", 
    RowBox[{"SuccessivePositions1", ",", "n"}], "]"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"NetDisplacement2", "[", "n_", "]"}], ":=", 
  RowBox[{"Norm", "[", 
   RowBox[{"Part", "[", 
    RowBox[{"SuccessivePositions2", ",", "n"}], "]"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"NetDisplacement3", "[", "n_", "]"}], ":=", 
  RowBox[{"Norm", "[", 
   RowBox[{"Part", "[", 
    RowBox[{"SuccessivePositions3", ",", "n"}], "]"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"NetDisplacement4", "[", "n_", "]"}], ":=", 
   RowBox[{"Norm", "[", 
    RowBox[{"Part", "[", 
     RowBox[{"SuccessivePositions4", ",", "n"}], "]"}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PlotNetDisplacement1", "=", 
   RowBox[{"ListPlot", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"NetDisplacement1", "[", "n", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "1000"}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"Joined", "\[Rule]", "True"}], ",", " ", 
     RowBox[{"PlotStyle", "\[Rule]", "Black"}], ",", " ", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0", ",", "80"}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PlotNetDisplacement2", "=", 
   RowBox[{"ListPlot", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"NetDisplacement2", "[", "n", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "1000"}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"Joined", "\[Rule]", "True"}], ",", " ", 
     RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", " ", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0", ",", "80"}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PlotNetDisplacement3", "=", 
   RowBox[{"ListPlot", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"NetDisplacement3", "[", "n", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "1000"}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"Joined", "\[Rule]", "True"}], ",", " ", 
     RowBox[{"PlotStyle", "\[Rule]", "Blue"}], ",", " ", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0", ",", "80"}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"PlotNetDisplacement4", "=", 
    RowBox[{"ListPlot", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"NetDisplacement4", "[", "n", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "1", ",", "1000"}], "}"}]}], "]"}], ",", " ", 
      RowBox[{"Joined", "\[Rule]", "True"}], ",", " ", 
      RowBox[{"PlotStyle", "\[Rule]", "Green"}], ",", " ", 
      RowBox[{"PlotRange", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"0", ",", "80"}], "}"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ExpectedNetDisplacement", "=", 
    RowBox[{"ListPlot", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        SqrtBox["n"], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "1", ",", "1000"}], "}"}]}], "]"}], ",", " ", 
      RowBox[{"PlotRange", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"0", ",", "80"}], "}"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
  "ExpectedNetDisplacement", ",", "PlotNetDisplacement1", " ", ",", 
   "PlotNetDisplacement2", ",", "PlotNetDisplacement3", ",", 
   "PlotNetDisplacement4"}], "]"}]}], "Input",
