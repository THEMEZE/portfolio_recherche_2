Cell["\<\
The long tail\[LongDash]evident in the figure\[LongDash]is so long that the \
variance is indeterminate:\
\>", "Text",
 CellChangeTimes->{{3.523738521748837*^9, 3.523738574795763*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Mean", "[", 
  RowBox[{"FRatioDistribution", "[", 
   RowBox[{"3", ",", "3.9999"}], "]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Variance", "[", 
  RowBox[{"FRatioDistribution", "[", 
   RowBox[{"3", ",", "3.9999"}], "]"}], "]"}]}], "Input",
 CellChangeTimes->{{3.523737270239056*^9, 3.5237373001641483`*^9}, {
