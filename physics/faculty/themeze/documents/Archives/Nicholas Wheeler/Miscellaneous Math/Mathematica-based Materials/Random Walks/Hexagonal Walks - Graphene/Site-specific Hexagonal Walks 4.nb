Cell[TextData[{
 "and were \"unbiased and site-independent\" in the sense that ",
 StyleBox["wherever the walker stands he is equally likely to step to any of \
the three adjacent nodes",
  FontSlant->"Italic"],
 ". \n\nIn \"Site-specific Hexagonal Walks 1\" (29 December 2011) I relaxed \
the \"unbiased\" assumption "
}], "Text",
