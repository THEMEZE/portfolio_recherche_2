Cell[TextData[{
 "place the walker alternately on nodes of two types,",
 StyleBox[" \[FilledCircle]",
  FontColor->RGBColor[1, 0, 0]],
 " & ",
 StyleBox["\[FilledCircle]",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox[". Correspondingly, his next-step options are of two types, \
described by R-vectors else B-vectors",
  FontColor->GrayLevel[0]]
}], "Text",
