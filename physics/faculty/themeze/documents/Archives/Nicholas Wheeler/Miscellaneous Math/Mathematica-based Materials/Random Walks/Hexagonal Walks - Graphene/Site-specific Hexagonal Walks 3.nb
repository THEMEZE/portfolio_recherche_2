Cell[TextData[{
 "We are interested in walks where the next-step probabilities are \
\"site-specific\"\[LongDash]vary in a controlled way from site to site. \n\nI \
have been thus far unable to use off-the-shelf material to construct a \
command that generates such walks automatically. It is my guess, after many \
instructive failures, that to capture the walker's \
insructions\[LongDash]simple though they are\[LongDash]I would have to resort \
to ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " programming, of which I am presently ignorant. So I proceed here \"by \
hand.\""
}], "Text",
 CellChangeTimes->{{3.535561775959034*^9, 3.535561844487295*^9}, {
  3.535561903132695*^9, 3.5355619643476677`*^9}, {3.535562308375279*^9, 
  3.535562454277808*^9}, {3.5355625996277447`*^9, 3.5355626139101152`*^9}}],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.535562624709395*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell["Proof of method: construction of unbiased walks", "Subsection",
 CellChangeTimes->{{3.535562668367261*^9, 3.5355626913332*^9}}],

Cell["\<\
To make next-step decisions I will make use of the weighted random choice \
command\
\>", "Text",
 CellChangeTimes->{{3.535562715832529*^9, 3.535562753939468*^9}}],

