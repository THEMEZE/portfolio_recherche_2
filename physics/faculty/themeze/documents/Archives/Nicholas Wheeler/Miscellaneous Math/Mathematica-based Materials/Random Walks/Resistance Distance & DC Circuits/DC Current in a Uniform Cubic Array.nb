 RowBox[{
  SubscriptBox["R", "effective"], "=", 
  RowBox[{
   FractionBox["3", "4"], "<", 
   FractionBox["5", "6"]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.525869660140839*^9, 3.52586968330114*^9}}],

Cell["\<\
and the currents provide (in their pattern of equalities) a kind of crookedly \
non-obvious reference to the system's (now broken) symmetry:\
\>", "Text",
 CellChangeTimes->{{3.525869767650498*^9, 3.525869901728195*^9}}],

