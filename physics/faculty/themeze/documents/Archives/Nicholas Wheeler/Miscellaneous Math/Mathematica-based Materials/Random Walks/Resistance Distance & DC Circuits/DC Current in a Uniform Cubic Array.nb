Cell[CellGroupData[{

Cell["\<\
Construction of a random \"no lingering allowed\" \
\[DoubleStruckCapitalT]-matrix\
\>", "Subsubsection",
 CellChangeTimes->{{3.525978429482696*^9, 3.5259784639570312`*^9}}],

Cell["The following sequence of commands does the job:", "Text",
 CellChangeTimes->{{3.525979514208126*^9, 3.5259795259358177`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      SubscriptBox["t", "j"], "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"KroneckerDelta", "[", 
            RowBox[{"j", ",", "k"}], "]"}]}], ")"}], 
         RowBox[{"RandomInteger", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", "9"}], "}"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", "8"}], "}"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "8"}], "}"}]}], "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[DoubleStruckT]", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       SubscriptBox["T", "j"], "=", 
       FractionBox[
        SubscriptBox["t", "j"], 
        RowBox[{"Total", "[", 
         SubscriptBox["t", "j"], "]"}]]}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", "8"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[DoubleStruckCapitalT]", "=", 
   RowBox[{"Transpose", "[", "\[DoubleStruckT]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"\[DoubleStruckCapitalT]", "//", "MatrixForm"}]}], "Input",
 CellChangeTimes->{{3.525978505327982*^9, 3.525978588370278*^9}, {
   3.525978620815481*^9, 3.525978640568416*^9}, {3.525978684316268*^9, 
   3.525978709272842*^9}, {3.525978774457086*^9, 3.525978780619247*^9}, {
   3.525978828347109*^9, 3.5259788986674347`*^9}, 3.525978952153522*^9, 
   3.5259790320255003`*^9, 3.525979071239017*^9, {3.525979439723534*^9, 
   3.525979497536968*^9}}],

