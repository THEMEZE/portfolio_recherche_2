Cell["\<\
The matrix is asymmetric (the principle of detailed balance is inoperative), \
as the \[DoubleStruckCapitalT]-matrices associated with most DC circuits can \
be expected to be, and even though the \[DoubleStruckCapitalR]-matrix from \
which they derive is symmetric. The asymmetry stems\[LongDash]as mentioned \
previously\[LongDash]from the fact that, though the numerators are symmetric, \
 different denominators are (typially) encountered in each column. The 0s on \
the principal diagonal deny to the walker the option of standing in place: he \
is obliged to keep moving.\
\>", "Text",
 CellChangeTimes->{{3.525979797437335*^9, 3.525979949517253*^9}, {
  3.5259799965502853`*^9, 3.525979998730929*^9}, {3.526068763539275*^9, 
  3.526068804738781*^9}, {3.526068841767364*^9, 3.5260689476009293`*^9}, {
  3.526068994119925*^9, 3.526069031913149*^9}, {3.526069087474564*^9, 
  3.526069095320511*^9}}],

Cell[BoxData[""], "Input",
 CellChangeTimes->{{3.525980009251441*^9, 3.5259800095194693`*^9}}]
}, Open  ]],

Cell[CellGroupData[{

Cell["Method for generating individual random walks", "Subsubsection",
 CellChangeTimes->{{3.525980041532872*^9, 3.525980064926702*^9}}],

Cell[TextData[{
 "If the walker stands momentarily on node #m (i.e., is in state ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "m"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 ") then where he will stand one step later is determined probabilistically \
by the numbers that appear in the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["m", "th"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " column of \[DoubleStruckCapitalT].  To that ordered list of numbers we \
already gave a name while constructing \[DoubleStruckCapitalT]. In (for \
example) the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["3", "rd"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " column we encounter the list "
}], "Text",
 CellChangeTimes->{{3.5259801337576847`*^9, 3.5259802966824007`*^9}, {
  3.525980337947216*^9, 3.5259803392510347`*^9}, {3.5259808680266438`*^9, 
  3.52598090382066*^9}, {3.525980953809989*^9, 3.525980979488253*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 SubscriptBox["T", "3"]], "Input",
 CellChangeTimes->{{3.525980918960258*^9, 3.52598092119104*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["7", "29"], ",", 
   FractionBox["9", "29"], ",", "0", ",", 
   FractionBox["2", "29"], ",", 
   FractionBox["1", "29"], ",", 
   FractionBox["4", "29"], ",", 
   FractionBox["3", "29"], ",", 
   FractionBox["3", "29"]}], "}"}]], "Output",
 CellChangeTimes->{3.5259809229943113`*^9}]
}, Open  ]],

Cell["from which we learn that", "Text",
 CellChangeTimes->{{3.525981067555756*^9, 3.525981071733363*^9}}],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Sigma]", "3"], "\[LongRightArrow]", 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{
       SubscriptBox["\[Sigma]", "1"], " ", "with", " ", "probablility", " ", 
       FractionBox["7", "29"]}]},
     {
      RowBox[{
       SubscriptBox["\[Sigma]", "2"], " ", "with", " ", "probablility", " ", 
       FractionBox["9", "29"]}]},
     {
      RowBox[{
       SubscriptBox["\[Sigma]", "3"], " ", "with", " ", "probablility", " ", 
       "0"}]},
     {
      RowBox[{
       SubscriptBox["\[Sigma]", "4"], " ", "with", " ", "probablility", " ", 
       FractionBox["2", "29"]}]},
     {
      RowBox[{
       SubscriptBox["\[Sigma]", "5"], " ", "with", " ", "probablility", " ", 
       FractionBox["1", "29"]}]},
     {
      RowBox[{
       SubscriptBox["\[Sigma]", "6"], " ", "with", " ", "probablility", " ", 
       FractionBox["4", "29"]}]},
     {
      RowBox[{
       SubscriptBox["\[Sigma]", "7"], " ", "with", " ", "probablility", " ", 
       FractionBox["3", "29"]}]},
     {
      RowBox[{
       SubscriptBox["\[Sigma]", "8"], " ", "with", " ", "probablility", " ", 
       FractionBox["3", "29"]}]}
    }], "\[NoBreak]", ")"}]}]], "DisplayFormula",
 CellChangeTimes->{{3.525981076801323*^9, 3.525981120634606*^9}, {
  3.525981154640381*^9, 3.525981258301846*^9}, {3.52598130642173*^9, 
  3.5259813093567123`*^9}}],

Cell[TextData[{
 "and that the walker goes ",
 StyleBox["somewhere",
  FontVariations->{"Underline"->True}],
 " (else) with ",
 StyleBox["certainty",
  FontVariations->{"Underline"->True}],
 ", since"
