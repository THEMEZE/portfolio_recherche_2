  3.5262354678042994`*^9, 3.5262355404529467`*^9}, {3.526235616713176*^9, 
  3.526235656095544*^9}}],

Cell[TextData[{
 "Evidently ",
 Cell[BoxData[
  FractionBox[
   SubscriptBox["C", "mn"], 
   SubscriptBox["C", "m"]]],
  CellChangeTimes->{{3.52623541541903*^9, 3.526235420649846*^9}, {
   3.5262354678042994`*^9, 3.5262355404529467`*^9}, {3.526235616713176*^9, 
   3.526235656095544*^9}}],
 " measures \"fractional conductance,\" and "
}], "Text",
 CellChangeTimes->{{3.526235893011428*^9, 3.526235945981537*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   UnderscriptBox["\[Sum]", 
    RowBox[{"n", "\[Element]", 
     RowBox[{"N", "[", "m", "]"}]}]], 
   FractionBox[
