Cell["\<\
REMARK: Column vectors fall most familiarly upon the eye, but for \
computational convenience and economy of display I from this point forward I \
elect to work with row vectors.\
\>", "Text",
 CellChangeTimes->{{3.5263135910406523`*^9, 3.5263136853711*^9}}],

Cell[TextData[{
 "The walker\[LongDash]before he can figure out the nest-step options \
available to him\[LongDash]must first discover the identity of the node on \
which he presently stands. If he finds himself to be standing on the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["j", "th"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " node he then looks to the transition probabilities recorded in the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["j", "th"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " column (or in the present instance\[LongDash]by symmetry\[LongDash]the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["j", "th"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " row) and makes a random choice based upon those probabilities. To \
orchestrate that decision process, we give names to the respective \
columns/rows of \[DoubleStruckCapitalT]"
}], "Text",
 CellChangeTimes->{{3.526312285857102*^9, 3.526312398416019*^9}, {
  3.5263132732367573`*^9, 3.526313507013838*^9}, {3.526313864987879*^9, 
  3.5263139161698303`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{
     SubscriptBox["T", "k"], "=", 
     RowBox[{
     "\[DoubleStruckCapitalT]", "\[LeftDoubleBracket]", "k", 
      "\[RightDoubleBracket]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", "1", ",", "8"}], "}"}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.5263137095365477`*^9, 3.526313760384058*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    SubscriptBox["T", "k"], ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", "1", ",", "8"}], "}"}]}], "]"}], "//", 
  "TableForm"}]], "Input",
 CellChangeTimes->{{3.526313769618252*^9, 3.526313792176738*^9}}],

Cell[BoxData[
 TagBox[GridBox[{
    {"0", 
     FractionBox["1", "3"], "0", 
