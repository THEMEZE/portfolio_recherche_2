Cell[TextData[{
 "inform us that\n  \[Bullet] 1 appears as the first element in Parts 1, 2, \
3, 4, 5, 6 of ",
 StyleBox["AllEdges", "Input"],
 ";\n  \[Bullet] 1 appears as the second element in Parts 7, 16, 21, 25, 30, \
34 of ",
 StyleBox["AllEdges\n", "Input"],
 "and that 1 enters into a total of 12 such bilateral pairings: 6 edges have \
1 as source point, 6 have 1 as endpoint. "
}], "Text",
 CellChangeTimes->{{3.525886391906308*^9, 3.525886397067266*^9}, {
   3.5258864537536573`*^9, 3.525886604200046*^9}, 3.525887132873084*^9, {
   3.5258871637179623`*^9, 3.5258873301792316`*^9}}],

Cell["\<\
To automate the extraction of that kind of information (which is precisely \
the information that dictates the formulation of the nodal constraint \
relations) we introduce definitions\
\>", "Text",
 CellChangeTimes->{{3.5258873436588163`*^9, 3.525887440068771*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Positions", "[", "k_", "]"}], ":=", 
  RowBox[{"Position", "[", 
   RowBox[{"AllEdges", ",", "k"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"NodeData", "[", "j_", "]"}], ":=", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"AllEdges", "\[LeftDoubleBracket]", 
     RowBox[{
      RowBox[{
       RowBox[{"Positions", "[", "j", "]"}], "\[LeftDoubleBracket]", "k", 
       "\[RightDoubleBracket]"}], "\[LeftDoubleBracket]", "1", 
      "\[RightDoubleBracket]"}], "\[RightDoubleBracket]"}], ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", "1", ",", 
      RowBox[{"Length", "[", 
       RowBox[{"Positions", "[", "j", "]"}], "]"}]}], "}"}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.525887473960697*^9, 3.5258874775350647`*^9}}],

