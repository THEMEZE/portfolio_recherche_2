 GraphicsBox[
  TagBox[GraphicsComplexBox[{{0.8660254037470249, 1.}, {0., 
    1.5000000000648028`}, {0.866025403612335, 0.}, {1.7320508076287395`, 
    1.499999999831513}}, {
     {RGBColor[0.5, 0., 0.], Arrowheads[{{0.035557484307934206`, 0.7}}], 
