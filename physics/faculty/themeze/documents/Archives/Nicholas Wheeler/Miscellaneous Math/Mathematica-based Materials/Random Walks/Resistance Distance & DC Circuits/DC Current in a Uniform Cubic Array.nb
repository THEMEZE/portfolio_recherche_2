Cell[CellGroupData[{

Cell["Monte Carlo approach to the solution of DC circuit problems", \
"Subsection",
 CellChangeTimes->{{3.5258097811061773`*^9, 3.5258098069145317`*^9}, {
  3.525881137518094*^9, 3.5258811498054657`*^9}, {3.52589829126108*^9, 
  3.525898312126246*^9}}],

Cell[TextData[{
 StyleBox["First some points of terminology",
  FontColor->RGBColor[1, 0, 0]],
 ": ",
 StyleBox["The nodes that are adjacent to node #m (in the sense: connected \
directly to #m by a wire/edge) will be said to be \"neighbors\" of #m. The \
term refers only to immediate neighbors",
  FontWeight->"Bold"],
 ", not to more remote neighbors that can be reached only by passage through \
one or more intermediate nodes. We will write N[m] to refer collectively to \
#m's population of neighbors.\n\nKirchhoff's nodal rule can now be phrased"
}], "Text",
 CellChangeTimes->{{3.52589835100311*^9, 3.52589851106573*^9}, {
  3.525898575160578*^9, 3.525898634158134*^9}, {3.525898675140148*^9, 
  3.5258987741009073`*^9}, {3.525898805032037*^9, 3.5258988310342083`*^9}, {
  3.525898870594253*^9, 3.525898955118609*^9}, {3.525898989667487*^9, 
  3.5258990060759363`*^9}, {3.525899358304544*^9, 3.52589936192994*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   UnderscriptBox["\[Sum]", 
    RowBox[{"n", " ", "\[Element]", " ", 
     RowBox[{"N", "[", "m", "]"}]}]], 
   SubscriptBox["J", 
    RowBox[{"m", ",", "n"}]]}], "\[Equal]", "0"}]], "DisplayFormula",
 CellChangeTimes->{{3.525899010195714*^9, 3.5258991379088*^9}}],

Cell[BoxData[""], "Input",
 CellChangeTimes->{{3.525900964384103*^9, 3.525900964936138*^9}}],

Cell[CellGroupData[{

Cell["\<\
How the potential at node #m relates to the potentials at neighboring nodes\
\>", "Subsubsection",
 CellChangeTimes->{{3.525900991287878*^9, 3.525901042107123*^9}}],

Cell[TextData[{
 "Let the potential at the entry node into a circuit be V, the potential at \
the exit node (ground) be 0, and the potential at the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["m", "th"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " node (after establishment of the steady DC state) be ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "m"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 ".  The nodal rule can (given Ohm's Law) be phrased"
}], "Text",
 CellChangeTimes->{{3.525899202356347*^9, 3.5258993397704687`*^9}, {
  3.5258993968765163`*^9, 3.525899474724311*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   UnderscriptBox["\[Sum]", 
    RowBox[{"n", " ", "\[Element]", " ", 
     RowBox[{"N", "[", "m", "]"}]}]], 
   FractionBox[
    RowBox[{
     SubscriptBox["V", "n"], "-", 
     SubscriptBox["V", "m"]}], 
    SubscriptBox["R", 
     RowBox[{"m", ",", "n"}]]]}], "\[Equal]", "0"}]], "DisplayFormula",
 CellChangeTimes->{{3.525899501421164*^9, 3.525899549020082*^9}}],

Cell["or again", "Text",
 CellChangeTimes->{{3.525899586976364*^9, 3.52589958800721*^9}, {
  3.5258997337095327`*^9, 3.525899734950192*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["V", "m"], "\[Times]", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     RowBox[{"n", " ", "\[Element]", " ", 
      RowBox[{"N", "[", "m", "]"}]}]], 
    FractionBox["1", 
     SubscriptBox["R", 
      RowBox[{"m", ",", "n"}]]]}]}], "=", 
  RowBox[{
   UnderscriptBox["\[Sum]", 
    RowBox[{"n", " ", "\[Element]", " ", 
     RowBox[{"N", "[", "m", "]"}]}]], 
   FractionBox[
    SubscriptBox["V", "n"], 
    SubscriptBox["R", 
     RowBox[{"m", ",", "n"}]]]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.5258996089733963`*^9, 3.525899685640932*^9}}],

Cell[TextData[{
 "At this point it becomes more convenient/natural to speak of \"",
 StyleBox["conductances",
  FontWeight->"Bold"],
 "\" than of \"resistances.\" In that language we have "
}], "Text",
 CellChangeTimes->{{3.525899740926865*^9, 3.5258997878596563`*^9}, {
  3.5258998219528427`*^9, 3.525899855153606*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["V", "m"], "\[Times]", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     RowBox[{"n", " ", "\[Element]", " ", 
      RowBox[{"N", "[", "m", "]"}]}]], 
    SubscriptBox["C", 
     RowBox[{"m", ",", "n"}]]}]}], "=", 
  RowBox[{
   UnderscriptBox["\[Sum]", 
    RowBox[{"n", " ", "\[Element]", " ", 
     RowBox[{"N", "[", "m", "]"}]}]], 
   RowBox[{
    SubscriptBox[
     RowBox[{"C", " "}], 
     RowBox[{"m", ",", "n"}]], 
    SubscriptBox["V", "n"]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.525899874449548*^9, 3.5258999205412416`*^9}}],

Cell["whence", "Text",
 CellChangeTimes->{{3.52590001562156*^9, 3.525900016722794*^9}}],

Cell[BoxData[
 RowBox[{
  SubscriptBox["V", "m"], "=", 
  RowBox[{
   RowBox[{
    UnderscriptBox["\[Sum]", 
     RowBox[{"n", " ", "\[Element]", " ", 
      RowBox[{"N", "[", "m", "]"}]}]], 
    RowBox[{
     FractionBox[
      SubscriptBox[
       RowBox[{"C", " "}], 
       RowBox[{"m", ",", "n"}]], 
      SubscriptBox["C", "m"]], 
     SubscriptBox["V", "n"], "     ", "where", "     ", 
     SubscriptBox["C", "m"]}]}], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     RowBox[{"k", " ", "\[Element]", " ", 
      RowBox[{"N", "[", "m", "]"}]}]], 
    SubscriptBox["C", 
     RowBox[{"m", ",", "k"}]]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.525900020953197*^9, 3.525900113190584*^9}, {
  3.525900178198435*^9, 3.525900181942045*^9}, {3.52590022804748*^9, 
  3.525900229874422*^9}}],

Cell[TextData[{
 "We note in this connection that, for any given m, the numbers ",
 Cell[BoxData[
  FractionBox[
   SubscriptBox[
    RowBox[{"C", " "}], 
    RowBox[{"m", ",", "n"}]], 
   SubscriptBox["C", "m"]]],
  CellChangeTimes->{{3.525900020953197*^9, 3.525900113190584*^9}, {
   3.525900178198435*^9, 3.525900181942045*^9}, {3.52590022804748*^9, 
   3.525900229874422*^9}}],
 "are\[LongDash]like probabilities!\[LongDash]positive real numbers with the \
property that they sum to unity:"
}], "Text",
 CellChangeTimes->{{3.5259002007663403`*^9, 3.525900206223027*^9}, {
  3.525900250532054*^9, 3.525900365298253*^9}, {3.5259004016286163`*^9, 
  3.52590041221537*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   UnderscriptBox["\[Sum]", 
    RowBox[{"n", " ", "\[Element]", " ", 
     RowBox[{"N", "[", "m", "]"}]}]], 
   FractionBox[
    SubscriptBox[
     RowBox[{"C", " "}], 
     RowBox[{"m", ",", "n"}]], 
    SubscriptBox["C", "m"]]}], "=", "1"}]], "DisplayFormula",
 CellChangeTimes->{{3.525900236419353*^9, 3.525900240205282*^9}}],

Cell[TextData[{
 "REMARK: The signal virtue of the ",
 StyleBox["variational approach",
  FontWeight->"Bold"],
 " to the solution of DE circuit problems is that it proceeds ",
 StyleBox["without reference to the nodal potentials (therefore without \
appeal to Kirchhoff's awkward loop rule)",
  FontVariations->{"Underline"->True}],
 ". It permits the nodal potential always to be recovered \"after the fact.\" \
The ",
 StyleBox["Monte Carlo approach",
  FontWeight->"Bold"],
 ", on the other hand, assigns ",
 StyleBox["primary",
  FontSlant->"Italic"],
 " importance to the nodal potentials, though it exploits only ",
 StyleBox["a particular property of the nodal potentials",
  FontVariations->{"Underline"->True}],
 " that is rooted in Kirchhoff's node rule, and it too proceeds without \
appeal to the loop rule."
}], "Text",
 CellChangeTimes->{{3.525901063606048*^9, 3.5259014160232553`*^9}, {
  3.525901446877017*^9, 3.525901456525468*^9}, {3.525901543549839*^9, 
  3.525901544360149*^9}}],

Cell[BoxData[""], "Input",
 CellChangeTimes->{{3.525901608221518*^9, 3.525901609920924*^9}}]
}, Open  ]],

Cell[CellGroupData[{

Cell["Contact with the theory of random walks on graphs", "Subsubsection",
 CellChangeTimes->{{3.5259016213681917`*^9, 3.525901631599325*^9}}],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "m"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " be the probability that a walker, starting at node #m, reaches the exit \
node without having visited the entry node. Clearly"
}], "Text",
 CellChangeTimes->{{3.525901653425329*^9, 3.525901767587175*^9}}],

Cell[BoxData[{
 RowBox[{
  SubscriptBox["P", 
   RowBox[{"exit", " ", "node"}]], "=", "1"}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["P", 
   RowBox[{"entry", " ", "node"}]], "=", "0"}]}], "DisplayFormula",
 CellChangeTimes->{{3.5259017727257853`*^9, 3.5259018027425423`*^9}}],

Cell[TextData[{
 "It is clear also that a walker, upon departing from node #m, must after one \
step visit one or another of the nodes in his immediate neighborhood, N[m]. \
If his first step takes him to neighboring node #n then his probability of \
success (i.e., of reaching the exit node  without having visited the entry \
node) has become ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "n"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 ". From the statistical independence of the wlker's steps we conclude that"
}], "Text",
 CellChangeTimes->{{3.525901881376937*^9, 3.5259019818197813`*^9}, {
  3.525902013391246*^9, 3.5259021827336607`*^9}}],

Cell[BoxData[
 RowBox[{
  SubscriptBox["P", "m"], "=", 
  RowBox[{
   UnderscriptBox["\[Sum]", 
    RowBox[{"n", " ", "\[Element]", " ", 
     RowBox[{"N", "[", "m", "]"}]}]], 
   RowBox[{
    RowBox[{"prob", "[", 
     RowBox[{"n", "\[LongLeftArrow]", "m"}], "]"}], 
    SubscriptBox["P", "n"]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.525902188693877*^9, 3.525902260109207*^9}}],

Cell["\<\
Suppose we were to postulate (as seems physically plausible if our walker is \
an electron) that\
\>", "Text",
 CellChangeTimes->{{3.5259023247641087`*^9, 3.525902364191901*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"prob", "[", 
   RowBox[{"n", "\[LongLeftArrow]", "m"}], "]"}], "=", 
  RowBox[{
   FractionBox[
    RowBox[{"conductance", "[", 
     RowBox[{"n", "\[LongLeftArrow]", "m"}], "]"}], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{" ", 
       RowBox[{"n", " ", "\[Element]", " ", 
        RowBox[{"N", "[", "m", "]"}]}]}]], 
     RowBox[{"conductance", "[", 
      RowBox[{"n", "\[LongLeftArrow]", "m"}], "]"}]}]], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     RowBox[{"n", " ", "\[Element]", " ", 
      RowBox[{"N", "[", "m", "]"}]}]], 
    FractionBox[
     SubscriptBox[
      RowBox[{"C", " "}], 
      RowBox[{"m", ",", "n"}]], 
     SubscriptBox["C", "m"]]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.5259023875070887`*^9, 3.5259024614076433`*^9}, {
  3.5259024939313173`*^9, 3.5259025375418377`*^9}}],

Cell["It then follows that", "Text",
 CellChangeTimes->{{3.5259026174097*^9, 3.525902621042316*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   UnderscriptBox["\[Sum]", 
    RowBox[{"n", " ", "\[Element]", " ", 
     RowBox[{"N", "[", "m", "]"}]}]], 
   RowBox[{"prob", "[", 
    RowBox[{"n", "\[LongLeftArrow]", "m"}], "]"}]}], "=", 
  RowBox[{"1", "  ", ":", " ", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       RowBox[{
        RowBox[{"the", " ", "walker", "  ", "cannot", " ", "linger"}], ",", 
        " ", "but"}]},
      {
       RowBox[{
       "steps", " ", "with", " ", "certainty", " ", "to", " ", "one", " ", 
        "or"}]},
      {
       RowBox[{" ", 
        RowBox[{
        "another", " ", "of", " ", "the", " ", "neighboring", " ", "nodes"}]}]}
     }], "\[NoBreak]", ")"}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.525902641235565*^9, 3.525902702210449*^9}, {
  3.525902741913198*^9, 3.525902841354216*^9}}],

Cell["and", "Text",
 CellChangeTimes->{{3.5259028829520617`*^9, 3.525902883270709*^9}}],

Cell[BoxData[
 RowBox[{
  SubscriptBox["P", "m"], "=", 
  RowBox[{
   UnderscriptBox["\[Sum]", 
    RowBox[{"n", " ", "\[Element]", " ", 
     RowBox[{"N", "[", "m", "]"}]}]], 
   RowBox[{
    FractionBox[
     SubscriptBox[
      RowBox[{"C", " "}], 
      RowBox[{"m", ",", "n"}]], 
     SubscriptBox["C", "m"]], 
    SubscriptBox["P", "n"]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.5259029078032312`*^9, 3.52590291208573*^9}}],

Cell["We are brought thus to this remarkable conclusion: If ", "Text",
 CellChangeTimes->{{3.525902963464815*^9, 3.525903006691773*^9}, {
  3.5259160734518337`*^9, 3.525916108523286*^9}, {3.525916140262991*^9, 
  3.525916140686791*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"prob", "[", 
    RowBox[{"n", "\[LongLeftArrow]", "m"}], "]"}], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     RowBox[{"n", " ", "\[Element]", " ", 
      RowBox[{"N", "[", "m", "]"}]}]], 
    FractionBox[
     SubscriptBox[
      RowBox[{"C", " "}], 
      RowBox[{"m", ",", "n"}]], 
     SubscriptBox["C", "m"]]}]}],
  FontColor->RGBColor[1, 0, 0]]], "DisplayFormula",
 CellChangeTimes->{{3.525916168205817*^9, 3.525916169203373*^9}}],

Cell[TextData[{
 "then the nodal potentials ",
 Cell[BoxData[
  SubscriptBox["V", "n"]],
  CellChangeTimes->{{3.5259162280651712`*^9, 3.525916230205799*^9}}],
 " and the nodal probabilities ",
 Cell[BoxData[
  SubscriptBox["P", "n"]],
  CellChangeTimes->{{3.5259162280651712`*^9, 3.525916230205799*^9}, 
    3.525916274025517*^9}],
 "\[LongDash]because they satisfy the same equation\[LongDash]are ",
 StyleBox["equal", "Subsection",
  FontSize->12],
 "! The Monte Carlo method estimates the latter to obtain approximate \
evaluations of the former."
}], "Text",
 CellChangeTimes->{{3.525916216672111*^9, 3.525916438036346*^9}}],

Cell[BoxData[""], "DisplayFormula",
 CellChangeTimes->{{3.5259162280651712`*^9, 3.525916230205799*^9}, 
   3.525916274025517*^9, 3.5259163347907763`*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell["From conductance matrix to transition matrix", "Subsubsection",
 CellChangeTimes->{{3.525916453696968*^9, 3.525916467031671*^9}}],

Cell["\<\
Suppose we possess only probabilistic information concerning the present \
location of the walker, and elect to display that information as a \
\"stochastic vector\"\
\>", "Text",
 CellChangeTimes->{{3.525916478168892*^9, 3.5259165566019278`*^9}}],

Cell[BoxData[
 SubscriptBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      SubscriptBox["p", "1"]},
     {
      SubscriptBox["p", "2"]},
     {
      SubscriptBox["p", "3"]},
     {"\[VerticalEllipsis]"},
     {
      SubscriptBox["p", "8"]}
    }], "\[NoBreak]", ")"}], "n"]], "DisplayFormula",
 CellChangeTimes->{{3.525916590309928*^9, 3.525916636353047*^9}, {
  3.5259166816008472`*^9, 3.525916682944532*^9}}],

Cell["One step later the stochastic vector becomes", "Text",
 CellChangeTimes->{{3.525916710989455*^9, 3.5259167446122303`*^9}}],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox["p", "1"]},
      {
       SubscriptBox["p", "2"]},
      {
       SubscriptBox["p", "3"]},
      {"\[VerticalEllipsis]"},
      {
       SubscriptBox["p", "8"]}
     }], "\[NoBreak]", ")"}], 
   RowBox[{"n", "+", "1"}]], "=", 
  RowBox[{
   RowBox[{
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        RowBox[{"prob", "[", 
         RowBox[{"1", "\[LongLeftArrow]", "1"}], "]"}], 
        RowBox[{"prob", "[", 
         RowBox[{"1", "\[LongLeftArrow]", "2"}], "]"}], 
        RowBox[{"prob", "[", 
         RowBox[{"1", "\[LongLeftArrow]", "3"}], "]"}], "\[CenterEllipsis]", 
        RowBox[{"prob", "[", 
         RowBox[{"1", "\[LongLeftArrow]", "8"}], "]"}]},
       {
        RowBox[{"prob", "[", 
         RowBox[{"2", "\[LongLeftArrow]", "1"}], "]"}], 
        RowBox[{"prob", "[", 
         RowBox[{"2", "\[LongLeftArrow]", "2"}], "]"}], 
        RowBox[{"prob", "[", 
         RowBox[{"2", "\[LongLeftArrow]", "3"}], "]"}], "\[CenterEllipsis]", 
        RowBox[{"prob", "[", 
         RowBox[{"2", "\[LongLeftArrow]", "8"}], "]"}]},
       {
        RowBox[{"prob", "[", 
         RowBox[{"3", "\[LongLeftArrow]", "1"}], "]"}], 
        RowBox[{"prob", "[", 
         RowBox[{"3", "\[LongLeftArrow]", "2"}], "]"}], 
        RowBox[{"prob", "[", 
         RowBox[{"3", "\[LongLeftArrow]", "3"}], "]"}], "\[CenterEllipsis]", 
        RowBox[{"prob", "[", 
         RowBox[{"3", "\[LongLeftArrow]", "8"}], "]"}]},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
        "\[DescendingEllipsis]", "\[VerticalEllipsis]"},
       {
        RowBox[{"prob", "[", 
         RowBox[{"8", "\[LongLeftArrow]", "1"}], "]"}], 
        RowBox[{"prob", "[", 
         RowBox[{"8", "\[LongLeftArrow]", "2"}], "]"}], 
        RowBox[{"prob", "[", 
         RowBox[{"8", "\[LongLeftArrow]", "3"}], "]"}], "\[CenterEllipsis]", 
        RowBox[{"prob", "[", 
         RowBox[{"8", "\[LongLeftArrow]", "8"}], "]"}]}
      }], "\[NoBreak]", ")"}], 
    SubscriptBox[
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {
         SubscriptBox["p", "1"]},
        {
         SubscriptBox["p", "2"]},
        {
         SubscriptBox["p", "3"]},
        {"\[VerticalEllipsis]"},
        {
         SubscriptBox["p", "8"]}
       }], "\[NoBreak]", ")"}], "n"]}], "\[Congruent]", 
   RowBox[{"\[DoubleStruckCapitalT]", 
    SubscriptBox[
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {
         SubscriptBox["p", "1"]},
        {
         SubscriptBox["p", "2"]},
        {
         SubscriptBox["p", "3"]},
        {"\[VerticalEllipsis]"},
        {
         SubscriptBox["p", "8"]}
       }], "\[NoBreak]", ")"}], "n"]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.5259167651871347`*^9, 3.525916974904066*^9}, {
  3.5259170635101957`*^9, 3.525917076581686*^9}}],

Cell[TextData[{
 "The \"transition martrix\" (\"Markoff matrix\") has these distinguishing \
properties:\n  \[Bullet] all elements are interpretable as probabilities \
(i.e., are non-negative real numbers \[LessSlantEqual] 1);\n  \[Bullet] the \
elements in each column sum to unity (so as to insure that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", ")"}], 
    RowBox[{"n", "+", "1"}]], TraditionalForm]]],
 " is again stochastic).\n  \nIn circuit-theoretic applications the \
transition matrix"
}], "Text",
 CellChangeTimes->{{3.525917154812381*^9, 3.5259173173182907`*^9}, {
  3.525917354113103*^9, 3.525917396734303*^9}, {3.5259174321870003`*^9, 
  3.525917469685896*^9}, {3.525919008915834*^9, 3.5259190247481728`*^9}, {
  3.5259707833215714`*^9, 3.525970789386259*^9}}],

Cell[BoxData[
 RowBox[{"\[DoubleStruckCapitalT]", "=", 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0", 
      FractionBox[
       SubscriptBox["C", 
        RowBox[{"1", ",", "2"}]], 
       SubscriptBox["C", "2"]], 
      FractionBox[
       SubscriptBox["C", 
        RowBox[{"1", ",", "3"}]], 
       SubscriptBox["C", "3"]], "\[CenterEllipsis]", 
      FractionBox[
       SubscriptBox["C", 
        RowBox[{"1", ",", "8"}]], 
       SubscriptBox["C", "8"]]},
     {
      FractionBox[
       SubscriptBox["C", 
        RowBox[{"2", ",", "1"}]], 
       SubscriptBox["C", "1"]], "0", 
      FractionBox[
       SubscriptBox["C", 
        RowBox[{"2", ",", "3"}]], 
       SubscriptBox["C", "3"]], "\[CenterEllipsis]", 
      FractionBox[
       SubscriptBox["C", 
        RowBox[{"2", ",", "8"}]], 
       SubscriptBox["C", "8"]]},
     {
      FractionBox[
       SubscriptBox["C", 
        RowBox[{"3", ",", "1"}]], 
       SubscriptBox["C", "1"]], 
      FractionBox[
       SubscriptBox["C", 
        RowBox[{"3", ",", "2"}]], 
       SubscriptBox["C", "2"]], "0", "\[CenterEllipsis]", 
      FractionBox[
       SubscriptBox["C", 
        RowBox[{"3", ",", "8"}]], 
       SubscriptBox["C", "8"]]},
     {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
      "\[DescendingEllipsis]", "\[VerticalEllipsis]"},
     {
      FractionBox[
       SubscriptBox["C", 
        RowBox[{"8", ",", "1"}]], 
       SubscriptBox["C", "1"]], 
      FractionBox[
       SubscriptBox["C", 
        RowBox[{"8", ",", "2"}]], 
       SubscriptBox["C", "2"]], 
      FractionBox[
       SubscriptBox["C", 
        RowBox[{"8", ",", "3"}]], 
       SubscriptBox["C", "3"]], "\[CenterEllipsis]", "0"}
    }], "\[NoBreak]", ")"}]}]], "DisplayFormula",
 CellChangeTimes->{{3.5259174781264772`*^9, 3.525917510693221*^9}, {
  3.5259175888095016`*^9, 3.525917667964262*^9}, {3.5259177473922663`*^9, 
  3.5259179271372147`*^9}}],

Cell["\<\
conveys all possibile information about (1) the values of the restances \
present in the circuit, and (2) how they are connected (as\[LongDash]in their \
own ways\[LongDash]do \[DoubleStruckCapitalR] and \[DoubleStruckCapitalC]), \
but supplies no indication of at what nodes the circuit has been connected to \
an external power source. In the general theory of random walks on graphs, \
\[DoubleStruckCapitalT] provides a sharp tool for tracing the evolving \
statistics of infinitely large populations of walks \
\>", "Text",
 CellChangeTimes->{{3.525970819395781*^9, 3.525971117436887*^9}}],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox["p", "1"]},
      {
       SubscriptBox["p", "2"]},
      {
       SubscriptBox["p", "3"]},
      {"\[VerticalEllipsis]"},
      {
       SubscriptBox["p", "8"]}
     }], "\[NoBreak]", ")"}], "1"], "\[LongRightArrow]", 
  SubscriptBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox["p", "1"]},
      {
       SubscriptBox["p", "2"]},
      {
       SubscriptBox["p", "3"]},
      {"\[VerticalEllipsis]"},
      {
       SubscriptBox["p", "8"]}
     }], "\[NoBreak]", ")"}], "2"], "\[LongRightArrow]", 
  SubscriptBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox["p", "1"]},
      {
       SubscriptBox["p", "2"]},
      {
       SubscriptBox["p", "3"]},
      {"\[VerticalEllipsis]"},
      {
       SubscriptBox["p", "8"]}
     }], "\[NoBreak]", ")"}], "3"], "\[LongRightArrow]", " ", 
  "\[CenterEllipsis]", " ", "\[LongRightArrow]", 
  SubscriptBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox["p", "1"]},
      {
       SubscriptBox["p", "2"]},
      {
       SubscriptBox["p", "3"]},
      {"\[VerticalEllipsis]"},
      {
       SubscriptBox["p", "8"]}
     }], "\[NoBreak]", ")"}], "asymptotic"]}]], "DisplayFormula",
 CellChangeTimes->{{3.525971150699798*^9, 3.52597122767593*^9}}],

Cell[TextData[{
 "of ",
 StyleBox["infinitely large populations",
  FontSlant->"Italic"],
 " of walks\[LongDash]what might be called the \"statistical mechanics\" of \
walks. But in the random walk approach to DC circuit theory we are asked to \
examine large populations of ",
 StyleBox["individual",
  FontSlant->"Italic"],
 " random walks "
}], "Text",
 CellChangeTimes->{{3.525971281330971*^9, 3.52597132032134*^9}, {
  3.5259729094926*^9, 3.525972955453964*^9}}],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["1", "st"], " ", 
  RowBox[{"node", " ", "\[LongRightArrow]", " ", 
   SuperscriptBox["2", "nd"]}], " ", 
  RowBox[{"node", " ", "\[LongRightArrow]", " ", 
   SuperscriptBox["3", "rd"]}], " ", 
  RowBox[{
  "node", " ", "\[LongRightArrow]", " ", 
   "\[CenterEllipsis]"}]}]], "DisplayFormula",
 CellChangeTimes->{{3.5259729798454857`*^9, 3.5259730496078444`*^9}}],

Cell["\<\
and to record the fraction of those which answer to some specified criterion: \
in short, to estimate the \"probabilty of success\". 

The \[DoubleStruckCapitalT] matrix is\[LongDash]by itself\[LongDash]unable to \
accomplish such an assignment. We are obliged to unpack the information \
incorporated into the design of \[DoubleStruckCapitalT] and to use it to \
assemble some new tools. 

To that end, I will work in reference to a complete 8-node graph\
\>", "Text",
 CellChangeTimes->{{3.525918330965115*^9, 3.525918331364188*^9}, {
  3.52597310462971*^9, 3.525973111741143*^9}, {3.525973149353396*^9, 
  3.525973231369576*^9}, {3.525976145640818*^9, 3.52597627032633*^9}, {
  3.525977055099279*^9, 3.525977066654632*^9}, {3.525977114041678*^9, 
  3.525977145038383*^9}}],

Cell[BoxData[
 GraphicsBox[
  TagBox[GraphicsComplexBox[{{0.6818738398391818, 1.3457714447698312`}, {
    1.3801037281035102`, 0.48680397686790006`}, {0., 0.4751285632595953}, {
    1.0005254554515925`, 0.005364735298296619}, {0.3872156233125754, 0.}, {
    1.2376565730374405`, 1.0835492871312704`}, {0.1313773550667936, 
    1.0755018943073889`}, {0.6882591265615811, 0.6402200933562421}}, {
     {RGBColor[0.5, 0., 0.], 
      LineBox[{{1, 2}, {1, 3}, {1, 4}, {1, 5}, {1, 6}, {1, 7}, {1, 8}, {2, 
       3}, {2, 4}, {2, 5}, {2, 6}, {2, 7}, {2, 8}, {3, 4}, {3, 5}, {3, 6}, {3,
        7}, {3, 8}, {4, 5}, {4, 6}, {4, 7}, {4, 8}, {5, 6}, {5, 7}, {5, 8}, {
       6, 7}, {6, 8}, {7, 8}}]}, {InsetBox[
       FrameBox["1",
        Background->RGBColor[1, 1, 0.8],
