   Annotation[#, 
    VertexCoordinateRules -> {{0., 0.6816892165626792}, {1.105984179535655, 
     0.6814160340895922}, {1.893410534088925, 1.3619227761147523`}, {
     2.6298389790080017`, 0.6814626429605871}, {1.892464329279284, 
     0.0009800630506900943}, {2.0250206385070126`, 0.6811421489416207}, {
