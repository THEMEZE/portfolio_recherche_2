Cell[TextData[{
 StyleBox["DIGRESSION",
  FontWeight->"Bold"],
 ": By looking to the last-state statistics of a much larger population of \
such walks one should be able to construct \"experimental estimates\" of the \
data written into the stochastic vector generated by the following command:"
}], "Text",
 CellChangeTimes->{{3.526316156624839*^9, 3.5263163139508467`*^9}}],

