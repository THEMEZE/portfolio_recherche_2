Cell["\<\
We make the trivial adjustments required to produce a much larger population \
of such walks\
\>", "Text",
 CellChangeTimes->{{3.526320458042926*^9, 3.526320483190557*^9}, {
  3.5263206542316227`*^9, 3.526320698225803*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["Walk", "n"], "=", 
      RowBox[{"NestWhileList", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"RandomChoice", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                "#", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}], 
                SubscriptBox["T", "k"]}], ",", 
               RowBox[{"{", 
                RowBox[{"k", ",", "1", ",", "8"}], "}"}]}], "]"}], "\[Rule]", 
             
