                    RowBox[{"8", ",", "5"}]], "=", 
                    RowBox[{
                    SubscriptBox["R", 
                    RowBox[{"8", ",", "7"}]], "=", 
                    "1"}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}], 
  ";"}]], "DisplayFormula",
 CellChangeTimes->{{3.525812880939514*^9, 3.525812892194495*^9}, {
  3.525812962360209*^9, 3.525813392121708*^9}, {3.525813428458768*^9, 
  3.525813449092187*^9}}],

Cell["and  therefore", "Text",
 CellChangeTimes->{{3.525813472160077*^9, 3.525813472566503*^9}, {
  3.525814245733508*^9, 3.5258142482694817`*^9}}],

Cell[BoxData[
 RowBox[{"DissipationRate", "=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox[
      SubscriptBox["J", 
       RowBox[{"1", ",", "2"}]], "2"], "+", 
     SuperscriptBox[
      SubscriptBox["J", 
       RowBox[{"1", ",", "4"}]], "2"], "+", 
     SuperscriptBox[
      SubscriptBox["J", 
