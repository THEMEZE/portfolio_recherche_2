Cell["We adjust the nodal constraints", "Text",
 CellChangeTimes->{{3.526230194719488*^9, 3.526230211629867*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"NodalConstraints2", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["J", 
        RowBox[{"1", ",", "2"}]], "+", 
       SubscriptBox["J", 
        RowBox[{"1", ",", "4"}]], "+", 
       SubscriptBox["J", 
        RowBox[{"1", ",", "6"}]], "-", "1"}], "\[Equal]", "0"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox["J", 
         RowBox[{"1", ",", "2"}]]}], "+", 
       SubscriptBox["J", 
        RowBox[{"2", ",", "3"}]], "+", 
       SubscriptBox["J", 
        RowBox[{"2", ",", "5"}]]}], "\[Equal]", "0"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox["J", 
         RowBox[{"2", ",", "3"}]]}], "-", 
       SubscriptBox["J", 
        RowBox[{"4", ",", "3"}]], "+", 
       SubscriptBox["J", 
        RowBox[{"3", ",", "8"}]]}], "\[Equal]", "0"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox["J", 
         RowBox[{"1", ",", "4"}]]}], "+", 
       SubscriptBox["J", 
        RowBox[{"4", ",", "3"}]], "+", 
       SubscriptBox["J", 
        RowBox[{"4", ",", "7"}]]}], "\[Equal]", "0"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox["J", 
         RowBox[{"2", ",", "5"}]]}], "-", 
       SubscriptBox["J", 
        RowBox[{"6", ",", "5"}]], "+", 
       SubscriptBox["J", 
        RowBox[{"5", ",", "8"}]]}], "\[Equal]", "0"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox["J", 
         RowBox[{"1", ",", "6"}]]}], "+", 
       SubscriptBox["J", 
        RowBox[{"6", ",", "5"}]], "+", 
       SubscriptBox["J", 
        RowBox[{"6", ",", "7"}]]}], "\[Equal]", "0"}], ",", 
     "\[IndentingNewLine]", 
