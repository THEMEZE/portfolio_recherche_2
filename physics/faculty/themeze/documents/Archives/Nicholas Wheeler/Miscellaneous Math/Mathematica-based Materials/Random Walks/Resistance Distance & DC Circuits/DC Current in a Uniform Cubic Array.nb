 CellChangeTimes->{{3.526222398792986*^9, 3.5262229002641478`*^9}, 
   3.52622591034451*^9}],

Cell[TextData[{
 "REMARK: It is because we are about to ask ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " to perform a calculation which it is ill-equipped to perform symbolically \
that I have at this point assigned a specific numerical value J = 1 to the \
through-current."
}], "Text",
