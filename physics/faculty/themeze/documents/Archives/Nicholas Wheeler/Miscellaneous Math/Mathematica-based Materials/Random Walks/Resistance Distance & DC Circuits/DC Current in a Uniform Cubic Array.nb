Cell[TextData[{
 "The idea now is to examine the walks, one at a time, and to print A if the \
1 s in the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["8", "th"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " place sum to 0\[LongDash]signifying that B has been successfully avoided\
\[LongDash]and in all other cases to print B. Here are illustrative instances \
of a command that is seen by inspection to accomplish that objective :"
}], "Text",
 CellChangeTimes->{{3.526319480288418*^9, 3.526319483355165*^9}, {
  3.52631951534874*^9, 3.526319530985858*^9}}],

