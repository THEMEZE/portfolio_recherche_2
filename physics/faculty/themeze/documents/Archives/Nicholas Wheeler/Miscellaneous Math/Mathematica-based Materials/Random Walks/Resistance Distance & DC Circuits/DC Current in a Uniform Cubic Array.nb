Cell[TextData[{
 StyleBox["So much by way of preparation", "Subsection"],
 ". The idea now is to construct a very long (10,000-step) walk, and to look \
to the ",
 StyleBox["frequency with which the various nodes are visited",
  FontVariations->{"Underline"->True}],
 " :"
}], "Text",
 CellChangeTimes->{{3.526005994935034*^9, 3.526005998541511*^9}, {
  3.5260069406281443`*^9, 3.52600694264397*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"Walk10000", "=", 
   RowBox[{"NestList", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"RandomChoice", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
             "#", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}], 
             SubscriptBox["T", "k"]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", "1", ",", "8"}], "}"}]}], "]"}], "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            SubscriptBox["\[Tau]", "1"], ",", 
            SubscriptBox["\[Tau]", "2"], ",", 
            SubscriptBox["\[Tau]", "3"], ",", 
            SubscriptBox["\[Tau]", "4"], ",", 
            SubscriptBox["\[Tau]", "5"], ",", 
            SubscriptBox["\[Tau]", "6"], ",", 
            SubscriptBox["\[Tau]", "7"], ",", 
            SubscriptBox["\[Tau]", "8"]}], "}"}]}], ",", "1"}], "]"}], 
       "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], "&"}], ",", 
     SubscriptBox["\[Tau]", "1"], ",", "10000"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.526005824872816*^9, 3.5260058581930532`*^9}, {
  3.526005918544655*^9, 3.5260059189345007`*^9}, {3.5260060062284327`*^9, 
  3.526006008983819*^9}}],

