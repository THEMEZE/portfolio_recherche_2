Cell[TextData[{
 "We assume the potential at the input node is 0, and at the output node is V \
= 1 (and so will have to use the known value of ",
 Cell[BoxData[
  SubscriptBox["R", "effective"]],
  CellChangeTimes->{{3.526043427919239*^9, 3.526043431350184*^9}}],
 " to rescale our results to obtain agreement with our former assumption that \
the total current was J = 1). We ask for the potential at (say) node #3. To \
that end, we construct a large population of walks that depart from node #3 \
and ask for the value of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "3"], TraditionalForm]]],
 ", i.e., for the fraction of them that manage to reach node #1 without \
having visited node #8. \n\nTo phrase the issue more generally: Given a graph \
(DC circuit) and an associated (generally unbalanced) transition matrix \
\[DoubleStruckCapitalT], we seek a numerical estimate of the probability that \
a walker who starts from C will arrive at A without visiting B.\n \nClearly, \
that probability is 1 in the case C = A, and 0 in the case C = B. \n\nFor \
purposes of discussion, I will\[LongDash]as stated above\[LongDash]take"
}], "Text",
 CellChangeTimes->{{3.526043187016035*^9, 3.526043268653829*^9}, {
  3.526043337333364*^9, 3.526043520135417*^9}, {3.526043553901616*^9, 
  3.526043697937727*^9}, {3.526044002883819*^9, 3.526044022540441*^9}, {
  3.5260552464205637`*^9, 3.526055358864691*^9}}],

Cell[BoxData[{
 RowBox[{"A", "=", 
  RowBox[{"{", 
   RowBox[{"0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "1"}], 
   "}"}]}], "\[IndentingNewLine]", 
 RowBox[{"B", "=", 
  RowBox[{"{", 
   RowBox[{"1", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0"}], 
   "}"}]}]}], "DisplayFormula",
 CellChangeTimes->{{3.526055383695012*^9, 3.526055426017548*^9}}],

Cell["\<\
which leaves our walker with a total of 6 non-trivial points C of departure \
(nodes #2 through 7).\
\>", "Text",
 CellChangeTimes->{{3.5260554579799747`*^9, 3.5260554634593678`*^9}, {
  3.5260555154167624`*^9, 3.526055556861813*^9}, {3.526055643945785*^9, 
  3.5260556443430643`*^9}}],

Cell["\<\
My plan is to construct a command that generates walks that begin at C and \
automatically stop at A, then to resolve those walks into two classes : those \
that DID NOT visit B en route to A, and those that DID visit B.\
\>", "Text",
 CellChangeTimes->{{3.526055917177575*^9, 3.5260559425658007`*^9}}],

Cell[CellGroupData[{

Cell["\<\
Generating walks that automatically stop upon first arrival at A\
\>", "Subsubsection",
 CellChangeTimes->{{3.525713662710685*^9, 3.525713695398789*^9}}],

Cell[TextData[{
 "We make use of ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 "'s ",
 StyleBox["NestWhileList", "Input"],
 " command. The following command generates a list 50-member list of named \
walks, each of which begins at C = {0, 0, 1, 0, 0, 0, 0, 0} and ends with the \
first visit to A = {0, 0, 0, 0, 0, 0, 0, 1}:\n"
}], "Text",
 CellChangeTimes->{{3.52605605360091*^9, 3.526056092092114*^9}, {
   3.52605654186896*^9, 3.526056629299883*^9}, {3.526056719351941*^9, 
   3.526056735432085*^9}, 3.5260567894274797`*^9, {3.52605740266728*^9, 
   3.526057484547464*^9}, {3.52605753784871*^9, 3.5260575566450567`*^9}, {
   3.526058795216318*^9, 3.526058857331897*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["Walk", "n"], "=", 
      RowBox[{"NestWhileList", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"RandomChoice", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                "#", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}], 
                SubscriptBox["T", "k"]}], ",", 
               RowBox[{"{", 
                RowBox[{"k", ",", "1", ",", "8"}], "}"}]}], "]"}], "\[Rule]", 
             
             RowBox[{"{", 
              RowBox[{
               SubscriptBox["\[Tau]", "1"], ",", 
               SubscriptBox["\[Tau]", "2"], ",", 
               SubscriptBox["\[Tau]", "3"], ",", 
               SubscriptBox["\[Tau]", "4"], ",", 
               SubscriptBox["\[Tau]", "5"], ",", 
               SubscriptBox["\[Tau]", "6"], ",", 
               SubscriptBox["\[Tau]", "7"], ",", 
               SubscriptBox["\[Tau]", "8"]}], "}"}]}], ",", "1"}], "]"}], 
          "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], "&"}], ",", 
        
        SubscriptBox["\[Tau]", "3"], ",", 
        RowBox[{
         RowBox[{"#", "\[NotEqual]", 
          RowBox[{"{", 
           RowBox[{
           "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", 
            ",", "1"}], "}"}]}], "&"}]}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "1", ",", "20"}], "}"}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.526056109269004*^9, 3.526056140985182*^9}, {
  3.526056197524259*^9, 3.526056237630031*^9}, {3.526056483475037*^9, 
  3.526056483646661*^9}, {3.526057022803667*^9, 3.526057034630599*^9}, {
  3.526057145081944*^9, 3.526057167103324*^9}, {3.526058880085816*^9, 
  3.526058896093807*^9}}],

Cell["Here are a representative few of those walks :", "Text"],

