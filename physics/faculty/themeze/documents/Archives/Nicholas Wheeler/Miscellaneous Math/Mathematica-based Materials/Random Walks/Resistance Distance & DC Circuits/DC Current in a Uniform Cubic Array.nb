Cell[TextData[{
 "\[LongDash]that no wires (edges) connect those nodes. We can assign any \
values we please to the resistances in those \"virtual wires:\" such \
assignments affect the ",
 StyleBox["appearanc",
  FontVariations->{"Underline"->True}],
 "e of the dissipation function, but have no effect upon the physics."
}], "Text",
 CellChangeTimes->{{3.52589780366564*^9, 3.525897852206655*^9}, {
  3.525897911036852*^9, 3.525898051686986*^9}}],

