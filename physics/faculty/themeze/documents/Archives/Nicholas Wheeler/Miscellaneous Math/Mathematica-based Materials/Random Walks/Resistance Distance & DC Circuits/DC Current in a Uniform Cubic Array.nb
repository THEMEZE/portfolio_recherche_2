     SubscriptBox["\[Sigma]", "j"], "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"KroneckerDelta", "[", 
          RowBox[{"j", ",", "k"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", "8"}], "}"}]}], "]"}], "}"}], "]"}]}], 
    ",", 
    RowBox[{"{", 
     RowBox[{"j", ",", "1", ",", "8"}], "}"}]}], "]"}], 
