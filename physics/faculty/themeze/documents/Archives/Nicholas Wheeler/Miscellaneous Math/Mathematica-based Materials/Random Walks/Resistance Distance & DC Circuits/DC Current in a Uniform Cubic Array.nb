Cell["So we have", "Text",
 CellChangeTimes->{{3.525880190661419*^9, 3.5258801923396683`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Minimize", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"DissipationRandomCube", ",", "Constraints"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["J", 
      RowBox[{"1", ",", "2"}]], ",", 
