   SubscriptBox["V", "m"], " ", "=", " ", 
   RowBox[{"potential", " ", "of", " ", 
    SuperscriptBox["m", "th"], " ", "node"}]}], ",", " ", 
  RowBox[{"relative", " ", "to", " ", "ground"}]}]], "DisplayFormula",
 CellChangeTimes->{{3.526226837713388*^9, 3.526226874082571*^9}}],

Cell[TextData[{
 "then ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox["V", "m"], "-", 
    SubscriptBox["V", "n"]}], "=", 
   RowBox[{
    SubscriptBox["R", 
     RowBox[{"m", ",", "n"}]], 
    SubscriptBox["J", 
     RowBox[{"m", ",", "n"}]]}]}]],
  CellChangeTimes->{{3.5262267698303967`*^9, 3.5262268138066*^9}}],
 ". In the present instance (since all resistances are unity, node #8 is \
grounded, and the potential at node #1 has been established to be ",
 Cell[BoxData[
  FormBox[
   FractionBox["5", "6"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 ") we have"
}], "Text",
 CellChangeTimes->{{3.52622689314087*^9, 3.52622703760432*^9}}],

