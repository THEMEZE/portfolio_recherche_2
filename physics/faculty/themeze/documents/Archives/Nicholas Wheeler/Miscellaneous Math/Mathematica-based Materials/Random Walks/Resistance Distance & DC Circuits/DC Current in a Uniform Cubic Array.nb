 CellChangeTimes->{{3.526235985679022*^9, 3.526235986212762*^9}}],

Cell["\<\
Consider now a guy (\"electron\") who walks randomly on the graph that \
represents the design of the circuit. Let \
\>", "Text",
 CellChangeTimes->{{3.526236028889064*^9, 3.526236126777747*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["p", 
    RowBox[{"m", ",", "n"}]], " ", "=", " ", 
   RowBox[{"probability", " ", "that"}]}], ",", 
  RowBox[{"if", " ", "at", " ", "Node", " ", "m"}], ",", 
  RowBox[{
  "his", " ", "next", " ", "step", " ", "takes", " ", "him", " ", "to", " ", 
   "adjacent", " ", "Node", " ", "n"}]}]], "DisplayFormula",
 CellChangeTimes->{{3.5262361338457127`*^9, 3.526236192738738*^9}, {
  3.52623645774034*^9, 3.526236468507558*^9}}],

Cell[TextData[{
 "Select two nodes that we agree to call ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["n", "A"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["n", "B"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " (or sometimes simply A and B), respectively. Let"
}], "Text",
 CellChangeTimes->{{3.52623653935448*^9, 3.526236591310979*^9}, {
  3.526236683725683*^9, 3.5262367058934298`*^9}, {3.526236762479353*^9, 
  3.5262367817476397`*^9}}],

Cell[BoxData[
 RowBox[{
  SubscriptBox["P", "m"], "=", " ", 
  RowBox[{"probability", " ", "of", " ", "walking", " ", 
   RowBox[{"m", " ", "\[LongRightArrow]", " ", "A"}], " ", "without", " ", 
   "visiting", " ", "B"}]}]], "DisplayFormula",
 CellChangeTimes->{{3.526236598927815*^9, 3.526236654811771*^9}}],

Cell["Clearly", "Text",
 CellChangeTimes->{{3.526236836280037*^9, 3.526236837407878*^9}}],

Cell[BoxData[{
 RowBox[{
  SubscriptBox["P", "A"], "=", "1"}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["P", "B"], "=", "0"}]}], "DisplayFormula",
 CellChangeTimes->{{3.526236851819941*^9, 3.526236898666016*^9}}],

Cell["and", "Text",
 CellChangeTimes->{{3.526236903580924*^9, 3.526236903940188*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   SubscriptBox["P", "m"], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     RowBox[{"n", "\[Element]", 
      RowBox[{"N", "[", "m", "]"}]}]], 
    RowBox[{
     SubscriptBox["p", 
      RowBox[{"m", ",", "n"}]], 
     SubscriptBox["P", "n"]}]}]}],
  FontColor->RGBColor[1, 0, 0]]], "DisplayFormula",
 CellChangeTimes->{{3.526236912585126*^9, 3.526236982669491*^9}}],

Cell[TextData[{
 "The ",
 StyleBox["Monte Carlo approach to DC circuit analysis hinges on the \
observation",
  FontWeight->"Bold"],
 " that ",
 StyleBox["if we set the transition probablities equal to the fractional \
conductances",
  FontVariations->{"Underline"->True}]
}], "Text",
 CellChangeTimes->{{3.526237555429432*^9, 3.526237637703806*^9}}],

Cell[BoxData[
 RowBox[{
  SubscriptBox["p", 
   RowBox[{"m", ",", "n"}]], "=", 
  FractionBox[
   SubscriptBox["C", "mn"], 
   SubscriptBox["C", "m"]]}]], "DisplayFormula",
 CellChangeTimes->{{3.526237643858756*^9, 3.5262376695778913`*^9}}],

Cell[TextData[{
 "\[LongDash]which, if our walker is an \"electron,\" seems eminently \
sensible\[LongDash]then ",
 StyleBox["the red equations become identical",
  FontWeight->"Bold",
  FontColor->RGBColor[1, 0, 0]],
 ": ",
 StyleBox["the nodal probablities",
  FontVariations->{"Underline"->True}],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "m"], TraditionalForm]],
  FormatType->"TraditionalForm",
  FontVariations->{"Underline"->False}],
 " ",
 StyleBox["become interpretable as nodal potentials",
  FontVariations->{"Underline"->True}],
 " (relative to the grounded node B, the potential at node A being assumed \
without loss of generality to be unity). "
}], "Text",
 CellChangeTimes->{{3.526237693894985*^9, 3.526237733618599*^9}, {
  3.526237790258683*^9, 3.526237870051722*^9}, {3.526237901250243*^9, 
  3.5262379175758677`*^9}, {3.526238008026997*^9, 3.5262380171456623`*^9}}],

Cell[BoxData[""], "Input",
 CellChangeTimes->{{3.5262381192189283`*^9, 3.526238121150258*^9}}]
}, Open  ]],

Cell[CellGroupData[{

Cell["Preparatory general remarks about random walks on graphs", \
"Subsubsection",
 CellChangeTimes->{{3.526238139075091*^9, 3.526238154680977*^9}}],

Cell["\<\
A walker who departs from a specified node on (let us say) an 8-node graph \
can, after an n-step walk, find himself standing on any one of a variety of \
nodes. We write\
\>", "Text",
 CellChangeTimes->{{3.526306028840963*^9, 3.5263061497053843`*^9}}],

Cell[BoxData[
 SubscriptBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      SubscriptBox["p", "1"]},
     {
      SubscriptBox["p", "2"]},
     {
      SubscriptBox["p", "3"]},
     {"\[VerticalEllipsis]"},
     {
      SubscriptBox["p", "8"]}
    }], "\[NoBreak]", ")"}], "n"]], "DisplayFormula",
 CellChangeTimes->{{3.526306191696019*^9, 3.526306229427814*^9}}],

Cell["\<\
to describe the probability (relative frequency in an indefinitely large \
population of such walks) that he finds himself on this node or that. We will \
refer to such stochastic vectors (vectors with elements drawn from the unit \
interval, which sum to unity) \"state vectors,\" though there refer to the \
\"state of our expectations,\" not to the momentary state of any individual \
walker. 

One step later, we have\
\>", "Text",
 CellChangeTimes->{{3.52630627067168*^9, 3.5263065201409073`*^9}}],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox["p", "1"]},
      {
       SubscriptBox["p", "2"]},
      {
       SubscriptBox["p", "3"]},
      {"\[VerticalEllipsis]"},
      {
       SubscriptBox["p", "8"]}
     }], "\[NoBreak]", ")"}], 
   RowBox[{"n", "+", "1"}]], "=", 
  RowBox[{
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       SubscriptBox["p", 
        RowBox[{"1", ",", "1"}]], 
       SubscriptBox["p", 
        RowBox[{"1", ",", "2"}]], 
       SubscriptBox["p", 
        RowBox[{"1", ",", "3"}]], "\[CenterEllipsis]", 
       SubscriptBox["p", 
        RowBox[{"1", ",", "8"}]]},
      {
       SubscriptBox["p", 
        RowBox[{"2", ",", "1"}]], 
       SubscriptBox["p", 
        RowBox[{"2", ",", "2"}]], 
       SubscriptBox["p", 
        RowBox[{"2", ",", "3"}]], "\[CenterEllipsis]", 
       SubscriptBox["p", 
        RowBox[{"2", ",", "8"}]]},
      {
       SubscriptBox["p", 
        RowBox[{"3", ",", "1"}]], 
       SubscriptBox["p", 
        RowBox[{"3", ",", "2"}]], 
       SubscriptBox["p", 
        RowBox[{"3", ",", "3"}]], "\[CenterEllipsis]", 
       SubscriptBox["p", 
        RowBox[{"3", ",", "8"}]]},
      {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
       "\[DescendingEllipsis]", "\[VerticalEllipsis]"},
      {
       SubscriptBox["p", 
        RowBox[{"8", ",", "1"}]], 
       SubscriptBox["p", 
        RowBox[{"8", ",", "2"}]], 
       SubscriptBox["p", 
        RowBox[{"8", ",", "3"}]], "\[CenterEllipsis]", 
       SubscriptBox["p", 
        RowBox[{"8", ",", "8"}]]}
     }], "\[NoBreak]", ")"}], 
   SubscriptBox[
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        SubscriptBox["p", "1"]},
       {
        SubscriptBox["p", "2"]},
       {
        SubscriptBox["p", "3"]},
       {"\[VerticalEllipsis]"},
       {
        SubscriptBox["p", "8"]}
      }], "\[NoBreak]", ")"}], "n"]}]}]], "DisplayFormula"],

Cell["where", "Text",
 CellChangeTimes->{3.526306804082849*^9}],

Cell[BoxData[
 RowBox[{
  SubscriptBox["p", 
   RowBox[{"m", ",", "n"}]], "=", 
  RowBox[{"probability", " ", "of", " ", "transition", " ", 
   RowBox[{"m", " ", "\[LongLeftArrow]", " ", "n"}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.526306831292087*^9, 3.526306865101398*^9}}],

Cell[TextData[{
 "and the square matrix \[DoubleStruckCapitalT] will be called the \
\"transition matrix.\" Such matrices (also called \"Markov matrices\") are \
distinguished from square-matrices-in-general by the circumstances that (1) \
all elements are drawn from the unit interval, and (2) the elements in any \
column sum to unity.  \n\nIn a special class of cases \[DoubleStruckCapitalT] \
is ",
 StyleBox["symmetric",
  FontSlant->"Italic"],
 ", meaning"
}], "Text",
 CellChangeTimes->{{3.526306961789671*^9, 3.5263071728313103`*^9}, {
  3.526307247108508*^9, 3.5263072669611893`*^9}}],

Cell[BoxData[
 RowBox[{
  SubscriptBox["p", 
   RowBox[{"m", ",", "n"}]], "=", 
  RowBox[{
   SubscriptBox["p", 
    RowBox[{"n", ",", "m"}]], "   ", ":", "   ", 
   RowBox[{"all", " ", "m", " ", "and", " ", "n"}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.526307271698085*^9, 3.52630729586087*^9}}],

Cell[TextData[{
 "The ",
 StyleBox["principle of detailed balance",
  FontWeight->"Bold"],
 " is operative in such cases. The DC circuit application will present us \
with \[DoubleStruckCapitalT]-matrices that are typically ",
 StyleBox["asymmetric",
  FontSlant->"Italic"],
 ", and the principle of detailed balance is typically ",
 StyleBox["not",
  FontSlant->"Italic"],
 " operative.\n\nIf (as was tacitly assumed above) the walker makes his \
next-step decision with full knowledge of where he momentarily is but with no \
recollection of where he previously was (if he is, in short, \"memoriless\"), \
if he bases his next-step decision upon information written into the \
structure of a \[DoubleStruckCapitalT]-matrix that remains ever constant, \
then his random walk provides an instance of a \"Markov process.\" \n\nAll \
information having to do with the ",
 StyleBox["evolution of state vectors",
  FontVariations->{"Underline"->True}],
 "  can be extracted from the spectral properties of \
\[DoubleStruckCapitalT]-matrices: that is a pretty subject, but I will \
postpone discussion of its principal features until we have specific need of \
them.\n\nThe DC circuit application asks us to look to individual walks, and \
to resolve them into two classes, according as they do or do not possess a \
certain property. To that end we will have to unpack and to reassemble the \
information written into \[DoubleStruckCapitalT]."
}], "Text",
 CellChangeTimes->{{3.526307346892529*^9, 3.5263073670513573`*^9}, {
  3.526307423737114*^9, 3.526307423904418*^9}, {3.526307602285531*^9, 
  3.5263077083750343`*^9}, {3.526307764539866*^9, 3.526307943425449*^9}, {
  3.526307986062763*^9, 3.526308062042362*^9}, {3.526308113176355*^9, 
  3.5263081293273153`*^9}, {3.526308242901555*^9, 3.526308351380435*^9}, {
  3.5263083905667562`*^9, 3.526308645671831*^9}}],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.526308650303102*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Preparing to generate individual random walks on a uniform cubic array\
\>", "Subsubsection",
 CellChangeTimes->{{3.5263086740823936`*^9, 3.526308686212915*^9}, {
  3.526308732746017*^9, 3.526308733185968*^9}, {3.52630882122923*^9, 
  3.5263088307162743`*^9}, {3.526309716889286*^9, 3.526309721791664*^9}}],

Cell["\<\
From the graph of the cubic array (pay no attention for the moment to the \
\"in\"/\"out\" details)\
\>", "Text",
 CellChangeTimes->{{3.526309204864605*^9, 3.526309224244796*^9}, {
  3.5263092984165087`*^9, 3.526309350518108*^9}}],

Cell[BoxData[
 GraphicsBox[
  TagBox[GraphicsComplexBox[{{0., 0.6816892165626792}, {1.105984179535655, 
    0.6814160340895922}, {1.893410534088925, 1.3619227761147523`}, {
