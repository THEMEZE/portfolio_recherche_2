Cell[TextData[{
 "\[LongDash]are again in precise agreement with results of the symmetry \
argument. These results are easily seen to be in conformity with Kirchhoff's \
loop rule, but nowhere did we ",
 StyleBox["draw",
  FontSlant->"Italic"],
 " upon that rule."
}], "Text",
 CellChangeTimes->{{3.5262289359863653`*^9, 3.52622904863575*^9}}],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.526229076378974*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell["Effect of changing the relative placement of the electrodes", \
"Subsubsection",
 CellChangeTimes->{{3.526229855683663*^9, 3.526229866298875*^9}}],

Cell["\<\
There are\[LongDash]because of the symmetry of the array\[LongDash]only two \
cases to consider: the electrodes, instead of being diametric, can be (1) \
next-to-adjacent or (2) adjacent. In both of the latter cases the symmetry \
argument becomes inapplicable (and beyond salvation), but the variational \
method requires only the slightest of adjustment:\
\>", "Text",
 CellChangeTimes->{{3.52622988123418*^9, 3.526230019793783*^9}}],

Cell[BoxData[""], "Input",
 CellChangeTimes->{{3.526230741775354*^9, 3.5262307420017443`*^9}}],

Cell[TextData[{
 StyleBox["NEXT-TO-ADJACENT ELECTRODES",
  FontWeight->"Bold"],
 ":"
}], "Text",
 CellChangeTimes->{{3.526230035928343*^9, 3.5262300473917093`*^9}}],

