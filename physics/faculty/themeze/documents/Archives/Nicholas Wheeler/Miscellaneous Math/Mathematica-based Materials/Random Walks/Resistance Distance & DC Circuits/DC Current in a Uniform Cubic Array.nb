       SubscriptBox["J", 
        RowBox[{"7", ",", "8"}]], "-", "1"}], "\[Equal]", " ", "0"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox["J", 
         RowBox[{"3", ",", "8"}]]}], "-", 
       SubscriptBox["J", 
        RowBox[{"5", ",", "8"}]], "-", 
       SubscriptBox["J", 
        RowBox[{"7", ",", "8"}]]}], "\[Equal]", " ", "0"}]}], "}"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.525868906041411*^9, 3.525868945588614*^9}}],

