  3.525821982005477*^9, 3.525822070676173*^9}}],

Cell["\<\
\[LongDash]in precise agreement with the results obtained by the elementary \
symmetry-based argument developed earlier.

Moreover, we have\
\>", "Text",
 CellChangeTimes->{{3.52582219027704*^9, 3.52582226200177*^9}, {
  3.525822468478902*^9, 3.525822492279119*^9}}],

Cell[BoxData[
 RowBox[{
  SubscriptBox["DissipationRate", "minimum"], "=", 
  RowBox[{
   SubscriptBox["R", "effective"], 
   SuperscriptBox[
    SubscriptBox["J", "total"], "2"]}]}]], "Input",
 CellChangeTimes->{{3.5258225007186413`*^9, 3.5258225711291*^9}}],

Cell[TextData[{
 "which, since we have for computational purposes set ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["J", "total"], "=", "1"}]],
  CellChangeTimes->{{3.5258226554608307`*^9, 3.525822667344524*^9}}],
 ", supplies"
}], "Text",
 CellChangeTimes->{{3.525822614477417*^9, 3.525822640560019*^9}, {
  3.525822688078779*^9, 3.525822710903203*^9}}],

Cell[BoxData[
 RowBox[{
  SubscriptBox["R", "effective"], "=", 
  FractionBox["5", "6"]}]], "DisplayFormula",
 CellChangeTimes->{{3.5258226554608307`*^9, 3.525822667344524*^9}, {
  3.5258227226554537`*^9, 3.5258227377042837`*^9}}],

Cell[TextData[{
 "\[LongDash]again in precise agreement with a result of the symmetry-based \
argument.\n\n",
 StyleBox["COMPUTATIONAL REMARK",
  FontWeight->"Bold"],
 ": If we had elected to work with all the elements of \
\[DoubleStruckCapitalJ] we would have had to add to the list of constraints \
28 statements of the form ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox["J", 
     RowBox[{"m", ",", "n"}]], "+", 
    SubscriptBox["J", 
     RowBox[{"n", ",", "m"}]]}], "\[Equal]", "0"}]],
  CellChangeTimes->{{3.525871407486496*^9, 3.525871423969451*^9}}],
 ". ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " would than have attempted to provide ",
 StyleBox["all possible (but equivalent) formulations of its solution",
  FontSlant->"Italic"],
 ", which would have expanded its output by a factor of ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["2", "28"], "=", "268435456"}]],
  CellChangeTimes->{{3.525871580898588*^9, 3.5258716096842833`*^9}}],
 "!"
}], "Text",
 CellChangeTimes->{{3.5258227657729273`*^9, 3.5258228024471073`*^9}, {
  3.525871255763619*^9, 3.5258713370821877`*^9}, {3.525871378253755*^9, 
  3.5258714016333*^9}, {3.525871449153213*^9, 3.525871568169724*^9}, {
  3.525871627908566*^9, 3.525871655250317*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.525871233326777*^9, 3.525871252905752*^9}}]
}, Open  ]],

