Cell[TextData[{
 "We seek the potentials at the 6 remaining nodes, but it was previous \
observed that (by symmetry) ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["V", "2"], "=", 
   RowBox[{
    SubscriptBox["V", "4"], "=", 
    SubscriptBox["V", "6"]}]}]],
  CellChangeTimes->{{3.526317478417083*^9, 3.52631750130058*^9}}],
 " and ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["V", "7"], "=", 
   RowBox[{
    SubscriptBox["V", "5"], "=", 
    SubscriptBox["V", "3"]}]}]],
  CellChangeTimes->{{3.526317478417083*^9, 3.52631750130058*^9}}],
 " so we really have only two cases to consider. Accordingly, we launch the \
walker (\"electron\") from"
}], "Text",
 CellChangeTimes->{{3.5263173909832067`*^9, 3.526317473402182*^9}, {
  3.5263175367136602`*^9, 3.526317545002454*^9}, {3.526317596207645*^9, 
  3.526317663791532*^9}, {3.5263182959695787`*^9, 3.5263183247435923`*^9}}],

Cell[BoxData[
 RowBox[{"C", "=", 
  RowBox[{"{", 
   RowBox[{
   "0", ",", "1", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", 
    "0"}], "}"}]}]], "DisplayFormula",
 CellChangeTimes->{{3.526318370203125*^9, 3.526318380480219*^9}}],

Cell["\<\
and ask for an estimate of the probability that he (it) successfully reaches \
A without having visited B, or we launch him from\
\>", "Text",
 CellChangeTimes->{{3.526318392992758*^9, 3.526318460343225*^9}}],

Cell[BoxData[
 RowBox[{"D", "=", 
  RowBox[{"{", 
   RowBox[{
   "0", ",", "0", ",", "1", ",", "0", ",", "0", ",", "0", ",", "0", ",", 
    "0"}], "}"}]}]], "DisplayFormula",
 CellChangeTimes->{{3.526318530215753*^9, 3.526318538246964*^9}}],

Cell[TextData[{
 "and ask the same thing.\n\nAs a first step toward that objective, I \
construct a command that generates (here\[LongDash]initially\[LongDash]a \
short list of 50) ",
 StyleBox["named walks that automatically stop upon first arrival at A",
  FontWeight->"Bold"],
 ":"
}], "Text",
 CellChangeTimes->{{3.526318555305434*^9, 3.526318687425644*^9}, {
   3.526319006066614*^9, 3.526319024174395*^9}, 3.5263193103037148`*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["Walk", "n"], "=", 
      RowBox[{"NestWhileList", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"RandomChoice", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                "#", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}], 
                SubscriptBox["T", "k"]}], ",", 
               RowBox[{"{", 
                RowBox[{"k", ",", "1", ",", "8"}], "}"}]}], "]"}], "\[Rule]", 
             
             RowBox[{"{", 
              RowBox[{
               SubscriptBox["\[Sigma]", "1"], ",", 
               SubscriptBox["\[Sigma]", "2"], ",", 
               SubscriptBox["\[Sigma]", "3"], ",", 
               SubscriptBox["\[Sigma]", "4"], ",", 
               SubscriptBox["\[Sigma]", "5"], ",", 
               SubscriptBox["\[Sigma]", "6"], ",", 
               SubscriptBox["\[Sigma]", "7"], ",", 
               SubscriptBox["\[Sigma]", "8"]}], "}"}]}], ",", "1"}], "]"}], 
          "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], "&"}], ",", 
        
        SubscriptBox["\[Sigma]", "2"], ",", 
        RowBox[{
         RowBox[{"#", "\[NotEqual]", 
          RowBox[{"{", 
           RowBox[{
           "1", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", 
            ",", "0"}], "}"}]}], "&"}]}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "1", ",", "50"}], "}"}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.5263187298586607`*^9, 3.526318750122058*^9}, 
   3.5263187999574223`*^9, 3.526318901990209*^9, 3.526319303237607*^9}],

Cell["\<\
Here is a 10-member sample of the walks thus generated. Notice that some are \
short, some are long; each begins at C and ends at A; some visit B one or \
more times en route to A, while some successfully avoid B:\
\>", "Text",
 CellChangeTimes->{{3.526319063187648*^9, 3.526319132359209*^9}, {
  3.526319167192499*^9, 3.526319276064097*^9}}],

