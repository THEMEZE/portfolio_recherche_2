                  RowBox[{
                   SubscriptBox["R", 
                    RowBox[{"6", ",", "5"}]], "=", 
                   RowBox[{
                    SubscriptBox["R", 
                    RowBox[{"6", ",", "7"}]], "=", 
                    RowBox[{
                    SubscriptBox["R", 
                    RowBox[{"7", ",", "4"}]], "=", 
                    RowBox[{
