Cell["\<\
The effective resistance has decreased (not surprisingly, since the in/out \
nodes are now closer together)\
\>", "Text",
 CellChangeTimes->{{3.5258696121689777`*^9, 3.5258696259079723`*^9}, {
  3.5258696949653883`*^9, 3.525869726341393*^9}}],

