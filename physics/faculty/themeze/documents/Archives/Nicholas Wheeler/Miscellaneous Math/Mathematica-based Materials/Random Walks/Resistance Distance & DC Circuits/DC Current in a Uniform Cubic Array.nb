Cell[TextData[{
 "We are looking, therefore, for the point on (in this instance) a \
12-dimensional hypersphere which conforms to a set of 8 nodal contraints.\n\n",
 StyleBox["COMPUTATIONAL REMARK",
  FontWeight->"Bold"],
 ": It is always advisable to use only ",
 StyleBox["independent",
  FontSlant->"Italic"],
 " variables (taken here to be the currents that lie above the principal \
diagonal of \[DoubleStruckCapitalJ]) when assigning work to ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 "."
}], "Text",
 CellChangeTimes->{{3.5258212013774652`*^9, 3.5258212791419363`*^9}, {
  3.5258705529695997`*^9, 3.5258705718997087`*^9}, {3.52587111217877*^9, 
  3.525871177761293*^9}}],

Cell[BoxData[""], "Input",
 CellChangeTimes->{{3.5258146041923447`*^9, 3.525814604359765*^9}}]
}, Open  ]],

