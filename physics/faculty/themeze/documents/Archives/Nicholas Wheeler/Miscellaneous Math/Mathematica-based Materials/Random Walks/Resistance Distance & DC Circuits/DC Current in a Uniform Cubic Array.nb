Cell[TextData[{
 "from which it becomes evident that the stochastic state vector is \
converging upon an asymptotically steady state. What we witness here is an \
\"equilibration process.\"\n\nWe draw now upon some general properties of \
\[DoubleStruckCapitalT]-matrices:\n\n",
 StyleBox["1",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0, 1]],
 ") The leading eigenvalue of a \[DoubleStruckCapitalT] matrix is invariably \
unity, and the others (whether real or complex) have absolute values that are \
less than unity:"
}], "Text",
 CellChangeTimes->{{3.525988647075912*^9, 3.525988727285722*^9}, {
  3.525988996772582*^9, 3.525988998473576*^9}, {3.526003835105027*^9, 
  3.526003954988782*^9}, {3.526005149121208*^9, 3.52600516601589*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Abs", "[", 
  RowBox[{"N", "[", 
   RowBox[{"Eigenvalues", "[", "\[DoubleStruckCapitalT]", "]"}], "]"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.526003964530683*^9, 3.5260039788496437`*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "1.`", ",", "0.3089612354182943`", ",", "0.23539017398049966`", ",", 
   "0.23539017398049966`", ",", "0.16065862904885408`", ",", 
   "0.11497245512874144`", ",", "0.11497245512874144`", ",", 
   "0.08060841941155603`"}], "}"}]], "Output",
 CellChangeTimes->{3.5260039828378487`*^9}]
}, Open  ]],

Cell[TextData[{
 StyleBox["2",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0, 1]],
 ") The eigenvectors of a \[DoubleStruckCapitalT] matrix are, as supplied to \
us by ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 ", normalized. The leading eigenvector is (by the Perron-Frobenius theorem) \
the only eigenvector with the properties that all of its elements have the \
same sign (which can be taken  to be positive), and it is, moreover, the only \
eigenvector with the property that the sum of its elements does not vanish:"
}], "Text",
 CellChangeTimes->{{3.526003994337165*^9, 3.526004037948904*^9}, {
  3.526004072280345*^9, 3.526004232113796*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"Chop", "[", 
    RowBox[{"Total", "[", 
     RowBox[{"N", "[", 
      RowBox[{
       RowBox[{"Eigenvectors", "[", "\[DoubleStruckCapitalT]", "]"}], 
       "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}], "]"}], "]"}], 
    "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"k", ",", "1", ",", "8"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.526004236893115*^9, 3.526004306297903*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "12.711099473854995`", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", 
   ",", "0", ",", "0"}], "}"}]], "Output",
 CellChangeTimes->{{3.526004289261036*^9, 3.5260043145759373`*^9}}]
}, Open  ]],

Cell["\<\
It is, therefore, the only eigenvector that can be \"unitized\" (meaning \
\"rescaled to that the sum of its elements is unity\"). When so unitized it \
becomes interpretable as a \"stochastic vector.\" In the present instance \
that vector is\
\>", "Text",
 CellChangeTimes->{{3.526004343922327*^9, 3.526004496289423*^9}, {
  3.526069582251555*^9, 3.52606959961719*^9}}],

