Cell[TextData[{
 "We notice that some of those walks visit B = {1, 0, 0, 0, 0, 0, 0, 0} one \
or more times ",
 StyleBox["en route",
  FontSlant->"Italic"],
 " C \[LongRightArrow] A, while others successfully manage to avoid B.\n\nThe \
idea now is to examine the walks, one at a time, and to print A if the 1s in \
the initial place sum to 0\[LongDash]signifying that B has been successfully \
avoided\[LongDash]and in all other cases to print B. Here are iollustrative \
instances of a command that is seen by inspection to accomplish that \
objective:"
}], "Text",
 CellChangeTimes->{{3.526057640245182*^9, 3.52605769300576*^9}, {
   3.5260578261771317`*^9, 3.526057838148369*^9}, {3.5260578852495537`*^9, 
   3.5260579020803347`*^9}, {3.526058119668902*^9, 3.526058150761799*^9}, 
   3.526059016034256*^9, {3.526059088734325*^9, 3.526059091318553*^9}, {
   3.526059127613627*^9, 3.526059166209114*^9}, {3.526059237935976*^9, 
   3.526059254553927*^9}}],

