 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " to a select a state from ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox["\[Tau]", "1"], ",", 
    SubscriptBox["\[Tau]", "2"], ",", 
    SubscriptBox["\[Tau]", "3"], ",", 
    SubscriptBox["\[Tau]", "4"], ",", 
