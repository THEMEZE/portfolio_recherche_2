 RowBox[{
  RowBox[{"IndexOrdering", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
  RowBox[{"Which", "[", 
   RowBox[{
    RowBox[{"x", "\[LessSlantEqual]", "y"}], ",", "1", ",", 
    RowBox[{"x", ">", "y"}], ",", 
    RowBox[{"-", "1"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"NodalTerms", "[", "x_", "]"}], ":=", 
  RowBox[{
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"n", "=", "1"}], 
    RowBox[{"Length", "[", 
     RowBox[{"NodeData", "[", "x", "]"}], "]"}]], 
   RowBox[{
    RowBox[{"IndexOrdering", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"NodeData", "[", "x", "]"}], "\[LeftDoubleBracket]", "n", 
        "\[RightDoubleBracket]"}], "\[LeftDoubleBracket]", "1", 
       "\[RightDoubleBracket]"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"NodeData", "[", "x", "]"}], "\[LeftDoubleBracket]", "n", 
        "\[RightDoubleBracket]"}], "\[LeftDoubleBracket]", "2", 
       "\[RightDoubleBracket]"}]}], "]"}], 
    SubscriptBox["J", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"NodeData", "[", "x", "]"}], "\[LeftDoubleBracket]", "n", 
        "\[RightDoubleBracket]"}], "\[LeftDoubleBracket]", "1", 
       "\[RightDoubleBracket]"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"NodeData", "[", "x", "]"}], "\[LeftDoubleBracket]", "n", 
