    RowBox[{"5", ",", "8"}]]}], "\[Equal]", "0"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    SubscriptBox["J", 
     RowBox[{"1", ",", "6"}]]}], "+", 
