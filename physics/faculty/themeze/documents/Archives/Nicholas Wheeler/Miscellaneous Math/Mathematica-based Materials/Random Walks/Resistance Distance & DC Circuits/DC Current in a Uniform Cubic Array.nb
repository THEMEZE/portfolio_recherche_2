 RowBox[{
  RowBox[{
   RowBox[{"Six10StepWalks", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"NestList", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"RandomChoice", "[", 
