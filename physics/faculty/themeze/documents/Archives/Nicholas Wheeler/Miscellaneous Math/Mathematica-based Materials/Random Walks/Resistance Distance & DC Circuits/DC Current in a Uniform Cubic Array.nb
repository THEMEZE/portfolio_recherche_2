Cell[TextData[{
 "Monte Carlo methods\[LongDash]to whatever end they are \
applied\[LongDash]require access to ",
 StyleBox["large populations",
  FontVariations->{"Underline"->True}],
 " of walks. The following command generates a 6-member population of 10-step \
walks, all of which take Node #3 as the point of departure:"
}], "Text",
 CellChangeTimes->{{3.5263157611195507`*^9, 3.526315839043038*^9}, {
  3.526315873731771*^9, 3.5263159319658527`*^9}}],

