Cell["\<\
The symmetry argument now fails, but the variational method very easily \
accommodates the adjustment. The constraint relations become\
\>", "Text",
 CellChangeTimes->{{3.525868765797698*^9, 3.5258687738201637`*^9}, {
  3.5258688084818897`*^9, 3.525868868415695*^9}, {3.525871752434626*^9, 
  3.525871777871367*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"NewConstraints", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["J", 
        RowBox[{"1", ",", "2"}]], "+", 
       SubscriptBox["J", 
        RowBox[{"1", ",", "4"}]], "+", 
       SubscriptBox["J", 
        RowBox[{"1", ",", "6"}]], "+", "1"}], "\[Equal]", " ", "0"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox["J", 
         RowBox[{"1", ",", "2"}]]}], "+", 
       SubscriptBox["J", 
        RowBox[{"2", ",", "3"}]], "+", 
       SubscriptBox["J", 
        RowBox[{"2", ",", "5"}]]}], "\[Equal]", " ", "0"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox["J", 
         RowBox[{"2", ",", "3"}]]}], "+", 
       SubscriptBox["J", 
        RowBox[{"3", ",", "4"}]], "+", 
       SubscriptBox["J", 
        RowBox[{"3", ",", "8"}]]}], " ", "\[Equal]", " ", "0"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox["J", 
         RowBox[{"1", ",", "4"}]]}], "-", 
       SubscriptBox["J", 
        RowBox[{"3", ",", "4"}]], "+", 
       SubscriptBox["J", 
        RowBox[{"4", ",", "7"}]]}], "\[Equal]", " ", "0"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox["J", 
         RowBox[{"2", ",", "5"}]]}], "+", 
       SubscriptBox["J", 
        RowBox[{"5", ",", "6"}]], "+", 
       SubscriptBox["J", 
        RowBox[{"5", ",", "8"}]]}], "\[Equal]", " ", "0"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox["J", 
         RowBox[{"1", ",", "6"}]]}], "-", 
       SubscriptBox["J", 
        RowBox[{"5", ",", "6"}]], "+", 
       SubscriptBox["J", 
        RowBox[{"6", ",", "7"}]]}], "\[Equal]", " ", "0"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SubscriptBox["J", 
