     1.499999999831513}}]& ],
  AspectRatio->Automatic,
  FrameTicks->None,
  PlotRange->All,
  PlotRangePadding->Scaled[0.1]]], "Output",
 CellChangeTimes->{3.526221301398905*^9}]
}, Open  ]],

Cell["Evidently ", "Text",
 CellChangeTimes->{{3.526221566173555*^9, 3.5262215682611322`*^9}}],

Cell[BoxData[{
 RowBox[{
  SubscriptBox["J", 
   RowBox[{"m", ",", "n"}]], "=", 
  RowBox[{"-", 
   SubscriptBox["J", 
    RowBox[{"n", ",", "m"}]]}]}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["J", 
   RowBox[{"m", ",", "m"}]], "=", "0"}]}], "DisplayFormula",
 CellChangeTimes->{{3.526221587928627*^9, 3.5262216251012774`*^9}}],

Cell[TextData[{
 "which is to say: ",
 StyleBox["the \"current matrix\" \[DoubleStruckCapitalJ] is antisymmetric",
  FontVariations->{"Underline"->True}],
 ".\n\nReading from the diagram"
}], "Text",
 CellChangeTimes->{{3.5262216541196632`*^9, 3.526221693677931*^9}, {
  3.526221796556841*^9, 3.5262218080707293`*^9}}],

