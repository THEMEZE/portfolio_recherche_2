Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.531107023744092*^9}],

Cell["\<\
Here I illustrate an unsophisticated procedure intended to accomplish the \
same calculation: \
\>", "Text",
 CellChangeTimes->{{3.531107055050663*^9, 3.53110712000027*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "z_", "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"z", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], "+", 
     RowBox[{"\[Tau]", " ", "3", 
      RowBox[{"z", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}]}],
     ",", 
    RowBox[{
     RowBox[{"z", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], "-", 
     RowBox[{"\[Tau]", " ", 
      RowBox[{
      "z", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}]}]}], 
   "}"}]}]], "Input",
 CellChangeTimes->{{3.531077497925221*^9, 3.531077583988577*^9}, {
   3.531077628794408*^9, 3.53107763404943*^9}, {3.531077842393983*^9, 
   3.531077884857914*^9}, {3.531077955126771*^9, 3.5310779583023863`*^9}, 
   3.531107000682289*^9}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Tau]", "=", ".01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y", "=", "1"}], ";"}]}], "Input",
 CellChangeTimes->{{3.531078894190447*^9, 3.5310789379519463`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"SuccessivePoints", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"NestList", "[", 
     RowBox[{"f", ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "y"}], "}"}], ",", "10000"}], "]"}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.531078858841795*^9, 3.53107886452549*^9}, {
  3.531079016544014*^9, 3.531079017100889*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{"SuccessivePoints", ",", 
   RowBox[{"AxesOrigin", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0"}], "}"}]}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"PointSize", "[", "0.004", "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.531078979633477*^9, 3.531079003037068*^9}}],

