Cell[CellGroupData[{

Cell["Stochastic classical motion", "Subsection",
 CellChangeTimes->{{3.531151278333156*^9, 3.531151286885387*^9}}],

Cell["\<\
This subject\[LongDash]pioneered by Einstein, Smoluchowski, Langevin, Fokker, \
Planck\[Ellipsis]and deepened by Ito, Kolmogorov,  Bogoliubov\[Ellipsis]\
\[LongDash]has given rise to an enormous literature, with most of which I am \
at present totally ignorant: see\
\>", "Text",
 CellChangeTimes->{{3.5311513225814457`*^9, 3.531151361363387*^9}, {
  3.531151401090702*^9, 3.531151415584826*^9}, {3.531151543507454*^9, 
  3.531151725149654*^9}}],

