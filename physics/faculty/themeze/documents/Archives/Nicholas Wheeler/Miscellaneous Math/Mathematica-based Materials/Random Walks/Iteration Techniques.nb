Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "z_", "]"}], ":=", 
  RowBox[{"RandomChoice", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"z", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
        "+", 
        RowBox[{"\[Tau]", " ", "3", 
         RowBox[{
         "z", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}]}], ",", 
       RowBox[{"z", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"z", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
       ",", 
       RowBox[{
        RowBox[{"z", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
        "-", 
        RowBox[{"\[Tau]", " ", 
         RowBox[{
         "z", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}]}]}], 
      "}"}]}], "}"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.531154431961516*^9, 3.5311544579858*^9}, {
  3.5311544949947453`*^9, 3.531154515533678*^9}, {3.531154861240014*^9, 
  3.5311548646445427`*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Tau]", "=", ".01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p", "=", "1"}], ";"}]}], "Input",
 CellChangeTimes->{{3.531154593004827*^9, 3.531154603508338*^9}, {
   3.5311546598592863`*^9, 3.53115467646348*^9}, 3.531154986269178*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"SuccessivePoints", "=", 
