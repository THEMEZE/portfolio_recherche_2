Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{"x", ",", "p", ",", "t"}], "]"}]], "Input",
 CellChangeTimes->{{3.531155273843587*^9, 3.531155283666306*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"OscillatorOrbit", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "t", "]"}], "\[Equal]", 
       RowBox[{"3", 
        RowBox[{"p", "[", "t", "]"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"p", "'"}], "[", "t", "]"}], "\[Equal]", 
       RowBox[{"-", 
        RowBox[{"x", "[", "t", "]"}]}]}], ",", 
      RowBox[{
       RowBox[{"x", "[", "0", "]"}], "\[Equal]", "0"}], ",", 
      RowBox[{
       RowBox[{"p", "[", "0", "]"}], "\[Equal]", "1"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "p"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "10"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.531079356943717*^9, 3.531079449163712*^9}, {
  3.531079504413191*^9, 3.531079531135206*^9}, {3.531079835815424*^9, 
  3.531079843027911*^9}, {3.531080122631411*^9, 3.531080122803294*^9}, {
  3.5310902719798117`*^9, 3.531090281728291*^9}, {3.5310904757859507`*^9, 
  3.53109052510604*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"x", "\[Rule]", 
     TagBox[
      RowBox[{"InterpolatingFunction", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"0.`", ",", "10.`"}], "}"}], "}"}], ",", "\<\"<>\"\>"}], 
       "]"}],
      False,
      Editable->False]}], ",", 
    RowBox[{"p", "\[Rule]", 
     TagBox[
      RowBox[{"InterpolatingFunction", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"0.`", ",", "10.`"}], "}"}], "}"}], ",", "\<\"<>\"\>"}], 
       "]"}],
      False,
      Editable->False]}]}], "}"}], "}"}]], "Output",
 CellChangeTimes->{
  3.531079455381632*^9, 3.531079490729897*^9, 3.5310795374108877`*^9, 
   3.531079651831902*^9, 3.5310797965588303`*^9, 3.531079847968195*^9, 
   3.531079883060433*^9, 3.5310801276854267`*^9, 3.531090532275207*^9, 
   3.531090657303503*^9, 3.531090705486322*^9, 3.531106462427157*^9, 
   3.531106964881784*^9, {3.53115526486202*^9, 3.5311552935767517`*^9}}]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NonrandomOrbit", "=", 
  RowBox[{"ParametricPlot", "[", 
   RowBox[{
    RowBox[{"Evaluate", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x", "[", "t", "]"}], ",", 
        RowBox[{"p", "[", "t", "]"}]}], "}"}], "/.", "OscillatorOrbit"}], 
     "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "10"}], "}"}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"Thick", ",", "Red"}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.5311553094958878`*^9, 3.531155383974595*^9}}],

