Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.5311631026999063`*^9}],

Cell["\<\
We are in position to study motion of the mean, but that would involve heavy \
Monte Carlo work that I am not motivated to undertake. One could introduce a \
\"more physical\" mechanism for introducing randomness\[Ellipsis]as is \
presumably contemplated in serious stochastic DE work\[Ellipsis]but again my \
motivation fails me. 

Note the clear violation of energy conservation, which I suppose is to be \
expected if randomness is considered to be a result of uncontrolled \
perturbative interaction with an \"environment.\" Energy non-conservation \
would be expected even if that interaction were \"more physical.\"

If my undergraduate self were to sketch his idea to me today I would advise \
him to forget it, for it seems incapable of capturing any of the essentials \
of quantum mechanics. A worthy objective would be to demonstrate a mechanism \
whereby the classical distribution\
\>", "Text",
 CellChangeTimes->{{3.531237347106667*^9, 3.53123767103226*^9}, {
  3.531262009045027*^9, 3.531262251187769*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"P", "[", 
   RowBox[{"x", ",", "p", ",", "t"}], "]"}], "=", 
  RowBox[{
   RowBox[{"\[Delta]", "[", 
    RowBox[{"x", "-", 
     RowBox[{"x", "[", "t", "]"}]}], "]"}], 
   RowBox[{"\[Delta]", "[", 
    RowBox[{"p", "-", 
     RowBox[{"p", "[", "t", "]"}]}], "]"}]}]}]], "Output",
 CellChangeTimes->{{3.531262257491983*^9, 3.5312623050947733`*^9}}],

Cell["\<\
acquires features of the Wigner distribution, of which the most essential is\
\>", "Text",
 CellChangeTimes->{{3.531262311672757*^9, 3.5312623312118053`*^9}, {
  3.531262374991515*^9, 3.5312623807288017`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Integral]", 
   RowBox[{
    RowBox[{"P", "[", 
     RowBox[{"x", ",", "p"}], "]"}], 
    RowBox[{"\[DifferentialD]", "x"}], 
    RowBox[{"\[DifferentialD]", "p"}]}]}], "=", "1"}]], "Output",
 CellChangeTimes->{{3.531262400871323*^9, 3.531262410356513*^9}, {
  3.5312624408674097`*^9, 3.531262454210249*^9}}],

Cell[TextData[{
 "But that looks pretty hopeless to me at the moment (maybe in another 56 \
years?).\n\nPossibly more workable/interesting is this idea: ",
 StyleBox["Introduce a random jiggle into",
  FontColor->RGBColor[1, 0, 0]]
}], "Text",
 CellChangeTimes->{{3.531262523244095*^9, 3.531262630968461*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   SubscriptBox["\[Psi]", "t"], "=", 
   RowBox[{
    RowBox[{"\[DoubleStruckCapitalU]", "[", "t", "]"}], 
    SubscriptBox["\[Psi]", "0"]}]}], "Output",
  FontColor->RGBColor[1, 0, 0]]], "Input",
 CellChangeTimes->{3.531262711110682*^9}]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Motion in a \"periodic Sina Zeytinoglu potential\"\
\>", "Subsection",
 CellChangeTimes->{{3.531163279020609*^9, 3.5311633033164988`*^9}}],

Cell["\<\
We are led by my understanding of the picture Zeytinoglu has in mind to \
contemplate a dynamic random walk on the 2D plane (4D phase space), in the \
presence of a spatially periodic potential. I construct a couple of such \
potentials:\
\>", "Text",
 CellChangeTimes->{{3.5312377185908546`*^9, 3.53123783464988*^9}}],

Cell[CellGroupData[{

Cell["Illustrative spatially periodic potentials in 2D", "Subsubsection",
 CellChangeTimes->{{3.53123784087386*^9, 3.531237855756629*^9}}],

Cell[BoxData[""], "Input",
 CellChangeTimes->{{3.531237890657295*^9, 3.531237892560655*^9}}],

Cell[TextData[StyleBox["A.  Sinusoidal Corregations",
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.531237900101985*^9, 3.531237926326763*^9}}],

Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{"x", ",", "y", ",", "p", ",", "q", ",", "t"}], "]"}]], "Input",
 CellChangeTimes->{{3.531237965980341*^9, 3.531237970617813*^9}, {
  3.531238742761551*^9, 3.531238744312955*^9}, {3.5312389153963118`*^9, 
  3.531238915800961*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"V", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
  RowBox[{"1", "+", 
   RowBox[{"Sin", "[", 
    RowBox[{"2", "\[Pi]", " ", "x"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.531237937978454*^9, 3.531237978704297*^9}, {
  3.531238011210565*^9, 3.531238091850565*^9}, {3.531262744504108*^9, 
  3.5312627465336237`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot3D", "[", 
  RowBox[{
   RowBox[{"1", "+", 
    RowBox[{"Sin", "[", 
     RowBox[{"2", "\[Pi]", " ", "x"}], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "4"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", "0", ",", "4"}], "}"}], ",", " ", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", "\"\<y\>\"", ",", "\"\<V\>\""}], "}"}]}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.5312381033600063`*^9, 3.531238147366281*^9}, {
