Cell["The Hamilton is of the form", "Text",
 CellChangeTimes->{{3.531238339802389*^9, 3.5312383943725643`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"H", "[", 
   RowBox[{"p", ",", "q", ",", "x", ",", "y"}], "]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["H", "1"], "[", 
     RowBox[{"p", ",", "x"}], "]"}], "+", 
    RowBox[{
     SubscriptBox["H", "2"], "[", 
     RowBox[{"q", ",", "y"}], "]"}]}], "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "2"], "[", 
     RowBox[{
      SuperscriptBox["p", "2"], "+", 
      SuperscriptBox["q", "2"]}], "]"}], "+", "1", "+", 
    RowBox[{"Sin", "[", 
     RowBox[{"2", "\[Pi]", " ", "x"}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.531254209282752*^9, 3.531254210550434*^9}}],

Cell["so the equations of motion separate:", "Text",
 CellChangeTimes->{{3.53123853418816*^9, 3.531238549797742*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"x", "'"}], "[", "t", "]"}], "\[Equal]", 
  RowBox[{"p", "[", "t", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"p", "'"}], "[", "t", "]"}], "\[Equal]", 
   RowBox[{
    RowBox[{"-", "2"}], "\[Pi]", " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"2", "\[Pi]", " ", 
      RowBox[{"x", "[", "t", "]"}]}], "]"}]}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"y", "'"}], "[", "t", "]"}], "\[Equal]", 
  RowBox[{"q", "[", "t", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"q", "'"}], "[", "t", "]"}], "\[Equal]", "0"}]}], "Input",
 CellChangeTimes->{{3.531238577366914*^9, 3.5312386911544724`*^9}, {
  3.531254182954967*^9, 3.5312541891562634`*^9}}],

Cell["The {y, q} motion is unaccelerated uniform:", "Text",
 CellChangeTimes->{{3.531254250146734*^9, 3.531254276690712*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"y", "[", "t", "]"}], "\[Equal]", 
  RowBox[{
   SubscriptBox["y", "0"], "+", 
   RowBox[{
    SubscriptBox["q", "0"], "t"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"q", "[", "t", "]"}], "\[Equal]", 
  SubscriptBox["q", "0"]}]}], "Input",
 CellChangeTimes->{{3.531254284641817*^9, 3.531254322918089*^9}}],

Cell["\<\
The {x. p} motion is pendular\[LongDash]oscillatory if E < 2 and libational \
if E > 2:\
\>", "Text",
 CellChangeTimes->{{3.531254339930152*^9, 3.531254383816938*^9}, {
   3.531254421512203*^9, 3.531254445882625*^9}, 3.5312618270822268`*^9, {
   3.5312618676222763`*^9, 3.53126189816098*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EnergyContours", "=", 
  RowBox[{"ContourPlot", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      SuperscriptBox["p", "2"]}], "+", "1", "+", 
     RowBox[{"Sin", "[", 
      RowBox[{"2", "\[Pi]", " ", "x"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "4"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"p", ",", "0", ",", "4"}], "}"}], ",", 
    RowBox[{"Contours", "\[Rule]", "15"}], ",", 
    RowBox[{"GridLines", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", "}"}], ",", 
       RowBox[{"{", "2", "}"}]}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.531254576670656*^9, 3.5312545821904297`*^9}, {
   3.531254613131859*^9, 3.531254657940034*^9}, {3.531254716365004*^9, 
   3.531254720509618*^9}, {3.531254765455326*^9, 3.5312547854698343`*^9}, {
   3.5312548971116467`*^9, 3.531254979198777*^9}, {3.5312551493327227`*^9, 
