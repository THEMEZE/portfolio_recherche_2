Cell[TextData[{
 "It is amazing (but gratifying!) that ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " is\[LongDash]though the computational burden has been much increased\
\[LongDash]still able to complete its work in only a few seconds."
}], "Text",
 CellChangeTimes->{{3.531107499035089*^9, 3.531107610512682*^9}}],

Cell["\<\
Here I repeat the calculation with a relatively large \[Tau]-value:  \
\>", "Text",
 CellChangeTimes->{{3.5311076430912933`*^9, 3.531107709490909*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Tau]", "=", ".1"}], ";"}]], "Input",
 CellChangeTimes->{{3.531107731977336*^9, 3.5311077454355173`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SuccessivePoints", "=", 
    RowBox[{"Simplify", "[", 
     RowBox[{"NestList", "[", 
      RowBox[{"f", ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "y"}], "}"}], ",", "800"}], "]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"SuccessivePoints", ",", 
   RowBox[{"AxesOrigin", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0"}], "}"}]}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"PointSize", "[", "0.01", "]"}]}], ",", 
   RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "80000"}], ",", "80000"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "40000"}], ",", "60000"}], "}"}]}], "}"}]}]}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.531078858841795*^9, 3.53107886452549*^9}, {
   3.531079016544014*^9, 3.531079017100889*^9}, {3.5310791170749683`*^9, 
