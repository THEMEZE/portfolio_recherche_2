Cell["\<\
Nicholas Wheeler
23 November 2011\
\>", "Text",
 CellChangeTimes->{{3.5310787607385197`*^9, 3.5310787724633293`*^9}},
 FontSize->10],

Cell[BoxData["\[IndentingNewLine]"], "Input",
