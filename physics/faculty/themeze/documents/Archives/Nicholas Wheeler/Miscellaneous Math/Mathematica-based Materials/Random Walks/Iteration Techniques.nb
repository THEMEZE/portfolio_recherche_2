Cell["\<\
To test whether the failure of the curve to close on itself can be attributed \
to the size of \[Tau] I repeat the calculation with an assortment of \
alternative \[Tau]-values:\
\>", "Text",
 CellChangeTimes->{{3.5311071843975477`*^9, 3.53110731407535*^9}, {
  3.531108240630383*^9, 3.531108259160434*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Tau]", "=", "0.001"}], ";"}]], "Input",
 CellChangeTimes->{{3.531079052996882*^9, 3.531079088642717*^9}, 
   3.531107267778467*^9}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SuccessivePoints", "=", 
    RowBox[{"Simplify", "[", 
     RowBox[{"NestList", "[", 
      RowBox[{"f", ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "y"}], "}"}], ",", "10000"}], "]"}], "]"}]}], ";"}],
   "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"SuccessivePoints", ",", 
   RowBox[{"AxesOrigin", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0"}], "}"}]}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"PointSize", "[", "0.001", "]"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.531078858841795*^9, 3.53107886452549*^9}, {
