Cell["\<\
\[LongDash]gives back the arithmetic and harmonic means as special cases, and \
is known to give rise to the generalized inequality\
\>", "Text",
 CellChangeTimes->{{3.530899493722176*^9, 3.530899534445051*^9}, {
  3.5308998499646053`*^9, 3.5308998746156178`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      FractionBox["1", "n"], 
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{"i", "=", "1"}], "n"], 
       SuperscriptBox[
        SubscriptBox["x", "i"], "q"]}]}], ")"}], "q"], "\[GreaterEqual]", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      FractionBox["1", "n"], 
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{"i", "=", "1"}], "n"], 
       SuperscriptBox[
        SubscriptBox["x", "i"], "p"]}]}], ")"}], "p"]}], "   ", ":", "   ", 
  RowBox[{"q", " ", ">", " ", "p"}]}]], "Input",
 CellChangeTimes->{
  3.530899679870145*^9, {3.530899712113557*^9, 3.5308997256212482`*^9}}],

Cell[TextData[{
 "Our immediate interest attaches to the cases ",
 StyleBox["q = 1 > p = -1", "Output"],
 ". We have"
}], "Text",
 CellChangeTimes->{{3.530899960314249*^9, 3.530900017511415*^9}, {
  3.530900144946348*^9, 3.530900150086691*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"Mean", " ", "Conductance"}], " ", "\[GreaterEqual]", " ", 
  RowBox[{"Effective", " ", "Conductance"}]}]], "Output",
 CellChangeTimes->{{3.530900104730917*^9, 3.530900134258087*^9}}],

Cell["\<\
with equality iff all resistances/conductances are the same. \
\>", "Text",
 CellChangeTimes->{{3.530900176013176*^9, 3.530900196347753*^9}}]
}, Open  ]]
