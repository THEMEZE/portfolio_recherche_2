Cell[TextData[{
 "Those three graphs are ",
 StyleBox["permutationally equivalent",
  FontVariations->{"Underline"->True}],
 ", but give unequal readings if we suppose that our ohmmeter is attached \
always to (say) nodes #1 and #2. Each is a ",
 StyleBox["disconnected",
  FontVariations->{"Underline"->True}],
 " graph, so a graph to which the Klein-Randi\[CAcute] method does not \
pertain: its application in the latter instance leads to a result "
}], "Text",
 CellChangeTimes->{{3.530722624721335*^9, 3.5307226632912807`*^9}, {
   3.530722698886932*^9, 3.5307228309978228`*^9}, {3.530722861936202*^9, 
   3.5307229123025618`*^9}, {3.530722944161017*^9, 3.5307229951181517`*^9}, {
   3.53072341794625*^9, 3.530723437793673*^9}, 3.530724373262866*^9, {
   3.530724404407174*^9, 3.530724415524356*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[DoubleStruckCapitalA]", "=", 
   RowBox[{
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"0", "0", "0"},
       {"0", "0", "1"},
       {"0", "0", "0"}
      }], "\[NoBreak]", ")"}], "+", 
    RowBox[{"Transpose", "[", 
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {"0", "0", "0"},
        {"0", "0", "1"},
        {"0", "0", "0"}
       }], "\[NoBreak]", ")"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[DoubleStruckCapitalD]", "=", 
   RowBox[{"DiagonalMatrix", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Total", "[", 
       RowBox[{
