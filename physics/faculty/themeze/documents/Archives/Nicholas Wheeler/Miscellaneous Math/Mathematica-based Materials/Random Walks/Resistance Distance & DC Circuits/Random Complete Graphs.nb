Cell["that gave", "Text",
 CellChangeTimes->{{3.5308983972920837`*^9, 3.5308984010575933`*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox["R", "mean"], "[", 
   RowBox[{"3", ",", "2"}], "]"}], "=", 
  RowBox[{
   FractionBox[
    RowBox[{"1", "+", "1", "+", "2"}], "3"], "=", 
   FractionBox["4", "3"]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["C", "mean"], "[", 
   RowBox[{"3", ",", "2"}], "]"}], "=", 
  RowBox[{
   FractionBox[
    RowBox[{"1", "+", "1", "+", 
     FractionBox["1", "2"]}], "3"], "=", 
   FractionBox["5", "6"]}]}]}], "Output",
 CellChangeTimes->{{3.530829103180253*^9, 3.5308292661296673`*^9}}],

Cell[TextData[{
 "Notice that  ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["C", "mean"], "[", 
   RowBox[{"3", ",", "2"}], "]"}]],
  CellChangeTimes->{{3.530829103180253*^9, 3.5308292661296673`*^9}}],
 "\[NotEqual]1/",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["R", "mean"], "[", 
   RowBox[{"3", ",", "2"}], "]"}]],
  CellChangeTimes->{{3.530829103180253*^9, 3.5308292661296673`*^9}}],
 ", and more particularly that"
}], "Text",
 CellChangeTimes->{{3.530898474391469*^9, 3.530898553183958*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["C", "mean"], "[", 
   RowBox[{"3", ",", "2"}], "]"}], ">", 
  FractionBox["1", 
   RowBox[{
    SubscriptBox["R", "mean"], "[", 
    RowBox[{"3", ",", "2"}], "]"}]]}]], "Output",
 CellChangeTimes->{{3.5308985955957203`*^9, 3.530898605349375*^9}}],

Cell["\<\
Or\[LongDash]to say the same thing another way\[LongDash]\
\>", "Text",
 CellChangeTimes->{{3.530898768981592*^9, 3.530898778914834*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["R", "mean"], "[", 
   RowBox[{"3", ",", "2"}], "]"}], ">", 
  FractionBox["1", 
   RowBox[{
    SubscriptBox["C", "mean"], "[", 
    RowBox[{"3", ",", "2"}], "]"}]]}]], "Output",
 CellChangeTimes->{{3.530898734067696*^9, 3.530898756236616*^9}}],

Cell["This is a particular instance of the assertion", "Text",
 CellChangeTimes->{{3.530899043165228*^9, 3.530899077536545*^9}}],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    SubscriptBox["r", "1"], "+", 
    SubscriptBox["r", "2"], "+", "\[CenterEllipsis]", "+", 
    SubscriptBox["r", "n"]}], "n"], "\[GreaterEqual]", 
  RowBox[{"n", " ", 
   FractionBox["1", 
    RowBox[{
     FractionBox["1", 
      SubscriptBox["r", "1"]], "+", 
     FractionBox["1", 
      SubscriptBox["r", "2"]], "+", "\[CenterEllipsis]", "+", 
     FractionBox["1", 
      SubscriptBox["r", "n"]]}]]}]}]], "Output",
 CellChangeTimes->{{3.5308988130412283`*^9, 3.530898847490864*^9}, {
  3.5308988790431232`*^9, 3.530898954368353*^9}}],

Cell["which\[LongDash]phrased", "Text",
 CellChangeTimes->{{3.530899144348536*^9, 3.530899159219543*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"arithemetic", " ", "mean"}], " ", "\[GreaterEqual]", " ", 
  RowBox[{"harmonic", " ", "mean"}]}]], "Output",
 CellChangeTimes->{{3.5308991664475813`*^9, 3.530899195988613*^9}}],

Cell["\[LongDash]is classic. See", "Text",
