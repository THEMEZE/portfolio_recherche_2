Cell["\<\
It is remarkable that such a small adjustment as 5\[LongRightArrow]10 can \
turn a tractable problem into a monster. But compare\
\>", "Text",
 CellChangeTimes->{{3.530738636228848*^9, 3.530738736743507*^9}, {
  3.530738847174253*^9, 3.530738849203299*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 SuperscriptBox["2", 
  RowBox[{"\[CapitalDelta]", "[", "5", "]"}]], "\[IndentingNewLine]", 
 SuperscriptBox["2", 
  RowBox[{"\[CapitalDelta]", "[", "10", "]"}]]}], "Input",
 CellChangeTimes->{{3.530738748802967*^9, 3.530738777381185*^9}}],

Cell[BoxData["1024"], "Output",
 CellChangeTimes->{3.530738780415188*^9}],

Cell[BoxData["35184372088832"], "Output",
 CellChangeTimes->{3.53073878046854*^9}]
}, Open  ]],

Cell["\<\
The adjustment 5\[LongRightArrow]10 inflates the problem by the following \
factor:\
\>", "Text",
 CellChangeTimes->{{3.530738860812454*^9, 3.530738889007312*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 FractionBox[
