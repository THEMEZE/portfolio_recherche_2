Cell["\<\
which is incorrect, but which differs from the correct internodal resistance \
matrix\
\>", "Text",
 CellChangeTimes->{{3.5307235120009947`*^9, 3.5307235512524967`*^9}}],

Cell[BoxData[
 RowBox[{"(", "\[NoBreak]", GridBox[{
    {"0", "\[Infinity]", "\[Infinity]"},
    {"\[Infinity]", "0", "1"},
    {"\[Infinity]", "1", "0"}
   }], "\[NoBreak]", ")"}]], "Input",
 CellChangeTimes->{{3.530722517838876*^9, 3.53072257381783*^9}}],

Cell[TextData[{
 "in a patterned way. One would have to dig into the bowels of the ",
 StyleBox["PseudoInverse", "Input"],
 " construction to discover how K-R came up with that"
}], "Text",
 CellChangeTimes->{{3.530723557706545*^9, 3.530723558436167*^9}, {
   3.530723590623691*^9, 3.530723663368175*^9}, {3.5307236988001213`*^9, 
