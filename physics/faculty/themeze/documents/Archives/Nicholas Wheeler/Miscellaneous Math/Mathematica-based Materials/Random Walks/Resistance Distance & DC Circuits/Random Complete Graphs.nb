Cell["\<\
We could, by similar means, isolate bi-connected, tri-connected \[Ellipsis] \
graphs if we had interest in them.\
\>", "Text",
 CellChangeTimes->{{3.5307466397553263`*^9, 3.5307466871443377`*^9}, {
  3.530804249224699*^9, 3.530804250312026*^9}}],

