Cell["I now reconstruct a previous list of 4-node matrices", "Text",
 CellChangeTimes->{{3.5307453335060253`*^9, 3.530745365842857*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"P4", "=", 
    RowBox[{"Permutations", "[", 
     RowBox[{"{", 
      RowBox[{"1", ",", "1", ",", "1", ",", "0", ",", "0", ",", "0"}], "}"}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RawMatrixSet", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[DoubleStruckCapitalM]4", "k"], "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"{", "0", "}"}], ",", 
          RowBox[{"Part", "[", 
           RowBox[{
            RowBox[{
            "P4", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}], ",", 
            RowBox[{"1", ";;", "3"}]}], "]"}]}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "0"}], "}"}], ",", 
          RowBox[{"Part", "[", 
           RowBox[{
            RowBox[{
            "P4", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}], ",", 
            RowBox[{"4", ";;", "5"}]}], "]"}]}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
          RowBox[{"Part", "[", 
           RowBox[{
            RowBox[{
            "P4", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}], ",", 
            RowBox[{"6", ";;", "6"}]}], "]"}]}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "20"}], "}"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.530742563853223*^9, 3.530742598947089*^9}, {
  3.530742812347699*^9, 3.5307428200238323`*^9}}],

Cell["That is a list of ", "Text",
 CellChangeTimes->{{3.530745594070758*^9, 3.530745598563294*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Length", "[", "RawMatrixSet", "]"}]], "Input",
 CellChangeTimes->{{3.530745607470682*^9, 3.530745618281824*^9}}],

Cell[BoxData["20"], "Output",
 CellChangeTimes->{3.530745619432131*^9}]
}, Open  ]],

Cell["\<\
matrices of which we know from previous work that 4 generate unconnected \
graphs. The command\
\>", "Text",
 CellChangeTimes->{{3.530745626221725*^9, 3.530745669693226*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"DistilledMatrixSet", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"CompletenessFilter", "[", 
      RowBox[{
      "RawMatrixSet", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}], 
      "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "20"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.530745547205329*^9, 3.53074555994722*^9}, 
   3.5307456791892242`*^9}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Length", "[", "DistilledMatrixSet", "]"}]], "Input",
 CellChangeTimes->{{3.530745853197564*^9, 3.530745862786277*^9}}],

Cell[BoxData["20"], "Output",
 CellChangeTimes->{3.530745864877041*^9}]
}, Open  ]],

Cell["\<\
converts those matrices to place-holding zeros, which the following command \
discards:\
\>", "Text",
 CellChangeTimes->{{3.5307457988455753`*^9, 3.53074583712318*^9}, {
  3.530745874175827*^9, 3.53074588824868*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"FilteredMatrixList", "=", 
   RowBox[{"DeleteCases", "[", 
    RowBox[{"DistilledMatrixSet", ",", "0"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.5307457109901533`*^9, 3.530745740682249*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Length", "[", "FilteredMatrixList", "]"}]], "Input",
 CellChangeTimes->{{3.530745752312768*^9, 3.530745765131917*^9}}],

Cell[BoxData["16"], "Output",
 CellChangeTimes->{3.530745768969797*^9, 3.530745903492176*^9}]
}, Open  ]],

Cell["\<\
We verify that each of the surviving matrices (elements of the filtered list) \
is connected:\
\>", "Text",
 CellChangeTimes->{{3.530746263171749*^9, 3.530746285320134*^9}, {
  3.530746544977469*^9, 3.5307465635180683`*^9}}],

