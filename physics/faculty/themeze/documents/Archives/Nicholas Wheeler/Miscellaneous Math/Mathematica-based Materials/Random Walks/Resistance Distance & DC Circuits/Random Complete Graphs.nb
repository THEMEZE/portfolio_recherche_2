     SubscriptBox["\[DoubleStruckCapitalM]4", "k"], "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"{", "0", "}"}], ",", 
         RowBox[{"Part", "[", 
          RowBox[{
           RowBox[{
           "P4", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}], ",", 
           
           RowBox[{"1", ";;", "3"}]}], "]"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Join", "[", 
