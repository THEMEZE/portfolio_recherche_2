      "\[RightDoubleBracket]"}], "]"}], "]"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"k", ",", "1", ",", 
     RowBox[{"Length", "[", "FilteredMatrixList", "]"}]}], "}"}]}], 
