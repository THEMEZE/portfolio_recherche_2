Cell[TextData[{
 "The ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["p", "th"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " power mean"
}], "Text",
 CellChangeTimes->{{3.530899340995303*^9, 3.530899357383562*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["M", "p"], "[", 
   RowBox[{
    SubscriptBox["r", "1"], ",", 
    SubscriptBox["r", "2"], ",", "\[Ellipsis]", ",", 
    SubscriptBox["r", "n"]}], "]"}], "=", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{
     FractionBox["1", "n"], 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"i", "=", "1"}], "n"], 
      SuperscriptBox[
       SubscriptBox["x", "i"], "p"]}]}], ")"}], 
   RowBox[{"1", "/", "p"}]]}]], "Output",
 CellChangeTimes->{{3.530899365222447*^9, 3.530899420743745*^9}}],

Cell["\[LongDash]see", "Text",
 CellChangeTimes->{{3.530899470411583*^9, 3.530899471608549*^9}}],

