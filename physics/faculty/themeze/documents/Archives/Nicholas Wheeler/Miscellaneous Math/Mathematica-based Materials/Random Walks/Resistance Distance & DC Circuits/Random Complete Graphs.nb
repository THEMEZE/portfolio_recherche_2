Cell[BoxData["0.25`"], "Output",
 CellChangeTimes->{3.530728589330435*^9}]
}, Open  ]],

Cell["\<\
It is possible but meaningless to construct (as in work cited in my \
Introduction I allowed myself to do)\
\>", "Text"],

Cell[BoxData[
 RowBox[{"\"\<K-R mean internodal resistance\>\"", "=", 
  FractionBox[
   RowBox[{"0.25", "+", "0.25", "+", "1.0"}], "3"]}]], "Input",
