Cell["\<\
Read R = {1, \[Infinity], \[Infinity]} with equal frequency. Note that\
\>", "Text",
 CellChangeTimes->{{3.530828412821476*^9, 3.530828452976605*^9}, {
  3.530828489166068*^9, 3.530828511561195*^9}, {3.530828546901207*^9, 
  3.530828548266363*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["R", "mean"], "[", 
   RowBox[{"3", ",", "1"}], "]"}], "=", 
  RowBox[{
   FractionBox[
    RowBox[{"1", "+", "\[Infinity]", "+", "\[Infinity]"}], "3"], "   ", "is", 
   " ", "undefined"}]}]], "Output"],

Cell["If, on the other hand, the meter is a conductance meter get", "Text",
 CellChangeTimes->{{3.530828630629243*^9, 3.530828658543189*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["C", "mean"], "[", 
   RowBox[{"3", ",", "1"}], "]"}], "=", 
  RowBox[{
