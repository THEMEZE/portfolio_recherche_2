Cell["\<\
and that all the other \[DoubleStruckCapitalM]4-matrices produce connected \
graphs. 

The four disconnected cases are permutationally equivalent, and when \
subjected (misguidedly) to K-R analysis give rise to the same pattern of \
error: K-R consistently writes 0.222222 where it should write \[Infinity].  I \
note in this connection that\
\>", "Text",
 CellChangeTimes->{{3.530725939117998*^9, 3.530725972775165*^9}, {
  3.530726260601659*^9, 3.530726276900124*^9}, {3.530726312880164*^9, 
  3.530726338274152*^9}, {3.5307263764113827`*^9, 3.5307264360126133`*^9}, {
  3.530726582716941*^9, 3.5307266622891407`*^9}, {3.530728774078356*^9, 
  3.530728774994768*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ContinuedFraction", "[", 
  RowBox[{".22222222", ",", "4"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "4", ",", "1", ",", "1"}], "}"}]], "Output",
 CellChangeTimes->{3.530726681082718*^9}]
}, Open  ]],

Cell["leads to the construction", "Text",
 CellChangeTimes->{{3.5307267016206207`*^9, 3.530726705199243*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 FractionBox["1", 
  RowBox[{"4", "+", 
   FractionBox["1", 
    RowBox[{"1", "+", "1"}]]}]], "\[IndentingNewLine]", 
 RowBox[{"%", "//", "N"}]}], "Input",
 CellChangeTimes->{{3.530726748484786*^9, 3.53072675411624*^9}}],

Cell[BoxData[
 FractionBox["2", "9"]], "Output",
 CellChangeTimes->{3.5307267280687723`*^9, 3.530726759646504*^9}],

Cell[BoxData["0.2222222222222222`"], "Output",
 CellChangeTimes->{3.5307267280687723`*^9, 3.5307267596694937`*^9}]
}, Open  ]],

Cell[TextData[{
 "Again, one would have to dig into the bowels of the  ",
 StyleBox["PseudoInverse ", "Input"],
 " to discover how K-R came up with that ",
 Cell[BoxData[
  FormBox[
   FractionBox["2", "9"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 ". "
}], "Text",
 CellChangeTimes->{{3.530728343587536*^9, 3.530728374963546*^9}, {
  3.530728669583539*^9, 3.530728735975273*^9}}],

Cell[CellGroupData[{

Cell["Case n = 4, m = 4", "Subsubsection",
 CellChangeTimes->{{3.530728938053095*^9, 3.530728965704342*^9}}],

Cell["Proceding as before, we construct", "Text",
 CellChangeTimes->{{3.530729206009712*^9, 3.530729224098773*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"P44", "=", 
