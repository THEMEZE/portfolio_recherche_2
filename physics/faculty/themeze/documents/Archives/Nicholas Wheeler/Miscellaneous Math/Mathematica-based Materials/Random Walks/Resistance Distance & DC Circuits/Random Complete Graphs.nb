Cell["\<\
The (n-1) edges that are required to create a minimally-connected n-node \
graph can be linked up in (n-1)! ways:\
\>", "Text",
 CellChangeTimes->{{3.530558727764247*^9, 3.53055884962645*^9}}],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.530633678955134*^9}],

Cell[TextData[{
 "One can identify ",
 StyleBox["the set of all n-node graphs",
  FontVariations->{"Underline"->True}],
 " (no self-connections, no more than one link between any nodal pair) with \
",
 StyleBox["the set of n \[Cross] n matrices",
  FontVariations->{"Underline"->True}]
}], "Text",
 CellChangeTimes->{{3.530634106189066*^9, 3.5306341758834457`*^9}, {
  3.530634210384613*^9, 3.5306342305638247`*^9}, {3.53063471533398*^9, 
  3.5306347172923393`*^9}}],

Cell[BoxData[
 RowBox[{"(", "\[NoBreak]", GridBox[{
    {"0", "\[Placeholder]", "\[Placeholder]", "\[Placeholder]", 
     "\[Placeholder]", "\[Placeholder]"},
    {"0", "0", "\[Placeholder]", "\[Placeholder]", "\[Placeholder]", 
     "\[Placeholder]"},
    {"0", "0", "0", "\[Placeholder]", "\[Placeholder]", "\[Placeholder]"},
    {"0", "0", "0", "0", "\[Placeholder]", "\[Placeholder]"},
    {"0", "0", "0", "0", "0", "\[Placeholder]"},
    {"0", "0", "0", "0", "0", "0"}
   }], "\[NoBreak]", ")"}]], "Input",
 CellChangeTimes->{{3.530634257959054*^9, 3.530634303191502*^9}}],

Cell[TextData[{
 StyleBox["in which ",
  FontVariations->{"Underline"->True}],
 StyleBox["0", "Input",
  FontVariations->{"Underline"->True}],
 StyleBox[" else ",
  FontVariations->{"Underline"->True}],
 StyleBox["1", "Input",
  FontVariations->{"Underline"->True}],
 StyleBox[" are inserted into the \[Placeholder]s in all possible ways",
  FontVariations->{"Underline"->True}],
 ". The number of ",
 StyleBox["\[Placeholder]s",
  FontVariations->{"Underline"->True}],
 " is the triangular number"
}], "Text",
 CellChangeTimes->{{3.530634315876636*^9, 3.530634373066708*^9}, {
   3.530634765459753*^9, 3.5306347756419287`*^9}, {3.530718352290326*^9, 
   3.530718376517255*^9}, 3.5307184920587673`*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[CapitalDelta]", "[", "n_", "]"}], ":=", 
  RowBox[{
   FractionBox["1", "2"], "n", 
   RowBox[{"(", 
    RowBox[{"n", "-", "1"}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.530637519441803*^9, 3.530637543255269*^9}}],

Cell["so the total number of n-node graphs is", "Text",
 CellChangeTimes->{{3.530718435085384*^9, 3.530718446318267*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"TotalGraphs", "[", "n_", "]"}], ":=", 
  SuperscriptBox["2", 
   RowBox[{"\[CapitalDelta]", "[", "n", "]"}]]}]], "Input",
 CellChangeTimes->{{3.530634388536974*^9, 3.530634407035955*^9}, {
  3.530634465922679*^9, 3.530634483383369*^9}, {3.530634518670382*^9, 
  3.5306345235560827`*^9}, {3.530718467099388*^9, 3.530718470812601*^9}}],

Cell["which grows very rapidly:", "Text",
 CellChangeTimes->{{3.530718506484996*^9, 3.530718513237322*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", ",", 
      RowBox[{"TotalGraphs", "[", "n", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "2", ",", "10"}], "}"}]}], "]"}], "//", 
  "TableForm"}]], "Input",
 CellChangeTimes->{{3.5306345338329763`*^9, 3.530634586866857*^9}}],

Cell[BoxData[
 TagBox[GridBox[{
    {"2", "2"},
    {"3", "8"},
    {"4", "64"},
    {"5", "1024"},
    {"6", "32768"},
    {"7", "2097152"},
    {"8", "268435456"},
    {"9", "68719476736"},
    {"10", "35184372088832"}
   },
   GridBoxAlignment->{
    "Columns" -> {{Left}}, "ColumnsIndexed" -> {}, "Rows" -> {{Baseline}}, 
     "RowsIndexed" -> {}},
   GridBoxSpacings->{"Columns" -> {
       Offset[0.27999999999999997`], {
        Offset[0.7]}, 
       Offset[0.27999999999999997`]}, "ColumnsIndexed" -> {}, "Rows" -> {
       Offset[0.2], {
        Offset[0.4]}, 
       Offset[0.2]}, "RowsIndexed" -> {}}],
  Function[BoxForm`e$, 
   TableForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.530634588418243*^9, 3.530718525985223*^9}]
}, Open  ]],

Cell["\<\
A collection of m resistors can be deposited on an n-node array (graph) in \
this many ways: \
\>", "Text",
 CellChangeTimes->{{3.530717975774294*^9, 3.530718044887035*^9}, {
  3.530718710381432*^9, 3.5307187993145027`*^9}, {3.530719479950742*^9, 
