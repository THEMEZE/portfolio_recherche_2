Cell[CellGroupData[{

Cell["Development of a \"connectedness filter\"", "Subsection",
 CellChangeTimes->{{3.530744132382221*^9, 3.530744146817161*^9}, {
  3.530744311389351*^9, 3.53074431350032*^9}, {3.530746591702692*^9, 
  3.5307465960478573`*^9}}],

Cell["\<\
If I am, for the reason just touched upon, forced to construct my connection \
matrices (graphs) not by exhaustive enumeration but randomly, then I will \
stand in need of means to discard unconnected graphs. To that end I introduce \
a command   \
\>", "Text",
 CellChangeTimes->{{3.5307441619585037`*^9, 3.530744167918355*^9}, {
   3.530744203585289*^9, 3.530744362224989*^9}, {3.530744503678832*^9, 
   3.530744506993618*^9}, {3.53074458212016*^9, 3.530744593325934*^9}, 
   3.530744983745243*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"CompletenessFilter", "[", "M_", "]"}], ":=", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Length", "[", 
      RowBox[{"WeakComponents", "[", "M", "]"}], "]"}], "\[NotEqual]", "1"}], 
    ",", "0", ",", "M"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.530744602320116*^9, 3.530744611156117*^9}}],

Cell["\<\
that is intended to accept (commection) matrices as arguments. To illustrate \
how this command works, I borrow from preceding work the matrices\
\>", "Text",
 CellChangeTimes->{{3.530744799108197*^9, 3.530744830230949*^9}, {
  3.53074500087331*^9, 3.5307450444450197`*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox["\[DoubleStruckCapitalM]", "1"], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "1", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["\[DoubleStruckCapitalM]", "2"], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "1", ",", "1", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}]}], "}"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.53074465164791*^9, 3.530744664556834*^9}, {
  3.530744730646716*^9, 3.5307447620192738`*^9}}],

Cell["\<\
of which the first generates a connected 4-node graph, the second an \
unconnected graph:\
\>", "Text",
