Cell[TextData[{
 "Which presented a problem? In the complete absence of resistors the \
averaged internodal resistance should be ",
 StyleBox["infinite, not zero",
  FontSlant->"Italic"],
 "!\n\nOnly belatedly did I realize that the Klein-Randi\[CAcute] method \
purports to work only for ",
 StyleBox["complete",
  FontSlant->"Italic"],
 " graphs, and that the small-p sector of my calculation violated that \
condition: graphs with only few edges are typically incomplete, and are \
inevitably incomplete if  "
}], "Text",
 CellChangeTimes->{{3.530474885057247*^9, 3.530475028079051*^9}, {
  3.530475187121521*^9, 3.530475275593996*^9}, {3.5304753080400867`*^9, 
  3.530475321663377*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"number", " ", "of", " ", "resistors"}], " ", "<", " ", 
  RowBox[{"n", "-", "1"}]}]], "Output",
 CellChangeTimes->{{3.530475330244465*^9, 3.530475350975325*^9}}],

Cell[BoxData[""], "Input",
