Cell[CellGroupData[{

Cell["4-node graphs", "Subsection",
 CellChangeTimes->{{3.5307250919297323`*^9, 3.530725095031664*^9}}],

Cell[TextData[{
 "When one looks to all the graphs in which m is set to the minimal value \
that makes connectivity possible one finds that ",
 StyleBox["some graphs are connected but some are not",
  FontVariations->{"Underline"->True}],
 ". To illustrate the point I look to the smallest non-trivial case n = 4, m \
=3. The number of subgraphs in this instance is"
}], "Text",
 CellChangeTimes->{{3.530640850785705*^9, 3.530641054532247*^9}, {
   3.5306739331385527`*^9, 3.530673941124145*^9}, 3.530725202937307*^9, {
   3.530725245269248*^9, 3.530725263511156*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"SubtotalGraphs", "[", 
  RowBox[{"4", ",", "3"}], "]"}]], "Input",
 CellChangeTimes->{3.530641071308566*^9}],

Cell[BoxData["20"], "Output",
 CellChangeTimes->{3.530641072106049*^9}]
}, Open  ]],

