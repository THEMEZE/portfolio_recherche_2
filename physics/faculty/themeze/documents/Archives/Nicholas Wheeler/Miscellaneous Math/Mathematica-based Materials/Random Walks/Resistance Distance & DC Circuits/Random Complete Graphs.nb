Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"m", ",", 
      RowBox[{"SubtotalGraphs", "[", 
       RowBox[{"5", ",", "m"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"m", ",", "4", ",", 
      RowBox[{"\[CapitalDelta]", "[", "5", "]"}]}], "}"}]}], "]"}], "//", 
  "TableForm"}]], "Input",
 CellChangeTimes->{{3.530738587297249*^9, 3.5307385950195713`*^9}}],

