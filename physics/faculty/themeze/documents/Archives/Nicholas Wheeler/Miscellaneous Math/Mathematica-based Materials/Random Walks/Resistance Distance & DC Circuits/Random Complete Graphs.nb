           RowBox[{"4", ";;", "5"}]}], "]"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
         RowBox[{"Part", "[", 
          RowBox[{
           RowBox[{
           "P4", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}], ",", 
           
           RowBox[{"6", ";;", "6"}]}], "]"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", "1", ",", "20"}], "}"}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.530641216667699*^9, 3.5306412946621113`*^9}, {
