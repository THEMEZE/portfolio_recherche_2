Cell["I will be making essential use later of these definitions:", "Text",
 CellChangeTimes->{{3.530547267303995*^9, 3.530547283238517*^9}, {
  3.530717659499823*^9, 3.530717661320829*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"r", "[", "p_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Which", "[", 
    RowBox[{
     RowBox[{"0", "<", "x", "<", "p"}], ",", "1", ",", 
     RowBox[{"p", "<", "x", "<", "1"}], ",", "0"}], "]"}], "/.", 
   RowBox[{"x", "\[Rule]", 
    RowBox[{"RandomReal", "[", "]"}]}]}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[DoubleStruckCapitalA]", "[", "p_", "]"}], ":=", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", "n"}], "}"}]}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"r", "[", "p", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", 
          RowBox[{"20", "-", "n"}]}], "}"}]}], "]"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "1", ",", "20"}], "}"}]}], "]"}]}]], "Input"],

Cell["\<\
Here it has been assumed that \[DoubleStruckCapitalA] is 20 \[Times] 20; an \
obvious adjustment changes the dimension of \[DoubleStruckCapitalA].\
\>", "Text",
 CellChangeTimes->{{3.530547340651882*^9, 3.530547406495241*^9}}],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.53047179342124*^9}]
}, Open  ]],

