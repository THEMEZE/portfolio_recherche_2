Cell[TextData[{
 "Those vectors\[LongDash]the same in every instance\[LongDash]refer to a \
flat or \"equal likelyhood\" distribution, an \"equipartition of probability.\
\" Interestingly, these results hold ",
 StyleBox["even when occasional minus signs intrude into the structure of \
\[DoubleStruckCapitalS]",
  FontVariations->{"Underline"->True}],
 ". "
}], "Text",
 CellChangeTimes->{{3.523637976658298*^9, 3.5236380063686733`*^9}, {
  3.523638056661222*^9, 3.523638106050303*^9}, {3.523638141800824*^9, 
  3.523638233013356*^9}}],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.523638333068533*^9}]
}, Open  ]],

