Cell["\<\
To illustrate the point more generally, I construct a random initial \
probability vector\
\>", "Text",
 CellChangeTimes->{{3.523543574992217*^9, 3.5235436051332273`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"x", "=", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"RandomReal", "[", "]"}], ",", 
    RowBox[{"{", 
