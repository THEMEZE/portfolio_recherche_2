Cell[TextData[{
 "From the fact that the \[DoubleStruckCapitalS]-matrices possess the \
structure peculiar to ",
 StyleBox["transition",
  FontSlant->"Italic"],
 " matrices it appears to follow that ",
 StyleBox["the elements of all but the leading eigenvectors sum to zero",
  FontVariations->{"Underline"->True}],
 ":"
}], "Text",
 CellChangeTimes->{{3.5236372673111553`*^9, 3.523637365542371*^9}, 
   3.523637407941414*^9}],

