Cell["\<\
It is a curious fact that all eigenvectors except the leading eigenvector \
have elements that sum to zero:\
\>", "Text",
 CellChangeTimes->{{3.523541549506762*^9, 3.52354159137492*^9}, {
  3.5235416314429607`*^9, 3.523541633528607*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"Chop", "[", 
     RowBox[{"Total", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"v", "[", "k", "]"}], "]"}], "\[LeftDoubleBracket]", "1", 
       "\[RightDoubleBracket]"}], "]"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", "1", ",", "5"}], "}"}]}], "]"}], 
  "\[IndentingNewLine]"}]], "Input",
 CellChangeTimes->{{3.523479504080393*^9, 3.523479600520583*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", "2.1504066220396276`"}], ",", "0", ",", "0", ",", "0", ",", 
   "0"}], "}"}]], "Output",
 CellChangeTimes->{{3.523479527472291*^9, 3.523479601754027*^9}}]
}, Open  ]],

Cell["\<\
The leading eigenvector is unique in that it can be \"unitized,\" meaning \
multiplied by a factor so as to cause the elements to sum to unity:\
\>", "Text",
 CellChangeTimes->{{3.52354170394457*^9, 3.523541820405599*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"V", "=", 
   FractionBox[
    RowBox[{"v", "[", "1", "]"}], 
    RowBox[{"Total", "[", 
     RowBox[{
      RowBox[{"Transpose", "[", 
       RowBox[{"v", "[", "1", "]"}], "]"}], "\[LeftDoubleBracket]", "1", 
      "\[RightDoubleBracket]"}], "]"}]]}], ";"}]], "Input",
 CellChangeTimes->{{3.523541832377109*^9, 3.523541856940093*^9}, {
  3.523541962986289*^9, 3.5235419710905113`*^9}}],

