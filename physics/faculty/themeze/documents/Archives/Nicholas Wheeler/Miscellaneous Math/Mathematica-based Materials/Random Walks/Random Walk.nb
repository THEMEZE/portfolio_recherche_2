Cell[TextData[{
 StyleBox["I implement the procedure (which will be found to work except when \
it fails to work, due to the intrusion of minus signs, from which it provides \
no protection), proceeding on the assumption that matrix elements are \
generated randomly by flat distribution on the unit interval, and use the \
implementation to construct an 8-element population of such 5",
  FontSlant->"Plain"],
 "\[Times]",
 StyleBox["5 symmetric transition matrices: ",
  FontSlant->"Plain"]
}], "Text",
