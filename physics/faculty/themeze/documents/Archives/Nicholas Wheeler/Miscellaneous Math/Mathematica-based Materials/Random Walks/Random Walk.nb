Cell[TextData[{
 "Notice, however, that (in this particular sample) ",
 Cell[BoxData[
  SubscriptBox["\[DoubleStruckCapitalS]", "5"]],
  CellChangeTimes->{{3.523630762720778*^9, 3.5236307746955137`*^9}}],
 ", ",
 Cell[BoxData[
  SubscriptBox["\[DoubleStruckCapitalS]", "6"]],
  CellChangeTimes->{{3.523630762720778*^9, 3.5236307746955137`*^9}}],
 " and ",
 Cell[BoxData[
  SubscriptBox["\[DoubleStruckCapitalS]", "8"]],
  CellChangeTimes->{{3.523630762720778*^9, 3.5236307746955137`*^9}}],
 " ",
 StyleBox["must be discarded because they contain elements that wear minus \
signs, and therefore do not admit of interpretation as transition \
probabilities",
  FontVariations->{"Underline"->True}],
 "."
}], "Text",
 CellChangeTimes->{{3.5236307366696663`*^9, 3.523630755172171*^9}, {
  3.523630789918849*^9, 3.523630858918103*^9}}],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.52363219961722*^9}]
}, Open  ]],

