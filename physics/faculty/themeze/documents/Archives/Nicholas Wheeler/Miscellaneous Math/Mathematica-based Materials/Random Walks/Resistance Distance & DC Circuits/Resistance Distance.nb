Cell["while in that case the variational method proceeds", "Text",
 CellChangeTimes->{{3.528927055874194*^9, 3.528927068333054*^9}, {
  3.528932886236536*^9, 3.528932888209815*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox["C", "25"], "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
          "\[DoubleStruckCapitalL]", "\[LeftDoubleBracket]", "j", 
           "\[RightDoubleBracket]"}], "\[LeftDoubleBracket]", "k", 
          "\[RightDoubleBracket]"}], 
         SubscriptBox["V", "k"]}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", "5"}], "}"}]}], "]"}], "\[Equal]", 
      RowBox[{
       RowBox[{"KroneckerDelta", "[", 
        RowBox[{"j", ",", "5"}], "]"}], "-", 
       RowBox[{"KroneckerDelta", "[", 
        RowBox[{"j", ",", "2"}], "]"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "5"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Minimize", "[", 
  RowBox[{
   RowBox[{"Flatten", "[", 
    RowBox[{"{", 
     RowBox[{"Diss", ",", 
      SubscriptBox["C", "25"]}], "}"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["V", "1"], ",", 
     SubscriptBox["V", "2"], ",", 
     SubscriptBox["V", "3"], ",", 
     SubscriptBox["V", "4"], ",", 
     SubscriptBox["V", "5"]}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.5289269882246437`*^9, 3.528927035569983*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.8484334429276603`", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SubscriptBox["V", "1"], "\[Rule]", 
      RowBox[{"-", "1.8159290042454934`"}]}], ",", 
     RowBox[{
