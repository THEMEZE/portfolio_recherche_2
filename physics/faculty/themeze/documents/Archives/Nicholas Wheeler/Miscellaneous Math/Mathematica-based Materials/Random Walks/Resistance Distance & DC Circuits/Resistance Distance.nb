}, Open  ]],

Cell[TextData[{
 "we see that \[DoubleStruckCapitalD]\[LongDash]equivalently \
\[DoubleStruckCapitalL]\[LongDash]is singular, so does not possess an \
inverse. It does, however, possess a ",
 StyleBox["Moore-Penrose pseudoinverse",
  FontWeight->"Bold"],
 ", which ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " knows how to construct:"
}], "Text",
 CellChangeTimes->{{3.528926283238845*^9, 3.5289262851988173`*^9}, {
  3.528926322532351*^9, 3.528926457720751*^9}, {3.528926647428528*^9, 
  3.528926655789053*^9}, {3.528926697400053*^9, 3.528926701865685*^9}, {
  3.52892716248293*^9, 3.5289271668086243`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "PseudoInverse"}]], "Input",
 CellChangeTimes->{{3.528927128952036*^9, 3.5289271364102297`*^9}}],

Cell[BoxData[
 RowBox[{
  StyleBox["\<\"\\!\\(\\*RowBox[{\\\"PseudoInverse\\\", \\\"[\\\", \
StyleBox[\\\"m\\\", \\\"TI\\\"], \\\"]\\\"}]\\) finds the pseudoinverse of a \
rectangular matrix. \"\>", "MSG"], "\[NonBreakingSpace]", 
  ButtonBox[
   StyleBox["\[RightSkeleton]", "SR"],
   Active->True,
   BaseStyle->"Link",
   ButtonData->"paclet:ref/PseudoInverse"]}]], "Print", "PrintUsage",
 CellChangeTimes->{3.5289271398016233`*^9},
 CellTags->"Info3528898339-4420344"]
}, Open  ]],

