Cell["The Klein-Randi\[CAcute] Method", "Subsection",
 CellChangeTimes->{{3.5289260461507683`*^9, 3.528926080306583*^9}}],

Cell["From", "Text",
 CellChangeTimes->{{3.528926263299464*^9, 3.528926268630588*^9}}],

