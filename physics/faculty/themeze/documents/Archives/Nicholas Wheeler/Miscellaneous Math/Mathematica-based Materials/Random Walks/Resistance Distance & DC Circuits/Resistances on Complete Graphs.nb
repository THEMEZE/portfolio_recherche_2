Cell[CellGroupData[{

Cell["Elementary arguments", "Subsection",
 CellChangeTimes->{{3.5303840460674267`*^9, 3.530384056533907*^9}}],

Cell["\<\
The conjectured value of the resistance between any pair of nodes in this \
simplest of cases\
\>", "Text",
 CellChangeTimes->{{3.5303840878305817`*^9, 3.530384126217684*^9}}],

Cell[BoxData[
 GraphicsBox[
  TagBox[GraphicsComplexBox[{{0.5030675882570581, 0.}, {0., 
    0.8642471832366334}, {0.9999936726203064, 0.8677928081377456}}, {
     {RGBColor[0.5, 0., 0.], PointSize[0.02], 
      LineBox[{{1, 2}, {1, 3}, {2, 3}}]}, 
     {PointSize[0.02], InsetBox[
       FrameBox["1",
        Background->RGBColor[1, 1, 0.8],
        FrameStyle->RGBColor[0.94, 0.85, 0.36],
        StripOnInput->False], 1], InsetBox[
       FrameBox["2",
        Background->RGBColor[1, 1, 0.8],
        FrameStyle->RGBColor[0.94, 0.85, 0.36],
        StripOnInput->False], 2], InsetBox[
       FrameBox["3",
        Background->RGBColor[1, 1, 0.8],
        FrameStyle->RGBColor[0.94, 0.85, 0.36],
        StripOnInput->False], 3]}}],
   Annotation[#, 
    VertexCoordinateRules -> {{0.5030675882570581, 0.}, {0., 
