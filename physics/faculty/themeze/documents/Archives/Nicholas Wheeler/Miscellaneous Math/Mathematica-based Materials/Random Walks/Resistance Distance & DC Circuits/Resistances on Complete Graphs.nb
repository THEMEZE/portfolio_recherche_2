 CellChangeTimes->{3.530381695970525*^9, 3.530385100216717*^9}],

Cell[TextData[{
 "is ",
 Cell[BoxData[
  FormBox[
   FractionBox["2", "3"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 ". Here two parallel paths, with resistances 1 and 2, link any nodal pair, \
so we expect the effective resistance to be"
}], "Text",
 CellChangeTimes->{{3.530384133417439*^9, 3.53038424182696*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 SuperscriptBox[
  RowBox[{"(", 
   RowBox[{
    FractionBox["1", "1"], "+", 
    FractionBox["1", "2"]}], ")"}], 
  RowBox[{"-", "1"}]]], "Input",
 CellChangeTimes->{{3.530384247184576*^9, 3.530384263284361*^9}}],

Cell[BoxData[
 FractionBox["2", "3"]], "Output",
 CellChangeTimes->{3.530384265618458*^9}]
}, Open  ]],

