Cell["Conclusion, and a conjecture", "Subsection",
 CellChangeTimes->{{3.5303827808753147`*^9, 3.530382790418145*^9}}],

Cell[TextData[{
 "It appears to be the case that on a circuit represented by a complete graph \
(all resistances set to unity) ",
 StyleBox["all internodal resistances are the same", "Subsection",
  FontSize->12],
 StyleBox[", and are given by",
  FontSize->12]
}], "Text",
