Notebook[{

Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{"2", "-", "2"}]], "Input",
 CellChangeTimes->{{3.530381336806288*^9, 3.530381337147204*^9}}],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{3.5303813386973057`*^9, 3.530456793042647*^9}]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["R", "effective"], "[", 
   RowBox[{"i_", ",", "j_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{
    "\[CapitalGamma]", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}],
     "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], "+", 
   RowBox[{
    RowBox[{
    "\[CapitalGamma]", "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}],
     "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}], "-", 
   RowBox[{"2", 
    RowBox[{
     RowBox[{
     "\[CapitalGamma]", "\[LeftDoubleBracket]", "i", 
      "\[RightDoubleBracket]"}], "\[LeftDoubleBracket]", "j", 
     "\[RightDoubleBracket]"}]}]}]}]], "Input"],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.5303813446746407`*^9}],

Cell[CellGroupData[{

Cell["Internodal Resistances on Complete Graphs", "Title",
 CellChangeTimes->{{3.5303813537094803`*^9, 3.530381368511425*^9}}],

Cell["\<\
Nicholas Wheeler
15 November 2011\
\>", "Text",
 CellChangeTimes->{{3.5303813761197433`*^9, 3.530381387238381*^9}},
 FontSize->10],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.530381395690206*^9}],

Cell[CellGroupData[{

Cell["Introduction", "Subsection",
 CellChangeTimes->{{3.530381413117289*^9, 3.530381415180769*^9}}],

Cell[TextData[{
 "I undertake this little project in connection with my belated discovery \
that the ",
 StyleBox["Klein-Randi\[CAcute]",
  FontWeight->"Bold"],
 " method pertains only to ",
 StyleBox["connected",
  FontSlant->"Italic"],
 " graphs. Here I look, by way of preliminary exploration, to complete (\
\[Therefore] maximally connected) graphs of increasingly many nodes:"
}], "Text",
 CellChangeTimes->{{3.530382424459178*^9, 3.5303824647416573`*^9}, {
  3.53038250412072*^9, 3.5303825605601587`*^9}, {3.530456823727666*^9, 
  3.530456823860343*^9}, {3.5304568807222223`*^9, 3.530456887078949*^9}, {
  3.530499243746152*^9, 3.530499257029406*^9}}],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.53038263969715*^9}],

Cell[CellGroupData[{

Cell["2-node complete", "Subsubsection",
 CellChangeTimes->{{3.530382577762307*^9, 3.530382582534567*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[DoubleStruckCapitalG]", "=", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"0", "1"},
      {"0", "0"}
     }], "\[NoBreak]", ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[DoubleStruckCapitalA]", "=", 
   RowBox[{"\[DoubleStruckCapitalG]", "+", 
    RowBox[{"Transpose", "[", "\[DoubleStruckCapitalG]", "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[DoubleStruckCapitalD]", "=", 
   RowBox[{"DiagonalMatrix", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Total", "[", 
       RowBox[{
       "\[DoubleStruckCapitalA]", "\[LeftDoubleBracket]", "k", 
        "\[RightDoubleBracket]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "2"}], "}"}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[DoubleStruckCapitalL]", "=", 
   RowBox[{"\[DoubleStruckCapitalD]", "-", "\[DoubleStruckCapitalA]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalGamma]", "=", 
   RowBox[{"PseudoInverse", "[", 
    RowBox[{"N", "[", "\[DoubleStruckCapitalL]", "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[DoubleStruckCapitalW]", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      SubscriptBox["R", "effective"], "[", 
      RowBox[{"i", ",", "j"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "2"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"GraphPlot", "[", 
  RowBox[{"\[DoubleStruckCapitalG]", ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"PointSize", "[", "0.02", "]"}]}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"\[DoubleStruckCapitalW]", "//", "MatrixForm"}]}], "Input",
 CellChangeTimes->{{3.5303815108389177`*^9, 3.5303815734147367`*^9}}],

