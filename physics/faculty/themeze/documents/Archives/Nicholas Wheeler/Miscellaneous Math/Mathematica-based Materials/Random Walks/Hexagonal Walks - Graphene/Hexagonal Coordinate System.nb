Cell["\<\
We are interested in the x-translates of those lines, where the elemental \
translation carries\
\>", "Text",
 CellChangeTimes->{{3.5360949328681726`*^9, 3.536095000857995*^9}}],

Cell[BoxData[
 RowBox[{"8", " ", 
  RowBox[{"o", "'"}], 
  RowBox[{"clock", "   ", "\[DoubleLongLeftRightArrow]", "   ", "4"}], " ", 
  RowBox[{"o", "'"}], "clock"}]], "Output",
 CellChangeTimes->{{3.5360950150900106`*^9, 3.5360950614856653`*^9}}],

Cell[TextData[{
 "and has length ",
 Cell[BoxData[
  FormBox[
   SqrtBox["3"], TraditionalForm]],
  FormatType->"TraditionalForm"],
 ". We re led thus to define"
}], "Text",
 CellChangeTimes->{{3.536095079319848*^9, 3.536095105551032*^9}, {
  3.5361590107953453`*^9, 3.536159025077609*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Rup", "[", 
   RowBox[{"x_", ",", " ", "y_", ",", "n_"}], "]"}], ":=", 
  RowBox[{
   FractionBox[
    SqrtBox["3"], "2"], "+", 
   FractionBox[
    RowBox[{"3", " ", 
     RowBox[{"(", 
      RowBox[{"x", "-", 
       RowBox[{"n", 
        SqrtBox["3"]}]}], ")"}]}], "2"], "-", 
   FractionBox[
    RowBox[{
     SqrtBox["3"], " ", "y"}], "2"]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Rdn", "[", 
   RowBox[{"x_", ",", " ", "y_", ",", "n_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     SqrtBox["3"], "2"]}], "+", 
   FractionBox[
    RowBox[{"3", " ", 
     RowBox[{"(", 
      RowBox[{"x", "-", 
       RowBox[{"n", 
        SqrtBox["3"]}]}], ")"}]}], "2"], "+", 
   FractionBox[
    RowBox[{
     SqrtBox["3"], " ", "y"}], "2"]}]}]}], "Input",
 CellChangeTimes->{{3.536095223479349*^9, 3.536095345878502*^9}, 
   3.536095976391306*^9, {3.536153511339328*^9, 3.5361535182584352`*^9}}],

Cell["\<\
where the function names suggest \"Red up-slope\" and \"Red down-slope.\"

\
\>", "Text",
 CellChangeTimes->{{3.536159039305911*^9, 3.53615907200299*^9}, {
  3.5361591066941977`*^9, 3.536159112406855*^9}, {3.536163105825324*^9, 
  3.536163105996204*^9}}],

Cell["\<\
The red nodes of the fundamental hex-cell lie at three of the four points \
where these lines (two up-sloping, two down-sloping) \
\>", "Text",
 CellChangeTimes->{{3.536163358668479*^9, 3.536163362708774*^9}, {
  3.536163418443185*^9, 3.536163549221263*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Join", "[", 
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Rup", "[", 
       RowBox[{"x", ",", "y", ",", "n"}], "]"}], "\[Equal]", "0"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", "1"}], "}"}]}], "]"}], ",", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Rdn", "[", 
       RowBox[{"x", ",", "y", ",", "m"}], "]"}], "\[Equal]", "0"}], ",", 
     RowBox[{"{", 
      RowBox[{"m", ",", 
       RowBox[{"-", "1"}], ",", "0"}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.536159186563876*^9, 3.536159224621624*^9}, {
  3.536159347209215*^9, 3.536159367627939*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     FractionBox[
      SqrtBox["3"], "2"], "+", 
     FractionBox[
      RowBox[{"3", " ", "x"}], "2"], "-", 
     FractionBox[
      RowBox[{
       SqrtBox["3"], " ", "y"}], "2"]}], "\[Equal]", "0"}], ",", 
   RowBox[{
    RowBox[{
     FractionBox[
      SqrtBox["3"], "2"], "+", 
     RowBox[{
      FractionBox["3", "2"], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         SqrtBox["3"]}], "+", "x"}], ")"}]}], "-", 
     FractionBox[
      RowBox[{
       SqrtBox["3"], " ", "y"}], "2"]}], "\[Equal]", "0"}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       SqrtBox["3"], "2"]}], "+", 
     RowBox[{
      FractionBox["3", "2"], " ", 
      RowBox[{"(", 
       RowBox[{
        SqrtBox["3"], "+", "x"}], ")"}]}], "+", 
     FractionBox[
      RowBox[{
       SqrtBox["3"], " ", "y"}], "2"]}], "\[Equal]", "0"}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       SqrtBox["3"], "2"]}], "+", 
     FractionBox[
      RowBox[{"3", " ", "x"}], "2"], "+", 
     FractionBox[
      RowBox[{
       SqrtBox["3"], " ", "y"}], "2"]}], "\[Equal]", "0"}]}], "}"}]], "Output",\

 CellChangeTimes->{
  3.536159231587089*^9, {3.536159357827887*^9, 3.5361593722630653`*^9}}]
}, Open  ]],

