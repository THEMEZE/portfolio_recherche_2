Cell[TextData[{
 "I elect to deploy those ",
 Cell[BoxData[
  RowBox[{"2", 
   SuperscriptBox["d", "2"]}]],
  CellChangeTimes->{{3.536355492403216*^9, 3.536355494821257*^9}}],
 " in a columnar array of this design:"
}], "Text",
 CellChangeTimes->{{3.536355443866346*^9, 3.536355529458831*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      SubscriptBox["e", "1"]},
     {"\[VerticalEllipsis]"},
     {
      SubscriptBox["e", 
       SuperscriptBox["d", "2"]]},
     {
      SubscriptBox["e", 
       RowBox[{
        SuperscriptBox["d", "2"], "+", "1"}]]},
     {"\[VerticalEllipsis]"},
     {
      SuperscriptBox["e", 
       RowBox[{"2", 
        SuperscriptBox["d", "2"]}]]}
    }], "\[NoBreak]", ")"}], "=", 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      SubscriptBox["a", 
       RowBox[{"1", ",", "1"}]]},
     {"\[VerticalEllipsis]"},
     {
      SubscriptBox["a", 
       RowBox[{"d", ",", "d"}]]},
     {
      SubscriptBox["b", 
       RowBox[{"1", ",", "1"}]]},
     {"\[VerticalEllipsis]"},
     {
      SubscriptBox["b", 
       RowBox[{"d", ",", "d"}]]}
    }], "\[NoBreak]", ")"}]}]], "Output",
 CellChangeTimes->{{3.536358175997305*^9, 3.536358275243162*^9}}],

Cell["We now have", "Text",
 CellChangeTimes->{{3.536358454100149*^9, 3.536358457811409*^9}}],

