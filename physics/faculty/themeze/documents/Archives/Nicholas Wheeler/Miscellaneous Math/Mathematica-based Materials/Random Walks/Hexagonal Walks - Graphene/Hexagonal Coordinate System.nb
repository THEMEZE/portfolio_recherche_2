Cell["\<\
We have actually no interest in the red/blue nodal lines themselves (which \
were introduced only as a coordinating device), but only in their points of \
intersection. Accordingly,  we use\
\>", "Text",
 CellChangeTimes->{{3.536169410779242*^9, 3.536169506563654*^9}, {
  3.5361702458233223`*^9, 3.5361702499426947`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"x", ",", "y"}], "}"}], "/.", 
  RowBox[{
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Rup", "[", 
         RowBox[{"x", ",", " ", "y", ",", "m"}], "]"}], "\[Equal]", "0"}], 
       ",", 
       RowBox[{
        RowBox[{"Rdn", "[", 
         RowBox[{"x", ",", " ", "y", ",", 
          RowBox[{"-", "n"}]}], "]"}], "\[Equal]", "0"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}]}], "]"}], "\[LeftDoubleBracket]", "1", 
   "\[RightDoubleBracket]"}]}]], "Input",
 CellChangeTimes->{{3.536167501943531*^9, 3.5361675141731052`*^9}, 
   3.536167676581585*^9, {3.536169531952573*^9, 3.536169541239676*^9}, {
   3.536169735449327*^9, 3.536169738495124*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    FractionBox["1", "2"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SqrtBox["3"], " ", "m"}], "-", 
      RowBox[{
       SqrtBox["3"], " ", "n"}]}], ")"}]}], ",", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", 
       SqrtBox["3"]}], "+", 
      RowBox[{"3", " ", 
       SqrtBox["3"], " ", "m"}], "+", 
      RowBox[{"3", " ", 
       SqrtBox["3"], " ", "n"}]}], 
     RowBox[{"2", " ", 
      SqrtBox["3"]}]]}]}], "}"}]], "Output",
 CellChangeTimes->{3.5361675217443323`*^9, 3.53616767822915*^9, 
  3.5361695433107433`*^9}]
}, Open  ]],

Cell["to construct an {m.n}-indexed array of points (red nodes)", "Text",
 CellChangeTimes->{{3.536170257471529*^9, 3.536170282730673*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"PR", "[", 
   RowBox[{"m_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     FractionBox[
      SqrtBox["3"], "2"], " ", 
     RowBox[{"(", " ", 
      RowBox[{"m", "-", " ", "n"}], ")"}]}], ",", 
    RowBox[{"1", "-", 
     RowBox[{
      FractionBox["3", "2"], " ", 
      RowBox[{"(", " ", 
       RowBox[{"m", "+", " ", "n"}], ")"}]}]}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.536169564498461*^9, 3.536169696749316*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{"PR", "[", 
    RowBox[{"m", ",", "n"}], "]"}], "==", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      FractionBox[
       SqrtBox["3"], "2"], " ", 
      RowBox[{"(", " ", 
       RowBox[{"m", "-", " ", "n"}], ")"}]}], ",", 
     RowBox[{"1", "-", 
      RowBox[{
       FractionBox["3", "2"], " ", 
       RowBox[{"(", " ", 
        RowBox[{"m", "+", " ", "n"}], ")"}]}]}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.536169764212817*^9, 3.536169799454114*^9}}],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.536169805310731*^9, 3.5365092263724527`*^9}]
}, Open  ]],

Cell["of which we plot a sample:", "Text",
 CellChangeTimes->{{3.5361703183254538`*^9, 3.536170332175754*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"RedPopulation", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"PR", "[", 
        RowBox[{"m", ",", "n"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"m", ",", 
         RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", 
         RowBox[{"-", "5"}], ",", "5"}], "}"}]}], "]"}], ",", "1"}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.536169826596017*^9, 3.5361698593197403`*^9}, {
   3.536169945149396*^9, 3.5361699519696827`*^9}, {3.536170059949888*^9, 
   3.536170066199744*^9}, 3.536170193384568*^9}],

Cell[CellGroupData[{

