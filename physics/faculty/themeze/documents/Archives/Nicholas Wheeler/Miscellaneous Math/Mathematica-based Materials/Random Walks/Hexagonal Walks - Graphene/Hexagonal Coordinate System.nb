        FractionBox[
         RowBox[{
          SqrtBox["3"], " ", "y"}], "2"]}], "\[Equal]", "0"}], ",", 
      RowBox[{
       RowBox[{
        FractionBox[
         SqrtBox["3"], "2"], "+", 
        RowBox[{
         FractionBox["3", "2"], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", 
            SqrtBox["3"]}], "+", "x"}], ")"}]}], "-", 
        FractionBox[
         RowBox[{
          SqrtBox["3"], " ", "y"}], "2"]}], "\[Equal]", "0"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         FractionBox[
          SqrtBox["3"], "2"]}], "+", 
        RowBox[{
         FractionBox["3", "2"], " ", 
         RowBox[{"(", 
          RowBox[{
           SqrtBox["3"], "+", "x"}], ")"}]}], "+", 
        FractionBox[
         RowBox[{
          SqrtBox["3"], " ", "y"}], "2"]}], "\[Equal]", "0"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         FractionBox[
          SqrtBox["3"], "2"]}], "+", 
        FractionBox[
         RowBox[{"3", " ", "x"}], "2"], "+", 
        FractionBox[
         RowBox[{
          SqrtBox["3"], " ", "y"}], "2"]}], "\[Equal]", "0"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", " ", 
    RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
    RowBox[{"Axes", "\[Rule]", "True"}]}], "]"}]}]], "Input",
