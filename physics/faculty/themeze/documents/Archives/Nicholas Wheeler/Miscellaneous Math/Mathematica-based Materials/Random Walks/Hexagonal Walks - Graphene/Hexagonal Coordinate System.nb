Cell["\<\
The down/up-sloping blue-node lines are got from the up/down-sloping red-node \
lines by this simple adjustment (reflection in the x-axis):\
\>", "Text",
 CellChangeTimes->{{3.536163765525662*^9, 3.53616389766696*^9}, {
  3.536163928359045*^9, 3.5361639412398453`*^9}}],

Cell[BoxData[
 RowBox[{"y", "\[LongRightArrow]", 
  RowBox[{"-", "y"}]}]], "Input",
 CellChangeTimes->{{3.536163901838026*^9, 3.536163911377657*^9}}],

Cell["Whence the constructions", "Text",
 CellChangeTimes->{{3.53616397939327*^9, 3.536163983507646*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Bdn", "[", 
   RowBox[{"x_", ",", " ", "y_", ",", "n_"}], "]"}], ":=", 
  RowBox[{
   FractionBox[
    SqrtBox["3"], "2"], "+", 
   FractionBox[
    RowBox[{"3", " ", 
     RowBox[{"(", 
      RowBox[{"x", "-", 
       RowBox[{"n", 
        SqrtBox["3"]}]}], ")"}]}], "2"], "+", 
   FractionBox[
    RowBox[{
     SqrtBox["3"], " ", "y"}], "2"]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Bup", "[", 
   RowBox[{"x_", ",", " ", "y_", ",", "n_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     SqrtBox["3"], "2"]}], "+", 
   FractionBox[
    RowBox[{"3", " ", 
     RowBox[{"(", 
      RowBox[{"x", "-", 
       RowBox[{"n", 
        SqrtBox["3"]}]}], ")"}]}], "2"], "-", 
   FractionBox[
    RowBox[{
     SqrtBox["3"], " ", "y"}], "2"]}]}]}], "Input",
 CellChangeTimes->{{3.536095223479349*^9, 3.536095345878502*^9}, 
   3.536095976391306*^9, {3.536153511339328*^9, 3.5361535182584352`*^9}, {
   3.536163992620501*^9, 3.5361640188185577`*^9}}],

Cell[CellGroupData[{

