Cell["\<\
The nodes of the fundamental cell stand at noon, 2:00, 4:00, 6:00, 8:00 & \
10:00 o'clock on the unit circle (center at the origin):\
\>", "Text",
 CellChangeTimes->{{3.5360873329831448`*^9, 3.536087421682004*^9}, {
  3.53608764854605*^9, 3.5360876623890333`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"P", "[", "n_", "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Re", "[", 
     RowBox[{"Exp", "[", 
      RowBox[{"\[ImaginaryI]", 
       RowBox[{"(", 
        RowBox[{
         FractionBox["\[Pi]", "2"], "-", 
         RowBox[{"n", 
          FractionBox["\[Pi]", "3"]}]}], ")"}]}], "]"}], "]"}], ",", 
    RowBox[{"Im", "[", 
     RowBox[{"Exp", "[", 
      RowBox[{"\[ImaginaryI]", 
       RowBox[{"(", 
        RowBox[{
         FractionBox["\[Pi]", "2"], "-", 
         RowBox[{"n", 
          FractionBox["\[Pi]", "3"]}]}], ")"}]}], "]"}], "]"}]}], 
   "}"}]}]], "Input",
 CellChangeTimes->{{3.536086834278167*^9, 3.5360868581630497`*^9}, {
  3.536086894986668*^9, 3.5360870523892593`*^9}, {3.5360871150388927`*^9, 
