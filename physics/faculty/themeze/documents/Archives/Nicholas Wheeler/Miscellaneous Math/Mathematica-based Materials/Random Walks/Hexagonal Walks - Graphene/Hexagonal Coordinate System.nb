Cell[TextData[{
 "and which, as has already beem remarked, refers to a ",
 StyleBox["disconnected",
  FontSlant->"Italic"],
 " graph (the top ",
 StyleBox["\[FilledCircle]",
  FontColor->RGBColor[1, 0, 0]],
 " and bottom ",
 StyleBox["\[FilledCircle]",
  FontColor->RGBColor[0, 0, 1]],
 " are disconnected from the rest of the graph).\n\nTo address this problem I \
propose tentatively to\n   \[Bullet] reduce the dimension of \
\[DoubleStruckCapitalO]  from 81 to 80;\n   \[Bullet] delete the first row \
and last column from \[DoubleStruckCapitalS] (so that it too will become 80 \
",
 "\[Times] 80",
 ").  "
}], "Text",
 CellChangeTimes->{{3.536516986466551*^9, 3.536517055215968*^9}, {
  3.536519186140073*^9, 3.536519397088706*^9}}],

