Cell[TextData[{
 "presents a ",
 StyleBox["duplex",
  FontSlant->"Italic"],
 " set of doubly-indexed nodal points:"
}], "Text",
 CellChangeTimes->{{3.536354832442581*^9, 3.5363548810011578`*^9}}],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   RowBox[{"{", 
    RowBox[{"m", ",", "n"}], "}"}], "red"], " ", "\[CirclePlus]", " ", 
  SubscriptBox[
   RowBox[{"{", 
    RowBox[{"m", ",", "n"}], "}"}], "blue"]}]], "Output",
 CellChangeTimes->{{3.536354885697542*^9, 3.5363549291402607`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      SubscriptBox["a", 
       RowBox[{"1", ",", "1"}]], 
      SubscriptBox["a", 
       RowBox[{"1", ",", "2"}]], "\[CenterEllipsis]", 
      SubscriptBox["a", 
       RowBox[{"1", ",", "d"}]]},
     {
      SubscriptBox["a", 
       RowBox[{"2", ",", "1"}]], 
      SubscriptBox["a", 
       RowBox[{"2", ",", "2"}]], "\[CenterEllipsis]", 
      SubscriptBox["a", 
       RowBox[{"2", ",", "d"}]]},
     {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
      "\[VerticalEllipsis]"},
     {
      SubscriptBox["a", 
       RowBox[{"d", ",", "1"}]], 
      SubscriptBox["a", 
       RowBox[{"d", ",", "2"}]], "\[CenterEllipsis]", 
      SubscriptBox["a", 
       RowBox[{"d", ",", "d"}]]}
    }], "\[NoBreak]", ")"}], "\[CirclePlus]", 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      SubscriptBox["b", 
       RowBox[{"1", ",", "1"}]], 
      SubscriptBox["b", 
       RowBox[{"1", ",", "2"}]], "\[CenterEllipsis]", 
      SubscriptBox["b", 
       RowBox[{"1", ",", "d"}]]},
     {
      SubscriptBox["b", 
       RowBox[{"2", ",", "1"}]], 
      SubscriptBox["b", 
       RowBox[{"2", ",", "2"}]], "\[CenterEllipsis]", 
      SubscriptBox["b", 
       RowBox[{"2", ",", "d"}]]},
     {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
      "\[VerticalEllipsis]"},
     {
      SubscriptBox["b", 
       RowBox[{"d", ",", "1"}]], 
      SubscriptBox["b", 
       RowBox[{"d", ",", "2"}]], "\[CenterEllipsis]", 
      SubscriptBox["b", 
       RowBox[{"d", ",", "d"}]]}
    }], "\[NoBreak]", ")"}]}]], "Output",
 CellChangeTimes->{{3.536354978934334*^9, 3.536355003831505*^9}}],

Cell[TextData[{
 "When those ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["d", "2"], "+", 
   SuperscriptBox["d", "2"]}]],
  CellChangeTimes->{{3.536355081659504*^9, 3.5363551220452423`*^9}}],
 " elements are deployed in columnar array we end up (in the case d = 9) with \
162-dimensional column vectors that are to be multiplied by 162 \[Times]162 \
Markov matrices that have (even though d = 9 constructs a very small sheet of \
graphene) already this very large number of elements:"
}], "Text",
 CellChangeTimes->{{3.536355059828615*^9, 3.536355076389227*^9}, {
  3.536355107896544*^9, 3.536355260328506*^9}, {3.536355312060053*^9, 
  3.536355396053652*^9}}],

