Cell["\<\
In construcing the red (ditto blue) nodes in this display we let m and n \
range independently on \
\>", "Text",
 CellChangeTimes->{{3.536171392892271*^9, 3.536171470218552*^9}, {
  3.536171566126986*^9, 3.5361715670928164`*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", "5"}], ",", " ", 
   RowBox[{"-", "4"}], ",", " ", 
   RowBox[{"-", "3"}], ",", " ", 
   RowBox[{"-", "2"}], ",", " ", 
   RowBox[{"-", "1"}], ",", " ", "0", ",", " ", "1", ",", " ", "2", ",", " ", 
   "3", ",", " ", "4", ",", " ", "5"}], "}"}]], "Output",
 CellChangeTimes->{{3.53617147573354*^9, 3.536171494875058*^9}}],

Cell[TextData[{
 "so there are ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["11", "2"], "=", " ", "121"}], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " red nodes, an equal number of blue nodes, and 242 nodes in total. \n\nIf \
those nodes were connected\[LongDash]each to its to nearest neighbors to \
construct complete or (at the edges) partial hexagons\[LongDash]the top red \
and bottom blue nodes would become disconnected, leaving a connected graph \
with 240 nodes. Markov matrices that act on 240-dimensional stochastic \
vectors have ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["240", "2"], "="}], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " 57,600 elements. Since each node is connected to (at most) three others, \
such matrices would be \"sparce,\" so computational management may not be out \
of the question."
}], "Text",
 CellChangeTimes->{{3.536171516366666*^9, 3.536171659589398*^9}, {
   3.536176296144187*^9, 3.536176496279484*^9}, {3.536176537811513*^9, 
   3.5361765534529343`*^9}, {3.536176583528034*^9, 3.536176702588134*^9}, 
   3.536176754297504*^9, 3.536176826984726*^9, {3.536176917034396*^9, 
   3.536176994546006*^9}}],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.5361770271797533`*^9}]
}, Open  ]],

