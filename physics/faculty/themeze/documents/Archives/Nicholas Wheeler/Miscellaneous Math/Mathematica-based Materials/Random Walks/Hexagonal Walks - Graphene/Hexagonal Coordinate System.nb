Cell["\<\
My problem is to assign coordinates to nodes in such a way that (1) the \
coordinates of nearest-neighbor nodes are easily identified and (2) it \
becomes possible to associated nodes in a natural way with the elements of a \
Markov matrix and of the stochastic vectors on which those matrices act. \
\>", "Text",
 CellChangeTimes->{{3.536092297507663*^9, 3.536092508679183*^9}}],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.536092513898568*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Basic idea: red/blue nodal lines and their points of intersection\
\>", "Subsection",
 CellChangeTimes->{{3.536092592662116*^9, 3.536092597590437*^9}, {
  3.536169326438135*^9, 3.5361693581803827`*^9}}],

Cell[TextData[{
 "We observe that each red (ditto blue) node lies at the intersection points \
of a pair of sloping node rows. We undertake, therefore, to describe those \
linear rows.\n\nGenerally, the line on the (x, y)-plane that passes through \
the points ",
 Cell[BoxData[
  RowBox[{"(", 
   RowBox[{
    SubscriptBox["a", "1"], ",", 
    SubscriptBox["a", "2"]}], ")"}]],
  CellChangeTimes->{{3.5360932827534027`*^9, 3.53609329907653*^9}}],
 " and  ",
 Cell[BoxData[
  RowBox[{"(", 
   RowBox[{
    SubscriptBox["b", "1"], ",", 
    SubscriptBox["b", "2"]}], ")"}]],
  CellChangeTimes->{{3.5360932827534027`*^9, 3.53609329907653*^9}}],
 " is defined implicitly by the requirement that"
}], "Text",
 CellChangeTimes->{{3.536092616432424*^9, 3.536092717051588*^9}, {
  3.53609276809862*^9, 3.536092836631736*^9}, {3.5360932324257793`*^9, 
  3.53609327409967*^9}, {3.536093320573638*^9, 3.536093367116647*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Det", "[", 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"1", "x", "y"},
     {"1", 
      SubscriptBox["a", "1"], 
      SubscriptBox["a", "2"]},
     {"1", 
      SubscriptBox["b", "1"], 
      SubscriptBox["b", "2"]}
    }], "\[NoBreak]", ")"}], "]"}]], "Input",
 CellChangeTimes->{{3.536093376829205*^9, 3.536093434779973*^9}, 
   3.5360936662282248`*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", "y"}], " ", 
   SubscriptBox["a", "1"]}], "+", 
  RowBox[{"x", " ", 
   SubscriptBox["a", "2"]}], "+", 
  RowBox[{"y", " ", 
   SubscriptBox["b", "1"]}], "-", 
  RowBox[{
   SubscriptBox["a", "2"], " ", 
   SubscriptBox["b", "1"]}], "-", 
  RowBox[{"x", " ", 
   SubscriptBox["b", "2"]}], "+", 
  RowBox[{
   SubscriptBox["a", "1"], " ", 
   SubscriptBox["b", "2"]}]}]], "Output",
 CellChangeTimes->{
  3.536093442574823*^9, {3.536093606279482*^9, 3.5360936314144917`*^9}, 
   3.5360936710973377`*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"%", "\[Equal]", 
   RowBox[{
    RowBox[{"x", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["a", "2"], "-", 
       SubscriptBox["b", "2"]}], ")"}]}], "-", 
    RowBox[{"y", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["a", "1"], "-", 
       SubscriptBox["b", "1"]}], ")"}]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SubscriptBox["a", "1"], 
       SubscriptBox["b", "2"]}], "-", 
      RowBox[{
       SubscriptBox["a", "2"], 
       SubscriptBox["b", "1"]}]}], ")"}]}]}], "//", "Simplify"}]], "Input",
 CellChangeTimes->{{3.5360935005089607`*^9, 3.5360936268310823`*^9}}],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{{3.5360936112329607`*^9, 3.5360936352582903`*^9}, 
   3.536093706353261*^9}]
}, Open  ]],

Cell["\<\
To obtain the lines that pass with positive/negative slope through the node \
at \"noon\" we construct\
\>", "Text",
 CellChangeTimes->{{3.536094094949951*^9, 3.536094179727191*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Det", "[", 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"1", "x", "y"},
     {"1", "0", "1"},
     {"1", 
      RowBox[{"-", 
       FractionBox[
        SqrtBox["3"], "2"]}], 
      RowBox[{"-", 
       FractionBox["1", "2"]}]}
    }], "\[NoBreak]", ")"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Det", "[", 
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"1", "x", "y"},
     {"1", "0", "1"},
     {"1", 
      RowBox[{"+", 
       FractionBox[
        SqrtBox["3"], "2"]}], 
      RowBox[{"-", 
       FractionBox["1", "2"]}]}
    }], "\[NoBreak]", ")"}], "]"}]}], "Input",
 CellChangeTimes->{{3.536093801280641*^9, 3.5360938567857313`*^9}, {
  3.5360941902145853`*^9, 3.536094209125875*^9}}],

Cell[BoxData[
 RowBox[{
  FractionBox[
   SqrtBox["3"], "2"], "+", 
  FractionBox[
   RowBox[{"3", " ", "x"}], "2"], "-", 
  FractionBox[
   RowBox[{
    SqrtBox["3"], " ", "y"}], "2"]}]], "Output",
 CellChangeTimes->{3.536093862794544*^9, 3.536094214271462*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   FractionBox[
    SqrtBox["3"], "2"]}], "+", 
  FractionBox[
   RowBox[{"3", " ", "x"}], "2"], "+", 
  FractionBox[
   RowBox[{
    SqrtBox["3"], " ", "y"}], "2"]}]], "Output",
 CellChangeTimes->{3.536093862794544*^9, 3.536094214283059*^9}]
}, Open  ]],

