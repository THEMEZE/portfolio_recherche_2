      RowBox[{
       RowBox[{"Bdn", "[", 
        RowBox[{"x", ",", "y", ",", "1"}], "]"}], "\[Equal]", "0"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Bup", "[", 
        RowBox[{"x", ",", "y", ",", "0"}], "]"}], "\[Equal]", "0"}], ",", 
      RowBox[{
       RowBox[{"Bup", "[", 
        RowBox[{"x", ",", "y", ",", 
         RowBox[{"-", "1"}]}], "]"}], "\[Equal]", "0"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
