      RowBox[{"\[DoubleStruckCapitalM]", "+", 
       RowBox[{"Transpose", "[", "\[DoubleStruckCapitalM]", "]"}]}], "2"], "/.", 
     RowBox[{"\[DoubleStruckCapitalM]", "\[Rule]", 
      RowBox[{"RandomReal", "[", 
       RowBox[{
        RowBox[{"{", "}"}], ",", 
        RowBox[{"{", 
