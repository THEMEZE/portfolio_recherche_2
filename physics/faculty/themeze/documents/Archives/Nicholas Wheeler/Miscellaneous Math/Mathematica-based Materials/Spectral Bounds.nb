 RowBox[{"-", "3.608052568175372`"}]], "Output",
 CellChangeTimes->{
  3.523976917369528*^9, {3.523977060558908*^9, 3.5239770752080317`*^9}, {
   3.523977576180903*^9, 3.523977599389943*^9}, 3.5239782112265587`*^9}]
}, Open  ]],

Cell[TextData[{
 "But in all cases the Laguerre bounds do in fact bracket the spectrum; they \
just don't provide very ",
 StyleBox["accurate",
  FontSlant->"Italic"],
 " estimates of its extrema."
}], "Text",
 CellChangeTimes->{{3.523977659890482*^9, 3.523977665164517*^9}, {
  3.5239780455124826`*^9, 3.523978121686405*^9}}],

Cell[BoxData["\[IndentingNewLine]"], "Input",
 CellChangeTimes->{3.526141035700184*^9}],

Cell[CellGroupData[{

Cell["Note added on 25 September", "Subsection",
 CellChangeTimes->{{3.526141067809018*^9, 3.526141079826879*^9}}],

Cell[TextData[{
 "Instead of by-hand repetition of the preceding command we can automatically \
do so many time, and plot the results\[Ellipsis]which will serve to expose \
the ",
 StyleBox["regularity",
  FontSlant->"Italic"],
 " of the results. To illustrate the procedure I look again to the case of \
symmetric 10 \[Times] 10 matrices, with elements selected at random from the \
unit interval:"
}], "Text",
 CellChangeTimes->{{3.526141093567028*^9, 3.526141172214622*^9}, {
  3.526141215344996*^9, 3.526141290591648*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"upper", "[", "x_", "]"}], ":=", 
  RowBox[{
   FractionBox[
    RowBox[{"Tr", "[", "x", "]"}], "10"], "+", " ", 
   RowBox[{
    FractionBox[
     RowBox[{"10", "-", "1"}], "10"], 
    SqrtBox[
     FractionBox[
      RowBox[{
       RowBox[{"10", 
        RowBox[{"Tr", "[", 
         RowBox[{"x", ".", "x"}], "]"}]}], "-", 
       SuperscriptBox[
        RowBox[{"Tr", "[", "x", "]"}], "2"]}], 
      RowBox[{"10", "-", "1"}]]]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"lower", "[", "x_", "]"}], ":=", 
  RowBox[{
   FractionBox[
    RowBox[{"Tr", "[", "x", "]"}], "10"], "-", " ", 
   RowBox[{
    FractionBox[
     RowBox[{"10", "-", "1"}], "10"], 
    SqrtBox[
     FractionBox[
      RowBox[{
       RowBox[{"10", 
        RowBox[{"Tr", "[", 
         RowBox[{"x", ".", "x"}], "]"}]}], "-", 
       SuperscriptBox[
        RowBox[{"Tr", "[", "x", "]"}], "2"]}], 
      RowBox[{"10", "-", "1"}]]]}]}]}]}], "Input",
 CellChangeTimes->{{3.526140653073838*^9, 3.526140740971807*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"SpectralBoundsData", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"upper", "[", "\[DoubleStruckCapitalA]", "]"}], ",", 
          RowBox[{"lower", "[", "\[DoubleStruckCapitalA]", "]"}]}], "}"}], "/.", 
        RowBox[{"\[DoubleStruckCapitalA]", "->", 
         FractionBox[
          RowBox[{"\[DoubleStruckCapitalM]", "+", 
           RowBox[{"Transpose", "[", "\[DoubleStruckCapitalM]", "]"}]}], 
          "2"]}]}], "/.", 
       RowBox[{"\[DoubleStruckCapitalM]", "\[Rule]", 
        RowBox[{"RandomReal", "[", 
         RowBox[{
          RowBox[{"{", "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"10", ",", "10"}], "}"}]}], "]"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "1000"}], "}"}]}], "]"}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.526141346147252*^9, 3.5261413795212193`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DisplayBounds", "=", 
  RowBox[{"ListPlot", "[", 
   RowBox[{"SpectralBoundsData", ",", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "6"}], ",", "7"}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.5261413937067003`*^9, 3.5261414094838676`*^9}, {
  3.526141816448251*^9, 3.526141822309729*^9}, {3.5261420535016317`*^9, 
  3.526142054117491*^9}}],

