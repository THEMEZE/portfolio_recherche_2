Cell[TextData[{
 StyleBox["REMARK",
  FontWeight->"Bold",
  FontColor->RGBColor[1, 0, 0]],
 ": If you SELECT the bracket that embraces both input and output, and then \
",
 StyleBox["double-click",
  FontWeight->"Bold"],
 ",",
 StyleBox[" ",
  FontWeight->"Bold"],
 "the output will disappear from view and a down-pointing arrow will appear \
on the right. Select and double-click again to make the output reappear. Try \
it!"
}], "Text",
