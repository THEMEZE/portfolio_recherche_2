 TextAlignment->Left,
 TextJustification->1.],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  StyleBox["\<\"\\!\\(\\*RowBox[{\\\"Information\\\", \\\"[\\\", \
StyleBox[\\\"symbol\\\", \\\"TI\\\"], \\\"]\\\"}]\\) prints information about \
a symbol. \"\>", "MSG"], " ", 
