Cell[BoxData[
 RowBox[{"D", "[", 
  RowBox[{
   RowBox[{"newvee", "[", "x", "]"}], ",", "x"}], "]"}]], "Input",
 CellChangeTimes->{{3.394760030247663*^9, 3.3947600443201113`*^9}}],

