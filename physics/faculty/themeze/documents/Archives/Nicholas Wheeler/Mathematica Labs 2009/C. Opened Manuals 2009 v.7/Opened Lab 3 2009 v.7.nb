Cell[TextData[{
 "To construct the determinant of such a matrix you would have to compute 5! \
five-number products and add the (appropriately signed) results; observe how \
quickly ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " does the job:"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
