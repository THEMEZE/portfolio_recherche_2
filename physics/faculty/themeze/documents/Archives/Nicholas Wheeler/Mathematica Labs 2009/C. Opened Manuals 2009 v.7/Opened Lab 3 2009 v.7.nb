 RowBox[{
  RowBox[{"NSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        SuperscriptBox["x", "2"], "+", 
        SuperscriptBox["y", "2"]}], "\[Equal]", 
       RowBox[{"1", "/", "3"}]}], ",", 
      RowBox[{
       RowBox[{"x", "+", "y"}], "\[Equal]", "1"}]}], "}"}], ",", 
    RowBox[{"{", 
