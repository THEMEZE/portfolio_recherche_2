Cell[TextData[{
 "To enable conversion  from one system of units to another on has available \
the resources of the Units Package. To learn about it, search for ",
 StyleBox["Units/tutorial/Units. ",
  FontColor->RGBColor[0, 0, 1]],
 "To activate it, command"
}], "Text",
 CellChangeTimes->{{3.3950062042715597`*^9, 3.395006336140264*^9}}],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<Units`\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.395006357514304*^9, 3.395006358269332*^9}}],

