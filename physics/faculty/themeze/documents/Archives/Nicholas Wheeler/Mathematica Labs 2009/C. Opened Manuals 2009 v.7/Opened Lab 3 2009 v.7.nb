Cell[TextData[{
 "But (approximate) ",
 StyleBox["numerical solution",
  FontColor->RGBColor[0, 0, 1]],
 " is possible in ",
 StyleBox["all",
  FontSlant->"Italic"],
 " specific cases:  the preceding command supplies an uninformative result"
}], "Text",
 CellChangeTimes->{{3.395014967750626*^9, 3.3950149704807787`*^9}, {
  3.395015039348929*^9, 3.395015085570737*^9}}],

