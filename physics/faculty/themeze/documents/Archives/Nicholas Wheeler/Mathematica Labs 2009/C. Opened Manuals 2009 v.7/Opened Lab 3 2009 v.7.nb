      RowBox[{"y", "[", "x", "]"}]}], ")"}], "2"]]}]], "Output",
 CellChangeTimes->{3.395177471277564*^9}]
}, Open  ]],

Cell["Define", "Text",
 CellChangeTimes->{{3.395177506963029*^9, 3.395177531931547*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"secondderivative", "[", 
   RowBox[{"x_", ",", "p_"}], "]"}], ":=", 
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "x"}], "+", 
       RowBox[{"5", " ", 
        RowBox[{"y", "[", "x", "]"}]}]}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{"5", "-", "p"}], ")"}]}], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"5", " ", "x"}], "-", 
       RowBox[{"y", "[", "x", "]"}]}], ")"}], "2"]], "-", 
   FractionBox[
    RowBox[{
     RowBox[{"-", "1"}], "+", 
     RowBox[{"5", " ", "p"}]}], 
    RowBox[{
     RowBox[{"5", " ", "x"}], "-", 
     RowBox[{"y", "[", "x", "]"}]}]]}]}]], "Input"],

