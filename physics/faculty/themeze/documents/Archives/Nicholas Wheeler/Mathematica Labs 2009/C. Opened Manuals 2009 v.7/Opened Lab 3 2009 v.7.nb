 RowBox[{
  FractionBox["31536000", 
   RowBox[{"\[Pi]", " ", 
    SuperscriptBox["10", "7"]}]], "//", "N"}]], "Input"],

Cell[BoxData["1.0038220570692022`"], "Output",
 CellChangeTimes->{3.3950066033348217`*^9}]
}, Open  ]],

