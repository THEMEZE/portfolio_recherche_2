Cell[TextData[{
 "But it was announced at the outset that",
 StyleBox[" ", "Output"],
 StyleBox[Cell[BoxData[
  RowBox[{
   RowBox[{
    SuperscriptBox["x", "2"], "+", 
    SuperscriptBox["y", "2"], "-", 
    RowBox[{"10", "x", " ", "y"}]}], "=", 
   SuperscriptBox["a", "2"]}]], "Output"], "Output"],
 " so we have finally"
}], "Text",
