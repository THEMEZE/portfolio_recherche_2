}, Open  ]],

Cell[TextData[{
 "To evaluate the ",
 StyleBox["determinant",
  FontWeight->"Bold"],
 " we command"
}], "Text",
 CellChangeTimes->{{3.3950821681998672`*^9, 3.395082177140143*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Det", "[", "A", "]"}]], "Input",
