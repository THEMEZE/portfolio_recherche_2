  FractionBox["1", "2"], " ", 
  RowBox[{"(", 
   RowBox[{"2", "+", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"x", "/", "4"}]], " ", 
     SqrtBox["\[Pi]"], " ", 
     SqrtBox["x"], " ", 
