Cell[TextData[{
 "But ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " stands ready to tell us about those higher functions: thus"
}], "Text",
 CellChangeTimes->{{3.395163161912277*^9, 3.395163191197225*^9}, 
   3.39601319792341*^9}],

