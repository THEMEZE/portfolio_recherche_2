Cell[TextData[{
 "How accurate is the claim that \"one year is about ",
 StyleBox["\[Pi]", "DisplayFormula"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["10", "7"], " "}], TraditionalForm]]],
 "long\"?"
}], "Text",
 CellChangeTimes->{{3.3950065758775597`*^9, 3.395006579418662*^9}}],

Cell[CellGroupData[{

