Cell[TextData[{
 StyleBox["REMARK",
  FontWeight->"Bold",
  FontColor->RGBColor[1, 0, 0]],
 ": Just about everything, if you penetrate deeply enough into the bowels of \
",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 ", becomes a \"list\" of one sort or another, and elaborate means are \
provided for the manipulation of lists. Sooner or later you will need to \
acquire familiarity with some of that material. For basic information, search \
for ",
 StyleBox["tutorial/ListsOverview",
  FontColor->RGBColor[0, 0, 1]],
 " and look at the links provided there."
}], "Text",
 CellChangeTimes->{{3.395085461575192*^9, 3.3950856245528393`*^9}}],

