     RowBox[{"Sin", "[", "\[Beta]", "]"}]}], ")"}], "2"], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"1", "-", 
  FractionBox[
   SuperscriptBox[
    RowBox[{"Cos", "[", "\[Alpha]", "]"}], "2"], "2"], "-", 
  FractionBox[
   SuperscriptBox[
    RowBox[{"Cos", "[", "\[Beta]", "]"}], "2"], "2"], "+", 
  FractionBox[
   SuperscriptBox[
    RowBox[{"Sin", "[", "\[Alpha]", "]"}], "2"], "2"], "+", 
  RowBox[{"2", " ", 
   RowBox[{"Sin", "[", "\[Alpha]", "]"}], " ", 
   RowBox[{"Sin", "[", "\[Beta]", "]"}]}], "+", 
  FractionBox[
   SuperscriptBox[
    RowBox[{"Sin", "[", "\[Beta]", "]"}], "2"], "2"]}]], "Output",
 CellChangeTimes->{3.3950667955681257`*^9}]
}, Open  ]],

