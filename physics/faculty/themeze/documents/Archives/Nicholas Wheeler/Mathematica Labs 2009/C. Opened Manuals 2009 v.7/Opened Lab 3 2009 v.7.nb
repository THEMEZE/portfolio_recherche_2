Cell[TextData[{
 "we see the ",
 StyleBox["real roots as axis-crossings",
  FontVariations->{"Underline"->True}],
 ", but are provided with only an obscure hint concerning the location of the \
complex roots. "
}], "Text",
 CellChangeTimes->{
  3.395023293078422*^9, {3.3950233561694307`*^9, 3.395023397871436*^9}}],

