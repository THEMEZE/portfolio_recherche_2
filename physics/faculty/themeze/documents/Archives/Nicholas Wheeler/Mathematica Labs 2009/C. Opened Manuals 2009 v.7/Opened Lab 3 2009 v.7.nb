     RowBox[{
      SuperscriptBox["y", "\[Prime]",
       MultilineFunction->None], "[", "x", "]"}]}]}], 
   RowBox[{
    RowBox[{"5", " ", "x"}], "-", 
    RowBox[{"y", "[", "x", "]"}]}]], "-", 
  FractionBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", "-", 
      RowBox[{"5", " ", 
       RowBox[{"y", "[", "x", "]"}]}]}], ")"}], " ", 
    RowBox[{"(", 
