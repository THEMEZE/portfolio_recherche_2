Cell[TextData[StyleBox["Another Example",
 FontColor->RGBColor[0, 0, 1]]], "Subsubsection",
 CellChangeTimes->{{3.39502293590239*^9, 3.395022938728417*^9}}],

Cell["Let ", "Text",
 CellChangeTimes->{{3.395022958127399*^9, 3.395022959800722*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"p", "[", "x_", "]"}], ":=", 
  RowBox[{
   SuperscriptBox["x", "6"], "-", 
   RowBox[{"2", 
    SuperscriptBox["x", "2"]}], "+", 
   RowBox[{"4", "x"}], "+", "4"}]}]], "Input",
