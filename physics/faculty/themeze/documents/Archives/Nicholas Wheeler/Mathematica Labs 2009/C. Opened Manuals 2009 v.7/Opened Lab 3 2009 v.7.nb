Cell[TextData[{
 "All efforts to solve the quintic (which everyone expected to be difficult) \
failed\[Ellipsis]for what Galois and Abel showed (early 19th Century) to be \
this very good reason: solution (in the sense of the preceding formulae) is \
",
 StyleBox["impossible",
  FontColor->RGBColor[0, 0, 1]],
 ", except in favorable special cases. ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " has this to say in the general case:"
}], "Text",
 CellChangeTimes->{{3.395970315788061*^9, 3.395970317994122*^9}}],

