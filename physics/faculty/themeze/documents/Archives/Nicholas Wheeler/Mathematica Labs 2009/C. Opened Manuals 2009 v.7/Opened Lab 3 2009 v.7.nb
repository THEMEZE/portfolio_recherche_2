Cell[TextData[{
 "The numerical evaluation of integrals is, as we just saw, very easy to \
command, and ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " is able to deal automatically with various pathologies"
}], "Text",
 CellChangeTimes->{{3.395165577321693*^9, 3.395165629305066*^9}, {
  3.396014838165394*^9, 3.3960148428884573`*^9}}],

