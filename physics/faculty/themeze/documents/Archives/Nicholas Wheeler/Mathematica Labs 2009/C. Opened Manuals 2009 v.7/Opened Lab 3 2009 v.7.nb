 CellChangeTimes->{{3.395076641275878*^9, 3.395076646715105*^9}}],

Cell[TextData[{
 "The simplest way to make a matrix appear at the cursor is to proceed ",
 StyleBox["Insert > Table/Matrix",
  FontWeight->"Bold"],
 " and select ",
 StyleBox["New",
  FontWeight->"Bold"],
 ". [REMARK: In ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " 5 one could achieve the same result from the keyboard, by typing ",
 StyleBox["\[ShiftKey]\[CloverLeaf]",
  FontWeight->"Bold",
