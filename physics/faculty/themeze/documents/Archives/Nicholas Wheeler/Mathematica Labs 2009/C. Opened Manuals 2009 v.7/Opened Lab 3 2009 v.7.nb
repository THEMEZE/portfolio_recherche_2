}, Open  ]],

Cell[TextData[{
 "Then to evaluate the ",
 StyleBox["trace",
  FontWeight->"Bold"],
 " we command"
}], "Text",
 CellChangeTimes->{{3.395082112233008*^9, 3.395082149940527*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Tr", "[", "A", "]"}]], "Input",
