Cell[CellGroupData[{

Cell[TextData[StyleBox["Evaluation of Limits",
 FontColor->RGBColor[1, 0, 0]]], "Subsection",
 CellChangeTimes->{{3.3960157227547703`*^9, 3.39601572763603*^9}}],

Cell[CellGroupData[{

Cell[TextData[StyleBox["First Example",
 FontColor->RGBColor[0, 0, 1]]], "Subsubsection",
 CellChangeTimes->{{3.395179890155208*^9, 3.3951798957041473`*^9}}],

Cell[BoxData[
 RowBox[{"Clear", "[", "f", "]"}]], "Input",
 CellChangeTimes->{{3.3951799354403467`*^9, 3.3951799386912394`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "x_", "]"}], ":=", 
  FractionBox[
   RowBox[{"Sin", "[", "x", "]"}], "x"]}]], "Input"],

Cell[TextData[{
 "At ",
 StyleBox["x",
  FontSlant->"Italic"],
 " = 0 we get the improper construction 0/0, yet from the figure"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"f", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{
      RowBox[{"-", "6"}], "\[Pi]"}], ",", 
     RowBox[{"6", "\[Pi]"}]}], "}"}], ",", " ", 
   RowBox[{"PlotRange", "\[Rule]", "All"}], ",", " ", 
   RowBox[{"Ticks", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "6"}], "\[Pi]"}], ",", 
        RowBox[{
         RowBox[{"-", "4"}], "\[Pi]"}], ",", 
        RowBox[{
         RowBox[{"-", "2"}], "\[Pi]"}], ",", 
        RowBox[{"2", "\[Pi]"}], ",", 
        RowBox[{"4", "\[Pi]"}], ",", 
        RowBox[{"6", "\[Pi]"}]}], "}"}], ",", 
      RowBox[{"{", "1", "}"}]}], "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.39517999801573*^9, 3.395180089665059*^9}}],

