Cell[TextData[{
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " interprets ",
 StyleBox["xy", "Input"],
 " to be a unitary symbol, but ",
 StyleBox["x y", "Input"],
 " as a command to construct the ",
 StyleBox["product",
  FontSlant->"Italic"],
 " of ",
 StyleBox["x", "Input"],
 " and ",
 StyleBox["y", "Input"],
 ":"
}], "Text",
 CellChangeTimes->{{3.395079704933453*^9, 3.395079713212757*^9}, {
  3.395079812342042*^9, 3.395079872800548*^9}}],

Cell[CellGroupData[{

