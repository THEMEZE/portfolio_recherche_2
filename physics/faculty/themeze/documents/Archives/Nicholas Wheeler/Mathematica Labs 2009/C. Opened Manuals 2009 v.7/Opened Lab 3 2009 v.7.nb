    RowBox[{"10.`", " ", "t"}], "]"}], " ", 
   RowBox[{"Sin", "[", 
    RowBox[{"11.`", " ", "t"}], "]"}]}], "+", 
  RowBox[{
   FractionBox["1", "2"], " ", 
   SuperscriptBox[
    RowBox[{"Sin", "[", 
     RowBox[{"11.`", " ", "t"}], "]"}], "2"]}]}]], "Output",
 CellChangeTimes->{3.395066911570476*^9}]
}, Open  ]],

