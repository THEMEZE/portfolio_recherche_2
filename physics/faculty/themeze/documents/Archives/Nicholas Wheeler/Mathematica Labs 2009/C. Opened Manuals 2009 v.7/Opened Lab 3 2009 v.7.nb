Cell[TextData[StyleBox["Examples: Some Familiar, Some Less Familiar",
 FontColor->RGBColor[0, 0, 1]]], "Subsubsection",
 CellChangeTimes->{{3.3960158258331003`*^9, 3.396015842043281*^9}}],

Cell[CellGroupData[{

