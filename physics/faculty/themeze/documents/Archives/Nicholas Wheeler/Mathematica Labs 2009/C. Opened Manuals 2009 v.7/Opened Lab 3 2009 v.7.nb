 RowBox[{"secondderivative", "[", 
  RowBox[{"x", ",", 
   RowBox[{"firstderivative", "[", "x", "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   FractionBox[
    RowBox[{
     RowBox[{"-", "1"}], "+", 
     FractionBox[
      RowBox[{"5", " ", 
       RowBox[{"(", 
        RowBox[{"x", "-", 
         RowBox[{"5", " ", 
          RowBox[{"y", "[", "x", "]"}]}]}], ")"}]}], 
      RowBox[{
       RowBox[{"5", " ", "x"}], "-", 
