Cell[TextData[{
 "we see that the leading zero of ",
 StyleBox["BesselJ[0, \[Rho]]", "Output"],
 " lies in the neighborhood of \[Rho] = 2.5, so we ask ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " to search for a zero in that neighborhood:"
}], "Text",
 CellChangeTimes->{{3.3955389794538116`*^9, 3.395538979911498*^9}, {
  3.395539051514626*^9, 3.3955390982434263`*^9}, {3.395539131047223*^9, 
  3.395539150900386*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FindRoot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"BesselJ", "[", 
     RowBox[{"0", ",", "\[Rho]"}], "]"}], "==", "0"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Rho]", ",", "2.5"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.395538521251614*^9, 3.395538576712071*^9}, {
   3.395538759765299*^9, 3.395538830803225*^9}, 3.395577333208001*^9}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\[Rho]", "\[Rule]", "2.404825557695773`"}], "}"}]], "Output",
 CellChangeTimes->{3.44509007123839*^9}]
}, Open  ]],

Cell["To find the next zero we command", "Text",
 CellChangeTimes->{{3.3955391622638903`*^9, 3.3955391735642967`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FindRoot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"BesselJ", "[", 
     RowBox[{"0", ",", "\[Rho]"}], "]"}], "==", "0"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Rho]", ",", "5.6"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.395539195604775*^9, 3.395539196819929*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\[Rho]", "\[Rule]", "5.52007811028631`"}], "}"}]], "Output",
 CellChangeTimes->{3.445090077082675*^9}]
}, Open  ]],

Cell[TextData[{
 "and so we might proceed. But ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " provides a command "
}], "Text",
 CellChangeTimes->{{3.3955392736869707`*^9, 3.395539283654051*^9}, {
  3.3955773689135942`*^9, 3.395577373641541*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "BesselJZero"}]], "Input",
 CellChangeTimes->{{3.395539309712535*^9, 3.3955393127216387`*^9}}],

Cell[BoxData[
 RowBox[{
  StyleBox["\<\"\\!\\(\\*RowBox[{\\\"BesselJZero\\\", \\\"[\\\", \
RowBox[{StyleBox[\\\"n\\\", \\\"TI\\\"], \\\",\\\", StyleBox[\\\"k\\\", \
\\\"TI\\\"]}], \\\"]\\\"}]\\) represents the \\!\\(\\*StyleBox[\\\"k\\\", \
\\\"TI\\\"]\\)\\!\\(\\*SuperscriptBox[\\\"\[Null]\\\", \\\"th\\\"]\\) zero of \
the Bessel function \\!\\(\\*RowBox[{SubscriptBox[\\\"J\\\", \\\"n\\\"], \
\\\"(\\\", StyleBox[\\\"x\\\", \\\"TI\\\"], \
\\\")\\\"}]\\).\\n\\!\\(\\*RowBox[{\\\"BesselJZero\\\", \\\"[\\\", \
RowBox[{StyleBox[\\\"n\\\", \\\"TI\\\"], \\\",\\\", StyleBox[\\\"k\\\", \
\\\"TI\\\"], \\\",\\\", SubscriptBox[StyleBox[\\\"x\\\", \\\"TI\\\"], \
StyleBox[\\\"0\\\", \\\"TR\\\"]]}], \\\"]\\\"}]\\) represents the \
\\!\\(\\*StyleBox[\\\"k\\\", \
\\\"TI\\\"]\\)\\!\\(\\*SuperscriptBox[\\\"\[Null]\\\", \\\"th\\\"]\\) zero \
greater than \\!\\(\\*SubscriptBox[StyleBox[\\\"x\\\", \\\"TI\\\"], StyleBox[\
\\\"0\\\", \\\"TR\\\"]]\\).\"\>", "MSG"], "\[NonBreakingSpace]", 
  ButtonBox[
   StyleBox["\[RightSkeleton]", "SR"],
   Active->True,
   BaseStyle->"Link",
   ButtonData->"paclet:ref/BesselJZero"]}]], "Print", "PrintUsage",
 CellChangeTimes->{3.4450900812218113`*^9},
 CellTags->"Info3445061280-2516947"]
}, Open  ]],

Cell["that does the work for us:", "Text",
 CellChangeTimes->{{3.3955393223624983`*^9, 3.3955393268706417`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"BesselJZero", "[", 
   RowBox[{"0", ",", "1"}], "]"}], "//", "N"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"BesselJZero", "[", 
   RowBox[{"0", ",", "2"}], "]"}], "//", "N"}]}], "Input",
 CellChangeTimes->{{3.395539569743001*^9, 3.395539582310939*^9}, {
  3.3955396132090807`*^9, 3.395539617447624*^9}}],

Cell[BoxData["2.404825557695773`"], "Output",
 CellChangeTimes->{3.445090083890789*^9}],

Cell[BoxData["5.5200781102863115`"], "Output",
 CellChangeTimes->{3.445090083941587*^9}]
}, Open  ]],

Cell[TextData[{
 "The following command creates a table, in which the first row presents the \
zeros of ",
 StyleBox["BesselJ[0, \[Rho]]", "Output"],
 " in ascending order, the second row presents the zeros of ",
 StyleBox["BesselJ[1, \[Rho]]", "Output"],
 ", ",
 StyleBox["etc",
  FontSlant->"Italic"],
 "."
}], "Text",
 CellChangeTimes->{{3.395539994816682*^9, 3.395540017417494*^9}, {
  3.395540051817995*^9, 3.39554010292339*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"BesselJZero", "[", 
      RowBox[{"m", ",", "n"}], "]"}], "//", "N"}], ",", 
    RowBox[{"{", 
     RowBox[{"m", ",", "0", ",", "3"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "1", ",", "5"}], "}"}]}], "]"}], "//", 
  "TableForm"}]], "Input",
 CellChangeTimes->{{3.395539362432364*^9, 3.395539441933717*^9}, {
   3.395539624082808*^9, 3.3955396247454033`*^9}, 3.395539671366556*^9, {
   3.395545926717166*^9, 3.395545929451777*^9}}],

Cell[BoxData[
 TagBox[GridBox[{
    {"2.404825557695773`", "5.5200781102863115`", "8.653727912911013`", 
     "11.791534439014281`", "14.930917708487787`"},
    {"3.831705970207512`", "7.0155866698156`", "10.173468135062722`", 
     "13.323691936314223`", "16.470630050877634`"},
    {"5.135622301840683`", "8.41724414039981`", "11.619841172149059`", 
     "14.79595178235126`", "17.959819494987826`"},
    {"6.3801618959239805`", "9.761023129981666`", "13.015200721698434`", 
     "16.223466160318768`", "19.409415226435012`"}
   },
   GridBoxAlignment->{
    "Columns" -> {{Left}}, "ColumnsIndexed" -> {}, "Rows" -> {{Baseline}}, 
     "RowsIndexed" -> {}},
   GridBoxSpacings->{"Columns" -> {
       Offset[0.27999999999999997`], {
        Offset[0.7]}, 
       Offset[0.27999999999999997`]}, "ColumnsIndexed" -> {}, "Rows" -> {
       Offset[0.2], {
        Offset[0.4]}, 
       Offset[0.2]}, "RowsIndexed" -> {}}],
  Function[BoxForm`e$, 
   TableForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.445090088809882*^9}]
}, Open  ]],

Cell["", "Text",
 CellChangeTimes->{{3.395577504358117*^9, 3.395577504452705*^9}}],

Cell["From", "Text",
 CellChangeTimes->{{3.395577559950282*^9, 3.395577560595797*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   SubscriptBox["\[Omega]", 
    RowBox[{"m", ",", "n"}]], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"c", "/", "a"}], ")"}], 
    RowBox[{"BesselJZero", "[", 
     RowBox[{"m", ",", "n"}], "]"}]}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.395577573141677*^9, 3.395577605470508*^9}}],

Cell[TextData[{
 "we become able, by inspection of the table, to list in ascending order the ",
 StyleBox["natural frequencies of a vibrating circular drumhead",
  FontWeight->"Bold"],
 ":"
}], "Text",
 CellChangeTimes->{{3.395577625717208*^9, 3.395577715183127*^9}}],

Cell[BoxData[{
 StyleBox[
  RowBox[{
   SubscriptBox["\[Omega]", 
    RowBox[{"0", ",", "1"}]], "  ", ":", "   ", "fundamental"}], "Output",
  FontColor->GrayLevel[0.5]], "\[IndentingNewLine]", 
 StyleBox[
  RowBox[{
   SubscriptBox["\[Omega]", 
    RowBox[{"1", ",", "1"}]], "  ", ":", "   ", 
   RowBox[{"first", " ", "harmonic"}]}], "Output",
  FontColor->GrayLevel[0.5]], "\[IndentingNewLine]", 
 StyleBox[
  RowBox[{
   SubscriptBox["\[Omega]", 
    RowBox[{"2", ",", "1"}]], "  ", ":", "   ", 
   RowBox[{"second", " ", "harmonic"}]}], "Output",
  FontColor->GrayLevel[0.5]], "\[IndentingNewLine]", 
 StyleBox[
  RowBox[{
   SubscriptBox["\[Omega]", 
    RowBox[{"0", ",", "2"}]], "  ", ":", "   ", 
   RowBox[{"third", " ", "harmonic"}]}], "Output",
  FontColor->GrayLevel[0.5]], "\[IndentingNewLine]", 
 StyleBox[
  RowBox[{
   SubscriptBox["\[Omega]", 
    RowBox[{"3", ",", "1"}]], "  ", ":", "   ", 
   RowBox[{"fourth", " ", "harmonic"}]}], "Output",
  FontColor->GrayLevel[0.5]], "\[IndentingNewLine]", 
 StyleBox["\[VerticalEllipsis]", "Output",
  FontColor->GrayLevel[0.5]]}], "Input",
 CellChangeTimes->{{3.39557776309129*^9, 3.3955778035614653`*^9}, {
   3.395577845131173*^9, 3.39557794064223*^9}, {3.395577974853778*^9, 
   3.3955780047051363`*^9}, 3.395578065868634*^9}],

Cell["", "Text",
 CellChangeTimes->{{3.395578213259657*^9, 3.395578213277419*^9}}]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Assembly of the Final Result",
 FontColor->RGBColor[0, 0, 1]]], "Subsubsection",
 CellChangeTimes->{{3.395592682792349*^9, 3.395592691707004*^9}}],

Cell["\<\
We have now in hand this doubly-indexed population of solutions of the \
equation of motion of a circular drumhead:\
\>", "Text",
 CellChangeTimes->{{3.395578228683282*^9, 3.395578291487485*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"F", "[", 
   RowBox[{
   "r_", ",", "\[Theta]_", ",", "t_", ",", "m_", ",", "n_", ",", "c_", ",", 
    "a_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"BesselJ", "[", 
    RowBox[{"m", ",", 
     RowBox[{
      FractionBox[
       RowBox[{"N", "[", 
        RowBox[{"BesselJZero", "[", 
         RowBox[{"m", ",", "n"}], "]"}], "]"}], "a"], "r"}]}], "]"}], "*", 
   RowBox[{"Cos", "[", 
    RowBox[{"m", " ", "\[Theta]"}], "]"}], "*", 
   RowBox[{"Cos", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"c", "/", "a"}], ")"}], 
     RowBox[{"N", "[", 
      RowBox[{"BesselJZero", "[", 
       RowBox[{"m", ",", "n"}], "]"}], "]"}], "t"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.395578298737961*^9, 3.395578389863982*^9}, {
  3.395578420231578*^9, 3.395578490581259*^9}, {3.3955785336377296`*^9, 
  3.3955785851073523`*^9}, {3.395578926444124*^9, 3.395578964488254*^9}, {
  3.395581367766487*^9, 3.3955813740362043`*^9}}],

Cell["The radial factors", "Text",
 CellChangeTimes->{{3.395578749279888*^9, 3.395578761670149*^9}, 
   3.3955788137366543`*^9, {3.395579236189467*^9, 3.395579249630333*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"R", "[", 
   RowBox[{"r_", ",", "m_", ",", "n_", ",", "a_"}], "]"}], ":=", 
  RowBox[{"BesselJ", "[", 
   RowBox[{"m", ",", 
    RowBox[{
     FractionBox[
      RowBox[{"N", "[", 
       RowBox[{"BesselJZero", "[", 
        RowBox[{"m", ",", "n"}], "]"}], "]"}], "a"], "r"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.395578826961957*^9, 3.395578865468647*^9}, {
  3.3955789061992598`*^9, 3.39557891960166*^9}}],

Cell[TextData[{
 " of low order\[LongDash]displayed as functions of ",
 StyleBox["\[Rho] = r/a", "Output"],
 " (which ranges between 0 and 1)\[LongDash]look like this:"
}], "Text",
 CellChangeTimes->{{3.395578876555235*^9, 3.395578880231896*^9}, {
   3.395579109430505*^9, 3.395579119971649*^9}, {3.395579168387877*^9, 
   3.395579221077929*^9}, 3.395579253312717*^9}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"R", "[", 
       RowBox[{"\[Rho]", ",", 
        StyleBox["0",
         FontColor->RGBColor[1, 0, 0]], ",", "1", ",", "1"}], "]"}], ",", 
      RowBox[{"R", "[", 
       RowBox[{"\[Rho]", ",", 
        StyleBox["0",
         FontColor->RGBColor[1, 0, 0]], ",", "2", ",", "1"}], "]"}], ",", 
      RowBox[{"R", "[", 
       RowBox[{"\[Rho]", ",", 
        StyleBox["0",
         FontColor->RGBColor[1, 0, 0]], ",", "3", ",", "1"}], "]"}]}], "}"}], 
    "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Rho]", ",", "0", ",", "1"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.395540539380734*^9, 3.395540616808729*^9}, {
  3.395540656956723*^9, 3.395540693726491*^9}, {3.39554091863833*^9, 
  3.395540929462462*^9}, {3.395579031477948*^9, 3.395579050473673*^9}, {
  3.39557908763657*^9, 3.395579100707036*^9}}],

