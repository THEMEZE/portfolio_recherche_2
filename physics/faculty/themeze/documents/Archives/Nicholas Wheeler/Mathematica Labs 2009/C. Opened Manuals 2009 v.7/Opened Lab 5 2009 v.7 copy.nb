Cell[TextData[{
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " has supplied here a result that does not much resemble the one reported by \
Griffiths.  The difference, however, is only notational, as I now demonstrate:"
}], "Text",
 CellChangeTimes->{{3.395603951370657*^9, 3.395603965497056*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"%", "==", 
   RowBox[{
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["r", "2"]], 
     RowBox[{
      SubscriptBox["\[PartialD]", "r"], " ", 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["r", 
         RowBox[{"2", " "}]], 
        RowBox[{"u", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], ")"}]}]}], 
    "+", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"r", " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}]], 
     RowBox[{
      SubscriptBox["\[PartialD]", "\[Theta]"], 
      RowBox[{"(", " ", 
       RowBox[{
        RowBox[{"v", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ")"}]}]}], "+", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"r", " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}]], 
     RowBox[{
      SubscriptBox["\[PartialD]", "\[Phi]"], " ", 
      RowBox[{"w", "[", 
       RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}]}]}]}], "//", 
  "Simplify", " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"That", "'"}], "s", " ", 
    RowBox[{"Griffiths", "'"}], " ", "result", " ", "on", " ", "the", " ", 
    "right"}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.3956040053529787`*^9, 3.3956040081719847`*^9}}],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.4450908237401867`*^9}]
}, Open  ]],

Cell["", "Text",
 CellChangeTimes->{{3.3956040447311172`*^9, 3.395604044840332*^9}}],

Cell["", "Text"],

Cell[TextData[{
 StyleBox["The Laplacian occurs very commonly in the PDEs of mathematical \
physics",
  FontColor->RGBColor[0, 0, 1]],
 ", and is (in curvilinear coordinates) quite tedious to compute longhand \
because it involves 2nd derivatives. ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " does the heavy labor in a jiffy: "
}], "Text",
 CellChangeTimes->{{3.3956040601460247`*^9, 3.395604061273508*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Laplacian", "[", 
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], ",", 
   RowBox[{"Spherical", "[", 
    RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", 
   SuperscriptBox["r", "2"]], 
  RowBox[{
   RowBox[{"Csc", "[", "\[Theta]", "]"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"Csc", "[", "\[Theta]", "]"}], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"0", ",", "0", ",", "2"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"0", ",", "1", ",", "0"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"0", ",", "2", ",", "0"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], "+", 
     RowBox[{"2", " ", "r", " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"1", ",", "0", ",", "0"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], "+", 
     RowBox[{
      SuperscriptBox["r", "2"], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"2", ",", "0", ",", "0"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}]}], 
    ")"}]}]}]], "Output",
 CellChangeTimes->{3.445090831793746*^9}]
}, Open  ]],

Cell["", "Text",
 CellChangeTimes->{{3.395604671912787*^9, 3.395604672023879*^9}}],

Cell["", "Text"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Total Derivatives, Total Differentials &  Fractional Change", "Section",
 CellChangeTimes->{{3.395604706702443*^9, 3.395604726081792*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.395604805992485*^9, 3.395604806017426*^9}}],

Cell["\<\
I turn now to discussion of some applications of a powerful little tool of \
many uses:\
\>", "Text",
 CellChangeTimes->{{3.3956048132874947`*^9, 3.39560484247628*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", 
  StyleBox["Dt",
   FontColor->GrayLevel[0]]}]], "Input"],

Cell[BoxData[
 RowBox[{
  StyleBox["\<\"\\!\\(\\*RowBox[{\\\"Dt\\\", \\\"[\\\", \
RowBox[{StyleBox[\\\"f\\\", \\\"TI\\\"], \\\",\\\", StyleBox[\\\"x\\\", \
\\\"TI\\\"]}], \\\"]\\\"}]\\) gives the total derivative \
\\!\\(\\*RowBox[{StyleBox[\\\"d\\\", \\\"TI\\\"], StyleBox[\\\"f\\\", \
\\\"TI\\\"], \\\"/\\\", StyleBox[\\\"d\\\", \\\"TI\\\"], StyleBox[\\\"x\\\", \
\\\"TI\\\"]}]\\). \\n\\!\\(\\*RowBox[{\\\"Dt\\\", \\\"[\\\", StyleBox[\\\"f\\\
\", \\\"TI\\\"], \\\"]\\\"}]\\) gives the total differential \
\\!\\(\\*StyleBox[RowBox[{\\\"d\\\", \\\"f\\\"}], \\\"TI\\\"]\\). \
\\n\\!\\(\\*RowBox[{\\\"Dt\\\", \\\"[\\\", RowBox[{StyleBox[\\\"f\\\", \\\"TI\
\\\"], \\\",\\\", RowBox[{\\\"{\\\", RowBox[{StyleBox[\\\"x\\\", \\\"TI\\\"], \
\\\",\\\", StyleBox[\\\"n\\\", \\\"TI\\\"]}], \\\"}\\\"}]}], \\\"]\\\"}]\\) \
gives the multiple derivative \
\\!\\(\\*RowBox[{SuperscriptBox[StyleBox[\\\"d\\\", \\\"TI\\\"], \
StyleBox[\\\"n\\\", \\\"TI\\\"]], StyleBox[\\\"f\\\", \\\"TI\\\"], \\\"/\\\", \
StyleBox[\\\"d\\\", \\\"TI\\\"], SuperscriptBox[StyleBox[\\\"x\\\", \
\\\"TI\\\"], StyleBox[\\\"n\\\", \\\"TI\\\"]]}]\\). \
\\n\\!\\(\\*RowBox[{\\\"Dt\\\", \\\"[\\\", RowBox[{StyleBox[\\\"f\\\", \\\"TI\
\\\"], \\\",\\\", SubscriptBox[StyleBox[\\\"x\\\", \\\"TI\\\"], \
StyleBox[\\\"1\\\", \\\"TR\\\"]], \\\",\\\", SubscriptBox[StyleBox[\\\"x\\\", \
\\\"TI\\\"], StyleBox[\\\"2\\\", \\\"TR\\\"]], \\\",\\\", StyleBox[\\\"\
\[Ellipsis]\\\", \\\"TR\\\"]}], \\\"]\\\"}]\\) gives \
\\!\\(\\*RowBox[{StyleBox[\\\"d\\\", \\\"TI\\\"], \\\"/\\\", \
RowBox[{StyleBox[\\\"d\\\", \\\"TI\\\"], SubscriptBox[StyleBox[\\\"x\\\", \
\\\"TI\\\"], StyleBox[\\\"1\\\", \\\"TR\\\"]], \\\" \\\", RowBox[{StyleBox[\\\
\"d\\\", \\\"TI\\\"], \\\"/\\\", StyleBox[\\\"d\\\", \\\"TI\\\"]}], \
SubscriptBox[StyleBox[\\\"x\\\", \\\"TI\\\"], StyleBox[\\\"2\\\", \
\\\"TR\\\"]], \\\" \\\", \\\"\[Ellipsis]\\\", \\\" \\\", StyleBox[\\\"f\\\", \
\\\"TI\\\"]}]}]\\). \"\>", "MSG"], "\[NonBreakingSpace]", 
  ButtonBox[
   StyleBox["\[RightSkeleton]", "SR"],
   Active->True,
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Dt"]}]], "Print", "PrintUsage",
 CellChangeTimes->{3.445090839993081*^9},
 CellTags->"Info3445062039-4760653"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Illustrative Applications",
 FontColor->RGBColor[0, 0, 1]]], "Subsubsection",
 CellChangeTimes->{{3.3956050521476*^9, 3.395605057205265*^9}}],

Cell["The command", "Text",
 CellChangeTimes->{{3.395605075893667*^9, 3.395605080151554*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Dt", "[", 
  RowBox[{
   SuperscriptBox["x", "2"], 
   SuperscriptBox["y", "3"]}], "]"}]], "Input",
 CellChangeTimes->{{3.395604981044525*^9, 3.395604986259763*^9}, {
  3.395605090362843*^9, 3.395605097305284*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"2", " ", "x", " ", 
   SuperscriptBox["y", "3"], " ", 
   RowBox[{"Dt", "[", "x", "]"}]}], "+", 
  RowBox[{"3", " ", 
   SuperscriptBox["x", "2"], " ", 
   SuperscriptBox["y", "2"], " ", 
   RowBox[{"Dt", "[", "y", "]"}]}]}]], "Output",
 CellChangeTimes->{3.4450908462948008`*^9}]
}, Open  ]],

Cell["gives a result that on paper we might express", "Text",
 CellChangeTimes->{{3.395605112172634*^9, 3.395605126648518*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"\[Delta]", 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["x", "2"], 
      SuperscriptBox["y", "3"]}], ")"}]}], "=", 
   RowBox[{
    RowBox[{"2", " ", "x", " ", 
     SuperscriptBox["y", "3"], "\[Delta]x"}], "+", 
    RowBox[{"3", " ", 
     SuperscriptBox["x", "2"], " ", 
     SuperscriptBox["y", "2"], "\[Delta]y"}]}]}], "Output"]], "Output",
 CellChangeTimes->{{3.395605136563408*^9, 3.395605169277398*^9}},
 FontColor->GrayLevel[0.5]],

Cell[TextData[{
 "and call the \"",
 StyleBox["total differential",
  FontWeight->"Bold"],
 "\" of ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["x", "2"], 
   SuperscriptBox["y", "3"]}]],
  CellChangeTimes->{{3.395604981044525*^9, 3.395604986259763*^9}, {
   3.395605090362843*^9, 3.395605097305284*^9}}],
 ". Comparison with"
}], "Text",
 CellChangeTimes->{{3.395605218972928*^9, 3.395605271052343*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Dt", "[", 
  RowBox[{
   SuperscriptBox["x", "2"], 
   SuperscriptBox["y", "n"]}], "]"}]], "Input",
 CellChangeTimes->{{3.3956053095813513`*^9, 3.395605335231647*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"2", " ", "x", " ", 
   SuperscriptBox["y", "n"], " ", 
   RowBox[{"Dt", "[", "x", "]"}]}], "+", 
  RowBox[{
   SuperscriptBox["x", "2"], " ", 
   SuperscriptBox["y", "n"], " ", 
   RowBox[{"(", 
    RowBox[{
     FractionBox[
      RowBox[{"n", " ", 
       RowBox[{"Dt", "[", "y", "]"}]}], "y"], "+", 
     RowBox[{
      RowBox[{"Dt", "[", "n", "]"}], " ", 
      RowBox[{"Log", "[", "y", "]"}]}]}], ")"}]}]}]], "Output",
 CellChangeTimes->{3.445090909349524*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Expand", "[", "%", "]"}]], "Input",
 CellChangeTimes->{{3.39560534945218*^9, 3.395605352383922*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"2", " ", "x", " ", 
   SuperscriptBox["y", "n"], " ", 
   RowBox[{"Dt", "[", "x", "]"}]}], "+", 
  RowBox[{"n", " ", 
   SuperscriptBox["x", "2"], " ", 
   SuperscriptBox["y", 
    RowBox[{
     RowBox[{"-", "1"}], "+", "n"}]], " ", 
   RowBox[{"Dt", "[", "y", "]"}]}], "+", 
  RowBox[{
   SuperscriptBox["x", "2"], " ", 
   SuperscriptBox["y", "n"], " ", 
   RowBox[{"Dt", "[", "n", "]"}], " ", 
   RowBox[{"Log", "[", "y", "]"}]}]}]], "Output",
 CellChangeTimes->{3.4450909130686817`*^9}]
}, Open  ]],

Cell[TextData[{
 "reveals an extra  term  because ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " assumes that ",
 StyleBox["n", "Input"],
 " should be included in the list of variables. To disabuse ",
 StyleBox["Mathematica ",
  FontSlant->"Italic"],
 "of that assumption, we command "
}], "Text",
 CellChangeTimes->{{3.395605374665716*^9, 3.3956054363737507`*^9}, {
  3.395605466900794*^9, 3.3956054932629633`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Dt", "[", 
   RowBox[{
    SuperscriptBox["x", "2"], 
    SuperscriptBox["y", "n"]}], "]"}], "/.", 
  RowBox[{
   RowBox[{"Dt", "[", "n", "]"}], "\[Rule]", "0"}]}]], "Input",
 CellChangeTimes->{{3.395605511382689*^9, 3.395605519251774*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"2", " ", "x", " ", 
   SuperscriptBox["y", "n"], " ", 
   RowBox[{"Dt", "[", "x", "]"}]}], "+", 
  RowBox[{"n", " ", 
   SuperscriptBox["x", "2"], " ", 
   SuperscriptBox["y", 
    RowBox[{
     RowBox[{"-", "1"}], "+", "n"}]], " ", 
   RowBox[{"Dt", "[", "y", "]"}]}]}]], "Output",
 CellChangeTimes->{3.445090927545032*^9}]
}, Open  ]],

Cell["In the case n = 3 we recover our former result:", "Text",
 CellChangeTimes->{{3.3956055358671217`*^9, 3.3956055487033243`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"%", "/.", 
  RowBox[{"n", "\[Rule]", "3"}]}]], "Input",
 CellChangeTimes->{{3.3956055580872107`*^9, 3.395605568602603*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"2", " ", "x", " ", 
   SuperscriptBox["y", "3"], " ", 
   RowBox[{"Dt", "[", "x", "]"}]}], "+", 
  RowBox[{"3", " ", 
   SuperscriptBox["x", "2"], " ", 
   SuperscriptBox["y", "2"], " ", 
   RowBox[{"Dt", "[", "y", "]"}]}]}]], "Output",
 CellChangeTimes->{3.445090931676488*^9}]
}, Open  ]],

Cell[TextData[{
 "This is a result that, if working on paper or in ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    RowBox[{"T", 
     AdjustmentBox["E",
      BoxBaselineShift->0.5,
      BoxMargins->{{-0.3, 0}, {0, 0}}], "X"}],
    SingleLetterItalics->False], TraditionalForm]]],
 ", we would most commonly write"
}], "Text",
 CellChangeTimes->{{3.3960983450505953`*^9, 3.3960983930450783`*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"\[Delta]", 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["x", "2"], 
      SuperscriptBox["y", "n"]}], ")"}]}], "=", 
   RowBox[{
    RowBox[{"2", " ", "x", " ", 
     SuperscriptBox["y", "3"], "\[Delta]x"}], "+", 
    RowBox[{"3", " ", 
     SuperscriptBox["x", "2"], " ", 
     SuperscriptBox["y", "2"], "\[Delta]y"}]}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{3.395605287404367*^9}],

Cell["", "Text",
 CellChangeTimes->{{3.396098444506513*^9, 3.396098444526627*^9}}],

Cell["", "Text"],

Cell[TextData[{
 "Here below is the ",
 StyleBox["total derivative with respect to t",
  FontWeight->"Bold"],
 " of a generic function of two variables:"
}], "Text",
 CellChangeTimes->{{3.3956056272477417`*^9, 3.3956056426406517`*^9}, {
  3.395605681015814*^9, 3.395605689873612*^9}, {3.396098453598139*^9, 
  3.396098454797402*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Dt", "[", 
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"x", ",", "y"}], "]"}], ",", "t"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Dt", "[", 
    RowBox[{"y", ",", "t"}], "]"}], " ", 
   RowBox[{
    SuperscriptBox["f", 
     TagBox[
      RowBox[{"(", 
       RowBox[{"0", ",", "1"}], ")"}],
      Derivative],
     MultilineFunction->None], "[", 
    RowBox[{"x", ",", "y"}], "]"}]}], "+", 
  RowBox[{
   RowBox[{"Dt", "[", 
    RowBox[{"x", ",", "t"}], "]"}], " ", 
   RowBox[{
    SuperscriptBox["f", 
     TagBox[
      RowBox[{"(", 
       RowBox[{"1", ",", "0"}], ")"}],
      Derivative],
     MultilineFunction->None], "[", 
    RowBox[{"x", ",", "y"}], "]"}]}]}]], "Output",
 CellChangeTimes->{3.445090949223692*^9}]
}, Open  ]],

Cell["On paper we would have written something like", "Text",
 CellChangeTimes->{{3.395605750215857*^9, 3.395605759018198*^9}, {
  3.395606125341585*^9, 3.3956061269842253`*^9}}],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{"df", "[", 
    RowBox[{"x", ",", "y"}], "]"}], "dt"], "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}]}], 
     RowBox[{"\[PartialD]", "x"}]], 
    FractionBox["dx", "dt"]}], "+", 
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}]}], 
     RowBox[{"\[PartialD]", "y"}]], 
    FractionBox["dy", "dt"]}]}]}]], "Output",
 CellChangeTimes->{{3.395605775293208*^9, 3.395605794351563*^9}, {
  3.395606054156384*^9, 3.395606102343315*^9}},
 FontColor->GrayLevel[0.5]],

Cell["", "Text",
 CellChangeTimes->{{3.3956062054516563`*^9, 3.395606205469545*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.395606255314231*^9, 3.395606255335198*^9}}]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Kinetic Energy of a Particle in Spherical Coordinates",
 FontColor->RGBColor[0, 0, 1]]], "Subsubsection"],

Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{"x", ",", "y", ",", "z", ",", "r", ",", "\[Theta]", ",", "\[Phi]"}],
   "]"}]], "Input"],

Cell["\<\
We begin by recalling how the spherical coordinates were introduced:\
\>", "Text"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"x", "[", 
   RowBox[{"r_", ",", "\[Theta]_", ",", " ", "\[Phi]_"}], "]"}], ":=", 
  RowBox[{"r", " ", 
   RowBox[{"Sin", "[", "\[Theta]", "]"}], 
   RowBox[{"Cos", "[", "\[Phi]", "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y", "[", 
   RowBox[{"r_", ",", "\[Theta]_", ",", " ", "\[Phi]_"}], "]"}], ":=", 
  RowBox[{"r", " ", 
   RowBox[{"Sin", "[", "\[Theta]", "]"}], 
   RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"z", "[", 
   RowBox[{"r_", ",", "\[Theta]_", ",", " ", "\[Phi]_"}], "]"}], ":=", 
  RowBox[{"r", " ", 
   RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]}], "Input"],

Cell["We know that in Cartesian coordinates", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"kineticenergy", "=", 
  RowBox[{
   FractionBox["m", "2"], 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"Dt", "[", 
       RowBox[{"x", ",", "t"}], "]"}], "2"], "+", 
     SuperscriptBox[
      RowBox[{"Dt", "[", 
       RowBox[{"y", ",", "t"}], "]"}], "2"], "+", 
     SuperscriptBox[
      RowBox[{"Dt", "[", 
       RowBox[{"z", ",", "t"}], "]"}], "2"]}], ")"}]}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", "m", " ", 
  RowBox[{"(", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"Dt", "[", 
      RowBox[{"x", ",", "t"}], "]"}], "2"], "+", 
    SuperscriptBox[
     RowBox[{"Dt", "[", 
      RowBox[{"y", ",", "t"}], "]"}], "2"], "+", 
    SuperscriptBox[
     RowBox[{"Dt", "[", 
      RowBox[{"z", ",", "t"}], "]"}], "2"]}], ")"}]}]], "Output",
 CellChangeTimes->{3.4450910152270412`*^9}]
}, Open  ]],

Cell["so in spherical coordinates have", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox["m", "2"], 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"Dt", "[", 
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", " ", "\[Phi]"}], "]"}], ",", 
        "t"}], "]"}], "2"], "+", 
     SuperscriptBox[
      RowBox[{"Dt", "[", 
       RowBox[{
        RowBox[{"y", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", " ", "\[Phi]"}], "]"}], ",", 
        "t"}], "]"}], "2"], "+", 
     SuperscriptBox[
      RowBox[{"Dt", "[", 
       RowBox[{
        RowBox[{"z", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", " ", "\[Phi]"}], "]"}], ",", 
        "t"}], "]"}], "2"]}], ")"}]}], "//", "Simplify"}]], "Input"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", "m", " ", 
  RowBox[{"(", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"Dt", "[", 
      RowBox[{"r", ",", "t"}], "]"}], "2"], "+", 
    RowBox[{
     SuperscriptBox["r", "2"], " ", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"Dt", "[", 
         RowBox[{"\[Theta]", ",", "t"}], "]"}], "2"], "+", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"Dt", "[", 
          RowBox[{"\[Phi]", ",", "t"}], "]"}], "2"], " ", 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}], ")"}]}]}], 
   ")"}]}]], "Output",
 CellChangeTimes->{3.445091019890501*^9}]
}, Open  ]],

Cell["\<\
If you have struggled as many times as I have to recreate this important \
result with pen and ink you will appreciate the swift efficiency of the \
procedure just described. \
\>", "Text"],

Cell["", "Text",
 CellChangeTimes->{{3.3956064762333937`*^9, 3.3956064763244457`*^9}}],

Cell[TextData[StyleBox["", "Subsubsection"]], "Text",
 CellChangeTimes->{{3.395606485220937*^9, 3.395606525645145*^9}}]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Logaritmic Differentiation", "Subsubsection",
 FontColor->RGBColor[0, 0, 1]]], "Subsubsection"],

Cell["The construction", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Dt", "[", 
  RowBox[{"Log", "[", "f", "]"}], "]"}]], "Input"],

Cell[BoxData[
 FractionBox[
  RowBox[{"Dt", "[", "f", "]"}], "f"]], "Output",
 CellChangeTimes->{3.44509103026939*^9}]
}, Open  ]],

Cell[TextData[{
 "speaks very usefully (and dimensionlessly!) of ",
 StyleBox["how the a ",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox["little change",
  FontSlant->"Italic",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox[" in ",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox["f", "Input",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox[" is related to the ",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox["value",
  FontSlant->"Italic",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox[" of ",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox["f", "Input",
  FontColor->RGBColor[0, 0, 1]],
 " .  Look by way of illustration to the familiar relationship "
}], "Text",
 CellChangeTimes->{{3.395606616793682*^9, 3.3956066234160423`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Omega]", "=", 
   SqrtBox[
    RowBox[{"L", "/", "g"}]]}], ";"}]], "Input"],

Cell["taken from the elementary theory of pendula. We command", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Dt", "[", 
   RowBox[{"Log", "[", "\[Omega]", "]"}], "]"}], "//", "Simplify"}]], "Input"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{"Dt", "[", "g", "]"}], "g"]}], "+", 
    FractionBox[
     RowBox[{"Dt", "[", "L", "]"}], "L"]}], ")"}]}]], "Output",
 CellChangeTimes->{3.4450910426883173`*^9}]
}, Open  ]],

Cell[TextData[{
 "and learn that a 1% increase in the value of ",
 StyleBox["g",
  FontSlant->"Italic"],
 " produces a 0.5% decrease in the value of \[Omega], while a 1% increase in \
the value of ",
 StyleBox["L",
  FontSlant->"Italic"],
 " produces a 0.5% increase in the value of \[Omega]. "
}], "Text"],

Cell[TextData[{
 "Elaborations of this basic idea permit one to describe with maximal \
simplicity and economy ",
 StyleBox["the fractional change in this that results from a fractional \
change in that",
  FontColor->RGBColor[0, 0, 1]],
 ", and are encountered also in the theory of errors."
}], "Text",
 CellChangeTimes->{{3.395606737401841*^9, 3.395606752508649*^9}}]
}, Open  ]]
}, Open  ]]
}, Open  ]]
}, Open  ]]
