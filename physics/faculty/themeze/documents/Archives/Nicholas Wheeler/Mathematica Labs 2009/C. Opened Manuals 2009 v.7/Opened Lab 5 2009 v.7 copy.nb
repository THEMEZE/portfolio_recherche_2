   StripOnInput->False],
  Manipulate`InterpretManipulate[1]]], "Output",
 CellChangeTimes->{3.4450896771156387`*^9}]
}, Open  ]],

Cell["\<\
INSTRUCTIONS: Animation tends in this instance to miss details at the times \
when the pulse is bouncing off one or the other of the clamps. Hand operation \
of the slider provides better control. \
\>", "Text",
 CellChangeTimes->{{3.395521477255021*^9, 3.3955216101962852`*^9}, {
  3.39609397752138*^9, 3.396093983317279*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.395525772989499*^9, 3.3955257730031357`*^9}}],

Cell["", "Text"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Solution by \"Separation of Variables\"",
 FontColor->RGBColor[1, 0, 0]]], "Subsection",
 CellChangeTimes->{{3.395525794342806*^9, 3.395525822509801*^9}}],

Cell["\<\
Our discussion of standing waves culmiated in a wave function of the form \
\>", "Text",
 CellChangeTimes->{{3.3955290726395187`*^9, 3.395529109296319*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"u", "[", 
   RowBox[{"x", ",", "t"}], "]"}], "=", 
  RowBox[{"2", " ", 
   RowBox[{"Cos", "[", 
    RowBox[{"2", "\[Pi]", 
     FractionBox[
      RowBox[{" ", "t"}], "\[Tau]"]}], "]"}], " ", 
   RowBox[{"Sin", "[", 
    RowBox[{"2", "\[Pi]", 
     FractionBox[
      RowBox[{" ", "x"}], "\[Lambda]"]}], "]"}]}]}]], "Output",
 CellChangeTimes->{{3.3955291175465403`*^9, 3.395529125996554*^9}, {
  3.395529193520759*^9, 3.3955292256424828`*^9}},
 FontColor->GrayLevel[0.5]],

Cell[TextData[{
 "in which the ",
 StyleBox["variables ",
  FontVariations->{"Underline"->True}],
 StyleBox["x", "Output",
  FontVariations->{"Underline"->True}],
 StyleBox[" and ",
  FontVariations->{"Underline"->True}],
 StyleBox["t", "Output",
  FontVariations->{"Underline"->True}],
 StyleBox[" have been \"separated",
  FontVariations->{"Underline"->True}],
 ",\" in the sense that they appear as the arguments of distinct and separate \
functions, which are multiplied together. Had we specifically sought  wave \
functions with that separated structure, the problem of solving the wave \
equation would have assumed quite a different aspect, as I now demonstrate:"
}], "Text",
 CellChangeTimes->{{3.395529241799079*^9, 3.395529465521123*^9}}],

Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{"u", ",", "f", ",", "g"}], "]"}]], "Input",
 CellChangeTimes->{{3.3955251685825663`*^9, 3.39552517780118*^9}}],

Cell["Assume the wave function to be a product function:", "Text",
 CellChangeTimes->{{3.395529474189845*^9, 3.395529500222693*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"u", "=", 
  RowBox[{
   RowBox[{"f", "[", "x", "]"}], "*", 
   RowBox[{"g", "[", "t", "]"}]}]}]], "Input",
 CellChangeTimes->{{3.3955252212486258`*^9, 3.395525230360568*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "x", "]"}], " ", 
  RowBox[{"g", "[", "t", "]"}]}]], "Output",
 CellChangeTimes->{3.4450897649241667`*^9}]
}, Open  ]],

Cell["From", "Text",
 CellChangeTimes->{{3.395529957289962*^9, 3.395529957709399*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["c", "2"], 
     RowBox[{
      SubscriptBox["\[PartialD]", 
       RowBox[{"x", ",", "x"}]], "u"}]}], "-", 
    RowBox[{
     SubscriptBox["\[PartialD]", 
      RowBox[{"t", ",", "t"}]], "u"}]}], "u"], "//", "Simplify"}]], "Input",
 CellChangeTimes->{
  3.395525247329789*^9, {3.3955252875283337`*^9, 3.395525358772406*^9}}],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    SuperscriptBox["f", "\[Prime]\[Prime]",
     MultilineFunction->None], "[", "x", "]"}], 
   RowBox[{"f", "[", "x", "]"}]], "-", 
  FractionBox[
   RowBox[{
    SuperscriptBox["g", "\[Prime]\[Prime]",
     MultilineFunction->None], "[", "t", "]"}], 
   RowBox[{"g", "[", "t", "]"}]]}]], "Output",
 CellChangeTimes->{3.445089768927511*^9}]
}, Open  ]],

Cell["we learn that the wave equation can be written", "Text",
 CellChangeTimes->{{3.395530014070725*^9, 3.395530019966527*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      RowBox[{
       SuperscriptBox["f", "\[Prime]\[Prime]",
        MultilineFunction->None], "[", "x", "]"}]}], 
     RowBox[{"f", "[", "x", "]"}]], "-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["g", "\[Prime]\[Prime]",
       MultilineFunction->None], "[", "t", "]"}], 
     RowBox[{"g", "[", "t", "]"}]]}], "=", "0"}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.395530035735125*^9, 3.395530036190888*^9}}],

Cell[TextData[{
 "But this requires that ",
 Cell[BoxData[
  FractionBox[
   RowBox[{
    SuperscriptBox["c", "2"], " ", 
    RowBox[{
     SuperscriptBox["f", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "x", "]"}]}], 
   RowBox[{"f", "[", "x", "]"}]]],
  CellChangeTimes->{{3.395530035735125*^9, 3.395530036190888*^9}}],
 "and ",
 Cell[BoxData[
  FractionBox[
   RowBox[{
    SuperscriptBox["g", "\[Prime]\[Prime]",
     MultilineFunction->None], "[", "t", "]"}], 
   RowBox[{"g", "[", "t", "]"}]]],
  CellChangeTimes->{{3.395530035735125*^9, 3.395530036190888*^9}}],
 " be separately equal to some mutual \"separation constant\":"
}], "Text",
 CellChangeTimes->{{3.395530090789475*^9, 3.395530156395763*^9}}],

Cell[BoxData[{
 StyleBox[
  RowBox[{
   FractionBox[
    RowBox[{
     SuperscriptBox["c", "2"], " ", 
     RowBox[{
      SuperscriptBox["f", "\[Prime]\[Prime]",
       MultilineFunction->None], "[", "x", "]"}]}], 
    RowBox[{"f", "[", "x", "]"}]], "=", "k"}], "Output",
  FontColor->GrayLevel[0.5]], "\[IndentingNewLine]", 
 StyleBox[
  RowBox[{
   FractionBox[
    RowBox[{
     SuperscriptBox["g", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "t", "]"}], 
    RowBox[{"g", "[", "t", "]"}]], "=", "k"}], "Output",
  FontColor->GrayLevel[0.5]]}], "Input",
 CellChangeTimes->{{3.395525502915511*^9, 3.3955255168837957`*^9}}],

Cell["From", "Text",
 CellChangeTimes->{{3.395530199542053*^9, 3.395530199929409*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DSolve", "[", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["g", "\[Prime]\[Prime]",
       MultilineFunction->None], "[", "t", "]"}], 
     RowBox[{"g", "[", "t", "]"}]], "==", "k"}], ",", 
   RowBox[{"g", "[", "t", "]"}], ",", "t"}], "]"}]], "Input",
 CellChangeTimes->{{3.395525548871616*^9, 3.395525593759733*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"g", "[", "t", "]"}], "\[Rule]", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        SqrtBox["k"], " ", "t"}]], " ", 
      RowBox[{"C", "[", "1", "]"}]}], "+", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", 
         SqrtBox["k"]}], " ", "t"}]], " ", 
      RowBox[{"C", "[", "2", "]"}]}]}]}], "}"}], "}"}]], "Output",
 CellChangeTimes->{3.445089779384448*^9}]
}, Open  ]],

Cell["\<\
we learn that, if we are to avoid exponential inflation/death the separation \
constant must be negative, which we emphasize by writing \
\>", "Text",
 CellChangeTimes->{{3.3955302112069187`*^9, 3.395530279594656*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{"k", "=", 
   RowBox[{"-", 
    SuperscriptBox["\[Omega]", "2"]}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.39553029303531*^9, 3.3955303024563723`*^9}}],

Cell["The command", "Text",
 CellChangeTimes->{{3.3955303869420443`*^9, 3.395530388148052*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DSolve", "[", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["g", "\[Prime]\[Prime]",
       MultilineFunction->None], "[", "t", "]"}], 
     RowBox[{"g", "[", "t", "]"}]], "\[Equal]", 
    RowBox[{"-", 
     SuperscriptBox["\[Omega]", "2"]}]}], ",", 
   RowBox[{"g", "[", "t", "]"}], ",", "t"}], "]"}]], "Input",
 CellChangeTimes->{{3.395525626646536*^9, 3.3955256294887457`*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"g", "[", "t", "]"}], "\[Rule]", 
    RowBox[{
     RowBox[{
      RowBox[{"C", "[", "1", "]"}], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"t", " ", "\[Omega]"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"C", "[", "2", "]"}], " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"t", " ", "\[Omega]"}], "]"}]}]}]}], "}"}], "}"}]], "Output",
 CellChangeTimes->{3.445089788732429*^9}]
}, Open  ]],

Cell[TextData[{
 "yields an oscillatory function, with period ",
 StyleBox["\[Tau] = 2 \[Pi]/\[Omega]", "Output"],
 ". The command"
}], "Text",
 CellChangeTimes->{{3.395530391697688*^9, 3.395530486318344*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DSolve", "[", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      RowBox[{
       SuperscriptBox["f", "\[Prime]\[Prime]",
        MultilineFunction->None], "[", "x", "]"}]}], 
     RowBox[{"f", "[", "x", "]"}]], "==", 
    RowBox[{"-", 
     SuperscriptBox["\[Omega]", "2"]}]}], ",", 
   RowBox[{"f", "[", "x", "]"}], ",", "x"}], "]"}]], "Input",
 CellChangeTimes->{{3.395525673310562*^9, 3.395525726273902*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"f", "[", "x", "]"}], "\[Rule]", 
    RowBox[{
     RowBox[{
      RowBox[{"C", "[", "1", "]"}], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"x", " ", "\[Omega]"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"C", "[", "2", "]"}], " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"x", " ", "\[Omega]"}], "]"}]}]}]}], "}"}], "}"}]], "Output",
 CellChangeTimes->{3.445089798878798*^9}]
}, Open  ]],

Cell["\<\
yields functions that are spatially oscillatory, with wavelength \
\>", "Text",
 CellChangeTimes->{{3.395530943583988*^9, 3.395530995893577*^9}, {
  3.395531103893711*^9, 3.3955311039039793`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Lambda]", "=", 
  RowBox[{"2", "\[Pi]", " ", 
   RowBox[{"c", "/", "\[Omega]"}]}]}]], "Input",
 CellChangeTimes->{{3.3955311169807053`*^9, 3.3955311535115757`*^9}}],

Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", "\[Pi]"}], "\[Omega]"]], "Output",
 CellChangeTimes->{3.445089811556213*^9}]
}, Open  ]],

Cell[TextData[{
 "To achieve clamping at ",
 StyleBox["x=0", "Output"],
 " and ",
 StyleBox["x=a", "Output"],
 StyleBox[" ", "Code"],
 StyleBox["we are obliged to set", "Code",
  FontWeight->"Plain"]
}], "Text",
 CellChangeTimes->{{3.395530686096489*^9, 3.395530766234644*^9}}],

Cell[BoxData[{
 StyleBox[
  RowBox[{
   RowBox[{"C", "[", "1", "]"}], "=", "0"}], "Output",
  FontColor->GrayLevel[0.5]], "\[IndentingNewLine]", 
 StyleBox[
  RowBox[{
   RowBox[{
    RowBox[{"a", " ", 
     RowBox[{"\[Omega]", "/", "c"}]}], "=", 
    RowBox[{
     RowBox[{"n", " ", 
      RowBox[{"\[Pi]", "   ", ":", "   ", "n"}]}], "=", "0"}]}], ",", "1", 
   ",", "2", ",", "...", " "}], "Output",
  FontColor->GrayLevel[0.5]]}], "Input",
 CellChangeTimes->{{3.395530779432769*^9, 3.395530786712667*^9}, {
  3.395530875256131*^9, 3.395530913241208*^9}, {3.395531250384447*^9, 
  3.3955312688354692`*^9}, {3.3955313041116953`*^9, 3.395531320127894*^9}}],

Cell["The latter equation can be formulated", "Text",
 CellChangeTimes->{{3.3955315455669413`*^9, 3.39553157069453*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   SubscriptBox["\[Lambda]", "n"], "=", 
   FractionBox[
    RowBox[{"2", "a"}], "n"]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.395531581593698*^9, 3.395531607891362*^9}, {
  3.395531719091488*^9, 3.3955317195017347`*^9}}],

Cell["\<\
Boundary conditions have forced the abandonment of all but a discrete set of \
wavelengths, and therefore all but a discrete set (spectrum) of frequencies\
\>", "Text",
 CellChangeTimes->{{3.39553173925852*^9, 3.395531747849133*^9}, {
  3.395531784067568*^9, 3.395531802994378*^9}, {3.3955318607232847`*^9, 
  3.395531877771459*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   SubscriptBox["f", "n"], "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[Omega]", "n"], "/", "2"}], "\[Pi]"}], " ", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"c", "/", "2"}], "a"}], ")"}], "n"}], "=", 
     RowBox[{"c", "/", 
      SubscriptBox["\[Lambda]", "n"]}]}]}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.3955318904472523`*^9, 3.395531961378337*^9}, {
  3.3955319989652987`*^9, 3.395532004626981*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.39553238172088*^9, 3.395532381807206*^9}}],

Cell["", "Text"],

Cell[TextData[{
 "It is in connection with higher-dimensional problems that the ",
 StyleBox["Method of Separation of Variable",
  FontWeight->"Bold"],
 "s most vividly reveals its exceptional power.  Note in this connection that "
}], "Text",
 CellChangeTimes->{{3.395532388048211*^9, 3.395532459996292*^9}, {
  3.3955324921977253`*^9, 3.395532504293297*^9}}],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["\[Bullet] ", "Code"],
 "in 2D boundaries become curves;"
}], "Item1Paragraph",
 CellChangeTimes->{{3.395532519278963*^9, 3.39553257618997*^9}}],

Cell["\<\
\[Bullet] in 3D boundaries become surfaces.\
\>", "Item1Paragraph",
 CellChangeTimes->{{3.395532537813222*^9, 3.395532571125972*^9}}]
}, Open  ]],

Cell["\<\
I illustrate the method as it pertains to the\[Ellipsis]\
\>", "Text",
 CellChangeTimes->{{3.3955325923526*^9, 3.3955326191827717`*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.395532636947418*^9, 3.395532636965958*^9}}],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Vibration of a Circular Drumhead",
 FontColor->RGBColor[0, 0, 1]]], "Subsubsection",
 CellChangeTimes->{{3.395532658658887*^9, 3.395532670231451*^9}}],

Cell["We want to solve ", "Text",
 CellChangeTimes->{{3.395532705310073*^9, 3.395532708079977*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SuperscriptBox["c", "2"], 
     RowBox[{
      StyleBox[
       StyleBox["(", "Output",
        FontColor->GrayLevel[0.500008]], "Output",
       FontColor->GrayLevel[0.500008]], 
      RowBox[{
       RowBox[{
        SubscriptBox["\[PartialD]", 
         RowBox[{"x", ",", "x"}]], 
        RowBox[{"u", "[", 
         RowBox[{"x", 
          StyleBox[
           StyleBox[
            StyleBox[
             StyleBox[
              StyleBox[
               StyleBox[",", "Output",
                FontColor->GrayLevel[0.500008]], "Output",
               FontColor->GrayLevel[0.500008]], "Output",
              FontColor->GrayLevel[0.500008]], "Output",
             FontColor->GrayLevel[0.500008]], "Output",
            FontColor->GrayLevel[0.500008]], "Output",
           FontColor->GrayLevel[0.500008]], 
          StyleBox[
           StyleBox[
            StyleBox[
             StyleBox[
              StyleBox[
               StyleBox[
                StyleBox["y", "Output",
                 FontColor->GrayLevel[0.500008]], "Output",
                FontColor->GrayLevel[0.500008]], "Output",
               FontColor->GrayLevel[0.500008]], "Output",
              FontColor->GrayLevel[0.500008]], "Output",
             FontColor->GrayLevel[0.500008]], "Output",
            FontColor->GrayLevel[0.500008]], "Output",
           FontColor->GrayLevel[0.500008]], ",", "t"}], "]"}]}], 
       StyleBox["+", "Output",
        FontColor->GrayLevel[0.500008]], 
       StyleBox[
        StyleBox[
         RowBox[{
          StyleBox[
           SubscriptBox["\[PartialD]", 
            RowBox[{"y", ",", "y"}]], "Output",
           FontColor->GrayLevel[0.500008]], 
          RowBox[{
           StyleBox["u", "Output",
            FontColor->GrayLevel[0.500008]], 
           StyleBox["[", "Output",
            FontColor->GrayLevel[0.500008]], 
           RowBox[{
            StyleBox["x", "Output",
             FontColor->GrayLevel[0.500008]], 
            StyleBox[
             StyleBox[
              StyleBox[
               StyleBox[",", "Output",
                FontColor->GrayLevel[0.500008]], "Output",
               FontColor->GrayLevel[0.500008]], "Output",
              FontColor->GrayLevel[0.500008]], "Output",
             FontColor->GrayLevel[0.500008]], 
            StyleBox[
             StyleBox[
              StyleBox[
               StyleBox[
                StyleBox["y", "Output",
                 FontColor->GrayLevel[0.500008]], "Output",
                FontColor->GrayLevel[0.500008]], "Output",
               FontColor->GrayLevel[0.500008]], "Output",
              FontColor->GrayLevel[0.500008]], "Output",
             FontColor->GrayLevel[0.500008]], 
            StyleBox[",", "Output",
             FontColor->GrayLevel[0.500008]], 
            StyleBox["t", "Output",
             FontColor->GrayLevel[0.500008]]}], 
           StyleBox["]", "Output",
            FontColor->GrayLevel[0.500008]]}]}], "Output",
         FontColor->GrayLevel[0.500008]], "Output",
        FontColor->GrayLevel[0.500008]]}], 
      StyleBox[
       StyleBox[
        StyleBox[
         StyleBox[")", "Output",
          FontColor->GrayLevel[0.500008]], "Output",
         FontColor->GrayLevel[0.500008]], "Output",
        FontColor->GrayLevel[0.500008]], "Output",
       FontColor->GrayLevel[0.500008]]}]}], "-", 
    RowBox[{
     SubscriptBox["\[PartialD]", 
      RowBox[{"t", ",", "t"}]], 
     RowBox[{"u", "[", 
      RowBox[{"x", 
       StyleBox[
        StyleBox[
         StyleBox[
          StyleBox[
           StyleBox[
            StyleBox[",", "Output",
             FontColor->GrayLevel[0.500008]], "Output",
            FontColor->GrayLevel[0.500008]], "Output",
           FontColor->GrayLevel[0.500008]], "Output",
          FontColor->GrayLevel[0.500008]], "Output",
         FontColor->GrayLevel[0.500008]], "Output",
        FontColor->GrayLevel[0.500008]], 
       StyleBox[
        StyleBox[
         StyleBox[
          StyleBox[
           StyleBox[
            StyleBox[
             StyleBox["y", "Output",
              FontColor->GrayLevel[0.500008]], "Output",
             FontColor->GrayLevel[0.500008]], "Output",
            FontColor->GrayLevel[0.500008]], "Output",
           FontColor->GrayLevel[0.500008]], "Output",
          FontColor->GrayLevel[0.500008]], "Output",
         FontColor->GrayLevel[0.500008]], "Output",
        FontColor->GrayLevel[0.500008]], ",", "t"}], "]"}]}]}], "\[Equal]", 
   "0"}], "Output",
  FontColor->GrayLevel[0.500008]]], "Input",
 CellChangeTimes->{{3.395532769448477*^9, 3.395532810544435*^9}}],

Cell[TextData[{
 "subject to the requirement that ",
 StyleBox["u[x, y, t]", "Output"],
 " vanishes (all ",
 StyleBox["t", "Output"],
 ") at the boundary of a circle of radius a."
}], "Text",
 CellChangeTimes->{{3.395532819285398*^9, 3.395532829777995*^9}, {
  3.3955328924598494`*^9, 3.395532939292494*^9}}],

Cell["\<\
The shape of the boundary makes it natural to work in polar coordinates:\
\>", "Text",
 CellChangeTimes->{{3.39553298914732*^9, 3.39553300598883*^9}}],

Cell[BoxData[{
 StyleBox[
  RowBox[{"x", "=", 
   RowBox[{"r", " ", 
    RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "Output",
  FontColor->GrayLevel[0.500008]], "\[IndentingNewLine]", 
 StyleBox[
  RowBox[{"y", "=", 
   RowBox[{"r", " ", 
    RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], "Output",
  FontColor->GrayLevel[0.500008]]}], "Input"],

Cell["We write", "Text",
 CellChangeTimes->{{3.395533107794265*^9, 3.395533108838069*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "y"}], "]"}], "=", 
   RowBox[{"F", "[", 
    RowBox[{
     RowBox[{"r", "[", 
      RowBox[{"x", ",", "y"}], "]"}], ",", 
     RowBox[{"\[Theta]", "[", 
      RowBox[{"x", ",", "y"}], "]"}]}], "]"}]}], "Output",
  FontColor->GrayLevel[0.500008]]], "Input"],

Cell["with", "Text",
 CellChangeTimes->{{3.395533142872093*^9, 3.3955331455749702`*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"r", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
  SqrtBox[
   RowBox[{
    SuperscriptBox["x", "2"], "+", 
    SuperscriptBox["y", "2"]}]]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Theta]", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
