Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        FractionBox["1", "3"], " ", 
        RowBox[{"Cos", "[", 
         RowBox[{"3", " ", 
          RowBox[{"(", 
           RowBox[{"t", "+", "x"}], ")"}]}], "]"}]}], ",", 
       RowBox[{"Sin", "[", 
        RowBox[{"t", "-", "x"}], "]"}], ",", 
       RowBox[{
        RowBox[{
         FractionBox["1", "3"], " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"3", " ", 
           RowBox[{"(", 
            RowBox[{"t", "+", "x"}], ")"}]}], "]"}]}], "+", 
        RowBox[{"Sin", "[", 
         RowBox[{"t", "-", "x"}], "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{
        RowBox[{"-", "2"}], "\[Pi]"}], ",", 
       RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Blue", ",", 
          RowBox[{"Thickness", "[", ".004", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"Green", ",", 
          RowBox[{"Thickness", "[", ".004", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"Red", ",", 
          RowBox[{"Thickness", "[", ".01", "]"}]}], "}"}]}], "}"}]}], ",", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1.5"}], ",", "1.5"}], "}"}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", 
     RowBox[{"4", "\[Pi]"}], ",", 
     RowBox[{"N", "[", 
      FractionBox["\[Pi]", "20"], "]"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.395429125580185*^9, 3.3954291672156763`*^9}, {
