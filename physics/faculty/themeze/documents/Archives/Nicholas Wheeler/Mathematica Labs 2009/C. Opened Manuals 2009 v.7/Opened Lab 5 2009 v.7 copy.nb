Cell[TextData[{
 StyleBox["INSTRUCTIONS",
  FontWeight->"Bold"],
 ": Hit the + button to expose the controls, then hit the \"play\" button. \
Slow down the motion to see more clearly that the blue sine curve slides \
rigidly to the left, while the  green sine curve slides rigidly to the right \
(at the same speed),"
}], "Text",
 CellChangeTimes->{{3.3954312052544937`*^9, 3.39543130015625*^9}, {
  3.3954328248093843`*^9, 3.395432827469818*^9}}],

Cell[BoxData[
 RowBox[{"Clear", "[", "u", "]"}]], "Input",
 CellChangeTimes->{{3.395431786742943*^9, 3.395431795230495*^9}}],

Cell["", "Text"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Third Example: d'Alembert's Solution",
 FontColor->RGBColor[0, 0, 1]]], "Subsubsection",
 CellChangeTimes->{{3.395431481777153*^9, 3.395431494447855*^9}}],

Cell[TextData[{
 "d'Alembert speaks of the wave form that evolves from ",
 StyleBox["prescribed initial data",
  FontWeight->"Bold"],
 " (a \"thrown wave,\" if you will\[LongDash]the term borrowed from what we \
prescribe when we throw a rock).  "
}], "Text",
 CellChangeTimes->{
  3.395431634022698*^9, {3.39543170884772*^9, 3.395431757015703*^9}, {
   3.395433497032063*^9, 3.395433499426207*^9}, 3.3955073715576677`*^9}],

Cell[TextData[{
 "Let us suppose, first off, that the ",
 StyleBox["string is intially at rest, but has a Gaussian profile",
  FontColor->RGBColor[1, 0, 0]],
 ":"
}], "Text"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"f", "[", "x", "]"}], ":=", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox["x", "2"]}], "/", "4"}]]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"g", "[", "x", "]"}], ":=", "0"}]}], "Input"],

Cell["d'Alembert's formula then supplies", "Text",
 CellChangeTimes->{{3.395431863323813*^9, 3.395431877071926*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}], "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "2"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"f", "[", 
        RowBox[{"x", "+", 
         RowBox[{"c", " ", "t"}]}], "]"}], "+", 
       RowBox[{"f", "[", 
        RowBox[{"x", "-", 
         RowBox[{"c", " ", "t"}]}], "]"}]}], ")"}]}], "+", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"2", "c"}]], 
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       RowBox[{"x", "-", 
        RowBox[{"c", " ", "t"}]}], 
       RowBox[{"x", "+", 
        RowBox[{"c", " ", "t"}]}]], 
      RowBox[{
       RowBox[{"g", "[", "\[Xi]", "]"}], 
       RowBox[{"\[DifferentialD]", "\[Xi]"}]}]}]}]}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input"],

Cell["then supplies", "Text",
 CellChangeTimes->{{3.3954335667212973`*^9, 3.3954335727651367`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"u1", "[", 
   RowBox[{"x_", ",", "t_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"x", "+", "t"}], ")"}], "2"]}], "/", "4"}]], "+", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"x", "-", "t"}], ")"}], "2"]}], "/", "4"}]]}], 
    ")"}]}]}]], "Input",
 CellChangeTimes->{{3.395432457577944*^9, 3.3954324648243227`*^9}, {
   3.395432642176152*^9, 3.3954326576369753`*^9}, 3.3954334348060293`*^9}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", 
      RowBox[{"x", ",", "x"}]], 
     RowBox[{"u1", "[", 
      RowBox[{"x", ",", "t"}], "]"}]}], "-", 
    RowBox[{
     SubscriptBox["\[PartialD]", 
      RowBox[{"t", ",", "t"}]], 
     RowBox[{"u1", "[", 
      RowBox[{"x", ",", "t"}], "]"}]}]}], "\[Equal]", "0"}], "//", 
  "Simplify"}]], "Input",
 CellChangeTimes->{{3.395432348297578*^9, 3.39543235122073*^9}, {
  3.395433438681773*^9, 3.395433441160893*^9}}],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.445089240606629*^9}]
}, Open  ]],

