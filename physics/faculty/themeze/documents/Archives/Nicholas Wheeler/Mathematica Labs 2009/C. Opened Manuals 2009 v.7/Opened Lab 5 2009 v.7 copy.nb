Cell["", "Text",
 CellChangeTimes->{{3.395579803741865*^9, 3.3955798037600718`*^9}}],

Cell["\<\
When we undertake to construct animated displays of various modes of drumhead \
vibration we discover\
\>", "Text",
 CellChangeTimes->{{3.395579811803117*^9, 3.395579885177402*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "PolarPlot3D"}]], "Input",
 CellChangeTimes->{{3.395542215165388*^9, 3.395542218097971*^9}, {
  3.395579789484956*^9, 3.395579790433403*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"Information", "::", "\<\"notfound\"\>"}], 
  RowBox[{
  ":", " "}], "\<\"\\!\\(\\*StyleBox[\\\"\\\\\\\"Symbol \\\\\\\"\\\", \
\\\"MT\\\"]\\)\[NoBreak]\\!\\(\\*StyleBox[\\!\\(\\\"PolarPlot3D\\\"\\), \
\\\"MT\\\"]\\)\[NoBreak]\\!\\(\\*StyleBox[\\\"\\\\\\\" not \
found.\\\\\\\"\\\", \\\"MT\\\"]\\) \
\\!\\(\\*ButtonBox[\\\"\[RightSkeleton]\\\", ButtonStyle->\\\"Link\\\", \
ButtonFrame->None, ButtonData:>\\\"paclet:ref/message/General/notfound\\\", \
ButtonNote -> \\\"Information::notfound\\\"]\\)\"\>"}]], "Message", "MSG",
 CellChangeTimes->{3.4450901375149307`*^9}]
}, Open  ]],

Cell[TextData[{
 "that ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " 7 does not provide a ",
 StyleBox["PolarPlot3D", "Input"],
 " command, so are forced to work in Cartesian coordinates:"
}], "Text",
 CellChangeTimes->{{3.39557988929981*^9, 3.395579923448112*^9}, 
   3.445090316697055*^9}],

Cell[BoxData[
 RowBox[{"Clear", "[", "u", "]"}]], "Input",
 CellChangeTimes->{{3.395542504442877*^9, 3.395542507347209*^9}, 
   3.4450903040853577`*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"u", "[", 
   RowBox[{
   "x_", ",", "y_", ",", "t_", ",", "m_", ",", "n_", ",", "c_", ",", "a_"}], 
   "]"}], ":=", 
  RowBox[{"F", "[", 
   RowBox[{
    SqrtBox[
     RowBox[{
      SuperscriptBox["x", "2"], "+", 
      SuperscriptBox["y", "2"]}]], ",", 
    RowBox[{"ArcTan", "[", 
     RowBox[{"x", ",", "y"}], "]"}], ",", "t", ",", "m", ",", "n", ",", "c", 
    ",", "a"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.395580013563624*^9, 3.3955800828751163`*^9}, {
  3.3955880167381163`*^9, 3.3955880178156424`*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.3955887436564703`*^9, 3.3955887436758957`*^9}}],

Cell[TextData[{
 StyleBox["REMARK",
  FontWeight->"Bold",
  FontColor->RGBColor[1, 0, 0]],
 ": From"
}], "Text",
 CellChangeTimes->{{3.3955887539335003`*^9, 3.39558876668859*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "ArcTan"}]], "Input",
 CellChangeTimes->{{3.395588775930024*^9, 3.395588781914729*^9}}],

Cell[BoxData[
 RowBox[{
  StyleBox["\<\"\\!\\(\\*RowBox[{\\\"ArcTan\\\", \\\"[\\\", \
StyleBox[\\\"z\\\", \\\"TI\\\"], \\\"]\\\"}]\\) gives the arc tangent \
\\!\\(\\*RowBox[{SuperscriptBox[\\\"tan\\\", RowBox[{\\\"-\\\", \\\"1\\\"}]], \
\\\"(\\\", StyleBox[\\\"z\\\", \\\"TI\\\"], \\\")\\\"}]\\) of the complex \
number \\!\\(\\*StyleBox[\\\"z\\\", \\\"TI\\\"]\\). \
\\n\\!\\(\\*RowBox[{\\\"ArcTan\\\", \\\"[\\\", RowBox[{StyleBox[\\\"x\\\", \\\
\"TI\\\"], \\\",\\\", StyleBox[\\\"y\\\", \\\"TI\\\"]}], \\\"]\\\"}]\\) gives \
the arc tangent of \\!\\(\\*FractionBox[\\\"y\\\", \\\"x\\\"]\\), taking into \
account which quadrant the point \\!\\(\\*RowBox[{\\\"(\\\", \
RowBox[{\\\"x\\\", \\\",\\\", \\\"y\\\"}], \\\")\\\"}]\\) is in. \"\>", 
   "MSG"], "\[NonBreakingSpace]", 
  ButtonBox[
   StyleBox["\[RightSkeleton]", "SR"],
   Active->True,
   BaseStyle->"Link",
   ButtonData->"paclet:ref/ArcTan"]}]], "Print", "PrintUsage",
 CellChangeTimes->{3.4450903540541563`*^9},
 CellTags->"Info3445061553-6253262"]
}, Open  ]],

Cell[TextData[{
 "we learn that ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " recognizes two distinct ",
 StyleBox["ArcTan", "Input"],
 " commands. It is to avoid catastrophy in  the construction of some \
subsequent figures that we have adopted the second alternative."
}], "Text",
 CellChangeTimes->{{3.3955887962060947`*^9, 3.395588847137344*^9}, {
  3.395588890457611*^9, 3.395588945874704*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.395588973421214*^9, 3.3955889734409533`*^9}}],

Cell["\<\
We look now to animated graphic representations of the following low-order \
vibrational modes:\
\>", "Text",
 CellChangeTimes->{{3.395589056476123*^9, 3.395589065366117*^9}, {
  3.395589109131743*^9, 3.3955891478780737`*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"fundamental", "[", 
   RowBox[{"x_", ",", "y_", ",", "t_"}], "]"}], ":=", 
  RowBox[{"u", "[", 
   RowBox[{"x", ",", "y", ",", "t", ",", 
    StyleBox["0",
     FontColor->RGBColor[1, 0, 0]], ",", 
    StyleBox["1",
     FontColor->RGBColor[1, 0, 0]], ",", "1", ",", "1"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"firstharmonic", "[", 
   RowBox[{"x_", ",", "y_", ",", "t_"}], "]"}], ":=", 
  RowBox[{"u", "[", 
   RowBox[{"x", ",", "y", ",", "t", ",", 
    StyleBox["1",
     FontColor->RGBColor[1, 0, 0]], ",", 
    StyleBox["1",
     FontColor->RGBColor[1, 0, 0]], ",", "1", ",", "1"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"secondharmonic", "[", 
   RowBox[{"x_", ",", "y_", ",", "t_"}], "]"}], ":=", 
  RowBox[{"u", "[", 
   RowBox[{"x", ",", "y", ",", "t", ",", 
    StyleBox["2",
     FontColor->RGBColor[1, 0, 0]], ",", 
    StyleBox["1",
     FontColor->RGBColor[1, 0, 0]], ",", "1", ",", "1"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"thirdharmonic", "[", 
   RowBox[{"x_", ",", "y_", ",", "t_"}], "]"}], ":=", 
  RowBox[{"u", "[", 
   RowBox[{"x", ",", "y", ",", "t", ",", 
    StyleBox["0",
     FontColor->RGBColor[1, 0, 0]], ",", 
    StyleBox["2",
     FontColor->RGBColor[1, 0, 0]], ",", "1", ",", "1"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fourthharmonic", "[", 
   RowBox[{"x_", ",", "y_", ",", "t_"}], "]"}], ":=", 
  RowBox[{"u", "[", 
   RowBox[{"x", ",", "y", ",", "t", ",", 
    StyleBox["3",
     FontColor->RGBColor[1, 0, 0]], ",", 
    StyleBox["1",
     FontColor->RGBColor[1, 0, 0]], ",", "1", ",", "1"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"higherharmonic", "[", 
   RowBox[{"x_", ",", "y_", ",", "t_"}], "]"}], ":=", 
  RowBox[{"u", "[", 
   RowBox[{"x", ",", "y", ",", "t", ",", 
    StyleBox["5",
     FontColor->RGBColor[1, 0, 0]], ",", 
    StyleBox["2",
     FontColor->RGBColor[1, 0, 0]], ",", "1", ",", "1"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.395580235916218*^9, 3.395580332628429*^9}, {
   3.395580390505615*^9, 3.395580436923025*^9}, {3.3955805000950527`*^9, 
   3.395580513642927*^9}, {3.395580577062957*^9, 3.3955805803761683`*^9}, {
   3.395580624896123*^9, 3.395580661620002*^9}, 3.3955807914197483`*^9, {
   3.395580835238081*^9, 3.3955808388533697`*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.395581942826741*^9, 3.395581942850477*^9}}],

Cell[TextData[{
 StyleBox["REMARK",
  FontWeight->"Bold",
  FontColor->RGBColor[1, 0, 0]],
 ": When viewing the following animations\[LongDash]which are activated in \
the familiar way\[LongDash]one must ",
 StyleBox["mentally trim off and discard",
  FontSlant->"Italic"],
 " the part of the membrane that lies outside the unit circle. It is \
sometimes easier to see what is going on if (with the animation stopped) one \
adjusts the viewpoint."
}], "Text",
 CellChangeTimes->{{3.395581951330188*^9, 3.395582127531633*^9}, {
  3.395588407477023*^9, 3.395588420930681*^9}, {3.395589176098784*^9, 
  3.3955892194305267`*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.3955821744832363`*^9, 3.395582174497768*^9}}],

Cell[TextData[{
 StyleBox["QUIRK",
  FontWeight->"Bold",
  FontColor->RGBColor[1, 0, 0]],
 ": Sometimes, after construction of the figure is complete, the cell marker \
on the right looks like ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " is still thinking. Scroll, and that misleading indicator will disappear. \
This should be done before you make your next command."
}], "Text",
 CellChangeTimes->{{3.3955900764816313`*^9, 3.395590230483555*^9}}],

Cell[CellGroupData[{

