}, Open  ]],

Cell[TextData[{
 "we conclude that ",
 StyleBox["u[x, t]", "Output"],
 " must have the specialized form"
}], "Text",
 CellChangeTimes->{{3.395513229002635*^9, 3.395513269967914*^9}}],

