Cell[TextData[{
 StyleBox["INSTRUCTIONS",
  FontWeight->"Bold"],
 ":  View the figure form several angles."
}], "Text",
 CellChangeTimes->{{3.3955986932397623`*^9, 3.395598710705413*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.395598757156713*^9, 3.395598757239296*^9}}],

Cell["", "Text"],

Cell["\<\
Here we do the same kind of thing for a less familiar coordinate system:\
\>", "Text",
 CellChangeTimes->{{3.395598766245097*^9, 3.39559878652134*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Coordinates", "[", "Paraboloidal", "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"Uu", ",", "Vv", ",", "Pphi"}], "}"}]], "Output",
 CellChangeTimes->{3.445090623578233*^9}]
}, Open  ]],

Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{"x", ",", "y", ",", "z", ",", "u", ",", "v", ",", "\[Phi]"}], 
  "]"}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"CoordinateRanges", "[", "Paraboloidal", "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"0", "\[LessEqual]", "Uu", "<", "\[Infinity]"}], ",", 
   RowBox[{"0", "\[LessEqual]", "Vv", "<", "\[Infinity]"}], ",", 
   RowBox[{
    RowBox[{"-", "\[Pi]"}], "\[LessEqual]", "Pphi", "\[LessEqual]", 
    "\[Pi]"}]}], "}"}]], "Output",
 CellChangeTimes->{3.445090634122273*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"CoordinatesToCartesian", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"v", ",", "u", ",", "\[Phi]"}], "}"}], ",", "Paraboloidal"}], 
  "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"u", " ", "v", " ", 
    RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ",", 
   RowBox[{"u", " ", "v", " ", 
    RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ",", 
   RowBox[{
    FractionBox["1", "2"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["u", "2"]}], "+", 
      SuperscriptBox["v", "2"]}], ")"}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.4450906374129543`*^9}]
}, Open  ]],

Cell[BoxData[{
 RowBox[{
  RowBox[{"x", "[", 
   RowBox[{"v_", ",", "u_", ",", "\[Phi]_"}], "]"}], ":=", 
  RowBox[{"u", " ", "v", " ", 
   RowBox[{"Cos", "[", "\[Phi]", "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y", "[", 
   RowBox[{"v_", ",", "u_", ",", "\[Phi]_"}], "]"}], ":=", 
  RowBox[{"u", " ", "v", " ", 
   RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"z", "[", 
   RowBox[{"v_", ",", "u_", ",", "\[Phi]_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", "2"], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox["u", "2"]}], "+", 
     SuperscriptBox["v", "2"]}], ")"}]}]}]}], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"constantv", "=", 
  RowBox[{"ParametricPlot3D", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "[", 
       RowBox[{"1", ",", "u", ",", "\[Phi]"}], "]"}], ",", 
      RowBox[{"y", "[", 
       RowBox[{"1", ",", "u", ",", "\[Phi]"}], "]"}], ",", 
      RowBox[{"z", "[", 
       RowBox[{"1", ",", "u", ",", "\[Phi]"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"u", ",", "0", ",", "3"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Phi]", ",", "0", ",", 
      RowBox[{
       FractionBox["3", "2"], "\[Pi]"}]}], "}"}], ",", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "4"}], ",", "4"}], "}"}]}], "}"}]}], ",", " ", 
    RowBox[{"Boxed", "\[Rule]", "False"}], ",", " ", 
    RowBox[{"Axes", "\[Rule]", "False"}]}], "]"}]}]], "Input",
 CellChangeTimes->{
  3.395598948835803*^9, 3.395599013908424*^9, {3.3955991777150497`*^9, 
   3.395599200315905*^9}, {3.395599393889703*^9, 3.3955994618789873`*^9}, 
