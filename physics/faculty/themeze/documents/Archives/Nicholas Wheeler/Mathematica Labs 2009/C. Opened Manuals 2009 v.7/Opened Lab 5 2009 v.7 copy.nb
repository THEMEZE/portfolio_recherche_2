Cell[BoxData[
 RowBox[{"Clear", "[", "u", "]"}]], "Input",
 CellChangeTimes->{{3.3954288127178173`*^9, 3.395428824209057*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.395428734922534*^9, 3.3954287349728413`*^9}}],

Cell["", "Text"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Second Example",
 FontColor->RGBColor[0, 0, 1]]], "Subsubsection",
 CellChangeTimes->{{3.39542874385531*^9, 3.395428750364135*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"u", "[", 
   RowBox[{"x", ",", "t"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Sin", "[", 
    RowBox[{"t", "-", 
     FractionBox["x", "c"]}], "]"}], "+", 
   RowBox[{
    FractionBox["1", "3"], 
    RowBox[{"Cos", "[", 
     RowBox[{"3", 
      RowBox[{"(", 
       RowBox[{"t", "+", 
        FractionBox["x", "c"]}], ")"}]}], "]"}]}]}]}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     SuperscriptBox["c", "2"], 
     RowBox[{
      SubscriptBox["\[PartialD]", 
       RowBox[{"x", ",", "x"}]], 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}]}]}], "-", 
    RowBox[{
     SubscriptBox["\[PartialD]", 
      RowBox[{"t", ",", "t"}]], 
     RowBox[{"u", "[", 
      RowBox[{"x", ",", "t"}], "]"}]}]}], "\[Equal]", "0"}], "//", 
  "Simplify"}]], "Input",
 CellChangeTimes->{{3.3954288467824*^9, 3.395428851104803*^9}}],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.445089177541936*^9}]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[CurlyPhi]", "[", 
   RowBox[{"x", ",", "t"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}], "/.", 
   RowBox[{"c", "\[Rule]", "1"}]}]}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[CurlyPhi]", "[", 
  RowBox[{"x", ",", "t"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox["1", "3"], " ", 
   RowBox[{"Cos", "[", 
    RowBox[{"3", " ", 
     RowBox[{"(", 
      RowBox[{"t", "+", "x"}], ")"}]}], "]"}]}], "+", 
  RowBox[{"Sin", "[", 
   RowBox[{"t", "-", "x"}], "]"}]}]], "Output",
 CellChangeTimes->{3.445089183806234*^9}]
}, Open  ]],

Cell["\<\
The static 3D figure is now almost too complicated to be informative:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot3D", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     FractionBox["1", "3"], " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"3", " ", 
       RowBox[{"(", 
        RowBox[{"t", "+", "x"}], ")"}]}], "]"}]}], "+", 
    RowBox[{"Sin", "[", 
     RowBox[{"t", "-", "x"}], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{
      RowBox[{"-", "2"}], "\[Pi]"}], ",", 
     RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "6"}], "}"}], ",", 
   RowBox[{"PlotPoints", "\[Rule]", "30"}], ",", "\[IndentingNewLine]", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
     "\"\<position x\>\"", ",", "\"\<time t\>\"", ",", "\"\<amplitude\>\""}], 
     "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"Ticks", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"None", ",", " ", "Automatic", ",", " ", "None"}], "}"}]}]}], 
  "]"}]], "Input",
