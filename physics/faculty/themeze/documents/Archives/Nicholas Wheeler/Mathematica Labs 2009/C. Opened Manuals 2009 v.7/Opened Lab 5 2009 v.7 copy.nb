Cell["\<\
NOTICE that is is only in the animations of the fundamental and 3rd harmonic \
that the center of the drumhead moves: in all other cases it is static. This \
is because\
\>", "Text",
 CellChangeTimes->{{3.395590336868843*^9, 3.395590374264884*^9}, {
  3.3955928707201643`*^9, 3.395592912123595*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"BesselJ", "[", 
   RowBox[{"m", ",", "0"}], "]"}], "=", 
  RowBox[{
   RowBox[{"0", "   ", "unless", "   ", "m"}], "=", "0"}]}]], "Output",
 CellChangeTimes->{{3.395590382063332*^9, 3.395590419045046*^9}},
 FontColor->GrayLevel[0.5]],

Cell["\<\
All modes that display center motion are axially symmetric, as is evident in \
the following figure:\
\>", "Text",
 CellChangeTimes->{{3.395591868897551*^9, 3.395591901247401*^9}}],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot3D", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "y", ",", "t", ",", 
        StyleBox["0",
         FontColor->RGBColor[1, 0, 0]], ",", 
        StyleBox["5",
         FontColor->RGBColor[1, 0, 0]], ",", "1", ",", "1"}], "]"}], "]"}], 
     ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", "1"}], "}"}]}], ",", 
     RowBox[{"Ticks", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
        RowBox[{"{", "0", "}"}]}], "}"}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", 
     FractionBox[
      RowBox[{"2", "\[Pi]"}], 
      RowBox[{"BesselJZero", "[", 
       RowBox[{
        StyleBox["0",
         FontColor->RGBColor[1, 0, 0]], ",", 
        StyleBox["5",
         FontColor->RGBColor[1, 0, 0]]}], "]"}]]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.395591768615788*^9, 3.395591781690996*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.395592965397863*^9, 3.3955929654817963`*^9}}],

Cell["", "Text"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Summary Remarks Concerning the Separation Method",
 FontColor->RGBColor[1, 0, 0]]], "Subsection",
 CellChangeTimes->{{3.395592975204886*^9, 3.39559301272864*^9}}],

Cell["\<\
The following remarks are of general significance, but will be phrased as \
they relate to our experience with the drum problem:\
\>", "Text"],

Cell[TextData[{
 "\[Bullet] Separation proceeded from a strong ",
 StyleBox["factorization assumption",
  FontColor->RGBColor[0, 0, 1]]
}], "Text",
 CellChangeTimes->{{3.3955931517793417`*^9, 3.3955931546945343`*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"u", "[", 
    RowBox[{"r", ",", "\[Theta]", ",", "t"}], "]"}], "=", 
   RowBox[{
    RowBox[{"R", "[", "r", "]"}], "*", 
    RowBox[{"A", "[", "\[Theta]", "]"}], "*", 
    RowBox[{"f", "[", "t", "]"}]}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input"],

Cell[TextData[{
 "and led to ",
 StyleBox["particular",
  FontColor->RGBColor[0, 0, 1]],
 " solutions of the PDE in question.  But the general solution (it could be \
shown) can be developed as a ",
 StyleBox["linear combination (superposition) of those particular solutions",
  FontColor->RGBColor[1, 0, 0]],
 "."
}], "Text",
 CellChangeTimes->{{3.396094112941374*^9, 3.396094118766603*^9}}],

Cell[TextData[{
 "\[Bullet] ",
 StyleBox["Spectral discreteness arose",
  FontColor->RGBColor[0, 0, 1]],
 " not from the PDE itself (which speaks in the language of smooth variation) \
but ",
 StyleBox["from the associated boundary conditions",
  FontColor->RGBColor[0, 0, 1]],
 ". It is from this same circumstance that quantum mechanics acquires the \
quantal discreteness to which its name refers, and so does music."
}], "Text",
 CellChangeTimes->{{3.395593207904147*^9, 3.395593217059717*^9}}],

Cell[TextData[{
 "\[Bullet] ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " made duck soup of the computational/graphic details, but ",
 StyleBox["we ourselves were responsible for the controlling ideas",
  FontColor->RGBColor[0, 0, 1]],
 "\[LongDash]responsible, in particular, for the decision to work in polar \
coordinates."
}], "Text"],

Cell[TextData[{
 "\[Bullet] The decision to work in polar coordinates served us in two \
distinct ways: (1) it ",
 StyleBox["permitted separation of the PDE",
  FontColor->RGBColor[0, 0, 1]],
 ", and (2) it ",
 StyleBox["permitted natural description of the boundary conditions",
  FontColor->RGBColor[0, 0, 1]],
 ".  The theory in hand could be adapted to a theory of wedge-shaped \
drumheads (more generally: any drumheads bounded by arcs of constant r and \
arcs of constant \[Theta]), but it has nothing to say about (say) elliptical \
drums, or annular drumheads with off-center holes."
}], "Text"],

Cell["\<\
\[Bullet] All strings have the same shape, and support therefore similar sets \
of harmonics. But drumheads (2-dimensional systems) can have an infinite \
variety of shapes, and each supports its own distinct  set of harmonics. It \
becomes plausibe to speculate that one can \"hear the shape of a drum.\"\
\>", "Text",
 CellChangeTimes->{{3.39559337541936*^9, 3.3955934522073317`*^9}, {
  3.3955934900941277`*^9, 3.39559353440847*^9}}],

Cell[TextData[{
 "\[Bullet] Our ability to adapt the separation of variables method to other \
physical problems is limited by our ",
 StyleBox["command of separating coordinate systems",
  FontColor->RGBColor[0, 0, 1]],
 ", and we can expect in all events to be able to deal only with systems in \
which the ",
 StyleBox["boundaries conform to the geometry",
  FontColor->RGBColor[0, 0, 1]],
 " of whatever coordinate system we have selected. (In other\[LongDash]more \
general cases\[LongDash]we would have to fall back on numerical methods which \
are a vast subject in themselves.)"
}], "Text"],

Cell[TextData[{
 "\tThe latter circumstance has\[LongDash]more than any \
other\[LongDash]inspired development of a great number of wonderful \
coordinate systems, about which ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " knows a great deal. Moreover, variable-separation procedures, carried out \
in those diverse coordinate systems, have inspired the invention and study of \
many of the \"higher transcendental functions\" (things like the Bessel \
functions encountered above) that are the bread & butter of mathematical \
physics, and about which ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " also knows a great deal."
}], "Text"],

Cell["", "Text",
 CellChangeTimes->{{3.395593703649667*^9, 3.3955937037455263`*^9}}],

Cell["", "Text"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Curvilinear Coordinate Systems", "Section",
 CellChangeTimes->{{3.395593745673039*^9, 3.395593754308226*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.39560144978868*^9, 3.395601449807878*^9}}],

Cell["", "Text"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["To and From Various Coordinate Systems",
 FontColor->RGBColor[1, 0, 0]]], "Subsection",
 CellChangeTimes->{{3.395601395016252*^9, 3.3956014187511473`*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.395601437610056*^9, 3.3956014376302643`*^9}}],

Cell[TextData[{
 "To activate ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 "'s expert command of this subject one must enter the Vector Analysis \
Package. For a survey of that resource, go to ",
 StyleBox["Help > Documentation Center",
  FontWeight->"Bold"],
 " and search for ",
 StyleBox["VectorAnalysis/guide/VectorAnalysisPackage",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox[". There you will be directed (see TUTORIALS at the bottom of the \
page) to the very informative ",
  FontColor->GrayLevel[0]],
 StyleBox["VectorAnalysis/tutorial/VectorAnalysis",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox[". To import the package, command ",
  FontColor->GrayLevel[0]]
}], "Text",
 CellChangeTimes->{{3.395594462890471*^9, 3.39559448904748*^9}, {
  3.3955946469411697`*^9, 3.395594818787911*^9}, {3.3955948533235064`*^9, 
  3.395594922109318*^9}, {3.39559548979851*^9, 3.395595519840576*^9}, {
  3.395595563736897*^9, 3.3955955775610847`*^9}}],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<VectorAnalysis`\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.39559565234022*^9, 3.3955956703072767`*^9}}],

Cell["The command", "Text",
 CellChangeTimes->{{3.395596177990279*^9, 3.395596179529088*^9}}],

Cell[CellGroupData[{

Cell[BoxData["CoordinateSystem"], "Input",
 CellChangeTimes->{{3.395595700883244*^9, 3.3955957036929283`*^9}}],

Cell[BoxData["Cartesian"], "Output",
 CellChangeTimes->{3.4450905336709414`*^9}]
}, Open  ]],

Cell[TextData[{
 "identifies the ",
 StyleBox["default coordinate system",
  FontWeight->"Bold"],
 ". The commands"
}], "Text",
 CellChangeTimes->{{3.395596196965517*^9, 3.3955962304981728`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"SetCoordinates", "[", "Cartesian", "]"}], "\[IndentingNewLine]", 
 RowBox[{"SetCoordinates", "[", "Spherical", "]"}], "\[IndentingNewLine]", 
 RowBox[{"SetCoordinates", "[", "Polar", "]"}]}], "Input",
 CellChangeTimes->{{3.395596013105029*^9, 3.395596037443119*^9}, {
  3.395596104505995*^9, 3.395596113556703*^9}}],

Cell[BoxData[
 RowBox[{"Cartesian", "[", 
  RowBox[{"Xx", ",", "Yy", ",", "Zz"}], "]"}]], "Output",
 CellChangeTimes->{3.445090536402708*^9}],

Cell[BoxData[
 RowBox[{"Spherical", "[", 
  RowBox[{"Rr", ",", "Ttheta", ",", "Pphi"}], "]"}]], "Output",
 CellChangeTimes->{3.4450905364130783`*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"Coordinates", "::", "\<\"invalid\"\>"}], 
  RowBox[{
  ":", " "}], "\<\"\[NoBreak]\\!\\(\\*StyleBox[\\!\\(Polar\\), \\\"MT\\\"]\\)\
\[NoBreak]\\!\\(\\*StyleBox[\\\"\\\\\\\" is not a valid coordinate system \
specification.\\\\\\\"\\\", \\\"MT\\\"]\\) \\!\\(\\*ButtonBox[\\\"\
\[RightSkeleton]\\\", ButtonStyle->\\\"Link\\\", ButtonFrame->None, \
ButtonData:>\\\"paclet:VectorAnalysis/ref/Coordinates\\\", ButtonNote -> \
\\\"VectorAnalysis`Coordinates::invalid\\\"]\\)\"\>"}]], "Message", "MSG",
 CellChangeTimes->{3.445090536588378*^9}],

Cell[BoxData[
 RowBox[{"SetCoordinates", "[", "Polar", "]"}]], "Output",
 CellChangeTimes->{3.445090536597166*^9}]
}, Open  ]],

Cell[TextData[{
 "inform us that\[LongDash]until instructed otherwise\[LongDash]",
 StyleBox["Mathematica ",
  FontSlant->"Italic"],
 "will assume Cartesian coodinates to be named ",
 StyleBox["{x,y,z}", "Output"],
 " (or perhaps ",
 StyleBox["{X,Y,Z}", "Output"],
 "), spherical coordinates to be named ",
 StyleBox["{r, theta, phi}", "Output"],
 " (or perhaps ",
 StyleBox["{R, T, P}", "Output"],
 "), and that ",
 StyleBox["polar coordinates fall outside the perview of the package",
  FontSlant->"Italic"],
 ", which has ",
 StyleBox["things to say ",
  FontColor->RGBColor[1, 0, 0]],
 StyleBox["only about 3-dimensional coordinate systems",
  FontWeight->"Bold",
  FontColor->RGBColor[1, 0, 0]],
 ". These are the names of the coordinate ystems it is prepared to discuss:"
}], "Text",
 CellChangeTimes->{{3.395596238183445*^9, 3.395596466718526*^9}, {
  3.395596497247518*^9, 3.395596498901565*^9}, {3.3955968167882757`*^9, 
  3.395596841788411*^9}, {3.395596932908029*^9, 3.395596954236802*^9}}],

Cell["\t\[Bullet] Bipolar", "Text",
 CellChangeTimes->{{3.395596961709734*^9, 3.395596964257936*^9}, {
   3.39559707676703*^9, 3.3955970772708683`*^9}, 3.3961376488322563`*^9}],

Cell["\t\[Bullet] Cartesian", "Text",
 CellChangeTimes->{{3.395596966285179*^9, 3.395596968866293*^9}, 
   3.3955970827447042`*^9, 3.396137651195959*^9}],

Cell["\t\[Bullet] ConfocalParaboloidal", "Text",
 CellChangeTimes->{{3.3955969703974133`*^9, 3.395596989938648*^9}, 
   3.395597084817986*^9, 3.396137653100967*^9}],

Cell["\t\[Bullet] Cylindrical", "Text",
 CellChangeTimes->{{3.39559699091786*^9, 3.395596994043557*^9}, 
   3.395597086818224*^9, 3.396137654892164*^9}],

Cell["\t\[Bullet] OblateSpheroidal", "Text",
 CellChangeTimes->{{3.395596995390087*^9, 3.3955970028558407`*^9}, 
   3.395597088441248*^9, 3.39613765687632*^9}],

Cell["\t\[Bullet] Paraboloidal", "Text",
 CellChangeTimes->{{3.395597006774124*^9, 3.395597011924592*^9}, 
   3.395597090257374*^9, 3.39613765901243*^9}],

Cell["\t\[Bullet] Spherical", "Text",
 CellChangeTimes->{{3.395597012814458*^9, 3.395597016659646*^9}, 
   3.395597092392798*^9, 3.396137661156743*^9}],

Cell["\t\[Bullet] Bispherical", "Text",
 CellChangeTimes->{{3.3955970182543583`*^9, 3.395597022827629*^9}, 
   3.395597094481022*^9, 3.39613766293283*^9}],

Cell["\t\[Bullet] ConfocalEllipsoidal", "Text",
 CellChangeTimes->{{3.395597023398241*^9, 3.395597030921133*^9}, 
   3.395597096273019*^9, {3.396137664997287*^9, 3.396137672533598*^9}}],

Cell["\t\[Bullet] Conical", "Text",
 CellChangeTimes->{{3.395597032774292*^9, 3.395597034507551*^9}, 
   3.395597098185556*^9, 3.39613767459025*^9}],

Cell["\t\[Bullet] EllipticCylindrical", "Text",
 CellChangeTimes->{{3.395597037063205*^9, 3.395597045163727*^9}, 
   3.395597100273205*^9, 3.396137676630471*^9}],

Cell["\t\[Bullet] ParabolicCylindrical", "Text",
 CellChangeTimes->{{3.395597046326672*^9, 3.395597059670692*^9}, 
   3.395597102803586*^9, 3.396137679080287*^9}],

Cell["\t\[Bullet] ProlateSpereoidal", "Text",
 CellChangeTimes->{{3.395597060838849*^9, 3.39559706852232*^9}, 
   3.395597104529509*^9, 3.396137681014575*^9}],

Cell["\t\[Bullet] Toroidal", "Text",
 CellChangeTimes->{{3.395597068943009*^9, 3.3955970706387663`*^9}, 
   3.3955971070576267`*^9, 3.396137682622856*^9}],

Cell[TextData[{
 "And ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " stands ready to tell us what it means by each. Let us look, for example, \
to the ",
 StyleBox["Spherical ", "Input"],
 "coordinate system:"
}], "Text",
 CellChangeTimes->{{3.3955972503753653`*^9, 3.3955972649945793`*^9}, {
  3.395597301099354*^9, 3.395597319515511*^9}, {3.3955975343078413`*^9, 
  3.39559753603157*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"SetCoordinates", "[", "Spherical", "]"}]], "Input",
 CellChangeTimes->{{3.395597349807042*^9, 3.395597366694984*^9}, {
  3.3955975431575327`*^9, 3.3955975448865013`*^9}}],

Cell[BoxData[
 RowBox[{"Spherical", "[", 
  RowBox[{"Rr", ",", "Ttheta", ",", "Pphi"}], "]"}]], "Output",
 CellChangeTimes->{3.445090562242078*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"Coordinates", 
    StyleBox["To",
     FontColor->RGBColor[1, 0, 0]], "Cartesian"}]], "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "}"}], ",", "Spherical"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.395597400214374*^9, 3.3955974319133*^9}, {
  3.395597557776333*^9, 3.3955975755278673`*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"r", " ", 
    RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
    RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
   RowBox[{"r", " ", 
    RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
    RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ",", 
   RowBox[{"r", " ", 
    RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.445090566275255*^9}]
}, Open  ]],

Cell[TextData[{
 "This means that ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " has defined"
}], "Text",
 CellChangeTimes->{{3.395598124312743*^9, 3.3955981337841387`*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"x", "[", 
   RowBox[{"r_", ",", "\[Theta]_", ",", " ", "\[Phi]_"}], "]"}], ":=", 
  RowBox[{"r", " ", 
   RowBox[{"Sin", "[", "\[Theta]", "]"}], 
   RowBox[{"Cos", "[", "\[Phi]", "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y", "[", 
   RowBox[{"r_", ",", "\[Theta]_", ",", " ", "\[Phi]_"}], "]"}], ":=", 
  RowBox[{"r", " ", 
   RowBox[{"Sin", "[", "\[Theta]", "]"}], 
   RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"z", "[", 
   RowBox[{"r_", ",", "\[Theta]_", ",", " ", "\[Phi]_"}], "]"}], ":=", 
  RowBox[{"r", " ", 
   RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]}], "Input"],

Cell[TextData[{
 "and so interprets \[Theta] to be not latitude but \"co-latitude\": \[Theta] \
is 0 at the north pole, \[Pi] at the south pole (not 0 at the equator, as  \
geographers and some physicists/mathematicians assume). This is, in \
particular, the spherical system employed by Griffiths in his ",
 StyleBox["Introduction to Electrodynamics",
  FontSlant->"Italic"],
 " (see the endpapers). To clarify the situation, we have the command "
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"CoordinateRanges", "[", "Spherical", "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"0", "\[LessEqual]", "Rr", "<", "\[Infinity]"}], ",", 
   RowBox[{"0", "\[LessEqual]", "Ttheta", "\[LessEqual]", "\[Pi]"}], ",", 
   RowBox[{
    RowBox[{"-", "\[Pi]"}], "<", "Pphi", "\[LessEqual]", "\[Pi]"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{3.4450905854040318`*^9}]
}, Open  ]],

Cell[TextData[{
 "To discover how ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " would describe r, \[Theta], \[Phi] in terms of ",
 StyleBox["x, y, z ",
  FontSlant->"Italic"],
 "we command"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"Coordinates", 
    StyleBox["From",
     FontColor->RGBColor[1, 0, 0]], "Cartesian"}]], "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", "Spherical"}], 
  "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   SqrtBox[
    RowBox[{
     SuperscriptBox["x", "2"], "+", 
     SuperscriptBox["y", "2"], "+", 
     SuperscriptBox["z", "2"]}]], ",", 
   RowBox[{"ArcCos", "[", 
    FractionBox["z", 
     SqrtBox[
      RowBox[{
       SuperscriptBox["x", "2"], "+", 
       SuperscriptBox["y", "2"], "+", 
       SuperscriptBox["z", "2"]}]]], "]"}], ",", 
   RowBox[{"ArcTan", "[", 
    RowBox[{"x", ",", "y"}], "]"}]}], "}"}]], "Output",
 CellChangeTimes->{3.445090589648428*^9}]
}, Open  ]],

Cell["", "Text",
 CellChangeTimes->{{3.3955982505350533`*^9, 3.395598250649372*^9}}],

Cell["", "Text"],

Cell["\<\
It is often useful to have before us a picture of the curvilinear coordinate \
system under consideration.  To obtain such images, we proceed\
\>", "Text",
 CellChangeTimes->{3.39559826293793*^9}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"constantradius", "=", 
  RowBox[{"ParametricPlot3D", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "[", 
       RowBox[{"1", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], ",", 
      RowBox[{"y", "[", 
       RowBox[{"1", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], ",", 
      RowBox[{"z", "[", 
       RowBox[{"1", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", 
      FractionBox["\[Pi]", "8"], ",", "\[Pi]"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Phi]", ",", "0", ",", 
      RowBox[{
       FractionBox["3", "2"], "\[Pi]"}]}], "}"}], ",", " ", 
    RowBox[{"Boxed", "\[Rule]", "False"}], ",", " ", 
    RowBox[{"Axes", "\[Rule]", "False"}]}], "]"}]}]], "Input",
 CellChangeTimes->{
  3.395598289418662*^9, {3.395598595942665*^9, 3.395598619575962*^9}}],

