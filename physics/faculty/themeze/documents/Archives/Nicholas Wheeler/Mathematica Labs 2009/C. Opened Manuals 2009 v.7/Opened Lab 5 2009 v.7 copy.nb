Cell[TextData[{
 "The beauty of the situation is that ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " can do the same thing\[LongDash]with equal ease\[LongDash]in ",
 StyleBox["any",
  FontSlant->"Italic"],
 " of the coordinate systems of which it has knowledge. Suppose we were \
working in spherical coordinates; then we would have (for example) "
}], "Text",
 CellChangeTimes->{{3.3956036689070463`*^9, 3.395603698317234*^9}}],

