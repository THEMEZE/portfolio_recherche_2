Cell["\<\
When the initially static Gaussian is released it resolves into two \
half-sized Gaussians traveling in opposite directions.\
\>", "Text",
 CellChangeTimes->{{3.39550723769445*^9, 3.395507298550638*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.39545106533468*^9, 3.39545106542354*^9}}],

Cell["", "Text"],

Cell[TextData[{
 "Going now to the other extreme, let us suppose that the string is",
 StyleBox[" initially flat, but that it has been given a Gaussian velocity \
profile",
  FontColor->RGBColor[1, 0, 0]],
 ", centered at the origin (where it has been \"plucked\"). Recall that the \
Gaussian (or \"normal\") distribution function is defined"
}], "Text",
 CellChangeTimes->{{3.395433625685029*^9, 3.395433645664579*^9}, {
  3.395433703661175*^9, 3.3954337128924837`*^9}, {3.395434341705257*^9, 
  3.3954343514288692`*^9}, {3.3954343899247513`*^9, 3.3954344314284773`*^9}, {
  3.395434505917873*^9, 3.39543453556896*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"g", "[", 
   RowBox[{"x_", ",", "a_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", 
    RowBox[{"a", 
     SqrtBox["\[Pi]"]}]], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"x", "/", "a"}], ")"}], "2"]}]]}]}]], "Input"],

Cell[TextData[{
 "and responds to manipulation of the ",
 StyleBox["a", "Input"],
 "-parameter as shown below:"
}], "Text",
 CellChangeTimes->{{3.395434807862753*^9, 3.395434857844616*^9}, {
  3.395451113356159*^9, 3.395451113844604*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"g", "[", 
      RowBox[{"x", ",", "a"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "20"}], ",", "20"}], "}"}], ",", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"a", ",", ".5", ",", "5"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.3954345802847443`*^9, 3.3954347032253304`*^9}, {
  3.395434744082696*^9, 3.395434762637506*^9}}],

