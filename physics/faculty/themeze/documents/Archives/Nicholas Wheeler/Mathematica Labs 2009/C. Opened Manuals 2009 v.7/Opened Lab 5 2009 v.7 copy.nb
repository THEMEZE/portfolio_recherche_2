Cell[TextData[{
 StyleBox["INSTRUCTIONS",
  FontWeight->"Bold"],
 ": Hit the + button to expose the controls, use the \[PlusMinus] buttons to \
show graphs of some low-order Bessel function."
}], "Text",
 CellChangeTimes->{{3.3955379758876467`*^9, 3.395538007082241*^9}, {
  3.395538039411746*^9, 3.395538089860146*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.395538115221449*^9, 3.395538115235833*^9}}],

Cell["", "Text"],

Cell[TextData[{
 "We require that the wave function ",
 StyleBox["vanish on the circular boundary",
  FontVariations->{"Underline"->True}],
 " of the drumhead"
}], "Text",
 CellChangeTimes->{{3.39557607960693*^9, 3.395576161247178*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"F", "[", 
    RowBox[{"a", ",", "\[Theta]", ",", "t"}], "]"}], "=", "0"}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.395576188711279*^9, 3.395576192603662*^9}},
 FontWeight->"Plain"],

Cell["so have interest only those k-values for which", "Text",
 CellChangeTimes->{{3.395538447991086*^9, 3.395538454833268*^9}, {
  3.395576249625499*^9, 3.395576249992475*^9}, {3.395576280017735*^9, 
  3.395576287065246*^9}, {3.395576342442321*^9, 3.395576343544039*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"BesselJ", "[", 
    RowBox[{"m", ",", 
     RowBox[{"k", " ", "a"}]}], "]"}], "=", "0"}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.395538479119998*^9, 3.395538484293598*^9}}],

Cell[TextData[{
 "We have interest, that is to say, in the numbers ",
 Cell[BoxData[
  SubscriptBox["k", 
   RowBox[{"m", ",", "n"}]]],
  CellChangeTimes->{{3.395576396052094*^9, 3.395576511762622*^9}}],
 " with the property that"
}], "Text",
 CellChangeTimes->{{3.395538875143456*^9, 3.395538928793377*^9}, {
  3.395576359892316*^9, 3.3955763798508987`*^9}, {3.3955765399783907`*^9, 
  3.395576553909224*^9}, {3.395576584967572*^9, 3.39557658837565*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["k", 
      RowBox[{"m", ",", "n"}]], "a"}], "=", 
    RowBox[{
     SuperscriptBox["n", "th"], " ", "zero", " ", "of", " ", 
     RowBox[{"BesselJ", "[", 
      RowBox[{"m", ",", "\[Rho]"}], "]"}]}]}], ",", 
   RowBox[{
   "the", " ", "Bessel", " ", "function", " ", "of", "  ", "order", " ", 
    "m"}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.395576396052094*^9, 3.395576511762622*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.3955767081830072`*^9, 3.395576708197207*^9}}],

Cell["\<\
NOTE: We have   \[Omega] \[Congruent] c k, so from the fact that the set of \
admissible k-values is discrete it follows that so also is the set of natural \
frequencies discrete:\
\>", "Text",
 CellChangeTimes->{{3.395576715781166*^9, 3.3955767195990677`*^9}, {
  3.395576844529313*^9, 3.395576893298123*^9}, {3.395576930804562*^9, 
  3.395576974211372*^9}, {3.3955770279217653`*^9, 3.395577028902445*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   SubscriptBox["\[Omega]", 
    RowBox[{"m", ",", "n"}]], "=", 
   RowBox[{"c", " ", 
    SubscriptBox["k", 
     RowBox[{"m", ",", "n"}]]}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.395576988662809*^9, 3.39557701979298*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.395577080311455*^9, 3.3955770803247957`*^9}}],

Cell[TextData[{
 "To find the ",
 Cell[BoxData[
  SuperscriptBox["n", "th"]],
  CellChangeTimes->{{3.395576396052094*^9, 3.395576511762622*^9}}],
 " zero of  ",
 "BesselJ[m, \[Rho]] ",
 " we might use the command"
}], "Text",
 CellChangeTimes->{{3.395577097471147*^9, 3.3955772630093946`*^9}}],

