  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.3955130887802267`*^9, 3.3955131070286283`*^9}, {
  3.395513670603129*^9, 3.3955136731493397`*^9}}],

Cell["From", "Text",
 CellChangeTimes->{{3.395513220959272*^9, 3.395513225218112*^9}}],

