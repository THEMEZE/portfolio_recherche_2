    Typeset`initDone$$, Typeset`skipInitDone$$ = 
    True, $CellContext`t$918950$$ = 0}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, "Variables" :> {$CellContext`t$$ = 0}, 
      "ControllerVariables" :> {
        Hold[$CellContext`t$$, $CellContext`t$918950$$, 0]}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, "Body" :> 
      Plot[{(1/3) Cos[3 ($CellContext`t$$ + $CellContext`x)], 
         Sin[$CellContext`t$$ - $CellContext`x], (1/3) 
          Cos[3 ($CellContext`t$$ + $CellContext`x)] + 
         Sin[$CellContext`t$$ - $CellContext`x]}, {$CellContext`x, (-2) Pi, 2 
         Pi}, PlotStyle -> {{Blue, 
           Thickness[0.004]}, {Green, 
           Thickness[0.004]}, {Red, 
           Thickness[0.01]}}, PlotRange -> {-1.5, 1.5}], 
