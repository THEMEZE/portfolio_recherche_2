Cell[TextData[{
 StyleBox["NOTE",
  FontWeight->"Bold"],
 ": On the ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " 7 screen we are not stuck with a single view of that surface, as we would \
be in a book."
}], "Text",
 CellChangeTimes->{{3.395427489267706*^9, 3.395427534448778*^9}, 
   3.445089116899626*^9}],

Cell["", "Text",
 CellChangeTimes->{{3.3954278913672*^9, 3.3954278913702707`*^9}}],

Cell[TextData[{
 "But if we planned to speak about it in a modern lecture hall we would \
probably find it more effective to use one means or another to animate the \
figure: ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " 6 permits us to proceed"
}], "Text",
 CellChangeTimes->{{3.395427908559309*^9, 3.395427937551532*^9}, {
  3.395428021506364*^9, 3.395428035585575*^9}, {3.395428668758918*^9, 
  3.39542868239259*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"t", "-", "x"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{
        RowBox[{"-", "2"}], "\[Pi]"}], ",", 
       RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", 
     RowBox[{"4", "\[Pi]"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.395427589788357*^9, 3.395427592874034*^9}, {
  3.395427623618455*^9, 3.395427682970221*^9}, {3.3954277154810867`*^9, 
  3.395427715843206*^9}, {3.395428534170869*^9, 3.3954285357040567`*^9}}],

