Cell[CellGroupData[{

Cell[TextData[StyleBox["Grad, Div, Curl  & Laplacian",
 FontColor->RGBColor[1, 0, 0]]], "Subsection",
 CellChangeTimes->{{3.395602276111496*^9, 3.395602285580468*^9}, {
  3.395602316154233*^9, 3.395602324925473*^9}}],

Cell["Let", "Text",
 CellChangeTimes->{{3.395603024607592*^9, 3.3956030249513283`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"scalar", "=", 
  RowBox[{"\[Phi]", "[", 
   RowBox[{"x", ",", "y", ",", "z"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.395602349152643*^9, 3.3956023640260057`*^9}}],

Cell[BoxData[
 RowBox[{"\[Phi]", "[", 
  RowBox[{"x", ",", "y", ",", "z"}], "]"}]], "Output",
 CellChangeTimes->{3.3956023683831253`*^9}]
}, Open  ]],

Cell["be a generic scalar field, and let ", "Text",
 CellChangeTimes->{{3.395603041978303*^9, 3.395603054616095*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"vector", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     SubscriptBox["A", "1"], "[", 
     RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
    RowBox[{
     SubscriptBox["A", "2"], "[", 
     RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
    RowBox[{
     SubscriptBox["A", "3"], "[", 
     RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.395602472651392*^9, 3.3956025209513187`*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    SubscriptBox["A", "1"], "[", 
    RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
   RowBox[{
    SubscriptBox["A", "2"], "[", 
    RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
   RowBox[{
    SubscriptBox["A", "3"], "[", 
    RowBox[{"x", ",", "y", ",", "z"}], "]"}]}], "}"}]], "Output",
 CellChangeTimes->{3.395603073005004*^9}]
}, Open  ]],

Cell["\<\
be a generic vector field\[Ellipsis]which, by the way, can be brought to a \
more familiar form by the command\
\>", "Text",
 CellChangeTimes->{{3.395603085166172*^9, 3.395603159042161*^9}, {
  3.395603219619121*^9, 3.3956032449715767`*^9}}],

