    RowBox[{"t", ",", "0", ",", "20"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.395512465760044*^9, 3.3955124798882113`*^9}, {
  3.395512645157342*^9, 3.39551265631194*^9}}],

