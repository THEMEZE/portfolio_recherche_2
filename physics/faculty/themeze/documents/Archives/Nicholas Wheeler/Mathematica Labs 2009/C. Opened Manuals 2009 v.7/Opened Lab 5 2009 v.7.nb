 CellChangeTimes->{{3.395597012814458*^9, 3.395597016659646*^9}, 
   3.395597092392798*^9, 3.3961380933179617`*^9}],

Cell["\t\[Bullet] Bispherical", "Text",
 CellChangeTimes->{{3.3955970182543583`*^9, 3.395597022827629*^9}, 
   3.395597094481022*^9, 3.3961380955821047`*^9}],

