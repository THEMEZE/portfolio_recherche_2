Cell[TextData[{
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " has supplied here a result that does not much resemble the one reported by \
Griffiths.  The difference, however, is only notational, as I now \
demonstrate:"
}], "Text",
 CellChangeTimes->{{3.395603951370657*^9, 3.395603965497056*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"%", "==", 
   RowBox[{
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["r", "2"]], 
     RowBox[{
      SubscriptBox["\[PartialD]", "r"], " ", 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["r", 
         RowBox[{"2", " "}]], 
        RowBox[{"u", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], ")"}]}]}], 
    "+", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"r", " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}]], 
     RowBox[{
      SubscriptBox["\[PartialD]", "\[Theta]"], 
      RowBox[{"(", " ", 
       RowBox[{
        RowBox[{"v", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ")"}]}]}], "+", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"r", " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}]], 
     RowBox[{
      SubscriptBox["\[PartialD]", "\[Phi]"], " ", 
      RowBox[{"w", "[", 
       RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}]}]}]}], "//", 
  "Simplify", " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"That", "'"}], "s", " ", 
    RowBox[{"Griffiths", "'"}], " ", "result", " ", "on", " ", "the", " ", 
    "right"}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.3956040053529787`*^9, 3.3956040081719847`*^9}}],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.395604013812606*^9}]
}, Open  ]],

Cell["", "Text",
 CellChangeTimes->{{3.3956040447311172`*^9, 3.395604044840332*^9}}],

Cell["", "Text"],

Cell[TextData[{
 StyleBox["The Laplacian occurs very commonly in the PDEs of mathematical \
physics",
  FontColor->RGBColor[0, 0, 1]],
 ", and is (in curvilinear coordinates) quite tedious to compute longhand \
because it involves 2nd derivatives. ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " does the heavy labor in a jiffy: "
}], "Text",
 CellChangeTimes->{{3.3956040601460247`*^9, 3.395604061273508*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Laplacian", "[", 
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], ",", 
   RowBox[{"Spherical", "[", 
    RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", 
   SuperscriptBox["r", "2"]], 
  RowBox[{
   RowBox[{"Csc", "[", "\[Theta]", "]"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"Csc", "[", "\[Theta]", "]"}], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"0", ",", "0", ",", "2"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"0", ",", "1", ",", "0"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"0", ",", "2", ",", "0"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], "+", 
     RowBox[{"2", " ", "r", " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"1", ",", "0", ",", "0"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], "+", 
     RowBox[{
      SuperscriptBox["r", "2"], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", 
          RowBox[{"2", ",", "0", ",", "0"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}]}], 
    ")"}]}]}]], "Output",
 CellChangeTimes->{3.395604103850113*^9}]
}, Open  ]],

