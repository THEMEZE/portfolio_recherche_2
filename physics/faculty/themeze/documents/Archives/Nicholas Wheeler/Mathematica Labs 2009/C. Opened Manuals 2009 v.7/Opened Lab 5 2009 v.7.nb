Cell["", "Text",
 CellChangeTimes->{{3.395579803741865*^9, 3.3955798037600718`*^9}}],

Cell["\<\
When we undertake to construct animated displays of various modes of drumhead \
vibration we discover\
\>", "Text",
 CellChangeTimes->{{3.395579811803117*^9, 3.395579885177402*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "PolarPlot3D"}]], "Input",
 CellChangeTimes->{{3.395542215165388*^9, 3.395542218097971*^9}, {
  3.395579789484956*^9, 3.395579790433403*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"Information", "::", "\<\"notfound\"\>"}], 
  RowBox[{
  ":", " "}], "\<\"Symbol \\!\\(\\\"PolarPlot3D\\\"\\) not found. \
\\!\\(\\*ButtonBox[\\\"\[RightSkeleton]\\\", ButtonStyle->\\\"Link\\\", \
ButtonFrame->None, ButtonData:>\\\"paclet:ref/message/General/notfound\\\", \
ButtonNote -> \\\"Information::notfound\\\"]\\)\"\>"}]], "Message", "MSG",
 CellChangeTimes->{3.395579792544877*^9}]
}, Open  ]],

Cell[TextData[{
 "that ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " 6 does not provide a ",
 StyleBox["PolarPlot3D", "Input"],
 " command, so are forced to work in Cartesian coordinates:"
}], "Text",
 CellChangeTimes->{{3.39557988929981*^9, 3.395579923448112*^9}}],

Cell[BoxData[
 RowBox[{"Clear", "[", "u", "]"}]], "Input",
 CellChangeTimes->{{3.395542504442877*^9, 3.395542507347209*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"u", "[", 
   RowBox[{
   "x_", ",", "y_", ",", "t_", ",", "m_", ",", "n_", ",", "c_", ",", "a_"}], 
   "]"}], ":=", 
  RowBox[{"F", "[", 
   RowBox[{
    SqrtBox[
     RowBox[{
      SuperscriptBox["x", "2"], "+", 
      SuperscriptBox["y", "2"]}]], ",", 
    RowBox[{"ArcTan", "[", 
     RowBox[{"x", ",", "y"}], "]"}], ",", "t", ",", "m", ",", "n", ",", "c", 
    ",", "a"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.395580013563624*^9, 3.3955800828751163`*^9}, {
  3.3955880167381163`*^9, 3.3955880178156424`*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.3955887436564703`*^9, 3.3955887436758957`*^9}}],

Cell[TextData[{
 StyleBox["REMARK",
  FontWeight->"Bold",
  FontColor->RGBColor[1, 0, 0]],
 ": From"
}], "Text",
 CellChangeTimes->{{3.3955887539335003`*^9, 3.39558876668859*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "ArcTan"}]], "Input",
 CellChangeTimes->{{3.395588775930024*^9, 3.395588781914729*^9}}],

Cell[BoxData[
 RowBox[{
  StyleBox["\<\"\\!\\(\\*RowBox[{\\\"ArcTan\\\", \\\"[\\\", \
StyleBox[\\\"z\\\", \\\"TI\\\"], \\\"]\\\"}]\\) gives the arc tangent \
\\!\\(\\*RowBox[{SuperscriptBox[\\\"tan\\\", RowBox[{\\\"-\\\", \\\"1\\\"}]], \
\\\"(\\\", \\\"z\\\", \\\")\\\"}]\\) of the complex number z. \
\\n\\!\\(\\*RowBox[{\\\"ArcTan\\\", \\\"[\\\", RowBox[{StyleBox[\\\"x\\\", \\\
\"TI\\\"], \\\",\\\", StyleBox[\\\"y\\\", \\\"TI\\\"]}], \\\"]\\\"}]\\) gives \
the arc tangent of \\!\\(\\*FractionBox[\\\"y\\\", \\\"x\\\"]\\), taking into \
account which quadrant the point \\!\\(\\*RowBox[{\\\"(\\\", \
RowBox[{\\\"x\\\", \\\",\\\", \\\"y\\\"}], \\\")\\\"}]\\) is in. \"\>", 
   "MSG"], " ", 
  ButtonBox[
   StyleBox["\[RightSkeleton]", "SR"],
   Active->True,
   BaseStyle->"Link",
   ButtonData->"paclet:ref/ArcTan"]}]], "Print", "PrintUsage",
 CellChangeTimes->{3.395588784598374*^9},
 CellTags->"Info3395563584-7727349"]
}, Open  ]],

Cell[TextData[{
 "we learn that ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " recognizes two distinct ",
 StyleBox["ArcTan", "Input"],
 " commands. It is to avoid catastrophy in  the construction of some \
subsequent figures that we have adopted the second alternative."
}], "Text",
 CellChangeTimes->{{3.3955887962060947`*^9, 3.395588847137344*^9}, {
  3.395588890457611*^9, 3.395588945874704*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.395588973421214*^9, 3.3955889734409533`*^9}}],

Cell["\<\
We look now to animated graphic representations of the following low-order \
vibrational modes:\
\>", "Text",
 CellChangeTimes->{{3.395589056476123*^9, 3.395589065366117*^9}, {
  3.395589109131743*^9, 3.3955891478780737`*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"fundamental", "[", 
   RowBox[{"x_", ",", "y_", ",", "t_"}], "]"}], ":=", 
  RowBox[{"u", "[", 
   RowBox[{"x", ",", "y", ",", "t", ",", 
    StyleBox["0",
     FontColor->RGBColor[1, 0, 0]], ",", 
    StyleBox["1",
     FontColor->RGBColor[1, 0, 0]], ",", "1", ",", "1"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"firstharmonic", "[", 
   RowBox[{"x_", ",", "y_", ",", "t_"}], "]"}], ":=", 
  RowBox[{"u", "[", 
   RowBox[{"x", ",", "y", ",", "t", ",", 
    StyleBox["1",
     FontColor->RGBColor[1, 0, 0]], ",", 
