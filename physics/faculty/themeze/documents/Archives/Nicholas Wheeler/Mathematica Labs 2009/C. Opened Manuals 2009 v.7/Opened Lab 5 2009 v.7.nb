   RowBox[{"S", "[", "\[Theta]", "]"}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.3955367329100246`*^9, 3.395536749843721*^9}}],

Cell[TextData[{
 "which in turn forces us to set m = 0, 1, 2, ... , giving ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"S", "[", "\[Theta]", "]"}], "=", 
