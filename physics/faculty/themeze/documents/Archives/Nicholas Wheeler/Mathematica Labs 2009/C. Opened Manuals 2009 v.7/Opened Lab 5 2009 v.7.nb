Cell[TextData[{
 StyleBox["INSTRUCTION",
  FontWeight->"Bold"],
 ": Hit the + button to expose the controls, then hit the \"play\" button."
}], "Text",
 CellChangeTimes->{{3.395427972432366*^9, 3.395428008323092*^9}, {
  3.395431128964011*^9, 3.395431144094041*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.3954286907470837`*^9, 3.395428690803089*^9}}],

Cell["or, alternatively,", "Text",
 CellChangeTimes->{{3.395428699537651*^9, 3.395428711886792*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Animate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"t", "-", "x"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{
        RowBox[{"-", "2"}], "\[Pi]"}], ",", 
       RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", 
     RowBox[{"4", "\[Pi]"}]}], "}"}], ",", 
   RowBox[{"AnimationRunning", "\[Rule]", "False"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.395428085197054*^9, 3.395428089412634*^9}, {
  3.395428205019533*^9, 3.395428319038378*^9}, {3.396093266975809*^9, 
