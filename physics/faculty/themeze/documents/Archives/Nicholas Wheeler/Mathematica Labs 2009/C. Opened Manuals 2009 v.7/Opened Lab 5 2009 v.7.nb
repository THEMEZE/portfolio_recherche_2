 RowBox[{
  RowBox[{"Div", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], ",", 
      RowBox[{"v", "[", 
