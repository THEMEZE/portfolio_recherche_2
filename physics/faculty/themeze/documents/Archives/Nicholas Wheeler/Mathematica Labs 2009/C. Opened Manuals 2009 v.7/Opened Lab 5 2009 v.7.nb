  CellChangeTimes->{{3.395536927084755*^9, 3.3955369999598913`*^9}, 
    3.395592320122904*^9, {3.395592377740016*^9, 3.395592382148185*^9}}],
 ". We ",
 "will find it most convenient to set"
}], "Text",
 CellChangeTimes->{{3.3955367261318398`*^9, 3.395536727173967*^9}, {
  3.395536773951252*^9, 3.395536782711399*^9}, {3.395536901857107*^9, 
