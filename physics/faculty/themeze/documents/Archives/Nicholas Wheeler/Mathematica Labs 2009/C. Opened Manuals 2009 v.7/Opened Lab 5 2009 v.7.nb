Cell[TextData[{
 StyleBox["INSTRUCTIONS",
  FontWeight->"Bold"],
 ": Again,  view the figure from several angles."
}], "Text",
 CellChangeTimes->{{3.395599690680683*^9, 3.395599716254608*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.395601265155321*^9, 3.395601265240292*^9}}],

Cell[TextData[{
 "\t\nIt is a  conspicuous feature of the preceding figures that the ",
 StyleBox["coordinate surfaces intersect orthogonally",
  FontColor->RGBColor[0, 0, 1]],
 ". This characteristic property of all \"named\" coordinate systems\
\[LongDash]those that have been studied closely enough, and are used \
frequently enough, to have been given names\[LongDash]is responsible for much \
of their interest and utility."
}], "Text",
 CellChangeTimes->{{3.395601511299426*^9, 3.3956015430192137`*^9}}],

Cell["", "Text"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Evaluating the Jacobian",
 FontColor->RGBColor[1, 0, 0]]], "Subsection",
 CellChangeTimes->{{3.3956015684469223`*^9, 3.395601572407544*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.3956016390152597`*^9, 3.395601639034137*^9}}],

Cell["The theory of multivariable integration supplies", "Text",
 CellChangeTimes->{{3.395601628337007*^9, 3.395601653779018*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{"dxdydz", "=", 
   RowBox[{"Jacobian", "*", "dudvdw"}]}], "Output",
  FontColor->GrayLevel[0.500008]]], "Input"],

Cell["\<\
where the Jacobian is the determinant of the matrix of first partials. Look \
again, by way of illustration, to the spherical coordinate system  \
\>", "Text"],

Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{"x", ",", "y", ",", "z", ",", "r", ",", "\[Theta]", ",", "\[Phi]"}],
   "]"}]], "Input"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"x", "[", 
   RowBox[{"r_", ",", "\[Theta]_", ",", " ", "\[Phi]_"}], "]"}], ":=", 
  RowBox[{"r", " ", 
   RowBox[{"Sin", "[", "\[Theta]", "]"}], 
   RowBox[{"Cos", "[", "\[Phi]", "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y", "[", 
   RowBox[{"r_", ",", "\[Theta]_", ",", " ", "\[Phi]_"}], "]"}], ":=", 
  RowBox[{"r", " ", 
   RowBox[{"Sin", "[", "\[Theta]", "]"}], 
   RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"z", "[", 
   RowBox[{"r_", ",", "\[Theta]_", ",", " ", "\[Phi]_"}], "]"}], ":=", 
  RowBox[{"r", " ", 
   RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]}], "Input"],

Cell["\<\
If we were working by hand on paper, we would proceed along these lines:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"matrixoffirstpartials", "=", 
  RowBox[{"(", GridBox[{
     {
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], ",", "r"}], 
       "]"}], 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], ",", 
        "\[Theta]"}], "]"}], 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], ",", 
        "\[Phi]"}], "]"}]},
     {
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"y", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], ",", "r"}], 
       "]"}], 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"y", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], ",", 
        "\[Theta]"}], "]"}], 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"y", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], ",", 
        "\[Phi]"}], "]"}]},
     {
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"z", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], ",", "r"}], 
       "]"}], 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"z", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], ",", 
        "\[Theta]"}], "]"}], 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"z", "[", 
         RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], ",", 
        "\[Phi]"}], "]"}]}
    }], ")"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
     RowBox[{"r", " ", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ",", 
     RowBox[{
      RowBox[{"-", "r"}], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ",", 
     RowBox[{"r", " ", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ",", 
     RowBox[{"r", " ", 
      RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", "\[Theta]", "]"}], ",", 
     RowBox[{
      RowBox[{"-", "r"}], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", "0"}], "}"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{3.395601770512927*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Det", "[", "%", "]"}], "//", "Simplify"}]], "Input"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["r", "2"], " ", 
  RowBox[{"Sin", "[", "\[Theta]", "]"}]}]], "Output",
 CellChangeTimes->{3.395601785413795*^9}]
}, Open  ]],

Cell[TextData[{
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " has already released us from many minutes of tedious work, but is smart \
enough to do such work entirely by itself:"
}], "Text",
 CellChangeTimes->{{3.39560181906378*^9, 3.395601849014469*^9}, {
  3.396097977230476*^9, 3.396097986727597*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"JacobianMatrix", "[", 
  RowBox[{"Spherical", "[", 
   RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
     RowBox[{"r", " ", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ",", 
     RowBox[{
      RowBox[{"-", "r"}], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ",", 
     RowBox[{"r", " ", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ",", 
     RowBox[{"r", " ", 
      RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", "\[Theta]", "]"}], ",", 
     RowBox[{
      RowBox[{"-", "r"}], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", "0"}], "}"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{3.3956018780107203`*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"JacobianDeterminant", "[", 
  RowBox[{"Spherical", "[", 
   RowBox[{"r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["r", "2"], " ", 
  RowBox[{"Sin", "[", "\[Theta]", "]"}]}]], "Output",
 CellChangeTimes->{3.395601893531918*^9}]
}, Open  ]],

