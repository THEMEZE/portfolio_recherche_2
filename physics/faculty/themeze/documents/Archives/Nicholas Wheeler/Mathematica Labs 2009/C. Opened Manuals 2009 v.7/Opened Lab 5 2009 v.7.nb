Cell["", "Text",
 CellChangeTimes->{{3.396093611471519*^9, 3.396093611567897*^9}}],

Cell[TextData[{
 "The string is seen to respond to having been \"plucked\" by developing a \
central deformation (the shape of which looks pretty Gaussian) which, after \
achieving its full size, spreads like a contagion to left and right. It may, \
on first blush, seem surprising that the ",
 StyleBox["pulse spreads without attenuation",
  FontVariations->{"Underline"->True}],
 ". This is a consequence of the one-dimensionality of strings. In \
N-dimensions, effects that \"fall off geometrically\" fall off as ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   SuperscriptBox["r", 
    RowBox[{"N", "-", "1"}]]}]],
  CellChangeTimes->{{3.395511862418316*^9, 3.395511883828936*^9}}],
 ", so on strings they fall off as  ",
 Cell[BoxData[
  RowBox[{"1", "/", 
   SuperscriptBox["r", "0"]}]],
  CellChangeTimes->{{3.395511862418316*^9, 3.395511883828936*^9}, 
    3.3955119317368507`*^9}],
 ", which is to say: not at all. In the present instance, the \"effect\" in \
question might be taken to be ",
 StyleBox["energy flux",
  FontWeight->"Bold"],
 ", which can be shown by physical argument to be proportional to ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[PartialD]", "t"], " ", 
     RowBox[{"u", "[", 
      RowBox[{"x", ",", "t"}], "]"}]}], ")"}], "2"]],
  CellChangeTimes->{{3.395511862418316*^9, 3.395511883828936*^9}, 
    3.3955119317368507`*^9, {3.395512337853404*^9, 3.395512362225953*^9}}],
 " and is non-zero only at the leading/trailing edges of the waveform, as \
shown in the following figure: "
}], "Text",
 CellChangeTimes->{{3.395451689191304*^9, 3.395451761709762*^9}, {
  3.3955075400806437`*^9, 3.395507567579818*^9}, {3.395507605330995*^9, 
  3.395507621692629*^9}, {3.395507652724442*^9, 3.395507743494507*^9}, {
  3.395510896821521*^9, 3.395510953007906*^9}, {3.395510986025642*^9, 
  3.3955109931839657`*^9}, {3.39551179924291*^9, 3.395511851451702*^9}, {
  3.39551189332719*^9, 3.395511955432026*^9}, {3.395512236757173*^9, 
  3.395512292931926*^9}, {3.395512374782731*^9, 3.395512416703845*^9}, {
  3.396093745649395*^9, 3.3960937673964767`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 SuperscriptBox[
  RowBox[{"D", "[", 
   RowBox[{
    RowBox[{"u2", "[", 
     RowBox[{"x", ",", "t"}], "]"}], ",", "t"}], "]"}], "2"]], "Input"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "16"], " ", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{
     FractionBox[
      RowBox[{"2", " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"-", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"t", "-", "x"}], ")"}], "2"]}]]}], 
      SqrtBox["\[Pi]"]], "+", 
     FractionBox[
      RowBox[{"2", " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"-", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"t", "+", "x"}], ")"}], "2"]}]]}], 
      SqrtBox["\[Pi]"]]}], ")"}], "2"]}]], "Output",
 CellChangeTimes->{3.3960936656468973`*^9}]
}, Open  ]],

