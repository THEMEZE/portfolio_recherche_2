Cell[BoxData[
 RowBox[{
  RowBox[{"Transpose", "[", 
   RowBox[{"{", "%", "}"}], "]"}], "//", "MatrixForm"}]], "Input",
 CellChangeTimes->{{3.395603172610818*^9, 3.395603191402845*^9}}],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{
       SubscriptBox["A", "1"], "[", 
