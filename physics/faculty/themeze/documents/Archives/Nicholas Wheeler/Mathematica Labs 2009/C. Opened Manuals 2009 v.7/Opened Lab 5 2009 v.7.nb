          RowBox[{"(", 
           RowBox[{"2", ",", "0"}], ")"}],
          Derivative],
         MultilineFunction->None], "[", 
        RowBox[{"r", ",", "\[Theta]"}], "]"}]}]}], ")"}]}]}], 
  SuperscriptBox[
   RowBox[{"(", 
    SuperscriptBox["r", "2"], ")"}], 
   RowBox[{"3", "/", "2"}]]]], "Output",
 CellChangeTimes->{3.395533672393594*^9}]
}, Open  ]],

Cell[TextData[{
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " does not know what to do with the ",
 Cell[BoxData[
  SuperscriptBox[
   RowBox[{"(", 
    SuperscriptBox["r", "2"], ")"}], 
   RowBox[{"3", "/", "2"}]]],
  CellChangeTimes->{3.395533672393594*^9}],
 "because it does not know whether r is positive or negative. So we tell it:"
}], "Text",
