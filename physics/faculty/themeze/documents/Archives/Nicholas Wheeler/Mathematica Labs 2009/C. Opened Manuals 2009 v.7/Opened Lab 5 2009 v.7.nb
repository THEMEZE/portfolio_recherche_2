Cell[CellGroupData[{

Cell[TextData[StyleBox["A More Intricate Business: Evaluating the Radial \
Factor",
 FontColor->RGBColor[0, 0, 1]]], "Subsubsection",
 CellChangeTimes->{{3.3955921913286037`*^9, 3.395592208828807*^9}}],

Cell["It remains to consider the equation", "Text",
 CellChangeTimes->{{3.39553704080622*^9, 3.395537045603441*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SuperscriptBox["r", "2"], 
    RowBox[{
     RowBox[{"R", "''"}], "[", "r", "]"}]}], "+", 
   RowBox[{"r", " ", 
    RowBox[{
     RowBox[{"R", "'"}], "[", "r", "]"}]}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["k", "2"], " ", 
       SuperscriptBox["r", "2"]}], "-", 
      SuperscriptBox["m", "2"]}], ")"}], 
    RowBox[{"R", "[", "r", "]"}]}]}], "=", 
  RowBox[{"0", "   ", ":", "   ", 
   RowBox[{"k", "\[Congruent]", " ", 
    RowBox[{"\[Omega]", "/", "c"}]}]}]}]], "Input",
 CellChangeTimes->{{3.395537077714159*^9, 3.395537109939088*^9}, 
   3.395537142108049*^9, 3.39553717325383*^9}],

Cell["We command", "Text",
 CellChangeTimes->{{3.3955371205403852`*^9, 3.395537121788589*^9}}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"DSolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
