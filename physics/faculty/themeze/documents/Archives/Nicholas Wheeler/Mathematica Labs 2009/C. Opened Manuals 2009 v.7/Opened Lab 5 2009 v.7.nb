Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        FractionBox["1", "3"], " ", 
        RowBox[{"Cos", "[", 
         RowBox[{"3", " ", 
          RowBox[{"(", 
           RowBox[{"t", "+", "x"}], ")"}]}], "]"}]}], ",", 
       RowBox[{"Sin", "[", 
        RowBox[{"t", "-", "x"}], "]"}], ",", 
       RowBox[{
        RowBox[{
         FractionBox["1", "3"], " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"3", " ", 
           RowBox[{"(", 
            RowBox[{"t", "+", "x"}], ")"}]}], "]"}]}], "+", 
        RowBox[{"Sin", "[", 
         RowBox[{"t", "-", "x"}], "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{
        RowBox[{"-", "2"}], "\[Pi]"}], ",", 
       RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Blue", ",", 
          RowBox[{"Thickness", "[", ".004", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
