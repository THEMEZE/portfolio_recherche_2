Cell["", "Text",
 CellChangeTimes->{{3.395577504358117*^9, 3.395577504452705*^9}}],

Cell["From", "Text",
 CellChangeTimes->{{3.395577559950282*^9, 3.395577560595797*^9}}],

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[Omega]", 
   RowBox[{"m", ",", "n"}]], "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"c", "/", "a"}], ")"}], 
   RowBox[{"BesselJZero", "[", 
    RowBox[{"m", ",", "n"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.395577573141677*^9, 3.395577605470508*^9}}],

Cell[TextData[{
 "we become able, by inspection of the table, to list in ascending order the \
",
 StyleBox["natural frequencies of a vibrating circular drumhead",
  FontWeight->"Bold"],
 ":"
}], "Text",
 CellChangeTimes->{{3.395577625717208*^9, 3.395577715183127*^9}}],

Cell[BoxData[{
 RowBox[{
  SubscriptBox["\[Omega]", 
   RowBox[{"0", ",", "1"}]], "  ", ":", "   ", 
  "fundamental"}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["\[Omega]", 
   RowBox[{"1", ",", "1"}]], "  ", ":", "   ", 
  RowBox[{"first", " ", "harmonic"}]}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["\[Omega]", 
   RowBox[{"2", ",", "1"}]], "  ", ":", "   ", 
  RowBox[{"second", " ", "harmonic"}]}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["\[Omega]", 
   RowBox[{"0", ",", "2"}]], "  ", ":", "   ", 
  RowBox[{"third", " ", "harmonic"}]}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox["\[Omega]", 
   RowBox[{"3", ",", "1"}]], "  ", ":", "   ", 
  RowBox[{
  "fourth", " ", 
   "harmonic"}]}], "\[IndentingNewLine]", "\[VerticalEllipsis]"}], "Input",
 CellChangeTimes->{{3.39557776309129*^9, 3.3955778035614653`*^9}, {
   3.395577845131173*^9, 3.39557794064223*^9}, {3.395577974853778*^9, 
   3.3955780047051363`*^9}, 3.395578065868634*^9}],

Cell["", "Text",
 CellChangeTimes->{{3.395578213259657*^9, 3.395578213277419*^9}}]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Assembly of the Final Result",
 FontColor->RGBColor[0, 0, 1]]], "Subsubsection",
 CellChangeTimes->{{3.395592682792349*^9, 3.395592691707004*^9}}],

Cell["\<\
We have now in hand this doubly-indexed population of solutions of the \
equation of motion of a circular drumhead:\
\>", "Text",
 CellChangeTimes->{{3.395578228683282*^9, 3.395578291487485*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"F", "[", 
   RowBox[{
   "r_", ",", "\[Theta]_", ",", "t_", ",", "m_", ",", "n_", ",", "c_", ",", 
    "a_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"BesselJ", "[", 
    RowBox[{"m", ",", 
     RowBox[{
      FractionBox[
       RowBox[{"N", "[", 
        RowBox[{"BesselJZero", "[", 
         RowBox[{"m", ",", "n"}], "]"}], "]"}], "a"], "r"}]}], "]"}], "*", 
   RowBox[{"Cos", "[", 
    RowBox[{"m", " ", "\[Theta]"}], "]"}], "*", 
   RowBox[{"Cos", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"c", "/", "a"}], ")"}], 
     RowBox[{"N", "[", 
      RowBox[{"BesselJZero", "[", 
       RowBox[{"m", ",", "n"}], "]"}], "]"}], "t"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.395578298737961*^9, 3.395578389863982*^9}, {
  3.395578420231578*^9, 3.395578490581259*^9}, {3.3955785336377296`*^9, 
  3.3955785851073523`*^9}, {3.395578926444124*^9, 3.395578964488254*^9}, {
  3.395581367766487*^9, 3.3955813740362043`*^9}}],

Cell["The radial factors", "Text",
 CellChangeTimes->{{3.395578749279888*^9, 3.395578761670149*^9}, 
   3.3955788137366543`*^9, {3.395579236189467*^9, 3.395579249630333*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"R", "[", 
   RowBox[{"r_", ",", "m_", ",", "n_", ",", "a_"}], "]"}], ":=", 
  RowBox[{"BesselJ", "[", 
   RowBox[{"m", ",", 
    RowBox[{
     FractionBox[
      RowBox[{"N", "[", 
       RowBox[{"BesselJZero", "[", 
        RowBox[{"m", ",", "n"}], "]"}], "]"}], "a"], "r"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.395578826961957*^9, 3.395578865468647*^9}, {
  3.3955789061992598`*^9, 3.39557891960166*^9}}],

Cell[TextData[{
 " of low order\[LongDash]displayed as functions of ",
 StyleBox["\[Rho] = r/a", "Output"],
 " (which ranges between 0 and 1)\[LongDash]look like this:"
}], "Text",
 CellChangeTimes->{{3.395578876555235*^9, 3.395578880231896*^9}, {
