}, Open  ]],

Cell[TextData[{
 "\[LongDash]precisely as reported by Griffiths on the front endpaper of his \
",
 StyleBox["Electrodynamics",
  FontSlant->"Italic"],
 ". But for "
}], "Text",
 CellChangeTimes->{{3.395603882352508*^9, 3.395603902440113*^9}}],

