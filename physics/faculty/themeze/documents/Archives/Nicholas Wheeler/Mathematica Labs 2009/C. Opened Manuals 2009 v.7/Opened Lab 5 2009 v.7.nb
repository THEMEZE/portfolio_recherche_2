Cell[CellGroupData[{

Cell["\<\
Accommodating Prescribed Boundary Conditions: the Clamped String\
\>", "Subsection",
 CellChangeTimes->{{3.395506854552147*^9, 3.395506866255911*^9}, {
  3.395506951422105*^9, 3.395506957114236*^9}, {3.395507003380599*^9, 
  3.395507021762438*^9}, {3.395512948315694*^9, 3.395512958326275*^9}},
 FontColor->RGBColor[1, 0, 0]],

Cell[TextData[{
 "Suppose we \"clamp\" the string at  ",
 StyleBox["x=0", "Output"],
 ". We are led then to look among general solutions of the wave equation"
}], "Text",
 CellChangeTimes->{{3.395513022378458*^9, 3.395513031119493*^9}, {
  3.395513323893134*^9, 3.3955133706927853`*^9}, {3.395513407710533*^9, 
  3.395513461999659*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"u", "[", 
   RowBox[{"x_", ",", "t_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"F", "[", 
    RowBox[{"t", "+", 
     FractionBox["x", "c"]}], "]"}], "+", 
   RowBox[{"G", "[", 
    RowBox[{"t", "-", 
     FractionBox["x", "c"]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.3955131771368933`*^9, 3.395513180210243*^9}}],

Cell["for solutions with the property that", "Text",
 CellChangeTimes->{{3.395513066735238*^9, 3.395513077440518*^9}, {
  3.395513440414156*^9, 3.3955134458780403`*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"u", "[", 
    RowBox[{"0", ",", "t"}], "]"}], "=", 
   RowBox[{"0", "   ", ":", "   ", 
    RowBox[{"all", " ", "t"}]}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.3955130887802267`*^9, 3.3955131070286283`*^9}, {
  3.395513670603129*^9, 3.3955136731493397`*^9}}],

Cell["From", "Text",
 CellChangeTimes->{{3.395513220959272*^9, 3.395513225218112*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"u", "[", 
  RowBox[{"0", ",", "t"}], "]"}]], "Input",
 CellChangeTimes->{3.395513162185959*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"F", "[", "t", "]"}], "+", 
  RowBox[{"G", "[", "t", "]"}]}]], "Output",
 CellChangeTimes->{{3.395513163176896*^9, 3.395513191961426*^9}}]
}, Open  ]],

Cell[TextData[{
 "we conclude that ",
 StyleBox["u[x, t]", "Output"],
 " must have the specialized form"
}], "Text",
 CellChangeTimes->{{3.395513229002635*^9, 3.395513269967914*^9}}],

Cell[BoxData[
 RowBox[{"Clear", "[", "u", "]"}]], "Input",
 CellChangeTimes->{{3.39551356043538*^9, 3.395513563495264*^9}},
 FontSize->10],

Cell[BoxData[
 RowBox[{
  RowBox[{"u", "[", 
   RowBox[{"x_", ",", "t_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"F", "[", 
    RowBox[{"t", "+", 
     FractionBox["x", "c"]}], "]"}], "-", 
   RowBox[{"F", "[", 
    RowBox[{"t", "-", 
     FractionBox["x", "c"]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.395513503318602*^9, 3.39551350445613*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"u", "[", 
  RowBox[{"x", ",", "t"}], "]"}]], "Input",
 CellChangeTimes->{{3.395513528930025*^9, 3.395513534763111*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   RowBox[{"F", "[", 
    RowBox[{"t", "-", 
     FractionBox["x", "c"]}], "]"}]}], "+", 
  RowBox[{"F", "[", 
   RowBox[{"t", "+", 
    FractionBox["x", "c"]}], "]"}]}]], "Output",
 CellChangeTimes->{3.3955135359268503`*^9, 3.395513577192922*^9}]
}, Open  ]],

Cell[TextData[{
 "Suppose, now, that we install a second clamp at ",
 StyleBox["x=a:", "Output"]
}], "Text",
 CellChangeTimes->{{3.395513618152836*^9, 3.395513656946002*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"u", "[", 
    RowBox[{
     StyleBox[
      StyleBox[
       StyleBox["a", "Output",
        FontColor->GrayLevel[0.5]], "Output",
       FontColor->GrayLevel[0.5]], "Output",
      FontColor->GrayLevel[0.5]], ",", "t"}], "]"}], "=", 
   RowBox[{
    StyleBox[
     StyleBox["0", "Output",
      FontColor->GrayLevel[0.5]], "Output",
     FontColor->GrayLevel[0.5]], "   ", ":", "   ", 
    RowBox[{"all", " ", "t"}]}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.395513692152564*^9, 3.395513695080987*^9}, 
   3.3955139804839*^9}],

Cell["From", "Text",
 CellChangeTimes->{{3.3955137643020678`*^9, 3.395513764747507*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"u", "[", 
  RowBox[{"a", ",", "t"}], "]"}]], "Input",
 CellChangeTimes->{3.395513717701922*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   RowBox[{"F", "[", 
    RowBox[{
     RowBox[{"-", 
      FractionBox["a", "c"]}], "+", "t"}], "]"}]}], "+", 
  RowBox[{"F", "[", 
   RowBox[{
    FractionBox["a", "c"], "+", "t"}], "]"}]}]], "Output",
 CellChangeTimes->{3.395513721123385*^9}]
}, Open  ]],

Cell[TextData[{
 "we conclude that ",
 StyleBox["F[]", "Output"],
 " must have the property that"
}], "Text",
 CellChangeTimes->{{3.3955137704761763`*^9, 3.395513790011588*^9}, 
   3.395513966867797*^9, {3.395513999865574*^9, 3.395514020015114*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"F", "[", "t", "]"}], "=", 
   RowBox[{
    RowBox[{"F", "[", 
     RowBox[{"t", "+", 
      RowBox[{"2", 
       FractionBox["a", "c"]}]}], "]"}], "   ", ":", "   ", 
    RowBox[{"all", " ", "t"}]}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.395513863909919*^9, 3.3955138644658127`*^9}, {
  3.39551391418531*^9, 3.395513958213399*^9}, {3.3955140072725973`*^9, 
  3.395514013291685*^9}, {3.395514046584437*^9, 3.3955140496464233`*^9}}],

Cell[TextData[{
 StyleBox["i.e",
  FontSlant->"Italic"],
 "., that ",
 StyleBox["F[]", "Output"],
 " must be periodic:"
}], "Text",
 CellChangeTimes->{{3.395514053712501*^9, 3.3955140895440073`*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{
    RowBox[{"F", "[", "t", "]"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"F", "[", 
       RowBox[{"t", "+", 
        RowBox[{"n", 
         FractionBox[
          RowBox[{"2", "a"}], "c"]}]}], "]"}], "   ", ":", "   ", "n"}], "=", 
     "0"}]}], ",", 
   RowBox[{"\[PlusMinus]", "1"}], ",", 
   RowBox[{"\[PlusMinus]", "2"}], ",", 
   RowBox[{"...", "  ", ";", "  ", 
    RowBox[{"all", " ", "t"}]}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.3955141324141283`*^9, 3.3955142118965883`*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.395514516681614*^9, 3.395514516788124*^9}}],

Cell[CellGroupData[{

Cell["Simple Example", "Subsubsection",
 CellChangeTimes->{{3.3955145354458723`*^9, 3.395514539782517*^9}}],

Cell[TextData[{
 "Let ",
 StyleBox["F[]", "Output"],
 " be the simplest of functions with the required period:"
}], "Text",
 CellChangeTimes->{{3.3955148569289*^9, 3.3955148881963663`*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"F", "[", "\[Xi]", "]"}], "=", 
   RowBox[{"Sin", "[", 
    RowBox[{"2", "\[Pi]", " ", 
     FractionBox["c", 
      RowBox[{"2", "a"}]], "\[Xi]"}], "]"}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.3955145719768343`*^9, 3.395514660455441*^9}}],

Cell["Then", "Text",
 CellChangeTimes->{{3.395514959989828*^9, 3.395514960316976*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}], "=", 
   RowBox[{
    RowBox[{"Sin", "[", 
     RowBox[{"2", "\[Pi]", " ", 
      FractionBox["c", 
       RowBox[{"2", "a"}]], 
      RowBox[{"(", 
       RowBox[{"t", "+", 
        FractionBox["x", "c"]}], ")"}]}], "]"}], "-", 
    RowBox[{"Sin", "[", 
     RowBox[{"2", "\[Pi]", " ", 
      FractionBox["c", 
       RowBox[{"2", "a"}]], 
      RowBox[{"(", 
       RowBox[{"t", "-", 
        FractionBox["x", "c"]}], ")"}]}], "]"}]}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.395514727525432*^9, 3.395514774308401*^9}, {
  3.395514927358596*^9, 3.395514932932624*^9}}],

Cell["But", "Text",
 CellChangeTimes->{{3.395514969452026*^9, 3.3955149702533627`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Sin", "[", 
    RowBox[{"2", "\[Pi]", " ", 
     FractionBox["c", 
      RowBox[{"2", "a"}]], 
     RowBox[{"(", 
      RowBox[{"t", "+", 
       FractionBox["x", "c"]}], ")"}]}], "]"}], "-", 
   RowBox[{"Sin", "[", 
    RowBox[{"2", "\[Pi]", " ", 
     FractionBox["c", 
      RowBox[{"2", "a"}]], 
     RowBox[{"(", 
      RowBox[{"t", "-", 
       FractionBox["x", "c"]}], ")"}]}], "]"}]}], "//", "Simplify"}]], "Input",\

 CellChangeTimes->{{3.395514820262466*^9, 3.395514824718625*^9}}],

Cell[BoxData[
 RowBox[{"2", " ", 
  RowBox[{"Cos", "[", 
   FractionBox[
    RowBox[{"c", " ", "\[Pi]", " ", "t"}], "a"], "]"}], " ", 
  RowBox[{"Sin", "[", 
   FractionBox[
    RowBox[{"\[Pi]", " ", "x"}], "a"], "]"}]}]], "Output",
 CellChangeTimes->{3.395514826109818*^9}]
}, Open  ]],

Cell["so we have", "Text",
 CellChangeTimes->{{3.3955150710277*^9, 3.3955150879535627`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"u", "[", 
   RowBox[{"x", ",", "t"}], "]"}], "=", 
  RowBox[{"2", " ", 
   RowBox[{"Cos", "[", 
    RowBox[{"2", "\[Pi]", 
     FractionBox[
      RowBox[{"c", " ", "t"}], 
      RowBox[{"2", "a"}]]}], "]"}], " ", 
