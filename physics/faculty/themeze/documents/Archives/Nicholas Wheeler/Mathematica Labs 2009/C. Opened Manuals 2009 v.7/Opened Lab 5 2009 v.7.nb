Cell[TextData[{
 "The fact that the wave function (since it refers to the instantaneous shape \
of the drumhead) must be ",
 StyleBox["single-valued",
  FontWeight->"Bold"],
 ", which forces us to insist that "
}], "Text",
 CellChangeTimes->{{3.3955365434058037`*^9, 3.395536627604672*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"F", "[", 
    RowBox[{"r", ",", 
     RowBox[{"\[Theta]", "+", 
      RowBox[{"2", "\[Pi]"}]}], ",", "t"}], "]"}], "=", 
