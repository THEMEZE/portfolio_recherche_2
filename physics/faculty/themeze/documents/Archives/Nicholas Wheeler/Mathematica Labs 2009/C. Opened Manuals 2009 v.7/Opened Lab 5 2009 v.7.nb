}, Open  ]],

Cell[TextData[{
 "Note the kink that then ripples back and forth along the string. Note \
particularly that it reverses sign when reflected from the clamped end, but \
preserves its sign  when reflected  from the unclamped end of the string. The \
problem is made interesting by the fact that it involves ",
 StyleBox["abrupt change of a boundary condition",
  FontSlant->"Italic"],
 ". For the source of my interest in the problem, see discussion on the web \
of the famous ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    PaneSelectorBox[{False->"\<\"Feynman spaghetti problem\"\>", True->
     StyleBox["\<\"Feynman spaghetti problem\"\>", "HyperlinkActive"]}, 
     Dynamic[
      CurrentValue["MouseOver"]],
     BaselinePosition->Baseline,
     FrameMargins->0,
     ImageSize->Automatic],
    BaseStyle->"Hyperlink",
    ButtonData->{
      URL[
      "http://ftp.aip.org/epaps/phys_rev_lett/E-PRLTAO-95-042531/movies-1-pb.\
html"], None},
    ButtonNote->
     "http://ftp.aip.org/epaps/phys_rev_lett/E-PRLTAO-95-042531/movies-1-pb.\
html"],
   Annotation[#, 
    "http://ftp.aip.org/epaps/phys_rev_lett/E-PRLTAO-95-042531/movies-1-pb.\
html", "Hyperlink"]& ]],
  CellChangeTimes->{3.395785393393173*^9}],
 ". Look particularly at the final videos."
}], "Text",
 CellChangeTimes->{{3.3957924827448683`*^9, 3.395792531060383*^9}, {
  3.395792577126793*^9, 3.395792682852672*^9}}],

Cell["", "Text",
 CellChangeTimes->{{3.3955172671260157`*^9, 3.395517267136709*^9}}]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Another Interesting Example: Gaussian Pulse on a Clamped String\
\>", "Subsubsection",
 CellChangeTimes->{{3.395517550163237*^9, 3.39551757684548*^9}, {
  3.396093902683049*^9, 3.396093903865296*^9}}],

Cell[TextData[{
 "From any ",
 StyleBox["f[\[Xi]]", "Output"],
 " that is well-defined for all ",
 StyleBox["\[Xi]", "Output"],
 ", construct "
}], "Text",
 CellChangeTimes->{{3.395517591549067*^9, 3.39551767067959*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"F", "[", "\[Xi]", "]"}], "=", 
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"n", " ", "=", 
      RowBox[{"-", "\[Infinity]"}]}], "\[Infinity]"], 
    RowBox[{"f", "[", 
     RowBox[{"\[Xi]", "+", 
      RowBox[{"n", " ", "p"}]}], "]"}]}]}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.3955176902392273`*^9, 3.3955177724146547`*^9}}],

Cell[TextData[{
 "and assume the infinite sum to be convergent. Clearly, every such ",
 StyleBox["F[\[Xi]]", "Output"],
 " will be periodic:"
}], "Text",
 CellChangeTimes->{{3.395517781319212*^9, 3.3955178512025433`*^9}}],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{
    RowBox[{"F", "[", "\[Xi]", "]"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"F", "[", 
       RowBox[{"\[Xi]", "+", 
        RowBox[{"n", " ", "p"}]}], "]"}], "   ", ":", "   ", "n"}], "=", 
     "0"}]}], ",", 
   RowBox[{"\[PlusMinus]", "1"}], ",", 
   RowBox[{"\[PlusMinus]", "2"}], ",", "..."}], "Output",
  FontColor->GrayLevel[0.5]]], "Input",
 CellChangeTimes->{{3.395517872282302*^9, 3.395517932919943*^9}}],

Cell["\<\
Suppose, in particular, that we use the previously-encountered Gaussian \
function\
\>", "Text",
 CellChangeTimes->{{3.395517991813148*^9, 3.395518022292964*^9}, {
  3.395518536349111*^9, 3.395518611102105*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"g", "[", 
   RowBox[{"\[Xi]_", ",", "a_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", 
    RowBox[{"a", 
     SqrtBox["\[Pi]"]}]], 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"\[Xi]", "/", "a"}], ")"}], "2"]}]]}]}]], "Input",
 CellChangeTimes->{{3.3955186349552603`*^9, 3.395518644532744*^9}}],

Cell["go define", "Text",
 CellChangeTimes->{{3.395518615839059*^9, 3.395518621101927*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "\[Xi]_", "]"}], ":=", 
  RowBox[{
   FractionBox[
    SqrtBox["\[Pi]"], "15"], 
   RowBox[{"g", "[", 
    RowBox[{
     RowBox[{"\[Xi]", "-", 
      FractionBox["1", "2"]}], ",", 
     FractionBox["1", "15"]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.3955186552578773`*^9, 3.3955186804175043`*^9}, 
   3.3955191978666897`*^9, {3.3955194111688957`*^9, 3.395519445104521*^9}, {
   3.395519793482176*^9, 3.395519827384325*^9}}],

Cell["and then to construct (NOTE the necessarily truncated sum)", "Text",
 CellChangeTimes->{{3.3955187405796337`*^9, 3.395518744399641*^9}, {
  3.3955211863462753`*^9, 3.395521198253764*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"F", "[", "\[Xi]_", "]"}], ":=", 
  RowBox[{
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"n", "=", 
     RowBox[{"-", "5"}]}], "5"], 
   RowBox[{"f", "[", 
    RowBox[{"\[Xi]", "+", 
     RowBox[{"2", "n"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.39551875217754*^9, 3.3955188369591713`*^9}, {
  3.395519016911601*^9, 3.395519129007084*^9}, {3.395521154301642*^9, 
  3.395521154896286*^9}}],

Cell["\<\
The following figure shows that we have successfully constructed a functions \
that has (at least in the neighborhood of interest) period p = 2  : \
\>", "Text",
 CellChangeTimes->{{3.395521208452961*^9, 3.395521305536209*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"F", "[", "\[Xi]", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Xi]", ",", 
     RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "2"}], "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.395518906997313*^9, 3.395518937391465*^9}, {
  3.395520023755082*^9, 3.3955200350103683`*^9}}],

