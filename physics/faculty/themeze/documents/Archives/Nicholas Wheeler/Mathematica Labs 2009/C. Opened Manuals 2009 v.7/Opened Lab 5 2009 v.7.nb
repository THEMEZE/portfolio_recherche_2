Cell[TextData[{
 "inform us that\[LongDash]until instructed otherwise\[LongDash]",
 StyleBox["Mathematica ",
  FontSlant->"Italic"],
 "will assume Cartesian coodinates to be named ",
 StyleBox["{x,y,z}", "Output"],
 " (or perhaps ",
 StyleBox["{X,Y,Z}", "Output"],
 "), spherical coordinates to be named ",
 StyleBox["{r, theta, phi}", "Output"],
 " (or perhaps ",
 StyleBox["{R, T, P}", "Output"],
 "), and that ",
 StyleBox["polar coordinates fall outside the perview of the package",
  FontSlant->"Italic"],
 ", which has ",
 StyleBox["things to say ",
  FontColor->RGBColor[1, 0, 0]],
 StyleBox["only about 3-dimensional coordinate systems",
  FontWeight->"Bold",
  FontColor->RGBColor[1, 0, 0]],
 ". These are the names of the coordinate ystems it is prepared to discuss:"
}], "Text",
 CellChangeTimes->{{3.395596238183445*^9, 3.395596466718526*^9}, {
  3.395596497247518*^9, 3.395596498901565*^9}, {3.3955968167882757`*^9, 
  3.395596841788411*^9}, {3.395596932908029*^9, 3.395596954236802*^9}}],

Cell["\t\[Bullet] Bipolar", "Text",
 CellChangeTimes->{{3.395596961709734*^9, 3.395596964257936*^9}, {
   3.39559707676703*^9, 3.3955970772708683`*^9}, 3.3961380829590387`*^9}],

