Cell[TextData[{
 StyleBox["INSTRUCTIONS",
  FontWeight->"Bold"],
 ": Hit the + button to expose the controls, then hit the \"play\" button. \
Slow down the motion to see more clearly that the blue sine curve slides \
rigidly to the left, while the  green sine curve slides rigidly to the right \
(at the same speed),"
}], "Text",
 CellChangeTimes->{{3.3954312052544937`*^9, 3.39543130015625*^9}, {
  3.3954328248093843`*^9, 3.395432827469818*^9}}],

