Cell[CellGroupData[{

Cell["Effect of Releasing a Clamp", "Subsubsection",
 CellChangeTimes->{{3.39579117783595*^9, 3.395791189579859*^9}}],

Cell["\<\
At the unclamped ends of a string it is\[LongDash]for physical reasons, \
arising from the that energy/momentum must vanish at such \
points\[LongDash]not the value but the spatial derivative of the field \
function that must vanish. This serves, in effect, to double the allowed  \
wave lengths, and halve the allowed frequencies. The following animation \
shows a string that is vibrating with both ends clamped when suddenly the \
clamp on the right is released.  Note the kink that then ripples back and \
forth along the string,   \
\>", "Text",
 CellChangeTimes->{{3.395791204190393*^9, 3.395791259867177*^9}, {
  3.3957912985188503`*^9, 3.39579135402801*^9}, {3.3957914038093576`*^9, 
  3.395791542478352*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Phi]", "[", 
   RowBox[{"x_", ",", "t_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"\[Pi]", " ", "t"}], "]"}], "+", 
     RowBox[{"Sin", "[", 
      RowBox[{"\[Pi]", " ", "t"}], "]"}]}], ")"}], 
   RowBox[{"Sin", "[", 
    RowBox[{"\[Pi]", " ", "x"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalPhi]", "[", 
   RowBox[{"x_", ",", "t_", ",", "f1_", ",", "g1_", ",", "p_"}], "]"}], ":=", 
  
  RowBox[{
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"k", "=", "0"}], "p"], 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"f1", 
       FractionBox["8", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"4", "-", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", "k"}], "+", "1"}], ")"}], "2"]}], ")"}], 
         "\[Pi]"}]], 
       RowBox[{"Sin", "[", 
        FractionBox[
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "k"}], "+", "1"}], ")"}], "\[Pi]"}], "2"], "]"}], 
       RowBox[{"Cos", "[", 
        RowBox[{
         FractionBox[
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "k"}], "+", "1"}], ")"}], "2"], "\[Pi]", " ", "t"}], 
        "]"}]}], "+", "\[IndentingNewLine]", 
      RowBox[{"g1", 
       FractionBox["2", 
        RowBox[{
         RowBox[{"2", "k"}], "+", "1"}]], 
       FractionBox["8", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"4", "-", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", "k"}], "+", "1"}], ")"}], "2"]}], ")"}], 
         "\[Pi]"}]], 
       RowBox[{"Sin", "[", 
        FractionBox[
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "k"}], "+", "1"}], ")"}], "\[Pi]"}], "2"], "]"}], 
       RowBox[{"Sin", "[", 
        RowBox[{
         FractionBox[
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "k"}], "+", "1"}], ")"}], "2"], "\[Pi]", " ", "t"}], 
        "]"}]}]}], ")"}], 
    RowBox[{"Sin", "[", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "k"}], "+", "1"}], ")"}], "\[Pi]"}], "2"], "x"}], 
     "]"}]}]}]}]}], "Input",
 CellChangeTimes->{3.395783176550159*^9, 3.395784009301114*^9}],

Cell[TextData[{
 "We  use the ",
 StyleBox["UnitStep", "Input"],
 " function to switch off the clamped/clamped solution and to switch on the \
clamped/unclamped solution at time ",
 StyleBox["t > 0", "Output"],
 ":"
}], "Text",
 CellChangeTimes->{{3.395791625246645*^9, 3.395791695620348*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"string", "[", 
   RowBox[{"x_", ",", "t_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Phi]", "[", 
     RowBox[{"x", ",", "t"}], "]"}], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"UnitStep", "[", "t", "]"}]}], ")"}]}], "+", 
   RowBox[{
    RowBox[{"\[CapitalPhi]", "[", 
     RowBox[{"x", ",", "t", ",", 
      RowBox[{"1", "/", "2"}], ",", 
      RowBox[{"1", "/", "2"}], ",", "15"}], "]"}], 
    RowBox[{"UnitStep", "[", "t", "]"}]}]}]}]], "Input",
 CellChangeTimes->{3.395780986738029*^9, 3.395784009313081*^9}],

