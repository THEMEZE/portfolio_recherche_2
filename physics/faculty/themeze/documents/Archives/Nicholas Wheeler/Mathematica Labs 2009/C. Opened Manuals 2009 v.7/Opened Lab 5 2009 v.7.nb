Cell[TextData[{
 "To activate ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 "'s expert command of this subject one must enter the Vector Analysis \
Package. For a survey of that resource, go to ",
 StyleBox["Help > Documentation Center",
  FontWeight->"Bold"],
 " and search for ",
 StyleBox["VectorAnalysis/guide/VectorAnalysisPackage",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox[". There you will be directed (see TUTORIALS at the bottom of the \
page) to the very informative ",
  FontColor->GrayLevel[0]],
 StyleBox["VectorAnalysis/tutorial/VectorAnalysis",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox[". To import the package, command ",
  FontColor->GrayLevel[0]]
}], "Text",
 CellChangeTimes->{{3.395594462890471*^9, 3.39559448904748*^9}, {
  3.3955946469411697`*^9, 3.395594818787911*^9}, {3.3955948533235064`*^9, 
  3.395594922109318*^9}, {3.39559548979851*^9, 3.395595519840576*^9}, {
  3.395595563736897*^9, 3.3955955775610847`*^9}}],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<VectorAnalysis`\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.39559565234022*^9, 3.3955956703072767`*^9}}],

Cell["The command", "Text",
 CellChangeTimes->{{3.395596177990279*^9, 3.395596179529088*^9}}],

Cell[CellGroupData[{

Cell[BoxData["CoordinateSystem"], "Input",
 CellChangeTimes->{{3.395595700883244*^9, 3.3955957036929283`*^9}}],

Cell[BoxData["Cartesian"], "Output",
 CellChangeTimes->{3.3955957053646584`*^9}]
}, Open  ]],

Cell[TextData[{
 "identifies the ",
 StyleBox["default coordinate system",
  FontWeight->"Bold"],
 ". The commands"
}], "Text",
 CellChangeTimes->{{3.395596196965517*^9, 3.3955962304981728`*^9}}],

Cell[CellGroupData[{

