Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox["\[Integral]", "0", "\[Pi]"], 
  RowBox[{
   RowBox[{"Cos", "[", 
    RowBox[{"x", " ", 
     RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "]"}], 
   RowBox[{"\[DifferentialD]", "\[Theta]"}]}]}]], "Input"],

Cell[BoxData[
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{"x", "\[Element]", "Reals"}], ",", 
   RowBox[{"\[Pi]", " ", 
    RowBox[{"BesselJ", "[", 
     RowBox[{"0", ",", 
      RowBox[{"Abs", "[", "x", "]"}]}], "]"}]}], ",", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"x", " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", "0", ",", "\[Pi]"}], "}"}], ",", 
     RowBox[{"Assumptions", "\[Rule]", 
      RowBox[{
       RowBox[{
        RowBox[{"Im", "[", "x", "]"}], "<", "0"}], "||", 
       RowBox[{
        RowBox[{"Im", "[", "x", "]"}], ">", "0"}]}]}]}], "]"}]}], 
  "]"}]], "Output",
 CellChangeTimes->{3.396216183438737*^9}]
}, Open  ]],

