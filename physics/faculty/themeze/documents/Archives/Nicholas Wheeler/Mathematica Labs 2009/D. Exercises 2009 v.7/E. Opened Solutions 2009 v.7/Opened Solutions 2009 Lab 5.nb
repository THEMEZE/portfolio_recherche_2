Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{"b", ",", "x", ",", "\[Mu]", ",", "t"}], "]"}]], "Input",
 CellChangeTimes->{{3.396554982462131*^9, 3.39655499593496*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"b", "[", 
   RowBox[{"x_", ",", "\[Mu]_"}], "]"}], ":=", 
  RowBox[{"\[Mu]", 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox["x", "2"], "-", "1"}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.396554926291173*^9, 3.396554958284295*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"solv1", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "''"}], "[", "t", "]"}], "+", 
        RowBox[{
         RowBox[{"b", "[", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], ",", 
           RowBox[{"1", "/", "8"}]}], "]"}], 
         RowBox[{
          RowBox[{"x", "'"}], "[", "t", "]"}]}], "+", 
        RowBox[{"x", "[", "t", "]"}]}], "\[Equal]", "0"}], ",", 
      RowBox[{
       RowBox[{"x", "[", "0", "]"}], "\[Equal]", "1"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "0", "]"}], "\[Equal]", "0"}]}], "}"}], ",", 
    
    RowBox[{"x", "[", "t", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "30"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.396555043882409*^9, 3.396555065545191*^9}, {
  3.3965551025162983`*^9, 3.3965551044826803`*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"x", "[", "t", "]"}], "\[Rule]", 
    RowBox[{
     TagBox[
      RowBox[{"InterpolatingFunction", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"0.`", ",", "30.`"}], "}"}], "}"}], ",", "\<\"<>\"\>"}], 
       "]"}],
      False,
      Editable->False], "[", "t", "]"}]}], "}"}], "}"}]], "Output",
 CellChangeTimes->{
  3.3963084285140743`*^9, {3.396555084868203*^9, 3.3965551107919617`*^9}}]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"graph1", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"x", "[", "t", "]"}], "/.", "solv1"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "30"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{3.396308444120152*^9}],

