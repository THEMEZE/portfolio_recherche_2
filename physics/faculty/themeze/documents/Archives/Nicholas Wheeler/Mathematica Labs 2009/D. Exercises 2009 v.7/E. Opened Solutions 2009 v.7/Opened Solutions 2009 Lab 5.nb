Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ReverseImpact", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"x", "''"}], "[", "t", "]"}], "\[Equal]", 
       RowBox[{
        RowBox[{"-", 
         FractionBox[
          RowBox[{"9", 
           RowBox[{"x", "[", "t", "]"}]}], 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox[
              RowBox[{"x", "[", "t", "]"}], "2"], "+", 
             SuperscriptBox[
              RowBox[{"y", "[", "t", "]"}], "2"]}], ")"}], 
           FractionBox["3", "2"]]]}], "+", 
        FractionBox[
         RowBox[{
          RowBox[{"1", "/", "2"}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "10"}], "+", 
            FractionBox["t", "4"], "-", 
            RowBox[{"x", "[", "t", "]"}]}], ")"}]}], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "10"}], "+", 
               FractionBox["t", "4"], "-", 
               RowBox[{"x", "[", "t", "]"}]}], ")"}], "2"], "+", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"4", "-", 
               RowBox[{"y", "[", "t", "]"}]}], ")"}], "2"]}], ")"}], 
          FractionBox["3", "2"]]]}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "''"}], "[", "t", "]"}], "\[Equal]", 
       RowBox[{
        RowBox[{"-", 
         FractionBox[
          RowBox[{"9", 
           RowBox[{"y", "[", "t", "]"}]}], 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox[
              RowBox[{"x", "[", "t", "]"}], "2"], "+", 
             SuperscriptBox[
              RowBox[{"y", "[", "t", "]"}], "2"]}], ")"}], 
           FractionBox["3", "2"]]]}], "+", 
        FractionBox[
         RowBox[{
          RowBox[{"1", "/", "2"}], 
          RowBox[{"(", 
           RowBox[{"4", "-", 
            RowBox[{"y", "[", "t", "]"}]}], ")"}]}], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "10"}], "+", 
               FractionBox["t", "4"], "-", 
               RowBox[{"x", "[", "t", "]"}]}], ")"}], "2"], "+", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"4", "-", 
               RowBox[{"y", "[", "t", "]"}]}], ")"}], "2"]}], ")"}], 
          FractionBox["3", "2"]]]}]}], ",", 
      RowBox[{
       RowBox[{"x", "[", "0", "]"}], "\[Equal]", "1"}], ",", 
      RowBox[{
       RowBox[{"y", "[", "0", "]"}], "\[Equal]", "0"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "0", "]"}], "\[Equal]", "0"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "'"}], "[", "0", "]"}], "\[Equal]", "3"}]}], "}"}], ",", 
    
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "[", "t", "]"}], ",", 
      RowBox[{"y", "[", "t", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "80"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{
  3.3963080719291563`*^9, {3.3965480308136673`*^9, 3.396548036834487*^9}, {
   3.396548108332844*^9, 3.396548122720682*^9}, {3.3965520470040913`*^9, 
   3.396552057124354*^9}, {3.396553819619657*^9, 3.396553823536276*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"x", "[", "t", "]"}], "\[Rule]", 
     RowBox[{
      TagBox[
       RowBox[{"InterpolatingFunction", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{"0.`", ",", "80.`"}], "}"}], "}"}], ",", "\<\"<>\"\>"}], 
        "]"}],
       False,
       Editable->False], "[", "t", "]"}]}], ",", 
    RowBox[{
     RowBox[{"y", "[", "t", "]"}], "\[Rule]", 
     RowBox[{
      TagBox[
       RowBox[{"InterpolatingFunction", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{"0.`", ",", "80.`"}], "}"}], "}"}], ",", "\<\"<>\"\>"}], 
        "]"}],
       False,
       Editable->False], "[", "t", "]"}]}]}], "}"}], "}"}]], "Output",
 CellChangeTimes->{3.3963080761962643`*^9, 3.396548142711281*^9, 
  3.3965520619909763`*^9, 3.396553835996245*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ShowReverse", "=", 
  RowBox[{"ParametricPlot", "[", 
   RowBox[{
    RowBox[{"Evaluate", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x", "[", "t", "]"}], ",", 
        RowBox[{"y", "[", "t", "]"}]}], "}"}], "/.", "ReverseImpact"}], "]"}],
     ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "80"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotRange", "\[Rule]", "All"}], ",", "\[IndentingNewLine]", " ", 
    
    RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
    "\[IndentingNewLine]", 
