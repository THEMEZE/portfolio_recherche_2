Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ImpactedOrbit", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"x", "''"}], "[", "t", "]"}], "\[Equal]", 
       RowBox[{
        RowBox[{"-", 
         FractionBox[
          RowBox[{"9", 
           RowBox[{"x", "[", "t", "]"}]}], 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox[
              RowBox[{"x", "[", "t", "]"}], "2"], "+", 
             SuperscriptBox[
              RowBox[{"y", "[", "t", "]"}], "2"]}], ")"}], 
           FractionBox["3", "2"]]]}], "+", 
        FractionBox[
         RowBox[{
          RowBox[{"1", "/", "2"}], 
          RowBox[{"(", 
           RowBox[{"10", "-", 
            FractionBox["t", "4"], "-", 
            RowBox[{"x", "[", "t", "]"}]}], ")"}]}], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"10", "-", 
               FractionBox["t", "4"], "-", 
               RowBox[{"x", "[", "t", "]"}]}], ")"}], "2"], "+", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"4", "-", 
               RowBox[{"y", "[", "t", "]"}]}], ")"}], "2"]}], ")"}], 
          FractionBox["3", "2"]]]}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "''"}], "[", "t", "]"}], "\[Equal]", 
       RowBox[{
        RowBox[{"-", 
         FractionBox[
          RowBox[{"9", 
           RowBox[{"y", "[", "t", "]"}]}], 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox[
              RowBox[{"x", "[", "t", "]"}], "2"], "+", 
             SuperscriptBox[
              RowBox[{"y", "[", "t", "]"}], "2"]}], ")"}], 
           FractionBox["3", "2"]]]}], "+", 
        FractionBox[
         RowBox[{
          RowBox[{"1", "/", "2"}], 
          RowBox[{"(", 
           RowBox[{"4", "-", 
            RowBox[{"y", "[", "t", "]"}]}], ")"}]}], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"10", "-", 
               FractionBox["t", "4"], "-", 
               RowBox[{"x", "[", "t", "]"}]}], ")"}], "2"], "+", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"4", "-", 
               RowBox[{"y", "[", "t", "]"}]}], ")"}], "2"]}], ")"}], 
          FractionBox["3", "2"]]]}]}], ",", 
      RowBox[{
       RowBox[{"x", "[", "0", "]"}], "\[Equal]", "1"}], ",", 
      RowBox[{
       RowBox[{"y", "[", "0", "]"}], "\[Equal]", "0"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "'"}], "[", "0", "]"}], "\[Equal]", "0"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "'"}], "[", "0", "]"}], "\[Equal]", "3"}]}], "}"}], ",", 
    
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "[", "t", "]"}], ",", 
      RowBox[{"y", "[", "t", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "80"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{
