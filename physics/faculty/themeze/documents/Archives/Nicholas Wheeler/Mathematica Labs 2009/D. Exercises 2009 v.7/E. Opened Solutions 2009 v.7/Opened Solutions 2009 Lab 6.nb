Cell[BoxData[
 RowBox[{
  StyleBox["\<\"\\!\\(\\*RowBox[{\\\"Hyperlink\\\", \\\"[\\\", \
StyleBox[\\\"uri\\\", \\\"TI\\\"], \\\"]\\\"}]\\) represents a hyperlink that \
jumps to the specified URI when clicked. \
\\n\\!\\(\\*RowBox[{\\\"Hyperlink\\\", \\\"[\\\", \
RowBox[{StyleBox[\\\"label\\\", \\\"TI\\\"], \\\",\\\", StyleBox[\\\"uri\\\", \
\\\"TI\\\"]}], \\\"]\\\"}]\\) represents a hyperlink to be displayed as \
\\!\\(\\*StyleBox[\\\"label\\\", \\\"TI\\\"]\\). \"\>", "MSG"], " ", 
  ButtonBox[
   StyleBox["\[RightSkeleton]", "SR"],
   Active->True,
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Hyperlink"]}]], "Print", "PrintUsage",
