Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{"a", ",", "b"}], "]"}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "D"}]], "Input",
 CellChangeTimes->{{3.396574259588698*^9, 3.3965742609227753`*^9}}],

Cell[BoxData[
 RowBox[{
  StyleBox["\<\"\\!\\(\\*RowBox[{\\\"D\\\", \\\"[\\\", RowBox[{StyleBox[\\\"f\
\\\", \\\"TI\\\"], \\\",\\\", StyleBox[\\\"x\\\", \\\"TI\\\"]}], \
\\\"]\\\"}]\\) gives the partial derivative \
\\!\\(\\*RowBox[{\\\"\[PartialD]\\\", \\\"f\\\", \\\"/\\\", \\\"\[PartialD]\\\
\", \\\"x\\\"}]\\). \\n\\!\\(\\*RowBox[{\\\"D\\\", \\\"[\\\", \
RowBox[{StyleBox[\\\"f\\\", \\\"TI\\\"], \\\",\\\", RowBox[{\\\"{\\\", \
RowBox[{StyleBox[\\\"x\\\", \\\"TI\\\"], \\\",\\\", StyleBox[\\\"n\\\", \
\\\"TI\\\"]}], \\\"}\\\"}]}], \\\"]\\\"}]\\) gives the multiple derivative \
\\!\\(\\*RowBox[{SuperscriptBox[\\\"\[PartialD]\\\", \\\"n\\\"], \\\"f\\\", \
\\\"/\\\", \\\"\[PartialD]\\\", SuperscriptBox[\\\"x\\\", \\\"n\\\"]}]\\). \
\\n\\!\\(\\*RowBox[{\\\"D\\\", \\\"[\\\", RowBox[{StyleBox[\\\"f\\\", \
\\\"TI\\\"], \\\",\\\", StyleBox[\\\"x\\\", \\\"TI\\\"], \\\",\\\", StyleBox[\
\\\"y\\\", \\\"TI\\\"], \\\",\\\", StyleBox[\\\"\[Ellipsis]\\\", \
\\\"TR\\\"]}], \\\"]\\\"}]\\) differentiates f successively with respect to \
\\!\\(\\*RowBox[{\\\"x\\\", \\\",\\\", \\\"y\\\", \\\",\\\", \
\\\"\[Ellipsis]\\\"}]\\).\\n\\!\\(\\*RowBox[{\\\"D\\\", \\\"[\\\", \
RowBox[{StyleBox[\\\"f\\\", \\\"TI\\\"], \\\",\\\", RowBox[{\\\"{\\\", \
RowBox[{\\\"{\\\", RowBox[{SubscriptBox[StyleBox[\\\"x\\\", \\\"TI\\\"], \
StyleBox[\\\"1\\\", \\\"TR\\\"]], \\\",\\\", SubscriptBox[StyleBox[\\\"x\\\", \
\\\"TI\\\"], StyleBox[\\\"2\\\", \\\"TR\\\"]], \\\",\\\", StyleBox[\\\"\
\[Ellipsis]\\\", \\\"TR\\\"]}], \\\"}\\\"}], \\\"}\\\"}]}], \\\"]\\\"}]\\) \
for a scalar f gives the vector derivative \\!\\(\\*RowBox[{\\\"(\\\", \
RowBox[{RowBox[{\\\"\[PartialD]\\\", RowBox[{\\\"f\\\", \\\"/\\\", RowBox[{\\\
\"\[PartialD]\\\", SubscriptBox[\\\"x\\\", \\\"1\\\"]}]}]}], \\\",\\\", \
RowBox[{\\\"\[PartialD]\\\", RowBox[{\\\"f\\\", \\\"/\\\", RowBox[{\\\"\
\[PartialD]\\\", SubscriptBox[\\\"x\\\", \\\"2\\\"]}]}]}], \\\",\\\", \\\"\
\[Ellipsis]\\\"}], \\\")\\\"}]\\). \"\>", "MSG"], " ", 
  ButtonBox[
   StyleBox["\[RightSkeleton]", "SR"],
   Active->True,
   BaseStyle->"Link",
   ButtonData->"paclet:ref/D"]}]], "Print", "PrintUsage",
 CellChangeTimes->{3.396574277639957*^9},
 CellTags->"Info3396549063-8648668"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"u", "[", 
   RowBox[{"x_", ",", "t_", ",", "b_"}], "]"}], ":=", 
  RowBox[{
   SuperscriptBox["b", "2"], "2", " ", 
   SuperscriptBox[
    RowBox[{"Sech", "[", 
     RowBox[{
      RowBox[{"b", "  ", "x"}], "-", 
      RowBox[{"4", 
       SuperscriptBox["b", "3"], " ", "t"}]}], "]"}], "2"]}]}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"u", "[", 
      RowBox[{"x", ",", "t", ",", "b"}], "]"}], ",", "t"}], "]"}], "+", 
   RowBox[{"6", 
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t", ",", "b"}], "]"}], 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t", ",", "b"}], "]"}], ",", "x"}], "]"}]}], "+", 
   " ", 
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"u", "[", 
      RowBox[{"x", ",", "t", ",", "b"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "3"}], "}"}]}], "]"}]}], "\[Equal]", "0"}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"-", "16"}], " ", 
    SuperscriptBox["b", "5"], " ", 
    SuperscriptBox[
     RowBox[{"Sech", "[", 
      RowBox[{
       RowBox[{"4", " ", 
        SuperscriptBox["b", "3"], " ", "t"}], "-", 
       RowBox[{"b", " ", "x"}]}], "]"}], "2"], " ", 
    RowBox[{"Tanh", "[", 
     RowBox[{
